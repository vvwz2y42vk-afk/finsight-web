<div class="csb-content">

<!-- PAGE HERO -->
<section class="about-hero">
  <div class="about-hero__overlay"></div>
  <div class="about-hero__content">
    <div class="sec-tag">من نحن</div>
    <h1 class="about-hero__title">نبني الثقة، <span class="c-gold">ونحقق الأحلام</span></h1>
    <p class="about-hero__sub">شركة BAREZ — شريكك العقاري الموثوق في المدينة المنورة</p>
  </div>
</section>

<!-- INTRO -->
<section style="padding:88px 0;background:#fff;">
  <div class="page-container">
    <div class="about-intro__grid">
      <div>
        <div class="sec-tag">قصتنا</div>
        <h2 style="font-size:clamp(1.6rem,3vw,2.3rem);font-weight:800;margin-bottom:20px;line-height:1.4;">
          شريكك الموثوق في <span class="c-gold">السوق العقاري</span>
        </h2>
        <p style="color:var(--text2);font-size:15px;line-height:2;margin-bottom:16px;">
          تأسست شركة BAREZ بهدف واحد واضح: تقديم خدمة عقارية متكاملة تجمع بين الاحترافية والأمانة. بنينا سمعتنا في المدينة المنورة عقداً بعد عقد، وعميلاً بعد عميل.
        </p>
        <p style="color:var(--text2);font-size:15px;line-height:2;margin-bottom:32px;">
          اليوم نفخر بإدارة ٤ مجمعات سكنية متكاملة، وتقديم خدمات الوساطة العقارية والتسويق لعملائنا بأعلى مستويات الكفاءة والشفافية.
        </p>
        <div style="display:flex;gap:24px;flex-wrap:wrap;">
          <div style="text-align:center;">
            <div style="font-size:2.4rem;font-weight:900;color:var(--gold);">فال ✓</div>
            <div style="font-size:13px;color:var(--text3);margin-top:4px;">رخصة معتمدة</div>
          </div>
          <div style="text-align:center;">
            <div style="font-size:2.4rem;font-weight:900;color:var(--gold);">4</div>
            <div style="font-size:13px;color:var(--text3);margin-top:4px;">مجمعات سكنية</div>
          </div>
          <div style="text-align:center;">
            <div style="font-size:2.4rem;font-weight:900;color:var(--gold);">+3000</div>
            <div style="font-size:13px;color:var(--text3);margin-top:4px;">عميل</div>
          </div>
        </div>
      </div>
      <div class="about-intro__visual">
        <div class="about-img" style="aspect-ratio:1/1;">
          <div class="about-img__stat">
            <div class="about-img__stat-num">الثقة أولاً</div>
            <div class="about-img__stat-lbl">قيمتنا الأساسية</div>
          </div>
        </div>
        <div class="about-img__badge">
          <div class="aib__ico">🏅</div>
          <div>
            <div class="aib__title">وسيط عقاري معتمد</div>
            <div class="aib__sub">المدينة المنورة</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- SERVICES CARDS -->
<section style="padding:88px 0;background:var(--light);">
  <div class="page-container">
    <div class="sec-header">
      <div class="sec-tag">ماذا نقدم</div>
      <h2 class="sec-title">خدماتنا العقارية <span class="c-gold">المتكاملة</span></h2>
      <p class="sec-sub">نغطي كل احتياجاتك العقارية تحت سقف واحد</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;">

      <div class="about-svc-card">
        <div class="about-svc-card__ico">🏢</div>
        <h3>إدارة الأملاك</h3>
        <p>نتولى الإدارة الكاملة للوحدات السكنية والتجارية — من التأجير والصيانة وتحصيل الإيجارات، وحتى التعامل مع المستأجرين باحترافية تامة.</p>
        <ul class="about-svc-card__list">
          <li>إدارة العقود والتجديد</li>
          <li>تحصيل الإيجارات</li>
          <li>الصيانة والمتابعة</li>
          <li>التقارير الدورية للملاك</li>
        </ul>
      </div>

      <div class="about-svc-card about-svc-card--featured">
        <div class="about-svc-card__ico">🤝</div>
        <h3>الوساطة العقارية</h3>
        <p>نربط البائعين بالمشترين والملاك بالمستأجرين بكل سهولة وشفافية. فريقنا المعتمد يضمن صفقة عادلة وموثقة لجميع الأطراف.</p>
        <ul class="about-svc-card__list">
          <li>بيع وشراء العقارات</li>
          <li>إيجار الوحدات السكنية</li>
          <li>توثيق العقود إلكترونياً</li>
          <li>استشارات قانونية</li>
        </ul>
      </div>

      <div class="about-svc-card">
        <div class="about-svc-card__ico">📣</div>
        <h3>التسويق العقاري</h3>
        <p>فريق تسويق محترف يضع عقارك أمام الجمهور المناسب عبر أحدث قنوات التسويق الرقمي والتقليدي لضمان أسرع بيع أو تأجير.</p>
        <ul class="about-svc-card__list">
          <li>تصوير احترافي للعقارات</li>
          <li>حملات إعلانية مستهدفة</li>
          <li>تسويق رقمي متكامل</li>
          <li>قاعدة عملاء واسعة</li>
        </ul>
      </div>

    </div>
  </div>
</section>

<!-- VISION MISSION VALUES -->
<section style="padding:88px 0;background:var(--dark);">
  <div class="page-container">
    <div class="sec-header">
      <div class="sec-tag">هويتنا</div>
      <h2 class="sec-title" style="color:#fff;">رؤيتنا، مهمتنا، <span class="c-gold">وقيمنا</span></h2>
    </div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;">

      <div class="vmv-card">
        <div class="vmv-card__ico">🔭</div>
        <div class="vmv-card__tag">رؤيتنا</div>
        <h3>أن نكون الخيار الأول</h3>
        <p>نسعى لأن نكون الشركة العقارية الأولى في المدينة المنورة من حيث الثقة، الجودة، والابتكار في تقديم الخدمات العقارية المتكاملة.</p>
      </div>

      <div class="vmv-card vmv-card--gold">
        <div class="vmv-card__ico">🎯</div>
        <div class="vmv-card__tag">مهمتنا</div>
        <h3>تبسيط تجربتك العقارية</h3>
        <p>نلتزم بتقديم خدمات عقارية استثنائية تجعل رحلة البيع والشراء والتأجير تجربة سلسة وآمنة وموثوقة لكل عملائنا.</p>
      </div>

      <div class="vmv-card">
        <div class="vmv-card__ico">💎</div>
        <div class="vmv-card__tag">قيمنا</div>
        <h3>الأمانة والتميز</h3>
        <p>نبني علاقاتنا على الشفافية والأمانة الكاملة. كل صفقة نُتمها تعكس التزامنا بأعلى معايير الأخلاق المهنية والجودة.</p>
      </div>

    </div>
  </div>
</section>

<!-- TEAM -->
<section style="padding:88px 0;background:#fff;">
  <div class="page-container">
    <div class="sec-header">
      <div class="sec-tag">فريقنا</div>
      <h2 class="sec-title">خبراء في <span class="c-gold">خدمتك</span></h2>
      <p class="sec-sub">فريق متخصص من المسوقين العقاريين والوسطاء المعتمدين</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:20px;">

      <div class="team-card">
        <div class="team-card__avatar" style="background:linear-gradient(135deg,#D4AF37,#A8892A);">م</div>
        <div class="team-card__name">المدير التنفيذي</div>
        <div class="team-card__role">إدارة الأملاك والوساطة</div>
        <div class="team-card__desc">مسؤول إدارة الأملاك والوساطة العقارية بالمدينة المنورة</div>
      </div>

      <div class="team-card">
        <div class="team-card__avatar" style="background:linear-gradient(135deg,#1A5276,#0D2139);">م</div>
        <div class="team-card__name">مسوق عقاري</div>
        <div class="team-card__role">مسوق عقاري معتمد</div>
        <div class="team-card__desc">متخصص في التسويق الرقمي وإيجاد المستأجرين المناسبين بأسرع وقت</div>
      </div>

      <div class="team-card">
        <div class="team-card__avatar" style="background:linear-gradient(135deg,#1A7340,#0D2E19);">و</div>
        <div class="team-card__name">وسيط عقاري</div>
        <div class="team-card__role">وسيط معتمد</div>
        <div class="team-card__desc">يضمن إتمام الصفقات بكل شفافية وسرعة مع توثيق رسمي لجميع العقود</div>
      </div>

      <div class="team-card">
        <div class="team-card__avatar" style="background:linear-gradient(135deg,#6E2F00,#3a1500);">إ</div>
        <div class="team-card__name">إدارة العملاء</div>
        <div class="team-card__role">مسؤول خدمة العملاء</div>
        <div class="team-card__desc">متابعة مستمرة لجميع احتياجات العملاء وضمان رضاهم التام</div>
      </div>

    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-section">
  <div class="page-container">
    <div class="cta-section__inner">
      <div class="cta-section__deco"></div>
      <h2 class="cta-section__title">هل تبحث عن شريك عقاري موثوق؟</h2>
      <p class="cta-section__sub">تواصل مع فريقنا اليوم — سواء كنت تريد إيجار وحدة، بيع عقار، أو تسويق ملكك</p>
      <div class="cta-section__btns">
        <a href="/listings" class="btn btn-gold btn-lg">تصفح الوحدات المتاحة</a>
        <a href="/inquiry" class="btn btn-ghost btn-lg">تواصل معنا</a>
      </div>
    </div>
  </div>
</section>

