<!-- INTRO -->
<section style="padding:88px 0;background:#fff;">
  <div class="page-container">
    <div class="about-intro__grid">
      <div>
        <div class="sec-tag">قصتنا</div>
        <h2 style="font-size:clamp(1.6rem,3vw,2.3rem);font-weight:800;margin-bottom:20px;line-height:1.4;">
          شريكك الموثوق في <span class="c-gold">السوق العقاري</span>
        </h2>
        <p style="color:var(--text2);font-size:15px;line-height:2;margin-bottom:16px;">
          تأسست شركة Finsight بهدف واحد واضح: تقديم خدمة عقارية متكاملة تجمع بين الاحترافية والأمانة. بنينا سمعتنا في المدينة المنورة عقداً بعد عقد، وعميلاً بعد عميل.
        </p>
        <p style="color:var(--text2);font-size:15px;line-height:2;margin-bottom:32px;">
          اليوم نفخر بإدارة ٤ مجمعات سكنية متكاملة، وتقديم خدمات الوساطة العقارية والتسويق لعملائنا بأعلى مستويات الكفاءة والشفافية.
        </p>
        <div style="display:flex;gap:24px;flex-wrap:wrap;">
          <div style="text-align:center;">
            <div style="font-size:2.4rem;font-weight:900;color:var(--gold);">فال ✓</div>
            <div style="font-size:13px;color:var(--text3);margin-top:4px;">رخصة معتمدة</div>
          </div>
          <div style="text-align:center;">
            <div style="font-size:2.4rem;font-weight:900;color:var(--gold);">4</div>
            <div style="font-size:13px;color:var(--text3);margin-top:4px;">مجمعات سكنية</div>
          </div>
          <div style="text-align:center;">
            <div style="font-size:2.4rem;font-weight:900;color:var(--gold);">+2000</div>
            <div style="font-size:13px;color:var(--text3);margin-top:4px;">عميل</div>
          </div>
        </div>
      </div>
      <div class="about-intro__visual">
        <div class="about-img" style="aspect-ratio:1/1;">
          <div class="about-img__stat">
            <div class="about-img__stat-num">الثقة أولاً</div>
            <div class="about-img__stat-lbl">قيمتنا الأساسية</div>
          </div>
        </div>
        <div class="about-img__badge">
          <div class="aib__ico">🏅</div>
          <div>
            <div class="aib__title">وسيط عقاري معتمد</div>
            <div class="aib__sub">المدينة المنورة</div>
          </div>
        </div>
      </div>
