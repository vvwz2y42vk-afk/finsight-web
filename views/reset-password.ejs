<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>إعادة تعيين كلمة المرور — Barez</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/client.css">
<style>
.auth-wrap{min-height:100vh;display:flex;align-items:center;justify-content:center;background:var(--light);padding:40px 16px;}
.auth-card{background:#fff;border-radius:20px;padding:40px 36px;width:100%;max-width:460px;box-shadow:0 4px 40px rgba(0,0,0,.07);}
.auth-logo{text-align:center;margin-bottom:28px;}
.auth-title{font-size:1.4rem;font-weight:800;margin-bottom:6px;}
.auth-sub{font-size:13px;color:var(--text3);margin-bottom:28px;}
.auth-err{background:rgba(192,57,43,.08);border:1px solid rgba(192,57,43,.3);border-radius:10px;padding:12px 16px;margin-bottom:20px;font-size:13px;color:#c0392b;font-weight:600;}
.auth-invalid{background:rgba(192,57,43,.05);border:1px solid rgba(192,57,43,.2);border-radius:10px;padding:20px;font-size:14px;color:var(--text2);text-align:center;}
.auth-invalid a{color:var(--gold);font-weight:700;text-decoration:none;}
.auth-group{margin-bottom:18px;}
.auth-lbl{display:block;font-size:13px;font-weight:600;margin-bottom:6px;color:var(--text2);}
.auth-inp{width:100%;padding:11px 14px;border-radius:10px;border:1px solid var(--border);font-family:inherit;font-size:14px;outline:none;transition:border .2s;background:#fff;}
.auth-inp:focus{border-color:var(--gold);}
.auth-btn{width:100%;padding:13px;background:var(--gold);border:none;border-radius:12px;color:#fff;font-family:inherit;font-size:1rem;font-weight:700;cursor:pointer;transition:opacity .2s;margin-top:8px;}
.auth-btn:hover{opacity:.9;}
.auth-foot{text-align:center;margin-top:20px;font-size:13px;color:var(--text3);}
.auth-foot a{color:var(--gold);font-weight:600;text-decoration:none;}
</style>
</head>
<body style="background:var(--light);">
<div class="auth-wrap">
  <div class="auth-card">
    <div class="auth-logo">
      <img src="/images/logo-dark.png" alt="Barez" style="height:60px;width:auto;margin:0 auto;display:block;">
    </div>
    <h2 class="auth-title">إعادة تعيين كلمة المرور</h2>
    <% if (error && !token) { %>
    <div class="auth-invalid">
      ⚠️ <%= error %><br><br>
      <a href="/account/forgot-password">طلب رابط جديد ←</a>
    </div>
    <% } else { %>
    <p class="auth-sub">أدخل كلمة المرور الجديدة (8 أحرف على الأقل)</p>
    <% if (error) { %><div class="auth-err">⚠️ <%= error %></div><% } %>
    <form method="POST" action="/account/reset-password/<%= token %>">
      <div class="auth-group">
        <label class="auth-lbl">كلمة المرور الجديدة</label>
        <input type="password" name="password" class="auth-inp" placeholder="••••••••" required minlength="8" autofocus>
      </div>
      <div class="auth-group">
        <label class="auth-lbl">تأكيد كلمة المرور</label>
        <input type="password" name="confirmPassword" class="auth-inp" placeholder="••••••••" required minlength="8">
      </div>
      <button type="submit" class="auth-btn">حفظ كلمة المرور الجديدة</button>
    </form>
    <% } %>
    <div class="auth-foot"><a href="/account/login">← العودة لتسجيل الدخول</a></div>
  </div>
</div>
</body>
</html>
