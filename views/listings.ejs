<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>عقاراتنا — Barez</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/client.css">
</head>
<body class="home-page csb-layout">

<aside class="client-sidebar" id="clientSidebar">
  <div class="csb-logo">
    <div class="nav-logo-icon">FS</div>
    <div><div class="nav-logo-name">BAREZ</div><div class="nav-logo-sub"></div></div>
  </div>
  <nav class="csb-nav">
    <a href="/" class="csb-lnk"><span class="csb-ico">⬡</span><span>الرئيسية</span></a>
    <div class="csb-divider"></div>
    <a href="/listings" class="csb-lnk active"><span class="csb-ico">🏢</span><span>عقاراتنا</span></a>
    <div class="csb-sub">
      <a href="/listings?cat=rental_apartment" class="csb-sublnk <%= cat==='rental_apartment'?'active':'' %>">🛏 شقق للإيجار</a>
      <a href="/listings?cat=rental_commercial" class="csb-sublnk <%= cat==='rental_commercial'?'active':'' %>">🏪 معارض للإيجار</a>
      <a href="/listings?cat=sale_land" class="csb-sublnk <%= cat==='sale_land'?'active':'' %>">🌍 أراضي للبيع</a>
      <a href="/listings?cat=sale_apartment" class="csb-sublnk <%= cat==='sale_apartment'?'active':'' %>">🏠 شقق للبيع</a>
    </div>
    <div class="csb-divider"></div>
    <a href="/search" class="csb-lnk"><span class="csb-ico">🔍</span><span>بحث</span></a>
    <% if (typeof customer !== 'undefined' && customer) { %>
    <a href="/account" class="csb-lnk"><span class="csb-ico">👤</span><span><%= customer.name %></span></a>
    <% } else { %>
    <a href="/account/login" class="csb-lnk"><span class="csb-ico">👤</span><span>حسابي</span></a>
    <% } %>
    <a href="/about" class="csb-lnk"><span class="csb-ico">ℹ️</span><span>من نحن</span></a>
    <a href="/inquiry" class="csb-lnk"><span class="csb-ico">💬</span><span>تواصل معنا</span></a>
  </nav>
  <div class="csb-foot">
    <a href="https://wa.me/966590561057" target="_blank" class="csb-wa">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
      <span>0590561057</span>
    </a>
    
  </div>
</aside>
<div class="csb-overlay" id="csbOverlay" onclick="closeSidebar()"></div>
<button class="csb-ham" id="csbHam" onclick="toggleSidebar()"><span></span><span></span><span></span></button>

<div class="csb-content">

<!-- HERO -->
<section class="about-hero" style="min-height:280px;">
  <div class="about-hero__content">
    <div class="sec-tag">Barez</div>
    <h1 class="about-hero__title">عقاراتنا في <span class="c-gold">المدينة المنورة</span></h1>
    <p class="about-hero__sub">شقق للإيجار • معارض تجارية • أراضي للبيع</p>
  </div>
</section>

<!-- FILTER BAR -->
<div class="listings-filter-bar" style="position:static;">
  <div class="page-container">
    <form method="GET" action="/listings" class="listings-filter-form" style="flex-wrap:wrap;gap:12px;">
      <input type="hidden" name="cat" value="<%= cat %>">

      <% if (cat==='rental_apartment' || cat==='sale_apartment') { %>
      <div class="lf-group">
        <label class="lf-lbl">المجمع</label>
        <select name="building" class="lf-select">
          <option value="">الكل</option>
          <% buildings.forEach(b => { %><option value="<%= b %>" <%= q.building===b?'selected':'' %>><%= b %></option><% }); %>
        </select>
      </div>
      <% } %>

      <% if (cat==='rental_apartment') { %>
      <div class="lf-group">
        <label class="lf-lbl">نوع الإيجار</label>
        <div class="lf-tabs">
          <a href="/listings?cat=rental_apartment<%= q.building?'&building='+encodeURIComponent(q.building):'' %>&sort=<%= q.sort||'newest' %>" class="lf-tab <%= !q.type||q.type==='all'?'active':'' %>">الكل</a>
          <a href="/listings?cat=rental_apartment<%= q.building?'&building='+encodeURIComponent(q.building):'' %>&type=daily&sort=<%= q.sort||'newest' %>" class="lf-tab <%= q.type==='daily'?'active':'' %>">يومي</a>
          <a href="/listings?cat=rental_apartment<%= q.building?'&building='+encodeURIComponent(q.building):'' %>&type=annual&sort=<%= q.sort||'newest' %>" class="lf-tab <%= q.type==='annual'?'active':'' %>">شهري</a>
        </div>
      </div>
      <% } %>

<div class="lf-group">
        <label class="lf-lbl">الترتيب</label>
        <select name="sort" class="lf-select">
          <option value="newest"     <%= (!q.sort||q.sort==='newest')   ?'selected':'' %>>الأحدث</option>
          <option value="featured"   <%= q.sort==='featured'            ?'selected':'' %>>المميزة أولاً</option>
          <option value="price_asc"  <%= q.sort==='price_asc'           ?'selected':'' %>>السعر: من الأقل</option>
          <option value="price_desc" <%= q.sort==='price_desc'          ?'selected':'' %>>السعر: من الأعلى</option>
        </select>
      </div>

      <button type="submit" class="btn btn-gold btn-sm" style="align-self:flex-end;margin-bottom:1px;">تصفية</button>

      <% if ((q.sort&&q.sort!=='newest')||(q.type&&q.type!=='all')||q.building) { %>
      <a href="/listings?cat=<%= cat %>" class="btn btn-sm" style="align-self:flex-end;color:var(--text3);border:1px solid var(--border);">مسح الفلاتر</a>
      <% } %>

      <div class="lf-count" style="margin-right:auto;">
        <span class="c-gold" style="font-weight:700;font-size:1.1rem;"><%= listings.length %></span>
        <span style="color:var(--text3);font-size:13px;"> نتيجة</span>
      </div>
    </form>
  </div>
</div>

<!-- LISTINGS GRID -->
<section style="padding:48px 0 80px;background:<%= (cat==='rental_apartment'||cat==='sale_apartment')?'var(--light)':'#fff' %>;">
  <div class="page-container">
    <% if (listings.length === 0) { %>
    <div style="text-align:center;padding:80px 0;">
      <div style="font-size:3.5rem;margin-bottom:16px;"><%= cat==='rental_apartment'?'🏠':cat==='rental_commercial'?'🏪':cat==='sale_apartment'?'🏠':'🌍' %></div>
      <h3 style="font-size:1.4rem;font-weight:700;margin-bottom:8px;">
        لا يوجد <%= cat==='rental_apartment'?'شقق للإيجار':cat==='rental_commercial'?'معارض للإيجار':cat==='sale_apartment'?'شقق للبيع':'أراضي للبيع' %> حالياً
      </h3>
      <p style="color:var(--text3);margin-bottom:20px;">تواصل معنا مباشرة للاستفسار</p>
      <a href="/inquiry" class="btn btn-gold" style="display:inline-flex;">تواصل معنا</a>
    </div>
    <% } else { %>
    <div class="listing-grid">
      <% listings.forEach(l => { %>
      <a href="/listings/<%= l._id %>" class="listing-card">
        <div class="listing-card__photo">
          <% if (l.photos && l.photos.length) { %>
          <img src="<%= l.photos[0] %>" alt="<%= l.title %>" loading="lazy">
          <% } else { %>
          <div class="listing-card__photo-ph">
            <%= cat==='rental_apartment'?'🏢':cat==='rental_commercial'?'🏪':cat==='sale_apartment'?'🏠':'🌍' %>
          </div>
          <% } %>
          <div class="listing-card__badges">
            <% if (l.featured) { %><span class="lc-badge lc-badge--featured">⭐ مميز</span><% } %>
            <% if (cat==='rental_apartment') { %>
            <span class="lc-badge lc-badge--type">
              <%= l.type==='daily'?'يومي':l.type==='annual'?'شهري':'يومي + شهري' %>
            </span>
            <% } else if (cat==='rental_commercial') { %>
            <span class="lc-badge lc-badge--type">للإيجار</span>
            <% } else if (cat==='sale_land') { %>
            <span class="lc-badge lc-badge--type" style="background:rgba(212,175,55,.9);">أرض للبيع</span>
            <% } else { %>
            <span class="lc-badge lc-badge--type" style="background:rgba(212,175,55,.9);">شقة للبيع</span>
            <% } %>
          </div>
        </div>
        <div class="listing-card__body">
          <% if (cat==='rental_apartment' && l.building) { %>
          <div class="listing-card__building"><%= l.building %></div>
          <% } else if (l.location) { %>
          <div class="listing-card__building">📍 <%= l.location %></div>
          <% } %>
          <div class="listing-card__title"><%= l.title %></div>

          <% if (cat==='rental_apartment' || cat==='sale_apartment') { %>
          <div class="listing-card__meta">
            <span>🛏 <%= l.bedrooms %> <%= l.bedrooms===1?'غرفة':'غرف' %></span>
            <span>🚿 <%= l.bathrooms %> حمام</span>
            <% if (l.area) { %><span>📐 <%= l.area %> م²</span><% } %>
          </div>
          <% } else if (cat==='rental_commercial') { %>
          <div class="listing-card__meta">
            <% if (l.area) { %><span>📐 المساحة: <%= l.area %> م²</span><% } %>
            <% if (l.floor) { %><span>🏢 الدور <%= l.floor %></span><% } %>
          </div>
          <% } else { %>
          <div class="listing-card__meta">
            <% if (l.area) { %><span>📐 المساحة: <%= l.area %> م²</span><% } %>
            <% if (l.frontage) { %><span>↔️ الواجهة: <%= l.frontage %> م</span><% } %>
          </div>
          <% } %>

          <div class="listing-card__footer">
            <span class="listing-card__cta">تفاصيل ←</span>
          </div>
        </div>
      </a>
      <% }); %>
    </div>
    <% } %>
  </div>
</section>

<!-- FOOTER -->
<footer class="site-footer-new">
  <div class="page-container">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="footer-brand__logo">
          <div class="nav-logo-icon">FS</div>
          <div><div class="nav-logo-name">BAREZ</div><div class="nav-logo-sub"></div></div>
        </div>
        <p class="footer-brand__desc">شركة رائدة في إدارة الأملاك والوساطة العقارية بالمدينة المنورة.</p>
      </div>
      <div class="footer-col">
        <div class="footer-col__title">الأقسام</div>
        <a href="/listings?cat=rental_apartment">🏠 شقق للإيجار</a>
        <a href="/listings?cat=rental_commercial">🏪 معارض للإيجار</a>
        <a href="/listings?cat=sale_land">🌍 أراضي للبيع</a>
      </div>
      <div class="footer-col">
        <div class="footer-col__title">روابط سريعة</div>
        <a href="/">الرئيسية</a>
        <a href="/about">من نحن</a>
        <a href="/inquiry">تواصل معنا</a>
      </div>
      <div class="footer-col">
        <div class="footer-col__title">تواصل معنا</div>
        <a href="https://wa.me/966590561057">0590561057</a>
        <a href="mailto:realstate@barezz.com">realstate@barezz.com</a>
      </div>
    </div>
    <div class="footer-bottom">
      <p>© 2026 Barez — جميع الحقوق محفوظة <p>© 2026 Barez — جميع الحقوق محفوظة</p>nbsp;·<p>© 2026 Barez — جميع الحقوق محفوظة</p>nbsp; <a href="/terms" style="color:inherit;opacity:.6;">الشروط والأحكام</a></p>
      
    </div>
  </div>
</footer>

</div><!-- /csb-content -->
<script>
function toggleSidebar(){document.getElementById('clientSidebar').classList.toggle('open');document.getElementById('csbOverlay').classList.toggle('open');document.getElementById('csbHam').classList.toggle('active');}
function closeSidebar(){document.getElementById('clientSidebar').classList.remove('open');document.getElementById('csbOverlay').classList.remove('open');document.getElementById('csbHam').classList.remove('active');}
</script>
</body>
</html>
