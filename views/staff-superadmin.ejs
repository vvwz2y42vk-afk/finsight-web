<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Super Admin — BAREZ</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Cairo',sans-serif;background:#04091a;color:#fff;min-height:100vh;}
.topbar{background:rgba(255,255,255,.04);border-bottom:1px solid rgba(255,255,255,.08);padding:16px 24px;display:flex;align-items:center;gap:16px;}
.topbar-logo{font-size:18px;font-weight:900;letter-spacing:.12em;color:#C9A844;}
.topbar-sub{font-size:11px;color:rgba(255,255,255,.35);letter-spacing:.08em;}
.topbar-user{margin-right:auto;font-size:12px;color:rgba(255,255,255,.45);}
.topbar-logout{padding:6px 14px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:8px;color:rgba(255,255,255,.6);font-family:inherit;font-size:12px;cursor:pointer;text-decoration:none;}
.page{padding:28px 24px;max-width:1300px;margin:0 auto;}
.page-title{font-size:1.4rem;font-weight:800;margin-bottom:6px;}
.page-sub{font-size:13px;color:rgba(255,255,255,.4);margin-bottom:24px;}
.stats-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:16px;margin-bottom:28px;}
.stat-card{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);border-radius:14px;padding:20px 18px;}
.stat-val{font-size:2rem;font-weight:900;line-height:1;}
.stat-lbl{font-size:12px;color:rgba(255,255,255,.4);margin-top:6px;}
.filters{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:20px;align-items:center;}
.filters input,.filters select{padding:9px 14px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:10px;font-family:inherit;font-size:13px;color:#fff;outline:none;}
.filters input::placeholder{color:rgba(255,255,255,.3);}
.filters input:focus,.filters select:focus{border-color:rgba(201,168,68,.6);}
.filters select option{background:#1a2035;}
.btn-filter{padding:9px 18px;background:#C9A844;border:none;border-radius:10px;color:#fff;font-family:inherit;font-size:13px;font-weight:700;cursor:pointer;}
.table-wrap{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:16px;overflow:hidden;}
table{width:100%;border-collapse:collapse;}
th{padding:12px 14px;text-align:right;font-size:11px;color:rgba(255,255,255,.4);font-weight:700;letter-spacing:.06em;border-bottom:1px solid rgba(255,255,255,.06);background:rgba(255,255,255,.02);}
td{padding:13px 14px;font-size:13px;border-bottom:1px solid rgba(255,255,255,.04);}
tr:last-child td{border-bottom:none;}
tr:hover td{background:rgba(255,255,255,.03);}
.badge{display:inline-flex;align-items:center;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;}
.badge-trial{background:rgba(251,191,36,.12);color:#FCD34D;}
.badge-basic{background:rgba(59,130,246,.12);color:#93C5FD;}
.badge-pro{background:rgba(16,185,129,.12);color:#6EE7B7;}
.badge-active{background:rgba(16,185,129,.1);color:#6EE7B7;}
.badge-inactive{background:rgba(239,68,68,.1);color:#FCA5A5;}
.badge-expired{background:rgba(239,68,68,.12);color:#FCA5A5;}
.act-btn{padding:5px 12px;border-radius:7px;font-family:inherit;font-size:11px;font-weight:700;cursor:pointer;border:none;transition:all .15s;}
.act-toggle{background:rgba(255,255,255,.07);color:rgba(255,255,255,.7);}
.act-toggle:hover{background:rgba(255,255,255,.12);}
.act-extend{background:rgba(201,168,68,.15);color:#C9A844;}
.act-extend:hover{background:rgba(201,168,68,.25);}
.act-plan{background:rgba(59,130,246,.12);color:#93C5FD;padding:4px 8px;border:none;border-radius:6px;font-family:inherit;font-size:11px;font-weight:700;cursor:pointer;}
.pager{display:flex;align-items:center;gap:10px;margin-top:20px;justify-content:center;}
.pager-btn{padding:8px 18px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:9px;color:rgba(255,255,255,.7);font-family:inherit;font-size:13px;cursor:pointer;}
.pager-btn:disabled{opacity:.3;cursor:default;}
.pager-info{font-size:13px;color:rgba(255,255,255,.4);}
.empty{padding:40px;text-align:center;color:rgba(255,255,255,.3);font-size:14px;}
.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#1e293b;border:1px solid rgba(255,255,255,.12);border-radius:12px;padding:12px 22px;font-size:13px;font-weight:600;z-index:9999;display:none;box-shadow:0 8px 32px rgba(0,0,0,.5);}
</style>
</head>
<body>

<div class="topbar">
  <div>
    <div class="topbar-logo">BAREZ</div>
    <div class="topbar-sub">SUPER ADMIN</div>
  </div>
  <div class="topbar-user">مرحباً <%= admin.name %></div>
  <a href="/logout" class="topbar-logout">خروج</a>
</div>

<div class="page">
  <div class="page-title">إدارة المستأجرين</div>
  <div class="page-sub">جميع المنشآت المسجلة في BAREZ Pro</div>

  <div class="stats-row" id="stats-row">
    <div class="stat-card"><div class="stat-val" id="s-total">—</div><div class="stat-lbl">إجمالي المستأجرين</div></div>
    <div class="stat-card"><div class="stat-val" id="s-active">—</div><div class="stat-lbl">نشط</div></div>
    <div class="stat-card"><div class="stat-val" id="s-trial">—</div><div class="stat-lbl">تجريبي</div></div>
    <div class="stat-card"><div class="stat-val" id="s-pro">—</div><div class="stat-lbl">Pro</div></div>
  </div>

  <div class="filters">
    <input type="text" id="q-input" placeholder="بحث بالاسم أو الإيميل..." style="min-width:220px;">
    <select id="plan-filter">
      <option value="">كل الخطط</option>
      <option value="trial">تجريبي</option>
      <option value="basic">Basic</option>
      <option value="pro">Pro</option>
    </select>
    <select id="active-filter">
      <option value="">الكل</option>
      <option value="true">نشط</option>
      <option value="false">موقوف</option>
    </select>
    <button class="btn-filter" onclick="load(1)">بحث</button>
  </div>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>المنشأة</th>
          <th>المدينة</th>
          <th>الإيميل</th>
          <th>الخطة</th>
          <th>انتهاء الخطة</th>
          <th>الموظفون</th>
          <th>الحجوزات</th>
          <th>الحالة</th>
          <th>إجراءات</th>
        </tr>
      </thead>
      <tbody id="tbody"></tbody>
    </table>
    <div id="empty" class="empty" style="display:none;">لا يوجد مستأجرون</div>
  </div>

  <div class="pager">
    <button class="pager-btn" id="prev-btn" onclick="load(_page-1)" disabled>السابق</button>
    <span class="pager-info" id="pager-info"></span>
    <button class="pager-btn" id="next-btn" onclick="load(_page+1)" disabled>التالي</button>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
let _page=1, _total=0, _limit=20;

function planBadge(p){ const m={trial:'badge-trial',basic:'badge-basic',pro:'badge-pro'}; const l={trial:'تجريبي',basic:'Basic',pro:'Pro'}; return `<span class="badge ${m[p]||'badge-trial'}">${l[p]||p}</span>`; }
function activeBadge(a){ return a ? '<span class="badge badge-active">نشط</span>' : '<span class="badge badge-inactive">موقوف</span>'; }
function fmtDate(d){ if(!d)return '—'; const dt=new Date(d); return dt.toLocaleDateString('ar-SA'); }
function isExpired(d){ return d && new Date(d)<new Date(); }

async function updateTenant(id,body){
  const r = await fetch(`/staff/api/superadmin/tenants/${id}`, {method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
  const j = await r.json();
  if(j.success){ showToast('تم التحديث'); load(_page); } else showToast('خطأ: '+(j.error||''), true);
}

function showToast(msg, err=false){
  const t=document.getElementById('toast');
  t.textContent=msg; t.style.display='block';
  t.style.color=err?'#FCA5A5':'#6EE7B7';
  clearTimeout(t._to); t._to=setTimeout(()=>t.style.display='none',2500);
}

async function load(page=1){
  _page=page;
  const q=document.getElementById('q-input').value.trim();
  const plan=document.getElementById('plan-filter').value;
  const active=document.getElementById('active-filter').value;
  const params=new URLSearchParams({page,limit:_limit});
  if(q)params.set('q',q);
  if(plan)params.set('plan',plan);
  if(active!=='')params.set('active',active);
  const r=await fetch('/staff/api/superadmin/tenants?'+params);
  const d=await r.json();
  if(!r.ok){showToast('خطأ: '+(d.error||''),true);return;}
  _total=d.total;

  // Stats
  document.getElementById('s-total').textContent=d.total;
  const rows=d.data;
  document.getElementById('s-active').textContent=rows.filter(t=>t.active).length;
  document.getElementById('s-trial').textContent=rows.filter(t=>t.plan==='trial').length;
  document.getElementById('s-pro').textContent=rows.filter(t=>t.plan==='pro').length;

  const tb=document.getElementById('tbody');
  const empty=document.getElementById('empty');
  if(!rows.length){tb.innerHTML='';empty.style.display='block';return;}
  empty.style.display='none';

  tb.innerHTML=rows.map(t=>`
    <tr>
      <td><strong>${t.name}</strong><br><span style="font-size:11px;color:rgba(255,255,255,.35);">${t.type||''}</span></td>
      <td>${t.city||'—'}</td>
      <td style="font-size:12px;">${t.adminEmail||'—'}</td>
      <td>${planBadge(t.plan)}</td>
      <td style="font-size:12px;${isExpired(t.planExpiry)?'color:#FCA5A5':''}">${fmtDate(t.planExpiry)}${isExpired(t.planExpiry)?' ⚠️':''}</td>
      <td style="text-align:center;">${t.staffCount}</td>
      <td style="text-align:center;">${t.bookingCount}</td>
      <td>${activeBadge(t.active)}</td>
      <td style="display:flex;gap:6px;flex-wrap:wrap;">
        <button class="act-btn act-toggle" onclick="updateTenant('${t._id}',{active:${!t.active}})">${t.active?'إيقاف':'تفعيل'}</button>
        <button class="act-btn act-extend" onclick="extendPlan('${t._id}')">تمديد 30 يوم</button>
        <select class="act-plan" onchange="if(this.value)updateTenant('${t._id}',{plan:this.value});this.value=''">
          <option value="">الخطة ▾</option>
          <option value="trial">تجريبي</option>
          <option value="basic">Basic</option>
          <option value="pro">Pro</option>
        </select>
      </td>
    </tr>
  `).join('');

  const pages=Math.ceil(_total/_limit);
  document.getElementById('pager-info').textContent=`صفحة ${_page} من ${pages} (${_total} منشأة)`;
  document.getElementById('prev-btn').disabled=_page<=1;
  document.getElementById('next-btn').disabled=_page>=pages;
  document.getElementById('next-btn').onclick=()=>load(_page+1);
  document.getElementById('prev-btn').onclick=()=>load(_page-1);
}

function extendPlan(id){
  const expiry=new Date();
  expiry.setDate(expiry.getDate()+30);
  updateTenant(id,{planExpiry:expiry.toISOString()});
}

document.getElementById('q-input').addEventListener('keydown',e=>{ if(e.key==='Enter') load(1); });
load(1);
</script>
</body>
</html>
