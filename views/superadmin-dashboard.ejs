function openExtend(id, name, plan){
  document.getElementById('ext-id').value=id;
  document.getElementById('ext-name').textContent=name;
  document.getElementById('ext-plan').value=plan||'trial';
  document.getElementById('extend-modal').classList.add('open');
}
async function submitExtend(){
  const id=document.getElementById('ext-id').value;
  const plan=document.getElementById('ext-plan').value;
  const days=document.getElementById('ext-days').value;
  try{
    const r=await fetch('/superadmin/api/extend',{
      method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({id,plan,days})
    });
    const d=await r.json();
    if(d.success){ toast('✅ تم التمديد حتى '+new Date(d.newExpiry).toLocaleDateString('ar-SA'),'ok'); closeModal('extend-modal'); loadProps(); loadOverview(); }
    else toast('❌ '+d.error,'err');
  }catch(e){ toast('❌ حدث خطأ','err'); }
}

async function toggleProp(id, btn){
  const isActive=!btn.classList.contains('off');
  if(isActive && !confirm('إيقاف هذه المنشأة سيمنع موظفيها من الدخول. متأكد؟')) return;
  try{
    const r=await fetch('/superadmin/api/toggle',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id})});
    const d=await r.json();
    if(d.success){
      toast(d.active?'✅ تم تفعيل المنشأة':'🔴 تم إيقاف المنشأة', d.active?'ok':'err');
      loadProps();
    } else toast('❌ '+d.error,'err');
  }catch(e){ toast('❌ حدث خطأ','err'); }
}

async function deleteProp(id, name){
  if(!confirm(`حذف "${name}" بشكل نهائي؟\nسيتم حذف جميع الموظفين المرتبطين.`)) return;
  try{
    const r=await fetch('/superadmin/api/properties/'+id,{method:'DELETE'});
    const d=await r.json();
    if(d.success){ toast('تم الحذف','ok'); loadProps(); }
    else toast('❌ '+d.error,'err');
  }catch(e){ toast('❌ حدث خطأ','err'); }
}

// ══════════════════════════════════════════════════════════
//  STAFF (all system staff)
// ══════════════════════════════════════════════════════════
let _staffCache = [];
async function loadStaff(){
  const tbody=document.getElementById('staff-tbody');
  tbody.innerHTML=skeletonRows(6,'skel-staff-row',6);

  try{
    // Fetch all staff (all properties)
    const propFilter=document.getElementById('staff-prop-filter')?.value||'all';
    const roleFilter=document.getElementById('staff-role-filter')?.value||'all';
    const q         =document.getElementById('staff-search')?.value.toLowerCase()||'';

    // Build requests: one per property (or all)
    let staff=[];
    if(propFilter==='all'){
      const fetches=_allProps.map(p=>
        fetch('/superadmin/api/properties/'+p._id+'/staff').then(r=>r.json()).then(list=>
          list.map(s=>({...s,_propName:p.name}))
        ).catch(()=>[])
      );
      const results=await Promise.all(fetches);
      staff=results.flat();
    }else{
      const prop=_allProps.find(p=>p._id===propFilter);
      const list=await fetch('/superadmin/api/properties/'+propFilter+'/staff').then(r=>r.json());
      staff=list.map(s=>({...s,_propName:prop?.name||propFilter}));
    }

    _staffCache=staff;

    // Filter client-side
    let filtered=staff;
    if(roleFilter!=='all') filtered=filtered.filter(s=>s.role===roleFilter);
    if(q) filtered=filtered.filter(s=>
      s.name?.toLowerCase().includes(q)||s.username?.toLowerCase().includes(q)
    );

    document.getElementById('staff-count-sub').textContent=`${filtered.length} موظف`;

    if(!filtered.length){
      tbody.innerHTML=`<tr><td colspan="6"><div class="empty">
        <div class="empty-ico">👥</div>
        <div class="empty-ttl">لا يوجد موظفون</div>
        <div class="empty-sub">لم يتم إضافة موظفين بعد</div>
      </div></td></tr>`;
      return;
    }

    tbody.innerHTML=filtered.map(s=>`<tr>
      <td>
        <div style="font-weight:700;color:var(--t1);">${esc(s.name)}</div>
        <div style="font-size:10px;color:var(--t4);direction:ltr;text-align:right;">${esc(s.username)}</div>
      </td>
      <td style="font-size:11px;color:var(--t3);">${esc(s._propName||s.building||'—')}</td>
      <td><span class="role-pill role-${s.role}">${s.role==='manager'?'مدير':'استقبال'}</span></td>
      <td><span class="bdg ${s.active?'bdg-active':'bdg-stopped'}">${s.active?'نشط':'موقوف'}</span></td>
      <td style="font-size:11px;color:var(--t4);">${fDate(s.createdAt)}</td>
      <td>
        <div class="ia-row">
          <button class="ia ia-pwd" data-tip="إعادة تعيين كلمة المرور" onclick="openResetPwd('${s._id}')">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </button>
          <button class="ia ia-tog ${!s.active?'off':''}" data-tip="${s.active?'إيقاف':'تفعيل'}" onclick="toggleStaff('${s._id}',this)">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18.36 6.64a9 9 0 1 1-12.73 0"/><line x1="12" y1="2" x2="12" y2="12"/></svg>
          </button>
          <button class="ia ia-del" data-tip="حذف الموظف" onclick="deleteStaff('${s._id}','${esc(s.name)}')">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/></svg>
          </button>
        </div>
      </td>
    </tr>`).join('');

  }catch(e){ toast('❌ تعذر تحميل الموظفين','err'); }
}

async function toggleStaff(id, btn){
