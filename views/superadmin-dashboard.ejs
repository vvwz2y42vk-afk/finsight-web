<div id="toast"></div>

<script>
/* ═════════════════════════════════════════════════════════
   BAREZ ADMIN — CLIENT INFRASTRUCTURE
   Cache layer · Lazy loading · Debounce · Pagination
   ═════════════════════════════════════════════════════════ */

// ── State & Cache ─────────────────────────────────────────
const _cache   = {};          // section cache: loaded data
const _loaded  = {};          // which sections have been loaded
let   _allProps = [];         // all properties (for staff filter)
let   _logPage  = 1;
let   _drawerPropId = null;
let   _debTimer = {};

// ── Clock ─────────────────────────────────────────────────
(function clock(){
  const el=document.getElementById('clock');
  const tick=()=>{ el.textContent=new Date().toLocaleString('ar-SA',{hour:'2-digit',minute:'2-digit',second:'2-digit',day:'2-digit',month:'short'}); };
  tick(); setInterval(tick,1000);
})();

// ── Helpers ───────────────────────────────────────────────
function toast(msg, type='info'){
  const t=document.getElementById('toast');
  t.className = type==='ok'?'show ok':type==='err'?'show err':'show';
  t.textContent=msg;
  clearTimeout(t._tmr);
  t._tmr=setTimeout(()=>t.className='',2800);
}
function esc(s){ return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
function fDate(d){ if(!d)return'—'; return new Date(d).toLocaleDateString('ar-SA',{year:'numeric',month:'short',day:'numeric'}); }
function daysLeft(expiry){
  if(!expiry) return null;
  return Math.ceil((new Date(expiry)-new Date())/86400000);
}
function debounce(fn, key, ms=320){
  clearTimeout(_debTimer[key]);
  _debTimer[key]=setTimeout(fn, ms);
}
function debounceLoadProps(){ debounce(loadProps,'props'); }
function debounceLoadStaff(){ debounce(loadStaff,'staff'); }
function debounceLoadLog()  { debounce(()=>loadLog(1),'log'); }

function statusInfo(p){
  const now=new Date();
  const exp=p.planExpiry?new Date(p.planExpiry):null;
  if(!p.active) return {cls:'bdg-stopped',lbl:'موقوفة'};
  if(exp&&exp<now) return {cls:'bdg-expired',lbl:'منتهية'};
  if(p.plan==='trial') return {cls:'bdg-trial',lbl:'تجريبية'};
  return {cls:'bdg-active',lbl:'نشطة'};
}
function planPill(plan){
  const m={trial:'plan-trial تجريبية',basic:'plan-basic أساسية',pro:'plan-pro احترافية'};
  const[cls,lbl]=(m[plan]||'plan-trial تجريبية').split(' ');
  return `<span class="plan-pill ${cls}">${lbl}</span>`;
}
function skeletonRows(count, cls, cols){
  return Array.from({length:count},()=>`<tr><td colspan="${cols}">
    <div class="skel-row ${cls}">${Array.from({length:cols-1},()=>'<span class="skel"></span>').join('')}</div>
  </td></tr>`).join('');
}

// ── Close modal ───────────────────────────────────────────
function closeModal(id){ document.getElementById(id).classList.remove('open'); }

// ── Tab navigation ────────────────────────────────────────
const TAB_TITLES = {
  overview:'نظرة <span>عامة</span>',
  properties:'المنشآت',
  staff:'الموظفون',
  log:'سجل <span>العمليات</span>',
};
function goTab(id, el){
  document.querySelectorAll('.tab-sec').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.sn').forEach(n=>n.classList.remove('active'));
  document.getElementById('tab-'+id).classList.add('active');
  if(el) el.classList.add('active');
  document.getElementById('tb-title').innerHTML = TAB_TITLES[id]||id;
  // lazy load
  if(!_loaded[id]){
    _loaded[id]=true;
    if(id==='properties') loadProps();
    if(id==='staff')      loadStaff();
    if(id==='log')        loadLog(1);
  }
}

// ══════════════════════════════════════════════════════════
//  OVERVIEW — KPIs + Chart + Feed + Expiring
// ══════════════════════════════════════════════════════════
async function loadOverview(){
  try{
    const [stats, chart, activity, props] = await Promise.all([
      fetch('/superadmin/api/stats').then(r=>r.json()),
      fetch('/superadmin/api/chart').then(r=>r.json()),
      fetch('/superadmin/api/activity?limit=8').then(r=>r.json()),
      fetch('/superadmin/api/properties').then(r=>r.json()),
    ]);

    // KPIs
    document.getElementById('kpi-total').textContent   = stats.total   ?? '—';
    document.getElementById('kpi-active').textContent  = stats.active  ?? '—';
    document.getElementById('kpi-trial').textContent   = stats.trial   ?? '—';
    document.getElementById('kpi-expired').textContent = stats.expired ?? '—';
    document.getElementById('kpi-staff').textContent   = stats.staffCount ?? '—';

    // Sidebar badges
    document.getElementById('sb-props-cnt').textContent = stats.total??'—';
    document.getElementById('sb-staff-cnt').textContent = stats.staffCount??'—';

    // Chart
    const ctx=document.getElementById('bookingsChart').getContext('2d');
    const grad=ctx.createLinearGradient(0,0,0,110);
    grad.addColorStop(0,'rgba(59,130,246,.3)');
    grad.addColorStop(1,'rgba(59,130,246,.02)');
    new Chart(ctx,{type:'line',data:{
      labels:chart.labels,
      datasets:[{data:chart.data,borderColor:'#3B82F6',backgroundColor:grad,borderWidth:2,tension:.42,fill:true,pointRadius:3,pointBackgroundColor:'#3B82F6'}]
    },options:{responsive:true,plugins:{legend:{display:false}},scales:{
      x:{grid:{color:'rgba(255,255,255,.04)'},ticks:{color:'#3D5275',font:{size:10,family:'Cairo'}}},
      y:{grid:{color:'rgba(255,255,255,.04)'},ticks:{color:'#3D5275',font:{size:10,family:'Cairo'}}},
    }}});

    // Activity feed
    const feedEl=document.getElementById('feed-list');
    const acts=activity.logs||[];
    const DOT={create:'#10B981',update:'#3B82F6',delete:'#EF4444',login:'#8B5CF6',approve:'#10B981',reject:'#EF4444'};
    feedEl.innerHTML=acts.length?acts.map(l=>`
      <div class="feed-item">
        <div class="feed-dot" style="background:${DOT[l.action]||'#6B84A8'};"></div>
        <div class="feed-content">
          <div class="feed-main">${esc(l.user)} — ${esc(l.summary||l.action)}</div>
          <div class="feed-sub">${esc(l.model||'')} ${l.ip?'· '+esc(l.ip):''}</div>
        </div>
        <div class="feed-time">${new Date(l.createdAt).toLocaleTimeString('ar-SA',{hour:'2-digit',minute:'2-digit'})}</div>
      </div>`).join(''):
      `<div class="empty"><div class="empty-sub">لا توجد عمليات بعد</div></div>`;

    // Expiring soon (≤7 days)
    const expiring=(props||[]).filter(p=>{
      const d=daysLeft(p.planExpiry);
      return p.active && d!==null && d>=0 && d<=7;
    });
    document.getElementById('expiring-sub').textContent=`${expiring.length} منشأة`;
    const tbody=document.getElementById('expiring-tbody');
    tbody.innerHTML=expiring.length?expiring.map(p=>{
      const d=daysLeft(p.planExpiry);
      const s=statusInfo(p);
      return `<tr>
        <td><b style="color:var(--t1);">${esc(p.name)}</b><div style="font-size:10px;color:var(--t4);">${esc(p.city||'—')}</div></td>
        <td>${planPill(p.plan)}</td>
        <td><span class="bdg ${s.cls}">${s.lbl}</span></td>
        <td style="color:${d<=2?'var(--red)':'var(--amber)'};">${d===0?'اليوم':d+' يوم'}</td>
        <td><button class="btn btn-amber btn-sm" onclick="openExtend('${p._id}','${esc(p.name)}','${p.plan}')">تمديد</button></td>
      </tr>`;
    }).join(''):
    `<tr><td colspan="5"><div class="empty">
      <div class="empty-ico"><svg width="22" height="22" fill="none" stroke="var(--green)" stroke-width="2" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></div>
      <div class="empty-ttl">لا توجد اشتراكات تنتهي قريباً</div>
    </div></td></tr>`;

    _allProps=props||[];
    _buildPropFilter();

  }catch(e){ toast('❌ تعذر تحميل البيانات','err'); console.error(e); }
}

