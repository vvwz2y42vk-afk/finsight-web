<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>BAREZ — لوحة التحكم</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
/* ═══════════════════════════════════════════════
   BAREZ ADMIN — DARK SaaS INFRASTRUCTURE LAYER
   ═══════════════════════════════════════════════ */
:root{
  --bg:#070C18;
  --s1:#0C1322;--s2:#101829;--s3:#141F33;--s4:#1A2540;
  --border:#1E2D45;--border-s:#162035;
  --t1:#F0F6FF;--t2:#B8C8E0;--t3:#6B84A8;--t4:#3D5275;
  --brand:#2563EB;--brand-l:#3B82F6;--brand-d:#1D4ED8;
  --green:#10B981;--green-bg:rgba(16,185,129,.1);--green-b:rgba(16,185,129,.2);
  --amber:#F59E0B;--amber-bg:rgba(245,158,11,.1);--amber-b:rgba(245,158,11,.2);
  --red:#EF4444;--red-bg:rgba(239,68,68,.1);--red-b:rgba(239,68,68,.2);
  --purple:#8B5CF6;--purple-bg:rgba(139,92,246,.1);
  --r:12px;--r-lg:16px;
  --sh:0 4px 24px rgba(0,0,0,.35);
  --sh-sm:0 2px 10px rgba(0,0,0,.25);
  --ease:cubic-bezier(.4,0,.2,1);
  --sb:220px;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Cairo',sans-serif;background:var(--bg);direction:rtl;display:flex;min-height:100vh;color:var(--t1);-webkit-font-smoothing:antialiased;}

/* ══ Sidebar ══════════════════════════════════════ */
.sb{
  width:var(--sb);background:var(--s1);
  border-left:1px solid var(--border);
  display:flex;flex-direction:column;
  position:fixed;top:0;right:0;bottom:0;z-index:100;
  padding:0 0 16px;overflow:hidden;
  box-shadow:-2px 0 20px rgba(0,0,0,.4);
}
.sb-brand{
  display:flex;align-items:center;gap:10px;
  padding:20px 18px 16px;
  border-bottom:1px solid var(--border);
  margin-bottom:8px;
}
.sb-brand-icon{
  width:34px;height:34px;border-radius:9px;
  background:linear-gradient(135deg,#1a3d8f,var(--brand-l));
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;font-size:16px;
}
.sb-brand-name{font-size:14px;font-weight:800;color:var(--t1);letter-spacing:-.02em;}
.sb-brand-sub{font-size:10px;color:var(--t4);letter-spacing:.06em;text-transform:uppercase;margin-top:1px;}
.sb-section{font-size:9px;font-weight:700;color:var(--t4);letter-spacing:.1em;text-transform:uppercase;padding:10px 18px 6px;}
.sb-nav{flex:1;overflow-y:auto;padding:0 10px;}
.sn{
  display:flex;align-items:center;gap:10px;
  padding:9px 10px;border-radius:9px;
  cursor:pointer;color:var(--t3);font-size:13px;font-weight:500;
  transition:all .18s var(--ease);margin-bottom:2px;white-space:nowrap;
}
.sn:hover{background:rgba(255,255,255,.04);color:var(--t2);}
.sn.active{
  background:linear-gradient(135deg,rgba(37,99,235,.2),rgba(59,130,246,.1));
  color:var(--brand-l);
  box-shadow:inset 0 0 0 1px rgba(59,130,246,.2);
}
.sn-ico{width:20px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.sn-badge{margin-right:auto;font-size:10px;font-weight:700;background:rgba(37,99,235,.2);color:var(--brand-l);padding:1px 7px;border-radius:20px;}
.sn-badge.red{background:rgba(239,68,68,.18);color:var(--red);}
.sb-foot{padding:0 10px;border-top:1px solid var(--border);padding-top:12px;margin-top:4px;}

/* ══ Main ═════════════════════════════════════════ */
.main{margin-right:var(--sb);flex:1;display:flex;flex-direction:column;min-height:100vh;min-width:0;}

/* ══ Topbar ═══════════════════════════════════════ */
.topbar{
  background:rgba(12,19,34,.95);backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border);
  height:56px;padding:0 28px;
  display:flex;align-items:center;justify-content:space-between;
  position:sticky;top:0;z-index:50;
}
.tb-title{font-size:15px;font-weight:700;color:var(--t1);}
.tb-title span{color:var(--brand-l);}
.tb-right{display:flex;align-items:center;gap:14px;}
.tb-clock{font-size:12px;color:var(--t4);font-variant-numeric:tabular-nums;letter-spacing:.03em;}
.tb-avatar{
  width:32px;height:32px;border-radius:8px;
  background:linear-gradient(135deg,var(--brand-d),var(--brand-l));
  display:flex;align-items:center;justify-content:center;
  font-size:13px;font-weight:800;color:#fff;
}
.tb-logout{font-size:11px;color:var(--t4);text-decoration:none;padding:5px 12px;border-radius:7px;border:1px solid var(--border);transition:all .15s;}
.tb-logout:hover{color:var(--red);border-color:rgba(239,68,68,.3);background:rgba(239,68,68,.06);}

/* ══ Content area ═════════════════════════════════ */
.content{padding:24px 28px;flex:1;}

/* ══ Tab sections ═════════════════════════════════ */
.tab-sec{display:none;}
.tab-sec.active{display:block;animation:fadeUp .2s ease both;}
@keyframes fadeUp{from{opacity:0;transform:translateY(5px);}to{opacity:1;transform:translateY(0);}}

/* ══ KPI Row ══════════════════════════════════════ */
.kpi-row{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:24px;}
.kpi{
  background:var(--s2);border:1px solid var(--border);border-radius:var(--r);
  padding:16px 18px;position:relative;overflow:hidden;
  transition:border-color .2s,transform .2s;
}
.kpi:hover{border-color:var(--brand);transform:translateY(-2px);}
.kpi::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;opacity:0;transition:opacity .2s;}
.kpi:hover::before{opacity:1;}
.kpi.k-blue::before{background:linear-gradient(90deg,var(--brand-d),var(--brand-l));}
.kpi.k-green::before{background:linear-gradient(90deg,#059669,var(--green));}
.kpi.k-amber::before{background:linear-gradient(90deg,#D97706,var(--amber));}
.kpi.k-red::before{background:linear-gradient(90deg,#DC2626,var(--red));}
.kpi.k-purple::before{background:linear-gradient(90deg,#6D28D9,var(--purple));}
.kpi-label{font-size:10px;font-weight:700;color:var(--t4);text-transform:uppercase;letter-spacing:.07em;margin-bottom:10px;}
.kpi-val{font-size:30px;font-weight:900;line-height:1;letter-spacing:-.04em;}
.kpi-val.blue{color:var(--brand-l);}
.kpi-val.green{color:var(--green);}
.kpi-val.amber{color:var(--amber);}
.kpi-val.red{color:var(--red);}
.kpi-val.purple{color:var(--purple);}
.kpi-sub{font-size:10px;color:var(--t4);margin-top:6px;}

/* ══ Section headers ══════════════════════════════ */
.sec-hd{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;gap:12px;flex-wrap:wrap;}
.sec-ttl{font-size:14px;font-weight:800;color:var(--t1);}
.sec-sub{font-size:11px;color:var(--t4);margin-top:1px;}

/* ══ Cards (table containers) ════════════════════ */
.card{
  background:var(--s2);border:1px solid var(--border);border-radius:var(--r-lg);
  overflow:hidden;width:100%;
}
.card-hd{
  padding:14px 18px;
  display:flex;align-items:center;justify-content:space-between;gap:12px;
  border-bottom:1px solid var(--border);background:rgba(255,255,255,.015);
  flex-wrap:wrap;
}
.card-hd-title{font-size:13px;font-weight:700;color:var(--t1);}
.card-hd-sub{font-size:11px;color:var(--t4);margin-top:1px;}

/* ══ Search / Filter bar ══════════════════════════ */
.filter-bar{display:flex;gap:8px;align-items:center;flex-wrap:wrap;}
.fi{
  padding:7px 12px;border-radius:8px;
  border:1px solid var(--border);background:var(--s3);
  font-family:'Cairo',sans-serif;font-size:12px;color:var(--t2);
  outline:none;transition:border-color .15s,box-shadow .15s;
}
.fi:focus{border-color:var(--brand);box-shadow:0 0 0 3px rgba(37,99,235,.1);}
.fi::placeholder{color:var(--t4);}
.fi-select{min-width:130px;}

/* ══ Primary button ═══════════════════════════════ */
.btn{
  display:inline-flex;align-items:center;gap:6px;
  padding:7px 14px;border-radius:8px;border:none;
  font-family:'Cairo',sans-serif;font-size:12px;font-weight:700;
  cursor:pointer;transition:all .15s;white-space:nowrap;
}
.btn-primary{background:linear-gradient(135deg,var(--brand-d),var(--brand-l));color:#fff;box-shadow:0 2px 8px rgba(37,99,235,.3);}
.btn-primary:hover{box-shadow:0 4px 14px rgba(37,99,235,.4);transform:translateY(-1px);}
.btn-sm{padding:5px 10px;font-size:11px;border-radius:7px;}
.btn-ghost{background:transparent;color:var(--t3);border:1px solid var(--border);}
.btn-ghost:hover{background:var(--s3);color:var(--t2);border-color:var(--t4);}
.btn-danger{background:rgba(239,68,68,.1);color:var(--red);border:1px solid rgba(239,68,68,.2);}
.btn-danger:hover{background:rgba(239,68,68,.18);}
.btn-success{background:rgba(16,185,129,.1);color:var(--green);border:1px solid rgba(16,185,129,.2);}
.btn-success:hover{background:rgba(16,185,129,.18);}
.btn-amber{background:rgba(245,158,11,.1);color:var(--amber);border:1px solid rgba(245,158,11,.2);}
.btn-amber:hover{background:rgba(245,158,11,.18);}

/* ══ Tables ═══════════════════════════════════════ */
.tbl-wrap{overflow-x:auto;width:100%;}
.atbl{width:100%;border-collapse:collapse;font-size:12.5px;}
.atbl th{
  padding:10px 14px;text-align:right;
  font-size:10px;font-weight:700;color:var(--t4);
  text-transform:uppercase;letter-spacing:.07em;
  background:var(--s1);border-bottom:1px solid var(--border);
  white-space:nowrap;
}
.atbl td{
  padding:12px 14px;border-bottom:1px solid var(--border-s);
  color:var(--t2);vertical-align:middle;
}
.atbl tbody tr:last-child td{border-bottom:none;}
.atbl tbody tr{transition:background .12s;}
.atbl tbody tr:hover td{background:rgba(255,255,255,.025);}

/* ══ Badges ═══════════════════════════════════════ */
.bdg{display:inline-flex;align-items:center;gap:4px;padding:3px 9px;border-radius:20px;font-size:10px;font-weight:700;white-space:nowrap;}
.bdg::before{content:'';width:5px;height:5px;border-radius:50%;flex-shrink:0;}
.bdg-active {background:var(--green-bg);color:var(--green);border:1px solid var(--green-b);}
.bdg-active::before{background:var(--green);}
.bdg-trial  {background:var(--amber-bg);color:var(--amber);border:1px solid var(--amber-b);}
.bdg-trial::before{background:var(--amber);}
.bdg-expired{background:var(--red-bg);color:var(--red);border:1px solid var(--red-b);}
.bdg-expired::before{background:var(--red);}
.bdg-stopped{background:rgba(107,132,168,.1);color:var(--t3);border:1px solid var(--border);}
.bdg-stopped::before{background:var(--t4);}
.plan-pill{display:inline-block;padding:2px 8px;border-radius:6px;font-size:10px;font-weight:700;}
.plan-trial{background:rgba(245,158,11,.12);color:var(--amber);}
.plan-basic{background:rgba(59,130,246,.12);color:#60A5FA;}
.plan-pro  {background:rgba(16,185,129,.12);color:var(--green);}
.role-pill{display:inline-block;padding:2px 8px;border-radius:6px;font-size:10px;font-weight:700;}
.role-manager  {background:rgba(139,92,246,.12);color:var(--purple);}
.role-receptionist{background:rgba(59,130,246,.1);color:#93C5FD;}

/* ══ Skeleton loaders ═════════════════════════════ */
@keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}
.skel{
  background:linear-gradient(90deg,var(--s3) 25%,var(--s4) 50%,var(--s3) 75%);
  background-size:200% 100%;
  animation:shimmer 1.8s infinite;
  border-radius:5px;display:block;
}
.skel-row{display:flex;gap:12px;padding:12px 14px;border-bottom:1px solid var(--border-s);}
.skel-row:last-child{border-bottom:none;}

/* Prop table skeleton */
.skel-prop-row .skel:nth-child(1){width:160px;height:14px;}
.skel-prop-row .skel:nth-child(2){width:60px;height:14px;}
.skel-prop-row .skel:nth-child(3){width:70px;height:18px;border-radius:20px;}
.skel-prop-row .skel:nth-child(4){width:70px;height:18px;border-radius:20px;}
.skel-prop-row .skel:nth-child(5){width:90px;height:14px;}
.skel-prop-row .skel:nth-child(6){flex:1;height:14px;}
.skel-prop-row .skel:nth-child(7){width:80px;height:26px;border-radius:7px;}

/* Staff skeleton */
.skel-staff-row .skel:nth-child(1){width:120px;height:14px;}
.skel-staff-row .skel:nth-child(2){width:100px;height:14px;}
.skel-staff-row .skel:nth-child(3){width:80px;height:18px;border-radius:20px;}
.skel-staff-row .skel:nth-child(4){width:70px;height:18px;border-radius:20px;}
.skel-staff-row .skel:nth-child(5){flex:1;height:14px;}
.skel-staff-row .skel:nth-child(6){width:60px;height:26px;border-radius:7px;}

/* Log skeleton */
.skel-log-row .skel:nth-child(1){width:80px;height:14px;}
.skel-log-row .skel:nth-child(2){width:50px;height:18px;border-radius:20px;}
.skel-log-row .skel:nth-child(3){width:50px;height:18px;border-radius:20px;}
.skel-log-row .skel:nth-child(4){flex:1;height:14px;}
.skel-log-row .skel:nth-child(5){width:90px;height:12px;}

/* ══ Pagination ═══════════════════════════════════ */
.pag{display:flex;align-items:center;gap:6px;padding:14px 18px;justify-content:space-between;border-top:1px solid var(--border);}
.pag-info{font-size:11px;color:var(--t4);}
.pag-btns{display:flex;gap:4px;}
.pag-btn{width:30px;height:30px;border-radius:7px;border:1px solid var(--border);background:var(--s3);cursor:pointer;color:var(--t3);font-size:12px;font-weight:600;display:flex;align-items:center;justify-content:center;transition:all .12s;font-family:'Cairo',sans-serif;}
.pag-btn:hover{background:var(--s4);color:var(--t1);border-color:var(--t4);}
.pag-btn.active{background:var(--brand);border-color:var(--brand);color:#fff;}
.pag-btn:disabled{opacity:.3;cursor:not-allowed;}

/* ══ Action icon buttons ══════════════════════════ */
.ia-row{display:inline-flex;gap:4px;}
.ia{width:26px;height:26px;border-radius:6px;border:none;cursor:pointer;display:inline-flex;align-items:center;justify-content:center;font-size:12px;transition:all .15s;position:relative;flex-shrink:0;}
.ia::after{content:attr(data-tip);position:absolute;bottom:calc(100%+5px);left:50%;transform:translateX(-50%);background:rgba(0,0,0,.85);color:#fff;font-size:10px;font-weight:600;padding:3px 8px;border-radius:5px;white-space:nowrap;pointer-events:none;opacity:0;transition:opacity .12s;font-family:'Cairo',sans-serif;z-index:20;}
.ia:hover::after{opacity:1;}
.ia:hover{transform:scale(1.12);}
.ia-ext {background:rgba(245,158,11,.12);color:var(--amber);}
.ia-tog {background:rgba(16,185,129,.1); color:var(--green);}
.ia-tog.off{background:rgba(239,68,68,.1);color:var(--red);}
.ia-del {background:rgba(239,68,68,.1);color:var(--red);}
.ia-view{background:rgba(59,130,246,.1);color:#60A5FA;}
.ia-pwd {background:rgba(139,92,246,.1);color:var(--purple);}

/* ══ Charts ═══════════════════════════════════════ */
.charts-row{display:grid;grid-template-columns:1fr 280px;gap:14px;margin-bottom:24px;}
.chart-card{background:var(--s2);border:1px solid var(--border);border-radius:var(--r-lg);padding:20px;}
.chart-ttl{font-size:12px;font-weight:700;color:var(--t2);margin-bottom:16px;display:flex;align-items:center;gap:8px;}
.chart-ttl::before{content:'';width:3px;height:14px;border-radius:2px;background:linear-gradient(180deg,var(--brand-l),var(--brand-d));flex-shrink:0;}

/* ══ Activity feed ════════════════════════════════ */
.feed-item{display:flex;align-items:flex-start;gap:10px;padding:10px 0;border-bottom:1px solid var(--border-s);}
.feed-item:last-child{border-bottom:none;}
.feed-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;margin-top:4px;}
.feed-content{flex:1;min-width:0;}
.feed-main{font-size:12px;color:var(--t2);font-weight:500;}
.feed-sub{font-size:10px;color:var(--t4);margin-top:2px;}
.feed-time{font-size:10px;color:var(--t4);white-space:nowrap;margin-top:2px;}

/* ══ Modal overlay ════════════════════════════════ */
.mover{display:none;position:fixed;inset:0;background:rgba(0,0,0,.65);backdrop-filter:blur(6px);z-index:200;align-items:center;justify-content:center;}
.mover.open{display:flex;}
.mdl{
  background:var(--s2);border:1px solid var(--border);border-radius:var(--r-lg);
  width:100%;max-width:460px;max-height:90vh;overflow:auto;
  box-shadow:0 24px 60px rgba(0,0,0,.5);
  animation:mdlIn .2s cubic-bezier(.34,1.2,.64,1) both;
}
@keyframes mdlIn{from{opacity:0;transform:scale(.94) translateY(12px);}to{opacity:1;transform:scale(1) translateY(0);}}
.mdl-hd{padding:18px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
.mdl-title{font-size:14px;font-weight:700;color:var(--t1);}
.mdl-close{background:none;border:none;color:var(--t4);font-size:20px;cursor:pointer;line-height:1;transition:color .12s;}
.mdl-close:hover{color:var(--t1);}
.mdl-body{padding:20px;}
.mdl-footer{padding:14px 20px;border-top:1px solid var(--border);display:flex;gap:8px;justify-content:flex-end;}

/* ══ Form fields ══════════════════════════════════ */
.fg{margin-bottom:14px;}
.fg label{display:block;font-size:11px;font-weight:700;color:var(--t3);margin-bottom:6px;letter-spacing:.03em;}
.fg input,.fg select,.fg textarea{
  width:100%;padding:9px 12px;
  background:var(--s1);border:1.5px solid var(--border);border-radius:8px;
  font-family:'Cairo',sans-serif;font-size:13px;color:var(--t1);outline:none;
  transition:border-color .15s,box-shadow .15s;
}
.fg input:focus,.fg select:focus,.fg textarea:focus{border-color:var(--brand);box-shadow:0 0 0 3px rgba(37,99,235,.1);}
.fg input::placeholder,.fg textarea::placeholder{color:var(--t4);}
.fg select option{background:var(--s2);color:var(--t1);}
.fg-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;}

/* ══ Empty state ══════════════════════════════════ */
.empty{
  text-align:center;padding:48px 20px;
  display:flex;flex-direction:column;align-items:center;gap:10px;
}
.empty-ico{width:48px;height:48px;border-radius:14px;background:var(--s3);display:flex;align-items:center;justify-content:center;margin-bottom:4px;}
.empty-ttl{font-size:13px;font-weight:700;color:var(--t2);}
.empty-sub{font-size:12px;color:var(--t4);}

/* ══ Log action colors ════════════════════════════ */
.ac-create{background:rgba(16,185,129,.12);color:var(--green);}
.ac-update{background:rgba(59,130,246,.12);color:#60A5FA;}
.ac-delete{background:rgba(239,68,68,.12);color:var(--red);}
.ac-login {background:rgba(139,92,246,.12);color:var(--purple);}
.ac-approve{background:rgba(16,185,129,.12);color:var(--green);}
.ac-reject {background:rgba(239,68,68,.12);color:var(--red);}

/* ══ Toast ════════════════════════════════════════ */
#toast{
  position:fixed;bottom:24px;left:50%;
  transform:translateX(-50%) translateY(60px);
  background:var(--s3);border:1px solid var(--border);
  border-radius:12px;padding:11px 20px;
  font-size:13px;font-weight:600;color:var(--t1);
  z-index:500;transition:transform .28s cubic-bezier(.34,1.56,.64,1);
  white-space:nowrap;box-shadow:var(--sh);
  display:flex;align-items:center;gap:8px;
}
#toast.show{transform:translateX(-50%) translateY(0);}
#toast.ok {background:linear-gradient(135deg,rgba(4,120,87,.9),rgba(16,185,129,.9));border-color:rgba(52,211,153,.2);}
#toast.err{background:linear-gradient(135deg,rgba(185,28,28,.9),rgba(239,68,68,.9));border-color:rgba(252,165,165,.2);}

/* ══ Drawer (staff panel) ═════════════════════════ */
.drawer{
  position:fixed;top:0;left:0;bottom:0;
  width:480px;background:var(--s1);
  border-right:1px solid var(--border);
  z-index:300;transform:translateX(-100%);
  transition:transform .3s var(--ease);
  display:flex;flex-direction:column;
  box-shadow:4px 0 24px rgba(0,0,0,.4);
}
.drawer.open{transform:translateX(0);}
.drawer-hd{padding:18px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-shrink:0;}
.drawer-title{font-size:14px;font-weight:700;color:var(--t1);}
.drawer-body{flex:1;overflow-y:auto;padding:16px 20px;}
.drawer-footer{padding:14px 20px;border-top:1px solid var(--border);flex-shrink:0;}
.drawer-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:290;}
.drawer-bg.open{display:block;}
</style>
</head>
<body>

<!-- ══ Sidebar ══════════════════════════════════════════════ -->
