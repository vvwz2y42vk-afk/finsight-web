async function loadProps(){
  const tbody=document.getElementById('props-tbody');
  tbody.innerHTML=skeletonRows(6,'skel-prop-row',8);

  const q      = document.getElementById('prop-search')?.value||'';
  const status = document.getElementById('prop-status')?.value||'all';
  const plan   = document.getElementById('prop-plan')?.value||'all';

  try{
    const params=new URLSearchParams({q,status,plan});
    const list=await fetch('/superadmin/api/properties?'+params).then(r=>r.json());
    document.getElementById('props-count-sub').textContent=`${list.length} منشأة`;

    if(!list.length){
      tbody.innerHTML=`<tr><td colspan="8"><div class="empty">
        <div class="empty-ico">🏢</div>
        <div class="empty-ttl">لا توجد منشآت</div>
        <div class="empty-sub">أضف منشأة جديدة لتبدأ</div>
      </div></td></tr>`;
      return;
    }

    tbody.innerHTML=list.map(p=>{
      const s=statusInfo(p);
      const d=daysLeft(p.planExpiry);
      const dStr=d===null?'—':d<0?`<span style="color:var(--red);">منتهي</span>`:d<=7?`<span style="color:var(--amber);">${d} يوم</span>`:`${d} يوم`;
      return `<tr id="prop-row-${p._id}">
        <td>
          <div style="font-weight:700;color:var(--t1);">${esc(p.name)}</div>
          <div style="font-size:10px;color:var(--t4);">${esc(p.city||'—')} ${p.adminEmail?'· '+esc(p.adminEmail):''}</div>
        </td>
        <td style="color:var(--t3);font-size:11px;">${{apartment:'شقق',hotel:'فندق',mixed:'مختلط'}[p.type]||p.type}</td>
        <td>${planPill(p.plan)}</td>
        <td><span class="bdg ${s.cls}">${s.lbl}</span></td>
        <td><div style="font-size:12px;">${fDate(p.planExpiry)}</div><div style="font-size:10px;color:var(--t4);">${dStr}</div></td>
        <td style="font-weight:700;color:var(--t2);">${p.staffCount||0}</td>
        <td style="font-weight:700;color:var(--t2);">${p.bookingCount||0}</td>
        <td>
          <div class="ia-row">
            <button class="ia ia-view" data-tip="موظفو المنشأة" onclick="openDrawer('${p._id}','${esc(p.name)}')">
              <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
            </button>
            <button class="ia ia-ext" data-tip="تمديد الاشتراك" onclick="openExtend('${p._id}','${esc(p.name)}','${p.plan}')">
              <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            </button>
            <button class="ia ia-tog ${!p.active?'off':''}" data-tip="${p.active?'إيقاف تشغيل':'تفعيل'}" onclick="toggleProp('${p._id}',this)">
              <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18.36 6.64a9 9 0 1 1-12.73 0"/><line x1="12" y1="2" x2="12" y2="12"/></svg>
            </button>
            <button class="ia ia-del" data-tip="حذف المنشأة" onclick="deleteProp('${p._id}','${esc(p.name)}')">
              <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6m4-6v6"/></svg>
            </button>
          </div>
        </td>
      </tr>`;
    }).join('');

    _allProps=list;
    _buildPropFilter();

  }catch(e){ toast('❌ تعذر تحميل المنشآت','err'); }
}

function _buildPropFilter(){
  const sel=document.getElementById('staff-prop-filter');
  if(!sel) return;
  const cur=sel.value;
  sel.innerHTML='<option value="all">كل المنشآت</option>'+
    _allProps.map(p=>`<option value="${p._id}" ${p._id===cur?'selected':''}>${esc(p.name)}</option>`).join('');
}

// CRUD
function openCreateProp(){ document.getElementById('create-prop-modal').classList.add('open'); }
async function submitCreateProp(){
  const name=document.getElementById('cp-name').value.trim();
  if(!name){ toast('اسم المنشأة مطلوب','err'); return; }
  try{
    const r=await fetch('/superadmin/api/properties',{
      method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({
        name, city:document.getElementById('cp-city').value.trim(),
        type:document.getElementById('cp-type').value,
