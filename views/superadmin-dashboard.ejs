<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>BAREZ — لوحة التحكم</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
/* ═══════════════════════════════════════════════════════════
   BAREZ ADMIN — PHASE 3: LUXURY SaaS UI
   ═══════════════════════════════════════════════════════════ */
:root{
  --bg:#060B16;
  --s1:#0A1020;--s2:#0E1628;--s3:#121D32;--s4:#172338;--s5:#1C2A42;
  --border:#1C2B42;--border-s:#111E30;--border-h:#243550;
  --t1:#ECF2FF;--t2:#A8BEDD;--t3:#5B7BA0;--t4:#2E4566;
  --brand:#2563EB;--brand-l:#3B82F6;--brand-d:#1D4ED8;--brand-g:linear-gradient(135deg,#1D4ED8,#3B82F6);
  --green:#10B981;--green-d:#059669;--green-bg:rgba(16,185,129,.08);--green-b:rgba(16,185,129,.18);
  --amber:#F59E0B;--amber-d:#D97706;--amber-bg:rgba(245,158,11,.08);--amber-b:rgba(245,158,11,.18);
  --red:#EF4444;--red-d:#DC2626;--red-bg:rgba(239,68,68,.08);--red-b:rgba(239,68,68,.18);
  --purple:#8B5CF6;--purple-d:#6D28D9;--purple-bg:rgba(139,92,246,.08);
  --r:10px;--r-lg:14px;--r-xl:18px;
  --sh:0 8px 32px rgba(0,0,0,.45);
  --sh-sm:0 2px 10px rgba(0,0,0,.3);
  --ease:cubic-bezier(.4,0,.2,1);
  --ease-spring:cubic-bezier(.34,1.3,.64,1);
  --sb:224px;
  --topbar:56px;
}

*{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{
  font-family:'Cairo',sans-serif;
  background:var(--bg);direction:rtl;display:flex;
  min-height:100vh;color:var(--t1);
  -webkit-font-smoothing:antialiased;
  background-image:
    radial-gradient(ellipse 80% 50% at 50% -10%,rgba(37,99,235,.12),transparent),
    url("data:image/svg+xml,%3Csvg width='32' height='32' viewBox='0 0 32 32' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='1' cy='1' r='.6' fill='%23162035'/%3E%3C/svg%3E");
  background-size:auto, 32px 32px;
}

/* ══ Scrollbar ══════════════════════════════════════════════ */
::-webkit-scrollbar{width:4px;height:4px;}
::-webkit-scrollbar-track{background:transparent;}
::-webkit-scrollbar-thumb{background:var(--s4);border-radius:4px;}
::-webkit-scrollbar-thumb:hover{background:var(--t4);}

/* ══ Sidebar ════════════════════════════════════════════════ */
.sb{
  width:var(--sb);
  background:linear-gradient(180deg,var(--s1) 0%,rgba(10,16,32,.98) 100%);
  border-left:1px solid var(--border);
  display:flex;flex-direction:column;
  position:fixed;top:0;right:0;bottom:0;z-index:100;
  overflow:hidden;
}
.sb::before{
  content:'';position:absolute;top:0;right:0;width:1px;height:100%;
  background:linear-gradient(180deg,transparent,rgba(59,130,246,.25) 30%,rgba(59,130,246,.1) 70%,transparent);
}

.sb-brand{
  display:flex;align-items:center;gap:11px;
  padding:22px 18px 18px;
  border-bottom:1px solid var(--border);
  position:relative;
}
.sb-logo{
  width:36px;height:36px;border-radius:10px;flex-shrink:0;
  background:linear-gradient(135deg,#0f2d7a,#2563EB,#60a5fa);
  display:flex;align-items:center;justify-content:center;
  font-size:18px;font-weight:900;color:#fff;
  box-shadow:0 4px 14px rgba(37,99,235,.45);
  letter-spacing:-.04em;
}
.sb-brand-txt{}
.sb-brand-name{font-size:15px;font-weight:900;color:var(--t1);letter-spacing:-.03em;line-height:1.1;}
.sb-brand-sub{font-size:9px;color:var(--t4);letter-spacing:.12em;text-transform:uppercase;margin-top:2px;}

.sb-sep{height:1px;background:var(--border);margin:8px 16px;}
.sb-label{font-size:9px;font-weight:700;color:var(--t4);letter-spacing:.12em;text-transform:uppercase;padding:12px 18px 6px;}

.sb-nav{flex:1;overflow-y:auto;padding:4px 10px;}
.sn{
  display:flex;align-items:center;gap:10px;
  padding:9px 10px;border-radius:9px;cursor:pointer;
  color:var(--t3);font-size:12.5px;font-weight:500;
  transition:all .16s var(--ease);margin-bottom:1px;
  white-space:nowrap;position:relative;text-decoration:none;
}
.sn:hover{background:rgba(255,255,255,.04);color:var(--t2);}
.sn.active{
  background:linear-gradient(135deg,rgba(37,99,235,.18),rgba(59,130,246,.08));
  color:#93C5FD;font-weight:600;
  box-shadow:inset 0 0 0 1px rgba(59,130,246,.2),0 2px 12px rgba(37,99,235,.1);
}
.sn.active::after{
  content:'';position:absolute;left:0;top:25%;bottom:25%;
  width:2.5px;border-radius:2px;
  background:linear-gradient(180deg,var(--brand-l),rgba(59,130,246,.4));
}
.sn-ico{
  width:22px;height:22px;display:flex;align-items:center;justify-content:center;
  flex-shrink:0;border-radius:6px;
  transition:background .15s;
}
.sn.active .sn-ico{background:rgba(59,130,246,.15);}
.sn-badge{
  margin-right:auto;font-size:10px;font-weight:700;
  background:rgba(37,99,235,.18);color:#93C5FD;
  padding:1px 8px;border-radius:20px;
  border:1px solid rgba(59,130,246,.2);
  min-width:22px;text-align:center;
}
.sn-badge.red{background:rgba(239,68,68,.15);color:#FCA5A5;border-color:rgba(239,68,68,.2);}

.sb-foot{padding:10px 10px 14px;border-top:1px solid var(--border);}

/* ══ Main ═══════════════════════════════════════════════════ */
.main{margin-right:var(--sb);flex:1;display:flex;flex-direction:column;min-height:100vh;min-width:0;}

/* ══ Topbar ═════════════════════════════════════════════════ */
.topbar{
  background:rgba(6,11,22,.9);backdrop-filter:blur(24px) saturate(180%);
  border-bottom:1px solid var(--border);
  height:var(--topbar);padding:0 28px;
  display:flex;align-items:center;justify-content:space-between;
  position:sticky;top:0;z-index:50;
}
.topbar::after{
  content:'';position:absolute;bottom:-1px;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,rgba(59,130,246,.2) 40%,rgba(59,130,246,.1) 60%,transparent);
}
.tb-title{font-size:15px;font-weight:800;color:var(--t1);letter-spacing:-.02em;}
.tb-title .hi{
  background:linear-gradient(135deg,var(--brand-l),#93C5FD);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.tb-right{display:flex;align-items:center;gap:12px;}
.tb-clock{
  font-size:11px;color:var(--t4);font-variant-numeric:tabular-nums;
  letter-spacing:.04em;background:var(--s2);border:1px solid var(--border);
  padding:4px 10px;border-radius:7px;
}
.tb-avatar{
  width:32px;height:32px;border-radius:8px;
  background:linear-gradient(135deg,var(--brand-d),var(--brand-l));
  display:flex;align-items:center;justify-content:center;
  font-size:12px;font-weight:800;color:#fff;
  box-shadow:0 2px 8px rgba(37,99,235,.3);
  border:1px solid rgba(59,130,246,.25);
}
.tb-logout{
  font-size:11px;color:var(--t3);text-decoration:none;
  padding:5px 12px;border-radius:7px;border:1px solid var(--border);
  background:var(--s2);transition:all .15s;font-weight:600;
}
.tb-logout:hover{color:var(--red);border-color:var(--red-b);background:var(--red-bg);}

/* ══ Content ════════════════════════════════════════════════ */
.content{padding:26px 28px;flex:1;}

/* ══ Tab fade ═══════════════════════════════════════════════ */
.tab-sec{display:none;}
.tab-sec.active{display:block;animation:fadeUp .22s var(--ease) both;}
@keyframes fadeUp{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}

/* ══ KPI cards ══════════════════════════════════════════════ */
.kpi-row{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:22px;}
.kpi{
  background:var(--s2);border:1px solid var(--border);border-radius:var(--r-lg);
  padding:18px 18px 16px;position:relative;overflow:hidden;
  transition:border-color .2s,transform .2s,box-shadow .2s;cursor:default;
}
.kpi:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,.3);}
.kpi-glow{
  position:absolute;top:-20px;left:-20px;
  width:80px;height:80px;border-radius:50%;
  opacity:.12;filter:blur(20px);pointer-events:none;
  transition:opacity .25s;
}
.kpi:hover .kpi-glow{opacity:.22;}
.k-blue  .kpi-glow{background:var(--brand-l);}
.k-green .kpi-glow{background:var(--green);}
.k-amber .kpi-glow{background:var(--amber);}
.k-red   .kpi-glow{background:var(--red);}
.k-purple.kpi-glow{background:var(--purple);}
.k-purple .kpi-glow{background:var(--purple);}
.kpi-top{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:12px;}
.kpi-icon{
  width:32px;height:32px;border-radius:9px;
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
}
.k-blue  .kpi-icon{background:rgba(37,99,235,.15);color:var(--brand-l);}
.k-green .kpi-icon{background:rgba(16,185,129,.12);color:var(--green);}
.k-amber .kpi-icon{background:rgba(245,158,11,.12);color:var(--amber);}
.k-red   .kpi-icon{background:rgba(239,68,68,.12);color:var(--red);}
.k-purple .kpi-icon{background:rgba(139,92,246,.12);color:var(--purple);}
.kpi-label{font-size:10px;font-weight:700;color:var(--t4);text-transform:uppercase;letter-spacing:.08em;line-height:1.3;}
.kpi-val{font-size:34px;font-weight:900;line-height:1;letter-spacing:-.05em;margin-bottom:6px;font-variant-numeric:tabular-nums;}
.kpi-val.blue  {color:var(--brand-l);}
.kpi-val.green {color:var(--green);}
.kpi-val.amber {color:var(--amber);}
.kpi-val.red   {color:var(--red);}
.kpi-val.purple{color:var(--purple);}
.kpi-sub{font-size:10px;color:var(--t4);}
.kpi-bar{
  position:absolute;bottom:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,transparent,currentColor);
  opacity:0;transition:opacity .25s;
}
.kpi:hover .kpi-bar{opacity:.5;}
.k-blue   .kpi-bar{color:var(--brand-l);}
.k-green  .kpi-bar{color:var(--green);}
.k-amber  .kpi-bar{color:var(--amber);}
.k-red    .kpi-bar{color:var(--red);}
.k-purple .kpi-bar{color:var(--purple);}

/* ══ Charts row ═════════════════════════════════════════════ */
.charts-row{display:grid;grid-template-columns:1fr 300px;gap:14px;margin-bottom:22px;}
.chart-card{
  background:var(--s2);border:1px solid var(--border);border-radius:var(--r-xl);
  padding:22px 22px 18px;position:relative;overflow:hidden;
}
.chart-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,rgba(59,130,246,.3),transparent);
}
.chart-ttl{
  font-size:12px;font-weight:800;color:var(--t2);
  margin-bottom:18px;display:flex;align-items:center;gap:9px;
  letter-spacing:-.01em;
}
.chart-ttl-dot{
  width:6px;height:20px;border-radius:3px;flex-shrink:0;
  background:var(--brand-g);
  box-shadow:0 0 10px rgba(59,130,246,.5);
}

/* ══ Feed ═══════════════════════════════════════════════════ */
.feed-item{display:flex;align-items:flex-start;gap:10px;padding:10px 0;border-bottom:1px solid var(--border-s);}
.feed-item:last-child{border-bottom:none;}
.feed-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;margin-top:4px;}
.feed-content{flex:1;min-width:0;}
.feed-main{font-size:12px;color:var(--t2);font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.feed-sub{font-size:10px;color:var(--t4);margin-top:2px;}
.feed-time{font-size:10px;color:var(--t4);white-space:nowrap;margin-top:3px;flex-shrink:0;}

/* ══ Section header ════════════════════════════════════════ */
.sec-hd{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;gap:12px;flex-wrap:wrap;}
.sec-ttl{font-size:15px;font-weight:800;color:var(--t1);letter-spacing:-.02em;}
.sec-sub{font-size:11px;color:var(--t4);margin-top:1px;}

/* ══ Card ═══════════════════════════════════════════════════ */
.card{
  background:var(--s2);border:1px solid var(--border);border-radius:var(--r-xl);
  overflow:hidden;width:100%;
  box-shadow:0 4px 20px rgba(0,0,0,.2);
}
.card-hd{
  padding:14px 18px;
  display:flex;align-items:center;justify-content:space-between;gap:12px;
  border-bottom:1px solid var(--border);
  background:linear-gradient(180deg,rgba(255,255,255,.025),transparent);
  flex-wrap:wrap;
}
.card-hd-title{font-size:13px;font-weight:700;color:var(--t1);}
.card-hd-sub{font-size:10px;color:var(--t4);margin-top:2px;}

/* ══ Filter bar ════════════════════════════════════════════ */
.filter-bar{display:flex;gap:8px;align-items:center;flex-wrap:wrap;}
.fi{
  padding:7px 12px;border-radius:8px;
  border:1px solid var(--border);background:var(--s3);
  font-family:'Cairo',sans-serif;font-size:12px;color:var(--t2);
  outline:none;transition:border-color .15s,box-shadow .15s,background .15s;
  height:34px;
}
.fi:focus{border-color:var(--brand);box-shadow:0 0 0 3px rgba(37,99,235,.12);background:var(--s2);}
.fi::placeholder{color:var(--t4);}
.fi-select{min-width:130px;cursor:pointer;}
.fi select option{background:var(--s2);}

/* ══ Buttons ════════════════════════════════════════════════ */
.btn{
  display:inline-flex;align-items:center;gap:6px;
  padding:7px 14px;border-radius:8px;border:none;height:34px;
  font-family:'Cairo',sans-serif;font-size:12px;font-weight:700;
  cursor:pointer;transition:all .16s;white-space:nowrap;
  position:relative;overflow:hidden;
}
.btn::after{
  content:'';position:absolute;inset:0;
  background:linear-gradient(105deg,transparent 40%,rgba(255,255,255,.08) 50%,transparent 60%);
  transform:translateX(-100%);transition:transform .4s;pointer-events:none;
}
.btn:hover::after{transform:translateX(100%);}
.btn-primary{
  background:var(--brand-g);color:#fff;
  box-shadow:0 2px 10px rgba(37,99,235,.35);
}
.btn-primary:hover{box-shadow:0 4px 18px rgba(37,99,235,.5);transform:translateY(-1px);}
.btn-sm{padding:5px 10px;font-size:11px;height:30px;}
.btn-ghost{background:var(--s3);color:var(--t3);border:1px solid var(--border);}
.btn-ghost:hover{background:var(--s4);color:var(--t2);border-color:var(--border-h);}
.btn-danger{background:var(--red-bg);color:var(--red);border:1px solid var(--red-b);}
.btn-danger:hover{background:rgba(239,68,68,.15);}
.btn-success{background:var(--green-bg);color:var(--green);border:1px solid var(--green-b);}
.btn-success:hover{background:rgba(16,185,129,.14);}
.btn-amber{background:var(--amber-bg);color:var(--amber);border:1px solid var(--amber-b);}
.btn-amber:hover{background:rgba(245,158,11,.14);}

/* ══ Table ══════════════════════════════════════════════════ */
.tbl-wrap{overflow-x:auto;width:100%;}
.atbl{width:100%;border-collapse:collapse;font-size:12.5px;}
.atbl th{
  padding:10px 16px;text-align:right;
  font-size:9.5px;font-weight:800;color:var(--t4);
  text-transform:uppercase;letter-spacing:.08em;
  background:var(--s1);border-bottom:1px solid var(--border);
  white-space:nowrap;
}
.atbl td{
  padding:12px 16px;border-bottom:1px solid var(--border-s);
  color:var(--t2);vertical-align:middle;
}
.atbl tbody tr{transition:background .12s;}
.atbl tbody tr:last-child td{border-bottom:none;}
.atbl tbody tr:nth-child(even) td{background:rgba(255,255,255,.013);}
.atbl tbody tr:hover td{background:rgba(59,130,246,.05);}
.atbl tbody tr:hover td:first-child{
  border-right:2px solid rgba(59,130,246,.4);
  padding-right:14px;
}

/* ══ Badges ═════════════════════════════════════════════════ */
.bdg{display:inline-flex;align-items:center;gap:5px;padding:3px 9px;border-radius:20px;font-size:10px;font-weight:700;white-space:nowrap;}
.bdg-dot{width:5px;height:5px;border-radius:50%;flex-shrink:0;}
.bdg-active {background:var(--green-bg);color:var(--green);border:1px solid var(--green-b);}
.bdg-active .bdg-dot{background:var(--green);animation:pulse-dot 2s infinite;}
.bdg-trial  {background:var(--amber-bg);color:var(--amber);border:1px solid var(--amber-b);}
.bdg-trial .bdg-dot{background:var(--amber);}
.bdg-expired{background:var(--red-bg);color:var(--red);border:1px solid var(--red-b);}
.bdg-expired .bdg-dot{background:var(--red);}
.bdg-stopped{background:rgba(46,69,102,.15);color:var(--t3);border:1px solid var(--border);}
.bdg-stopped .bdg-dot{background:var(--t4);}
@keyframes pulse-dot{0%,100%{opacity:1;transform:scale(1);}50%{opacity:.5;transform:scale(.7);}}

.plan-pill{display:inline-block;padding:2px 9px;border-radius:6px;font-size:10px;font-weight:700;}
.plan-trial {background:rgba(245,158,11,.1);color:#FCD34D;border:1px solid rgba(245,158,11,.15);}
.plan-basic {background:rgba(59,130,246,.1);color:#93C5FD;border:1px solid rgba(59,130,246,.15);}
.plan-pro   {background:rgba(16,185,129,.1);color:#6EE7B7;border:1px solid rgba(16,185,129,.15);}

.role-pill{display:inline-block;padding:2px 9px;border-radius:6px;font-size:10px;font-weight:700;}
.role-manager     {background:rgba(139,92,246,.1);color:#C4B5FD;border:1px solid rgba(139,92,246,.15);}
.role-receptionist{background:rgba(59,130,246,.08);color:#93C5FD;border:1px solid rgba(59,130,246,.12);}

/* ══ Skeleton ═══════════════════════════════════════════════ */
@keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}
.skel{
  background:linear-gradient(90deg,var(--s3) 25%,var(--s4) 50%,var(--s3) 75%);
  background-size:200% 100%;animation:shimmer 1.8s infinite;
  border-radius:5px;display:block;
}
.skel-row{display:flex;gap:12px;padding:12px 16px;border-bottom:1px solid var(--border-s);align-items:center;}
.skel-row:last-child{border-bottom:none;}
.skel-prop-row .skel:nth-child(1){width:140px;height:13px;}
.skel-prop-row .skel:nth-child(2){width:55px;height:13px;}
.skel-prop-row .skel:nth-child(3){width:65px;height:18px;border-radius:20px;}
.skel-prop-row .skel:nth-child(4){width:65px;height:18px;border-radius:20px;}
.skel-prop-row .skel:nth-child(5){width:80px;height:13px;}
.skel-prop-row .skel:nth-child(6){flex:1;height:13px;}
.skel-prop-row .skel:nth-child(7){width:75px;height:26px;border-radius:7px;}
.skel-staff-row .skel:nth-child(1){width:110px;height:13px;}
.skel-staff-row .skel:nth-child(2){width:90px;height:13px;}
.skel-staff-row .skel:nth-child(3){width:75px;height:18px;border-radius:20px;}
.skel-staff-row .skel:nth-child(4){width:65px;height:18px;border-radius:20px;}
.skel-staff-row .skel:nth-child(5){flex:1;height:13px;}
.skel-staff-row .skel:nth-child(6){width:56px;height:26px;border-radius:7px;}
.skel-log-row .skel:nth-child(1){width:70px;height:13px;}
.skel-log-row .skel:nth-child(2){width:48px;height:18px;border-radius:20px;}
.skel-log-row .skel:nth-child(3){width:48px;height:18px;border-radius:20px;}
.skel-log-row .skel:nth-child(4){flex:1;height:13px;}
.skel-log-row .skel:nth-child(5){width:80px;height:11px;}

/* ══ Pagination ═════════════════════════════════════════════ */
.pag{
  display:flex;align-items:center;gap:6px;
  padding:14px 18px;justify-content:space-between;
  border-top:1px solid var(--border);
  background:linear-gradient(180deg,transparent,rgba(0,0,0,.08));
}
.pag-info{font-size:11px;color:var(--t4);}
.pag-btns{display:flex;gap:4px;}
.pag-btn{
  min-width:30px;height:30px;border-radius:7px;border:1px solid var(--border);
  background:var(--s3);cursor:pointer;color:var(--t3);font-size:12px;font-weight:600;
  display:flex;align-items:center;justify-content:center;transition:all .12s;
  font-family:'Cairo',sans-serif;padding:0 8px;
}
.pag-btn:hover:not(:disabled){background:var(--s4);color:var(--t1);border-color:var(--border-h);}
.pag-btn.active{background:var(--brand);border-color:var(--brand);color:#fff;box-shadow:0 2px 8px rgba(37,99,235,.3);}
.pag-btn:disabled{opacity:.3;cursor:not-allowed;}

/* ══ Action icon buttons ════════════════════════════════════ */
.ia-row{display:inline-flex;gap:4px;}
.ia{
  width:27px;height:27px;border-radius:7px;border:none;cursor:pointer;
  display:inline-flex;align-items:center;justify-content:center;
  font-size:12px;transition:all .15s;position:relative;flex-shrink:0;
}
.ia::after{
  content:attr(data-tip);position:absolute;bottom:calc(100%+6px);left:50%;
  transform:translateX(-50%);
  background:rgba(0,8,20,.9);backdrop-filter:blur(8px);
  color:var(--t1);font-size:10px;font-weight:600;
  padding:4px 9px;border-radius:6px;white-space:nowrap;
  pointer-events:none;opacity:0;transition:opacity .12s;
  font-family:'Cairo',sans-serif;z-index:20;
  border:1px solid var(--border);
  box-shadow:0 4px 12px rgba(0,0,0,.4);
}
.ia:hover::after{opacity:1;}
.ia:hover{transform:scale(1.15);}
.ia-ext {background:rgba(245,158,11,.1);color:var(--amber);  border:1px solid rgba(245,158,11,.15);}
.ia-tog {background:rgba(16,185,129,.08);color:var(--green); border:1px solid rgba(16,185,129,.12);}
.ia-tog.off{background:rgba(239,68,68,.08);color:var(--red);  border:1px solid rgba(239,68,68,.12);}
.ia-del {background:rgba(239,68,68,.08);color:var(--red);   border:1px solid rgba(239,68,68,.12);}
.ia-view{background:rgba(59,130,246,.08);color:#93C5FD;     border:1px solid rgba(59,130,246,.12);}
.ia-pwd {background:rgba(139,92,246,.08);color:var(--purple);border:1px solid rgba(139,92,246,.12);}

/* ══ Log action chips ═══════════════════════════════════════ */
.ac{display:inline-flex;padding:2px 9px;border-radius:6px;font-size:10px;font-weight:700;}
.ac-create {background:rgba(16,185,129,.1);color:#6EE7B7;}
.ac-update {background:rgba(59,130,246,.1);color:#93C5FD;}
.ac-delete {background:rgba(239,68,68,.1);color:#FCA5A5;}
.ac-login  {background:rgba(139,92,246,.1);color:#C4B5FD;}
.ac-approve{background:rgba(16,185,129,.1);color:#6EE7B7;}
.ac-reject {background:rgba(239,68,68,.1);color:#FCA5A5;}

/* ══ Empty state ════════════════════════════════════════════ */
.empty{text-align:center;padding:52px 20px;display:flex;flex-direction:column;align-items:center;gap:10px;}
.empty-ico{
  width:52px;height:52px;border-radius:16px;
  background:linear-gradient(135deg,var(--s3),var(--s4));
  border:1px solid var(--border);
  display:flex;align-items:center;justify-content:center;margin-bottom:2px;
  font-size:22px;
}
.empty-ttl{font-size:13px;font-weight:700;color:var(--t2);}
.empty-sub{font-size:11.5px;color:var(--t4);max-width:240px;}

/* ══ Toast ══════════════════════════════════════════════════ */
#toast{
  position:fixed;bottom:24px;left:50%;
  transform:translateX(-50%) translateY(70px);
  background:var(--s3);border:1px solid var(--border-h);
  border-radius:12px;padding:10px 18px 10px 16px;
  font-size:13px;font-weight:600;color:var(--t1);
  z-index:600;transition:transform .3s var(--ease-spring);
  white-space:nowrap;box-shadow:0 12px 40px rgba(0,0,0,.5);
  display:flex;align-items:center;gap:9px;
  backdrop-filter:blur(12px);
}
#toast.show{transform:translateX(-50%) translateY(0);}
#toast.ok {background:linear-gradient(135deg,rgba(4,108,78,.95),rgba(16,185,129,.9));border-color:rgba(52,211,153,.25);}
#toast.err{background:linear-gradient(135deg,rgba(153,27,27,.95),rgba(239,68,68,.9));border-color:rgba(252,165,165,.25);}

/* ══ Modal ══════════════════════════════════════════════════ */
.mover{
  display:none;position:fixed;inset:0;
  background:rgba(0,5,15,.7);backdrop-filter:blur(8px) saturate(150%);
  z-index:200;align-items:center;justify-content:center;
}
.mover.open{display:flex;}
.mdl{
  background:linear-gradient(160deg,var(--s3),var(--s2));
  border:1px solid var(--border-h);border-radius:var(--r-xl);
  width:100%;max-width:460px;max-height:90vh;overflow:auto;
  box-shadow:0 32px 80px rgba(0,0,0,.6),0 0 0 1px rgba(59,130,246,.06);
  animation:mdlIn .22s var(--ease-spring) both;
  position:relative;
}
.mdl::before{
  content:'';position:absolute;top:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,rgba(59,130,246,.5) 50%,transparent);border-radius:var(--r-xl) var(--r-xl) 0 0;
}
@keyframes mdlIn{from{opacity:0;transform:scale(.93) translateY(14px);}to{opacity:1;transform:scale(1) translateY(0);}}
.mdl-hd{padding:18px 22px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;gap:10px;}
.mdl-title{font-size:14px;font-weight:800;color:var(--t1);letter-spacing:-.01em;}
.mdl-close{background:var(--s4);border:1px solid var(--border);color:var(--t3);width:28px;height:28px;border-radius:7px;font-size:16px;cursor:pointer;line-height:1;transition:all .12s;display:flex;align-items:center;justify-content:center;}
.mdl-close:hover{color:var(--t1);background:var(--s5);}
.mdl-body{padding:22px;}
.mdl-footer{padding:14px 22px;border-top:1px solid var(--border);display:flex;gap:8px;justify-content:flex-end;background:rgba(0,0,0,.1);}

/* ══ Form fields ════════════════════════════════════════════ */
.fg{margin-bottom:14px;}
.fg label{display:block;font-size:11px;font-weight:700;color:var(--t3);margin-bottom:6px;letter-spacing:.04em;text-transform:uppercase;}
.fg input,.fg select,.fg textarea{
  width:100%;padding:9px 12px;
  background:var(--s1);border:1.5px solid var(--border);border-radius:8px;
  font-family:'Cairo',sans-serif;font-size:13px;color:var(--t1);outline:none;
  transition:border-color .15s,box-shadow .15s,background .15s;
  height:38px;
}
.fg textarea{height:auto;}
.fg input:focus,.fg select:focus,.fg textarea:focus{
  border-color:var(--brand);box-shadow:0 0 0 3px rgba(37,99,235,.12);background:var(--s2);
}
.fg input::placeholder,.fg textarea::placeholder{color:var(--t4);}
.fg select option{background:var(--s2);color:var(--t1);}
.fg-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;}

/* ══ Drawer ═════════════════════════════════════════════════ */
.drawer{
  position:fixed;top:0;left:0;bottom:0;width:440px;
  background:linear-gradient(180deg,var(--s2),var(--s1));
  border-right:1px solid var(--border);
  z-index:300;transform:translateX(-100%);transition:transform .3s var(--ease);
  display:flex;flex-direction:column;box-shadow:8px 0 40px rgba(0,0,0,.5);
}
.drawer.open{transform:translateX(0);}
.drawer-hd{
  padding:18px 20px;border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;flex-shrink:0;
  background:linear-gradient(180deg,rgba(255,255,255,.02),transparent);
}
.drawer-title{font-size:14px;font-weight:800;color:var(--t1);letter-spacing:-.01em;}
.drawer-body{flex:1;overflow-y:auto;padding:16px 20px;}
.drawer-footer{padding:14px 20px;border-top:1px solid var(--border);flex-shrink:0;}
.drawer-bg{display:none;position:fixed;inset:0;background:rgba(0,5,15,.55);z-index:290;backdrop-filter:blur(3px);}
.drawer-bg.open{display:block;}

/* ══ Staff card in drawer ═══════════════════════════════════ */
.staff-item{
  display:flex;align-items:center;gap:12px;
  padding:12px;border-radius:10px;
  border:1px solid var(--border);background:var(--s3);
  margin-bottom:8px;transition:border-color .15s,background .15s;
}
.staff-item:hover{border-color:var(--border-h);background:var(--s4);}
.staff-avatar{
  width:38px;height:38px;border-radius:10px;flex-shrink:0;
  background:var(--brand-g);display:flex;align-items:center;justify-content:center;
  font-size:15px;font-weight:800;color:#fff;
  box-shadow:0 2px 8px rgba(37,99,235,.25);
}
</style>
</head>
<body>

<!-- ══ Sidebar ═══════════════════════════════════════════════ -->
<aside class="sb">
  <div class="sb-brand">
    <div class="sb-logo">B</div>
    <div class="sb-brand-txt">
      <div class="sb-brand-name">BAREZ</div>
      <div class="sb-brand-sub">Admin Control</div>
    </div>
  </div>

  <nav class="sb-nav">
    <div class="sb-label">الرئيسية</div>
    <div class="sn active" onclick="goTab('overview',this)">
      <span class="sn-ico">
        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg>
      </span>
      نظرة عامة
    </div>

    <div class="sb-sep" style="margin-top:10px;"></div>
    <div class="sb-label">إدارة النظام</div>

    <div class="sn" onclick="goTab('properties',this)">
      <span class="sn-ico">
        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      </span>
      المنشآت
      <span class="sn-badge" id="sb-props-cnt">—</span>
    </div>

    <div class="sn" onclick="goTab('staff',this)">
      <span class="sn-ico">
        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      </span>
      الموظفون
      <span class="sn-badge" id="sb-staff-cnt">—</span>
    </div>

    <div class="sn" onclick="goTab('log',this)">
      <span class="sn-ico">
        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
      </span>
      سجل العمليات
    </div>
  </nav>

  <div class="sb-foot">
    <a href="/superadmin/logout" class="sn" style="color:#F87171;">
      <span class="sn-ico">
        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
      </span>
      تسجيل خروج
    </a>
  </div>
</aside>

<!-- ══ Main ══════════════════════════════════════════════════ -->
<div class="main">

  <header class="topbar">
    <div class="tb-title" id="tb-title">نظرة <span class="hi">عامة</span></div>
    <div class="tb-right">
      <div class="tb-clock" id="clock"></div>
      <div class="tb-avatar">SA</div>
      <a href="/superadmin/logout" class="tb-logout">خروج</a>
    </div>
  </header>

  <div class="content">

    <!-- ══════════════ TAB: Overview ═════════════════════════ -->
    <div class="tab-sec active" id="tab-overview">

      <!-- KPI cards -->
      <div class="kpi-row">
        <div class="kpi k-blue">
          <div class="kpi-glow"></div>
          <div class="kpi-top">
            <div class="kpi-label">إجمالي<br>المنشآت</div>
            <div class="kpi-icon">
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
            </div>
          </div>
          <div class="kpi-val blue" id="kpi-total"><span class="skel" style="width:48px;height:34px;display:inline-block;border-radius:6px;"></span></div>
          <div class="kpi-sub">مسجّل في المنصة</div>
          <div class="kpi-bar"></div>
        </div>

        <div class="kpi k-green">
          <div class="kpi-glow"></div>
          <div class="kpi-top">
            <div class="kpi-label">نشطة<br>ومدفوعة</div>
            <div class="kpi-icon">
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
          </div>
          <div class="kpi-val green" id="kpi-active"><span class="skel" style="width:40px;height:34px;display:inline-block;border-radius:6px;"></span></div>
          <div class="kpi-sub">اشتراك ساري</div>
          <div class="kpi-bar"></div>
        </div>

        <div class="kpi k-amber">
          <div class="kpi-glow"></div>
          <div class="kpi-top">
            <div class="kpi-label">تجريبية<br>&nbsp;</div>
            <div class="kpi-icon">
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
          </div>
          <div class="kpi-val amber" id="kpi-trial"><span class="skel" style="width:40px;height:34px;display:inline-block;border-radius:6px;"></span></div>
          <div class="kpi-sub">30 يوم مجاني</div>
          <div class="kpi-bar"></div>
        </div>

        <div class="kpi k-red">
          <div class="kpi-glow"></div>
          <div class="kpi-top">
            <div class="kpi-label">منتهية<br>الصلاحية</div>
            <div class="kpi-icon">
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
            </div>
          </div>
          <div class="kpi-val red" id="kpi-expired"><span class="skel" style="width:40px;height:34px;display:inline-block;border-radius:6px;"></span></div>
          <div class="kpi-sub">تحتاج تجديد</div>
          <div class="kpi-bar"></div>
        </div>

        <div class="kpi k-purple">
          <div class="kpi-glow"></div>
          <div class="kpi-top">
            <div class="kpi-label">موظفون<br>نشطون</div>
            <div class="kpi-icon">
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/></svg>
            </div>
          </div>
          <div class="kpi-val purple" id="kpi-staff"><span class="skel" style="width:40px;height:34px;display:inline-block;border-radius:6px;"></span></div>
          <div class="kpi-sub">في كل المنشآت</div>
          <div class="kpi-bar"></div>
        </div>
      </div>

      <!-- Charts + Feed -->
      <div class="charts-row">
        <div class="chart-card">
          <div class="chart-ttl"><div class="chart-ttl-dot"></div>الحجوزات — آخر 12 شهر</div>
          <canvas id="bookingsChart" height="108"></canvas>
        </div>
        <div class="chart-card">
          <div class="chart-ttl"><div class="chart-ttl-dot" style="background:linear-gradient(180deg,var(--green),var(--green-d));box-shadow:0 0 10px rgba(16,185,129,.4);"></div>آخر العمليات</div>
          <div id="feed-list" style="max-height:198px;overflow-y:auto;">
            <% for(let i=0;i<5;i++){ %>
            <div class="feed-item">
              <span class="skel" style="width:7px;height:7px;border-radius:50%;flex-shrink:0;margin-top:4px;"></span>
              <div class="feed-content">
                <div class="skel" style="width:80%;height:11px;margin-bottom:5px;"></div>
                <div class="skel" style="width:50%;height:9px;"></div>
              </div>
            </div>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Expiring soon -->
      <div class="card">
        <div class="card-hd">
          <div>
            <div class="card-hd-title">تنتهي خلال 7 أيام</div>
            <div class="card-hd-sub" id="expiring-sub">جاري التحميل...</div>
          </div>
          <button class="btn btn-ghost btn-sm" onclick="goTab('properties',document.querySelectorAll('.sn')[1])">عرض الكل</button>
        </div>
        <div class="tbl-wrap">
          <table class="atbl">
            <thead><tr><th>المنشأة</th><th>الخطة</th><th>الحالة</th><th>ينتهي في</th><th>إجراء</th></tr></thead>
            <tbody id="expiring-tbody">
              <tr><td colspan="5"><div class="skel-row skel-prop-row">
                <span class="skel"></span><span class="skel"></span><span class="skel"></span><span class="skel"></span><span class="skel"></span>
              </div></td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ══════════════ TAB: Properties ══════════════════════ -->
    <div class="tab-sec" id="tab-properties">
      <div class="sec-hd">
        <div>
          <div class="sec-ttl">المنشآت</div>
          <div class="sec-sub" id="props-count-sub">جاري التحميل...</div>
        </div>
        <div class="filter-bar">
          <input class="fi" id="prop-search" placeholder="بحث بالاسم أو المدينة..." style="width:210px;" oninput="debounceLoadProps()">
          <select class="fi fi-select" id="prop-status" onchange="loadProps()">
            <option value="all">كل الحالات</option>
            <option value="active">نشطة</option>
            <option value="trial">تجريبية</option>
            <option value="expired">منتهية</option>
            <option value="stopped">موقوفة</option>
          </select>
          <select class="fi fi-select" id="prop-plan" onchange="loadProps()">
            <option value="all">كل الخطط</option>
            <option value="trial">تجريبية</option>
            <option value="basic">أساسية</option>
            <option value="pro">احترافية</option>
          </select>
          <button class="btn btn-primary" onclick="openCreateProp()">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            منشأة جديدة
          </button>
        </div>
      </div>
      <div class="card">
        <div class="tbl-wrap">
          <table class="atbl">
            <thead>
              <tr><th>المنشأة</th><th>النوع</th><th>الخطة</th><th>الحالة</th><th>انتهاء الاشتراك</th><th>الموظفون</th><th>الحجوزات</th><th>إجراءات</th></tr>
            </thead>
            <tbody id="props-tbody">
              <% for(let i=0;i<6;i++){ %>
              <tr><td colspan="8"><div class="skel-row skel-prop-row">
                <span class="skel"></span><span class="skel"></span><span class="skel"></span>
                <span class="skel"></span><span class="skel"></span><span class="skel"></span><span class="skel"></span>
              </div></td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ══════════════ TAB: Staff ════════════════════════════ -->
    <div class="tab-sec" id="tab-staff">
      <div class="sec-hd">
        <div>
          <div class="sec-ttl">الموظفون</div>
          <div class="sec-sub" id="staff-count-sub">جاري التحميل...</div>
        </div>
        <div class="filter-bar">
          <input class="fi" id="staff-search" placeholder="بحث بالاسم أو المستخدم..." style="width:210px;" oninput="debounceLoadStaff()">
          <select class="fi fi-select" id="staff-prop-filter" onchange="loadStaff()">
            <option value="all">كل المنشآت</option>
          </select>
          <select class="fi fi-select" id="staff-role-filter" onchange="loadStaff()">
            <option value="all">كل الأدوار</option>
            <option value="manager">مدير</option>
            <option value="receptionist">موظف استقبال</option>
          </select>
        </div>
      </div>
      <div class="card">
        <div class="tbl-wrap">
          <table class="atbl">
            <thead>
              <tr><th>الموظف</th><th>المنشأة</th><th>الدور</th><th>الحالة</th><th>تاريخ الإضافة</th><th>إجراءات</th></tr>
