<div id="toast"></div>

<script>
/* ═══════════════════════════════════════════════════════════
   BAREZ ADMIN — CLIENT ENGINE
   ═══════════════════════════════════════════════════════════ */
const _allProps = [];
let   _logPage  = 1;
let   _drawerPropId = null;
const _debTimer = {};

// ── Clock ────────────────────────────────────────────────
(function(){
  const el = document.getElementById('clock');
  const tick = () => { el.textContent = new Date().toLocaleString('ar-SA',{hour:'2-digit',minute:'2-digit',second:'2-digit',day:'2-digit',month:'short'}); };
  tick(); setInterval(tick, 1000);
})();

// ── Animated number counter ──────────────────────────────
function animateNum(el, target, dur=800){
  const start = Date.now();
  const tick = () => {
    const p = Math.min(1,(Date.now()-start)/dur);
    const ease = 1-Math.pow(1-p,3); // ease-out cubic
    el.textContent = Math.round(ease * target);
    if(p<1) requestAnimationFrame(tick);
    else el.textContent = target;
  };
  requestAnimationFrame(tick);
}

// ── Helpers ───────────────────────────────────────────────
function toast(msg, type='info'){
  const t = document.getElementById('toast');
  t.className = type==='ok' ? 'show ok' : type==='err' ? 'show err' : 'show';
  t.textContent = msg;
  clearTimeout(t._tmr);
  t._tmr = setTimeout(() => t.className = '', 2800);
}
function esc(s){ return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
function fDate(d){ return d ? new Date(d).toLocaleDateString('ar-SA',{year:'numeric',month:'short',day:'numeric'}) : '—'; }
function daysLeft(exp){ if(!exp) return null; return Math.ceil((new Date(exp)-new Date())/86400000); }
function debounce(fn, key, ms=320){ clearTimeout(_debTimer[key]); _debTimer[key] = setTimeout(fn, ms); }
function debounceLoadProps(){ debounce(loadProps,'props'); }
function debounceLoadStaff(){ debounce(loadStaff,'staff'); }
function debounceLoadLog(){   debounce(()=>loadLog(1),'log'); }
function closeModal(id){ document.getElementById(id).classList.remove('open'); }

function statusInfo(p){
  const now=new Date(), exp=p.planExpiry?new Date(p.planExpiry):null;
  if(!p.active) return {cls:'bdg-stopped',lbl:'موقوفة'};
  if(exp&&exp<now) return {cls:'bdg-expired',lbl:'منتهية'};
  if(p.plan==='trial') return {cls:'bdg-trial',lbl:'تجريبية'};
  return {cls:'bdg-active',lbl:'نشطة'};
}
function planPill(plan){
  const m={trial:['plan-trial','تجريبية'],basic:['plan-basic','أساسية'],pro:['plan-pro','احترافية']};
  const[cls,lbl]=m[plan]||['plan-trial','تجريبية'];
  return `<span class="plan-pill ${cls}">${lbl}</span>`;
}
function badge(cls, lbl){ return `<span class="bdg ${cls}"><span class="bdg-dot"></span>${lbl}</span>`; }
function skelRows(n, cls, cols){
  return Array.from({length:n},()=>`<tr><td colspan="${cols}"><div class="skel-row ${cls}">${
    Array.from({length:cols-1},()=>'<span class="skel"></span>').join('')
  }</div></td></tr>`).join('');
}

// ── Tab navigation ────────────────────────────────────────
const TAB_TITLE = {
  overview:'نظرة <span class="hi">عامة</span>',
  properties:'إدارة <span class="hi">المنشآت</span>',
  staff:'إدارة <span class="hi">الموظفين</span>',
  log:'سجل <span class="hi">العمليات</span>',
};
const _loaded = {};
function goTab(id, el){
  document.querySelectorAll('.tab-sec').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.sn').forEach(n=>n.classList.remove('active'));
  document.getElementById('tab-'+id).classList.add('active');
  if(el) el.classList.add('active');
  document.getElementById('tb-title').innerHTML = TAB_TITLE[id]||id;
  if(!_loaded[id]){
    _loaded[id]=true;
    if(id==='properties') loadProps();
    if(id==='staff')      loadStaff();
    if(id==='log')        loadLog(1);
  }
}

// ═══════════════════════════════════════════════════════════
//  OVERVIEW
// ═══════════════════════════════════════════════════════════
async function loadOverview(){
  try{
    const [stats, chart, activity, props] = await Promise.all([
      fetch('/superadmin/api/stats').then(r=>r.json()),
      fetch('/superadmin/api/chart').then(r=>r.json()),
      fetch('/superadmin/api/activity?limit=8').then(r=>r.json()),
      fetch('/superadmin/api/properties').then(r=>r.json()),
    ]);

    // KPIs with animated counters
    const kpiMap = {
      'kpi-total':{val:stats.total??0,cls:'blue'},
      'kpi-active':{val:stats.active??0,cls:'green'},
      'kpi-trial':{val:stats.trial??0,cls:'amber'},
      'kpi-expired':{val:stats.expired??0,cls:'red'},
      'kpi-staff':{val:stats.staffCount??0,cls:'purple'},
    };
    Object.entries(kpiMap).forEach(([id,{val,cls}])=>{
      const el = document.getElementById(id);
      el.innerHTML = `<span class="kpi-val ${cls}" style="font-size:34px;font-weight:900;letter-spacing:-.05em;">0</span>`;
      animateNum(el.querySelector('span'), val, 900);
    });

    // Sidebar badges
    document.getElementById('sb-props-cnt').textContent = stats.total??'—';
    document.getElementById('sb-staff-cnt').textContent = stats.staffCount??'—';

    // Chart
    const ctx = document.getElementById('bookingsChart').getContext('2d');
    const grad = ctx.createLinearGradient(0,0,0,108);
    grad.addColorStop(0,'rgba(59,130,246,.28)');
    grad.addColorStop(1,'rgba(59,130,246,.01)');
    new Chart(ctx,{
      type:'line',
      data:{
        labels:chart.labels,
        datasets:[{
          data:chart.data,
          borderColor:'#3B82F6',
          backgroundColor:grad,
          borderWidth:2,tension:.42,fill:true,
          pointRadius:3,pointBackgroundColor:'#3B82F6',
          pointBorderColor:'#0e1628',pointBorderWidth:2,
        }]
      },
      options:{
        responsive:true,
        plugins:{legend:{display:false},tooltip:{
          backgroundColor:'rgba(0,8,20,.9)',borderColor:'rgba(59,130,246,.3)',borderWidth:1,
          titleFont:{family:'Cairo',size:11},bodyFont:{family:'Cairo',size:12},
          callbacks:{label:ctx=>' '+ctx.parsed.y+' حجز'}
        }},
        scales:{
          x:{grid:{color:'rgba(255,255,255,.04)'},ticks:{color:'#2E4566',font:{size:10,family:'Cairo'}}},
          y:{grid:{color:'rgba(255,255,255,.04)'},ticks:{color:'#2E4566',font:{size:10,family:'Cairo'}}},
        }
      }
    });

    // Feed
    const DOT={create:'#10B981',update:'#3B82F6',delete:'#EF4444',login:'#8B5CF6',approve:'#10B981',reject:'#EF4444'};
    const feedEl = document.getElementById('feed-list');
    const acts = activity.logs||[];
    feedEl.innerHTML = acts.length ? acts.map(l=>`
      <div class="feed-item">
        <div class="feed-dot" style="background:${DOT[l.action]||'#2E4566'};box-shadow:0 0 5px ${DOT[l.action]||'#2E4566'}66;"></div>
        <div class="feed-content">
          <div class="feed-main">${esc(l.user)} · ${esc(l.summary||l.action)}</div>
          <div class="feed-sub">${esc(l.model||'')}${l.ip?' · '+esc(l.ip):''}</div>
        </div>
        <div class="feed-time">${new Date(l.createdAt).toLocaleTimeString('ar-SA',{hour:'2-digit',minute:'2-digit'})}</div>
      </div>`).join('') :
      `<div class="empty" style="padding:20px;"><div class="empty-sub">لا توجد عمليات بعد</div></div>`;

    // Expiring soon
    const expiring = (props||[]).filter(p=>{ const d=daysLeft(p.planExpiry); return p.active&&d!==null&&d>=0&&d<=7; });
    document.getElementById('expiring-sub').textContent = `${expiring.length} منشأة تنتهي خلال أسبوع`;
    const tbody = document.getElementById('expiring-tbody');
    tbody.innerHTML = expiring.length ? expiring.map(p=>{
      const d=daysLeft(p.planExpiry), s=statusInfo(p);
      const dStr = d===0?'<span style="color:var(--red);font-weight:700;">اليوم</span>':
                   d<=2?`<span style="color:var(--red);">${d} يوم</span>`:`<span style="color:var(--amber);">${d} يوم</span>`;
      return `<tr>
        <td><div style="font-weight:700;color:var(--t1);">${esc(p.name)}</div><div style="font-size:10px;color:var(--t4);">${esc(p.city||'—')}</div></td>
        <td>${planPill(p.plan)}</td>
        <td>${badge(s.cls,s.lbl)}</td>
        <td>${dStr}</td>
        <td><button class="btn btn-amber btn-sm" onclick="openExtend('${p._id}','${esc(p.name)}','${p.plan}')">تمديد</button></td>
      </tr>`;
    }).join('') :
    `<tr><td colspan="5"><div class="empty">
      <div class="empty-ico"><svg width="22" height="22" fill="none" stroke="var(--green)" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></div>
      <div class="empty-ttl">لا توجد اشتراكات تنتهي قريباً</div>
    </div></td></tr>`;

    _allProps.length = 0;
    (props||[]).forEach(p=>_allProps.push(p));
    _buildPropFilter();

  }catch(e){ toast('❌ تعذر تحميل البيانات','err'); console.error(e); }
}

// ═══════════════════════════════════════════════════════════
//  PROPERTIES
// ═══════════════════════════════════════════════════════════
async function loadProps(){
  const tbody = document.getElementById('props-tbody');
  tbody.innerHTML = skelRows(6,'skel-prop-row',8);
  const q=document.getElementById('prop-search')?.value||'';
  const status=document.getElementById('prop-status')?.value||'all';
  const plan=document.getElementById('prop-plan')?.value||'all';
  try{
    const list = await fetch('/superadmin/api/properties?'+new URLSearchParams({q,status,plan})).then(r=>r.json());
    document.getElementById('props-count-sub').textContent = `${list.length} منشأة`;
    if(!list.length){
      tbody.innerHTML=`<tr><td colspan="8"><div class="empty">
        <div class="empty-ico">🏢</div>
        <div class="empty-ttl">لا توجد منشآت</div>
        <div class="empty-sub">اضغط "منشأة جديدة" للبدء</div>
      </div></td></tr>`;
      return;
    }
    tbody.innerHTML = list.map(p=>{
      const s=statusInfo(p), d=daysLeft(p.planExpiry);
      const dStr = d===null?'—':d<0?`<span style="color:var(--red);">منتهي</span>`:
                   d<=7?`<span style="color:var(--amber);">${d} يوم</span>`:`${d} يوم`;
      return `<tr>
        <td>
          <div style="font-weight:700;color:var(--t1);margin-bottom:2px;">${esc(p.name)}</div>
          <div style="font-size:10px;color:var(--t4);">${esc(p.city||'—')}${p.adminEmail?' · '+esc(p.adminEmail):''}</div>
        </td>
        <td style="color:var(--t3);font-size:11px;">${{apartment:'شقق',hotel:'فندق',mixed:'مختلط'}[p.type]||p.type}</td>
        <td>${planPill(p.plan)}</td>
        <td>${badge(s.cls,s.lbl)}</td>
        <td><div style="font-size:12px;">${fDate(p.planExpiry)}</div><div style="font-size:10px;color:var(--t4);margin-top:2px;">${dStr}</div></td>
        <td><span style="font-weight:700;color:var(--t1);">${p.staffCount||0}</span></td>
        <td><span style="font-weight:700;color:var(--t1);">${p.bookingCount||0}</span></td>
        <td>
          <div class="ia-row">
            <button class="ia ia-view" data-tip="موظفو المنشأة" onclick="openDrawer('${p._id}','${esc(p.name)}')">
              <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
            </button>
            <button class="ia ia-ext" data-tip="تمديد الاشتراك" onclick="openExtend('${p._id}','${esc(p.name)}','${p.plan}')">
              <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            </button>
            <button class="ia ia-tog ${!p.active?'off':''}" data-tip="${p.active?'إيقاف تشغيل':'تفعيل'}" onclick="toggleProp('${p._id}',this)">
              <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18.36 6.64a9 9 0 1 1-12.73 0"/><line x1="12" y1="2" x2="12" y2="12"/></svg>
            </button>
            <button class="ia ia-del" data-tip="حذف المنشأة" onclick="deleteProp('${p._id}','${esc(p.name)}')">
              <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6m4-6v6"/></svg>
            </button>
          </div>
        </td>
      </tr>`;
    }).join('');
    _allProps.length=0; list.forEach(p=>_allProps.push(p));
    _buildPropFilter();
  }catch(e){ toast('❌ تعذر تحميل المنشآت','err'); }
}

function _buildPropFilter(){
  const sel = document.getElementById('staff-prop-filter'); if(!sel) return;
  const cur = sel.value;
  sel.innerHTML = '<option value="all">كل المنشآت</option>'+
    _allProps.map(p=>`<option value="${p._id}"${p._id===cur?' selected':''}>${esc(p.name)}</option>`).join('');
}

function openCreateProp(){ document.getElementById('create-prop-modal').classList.add('open'); }
async function submitCreateProp(){
  const name = document.getElementById('cp-name').value.trim();
  if(!name){ toast('اسم المنشأة مطلوب','err'); return; }
  try{
    const r = await fetch('/superadmin/api/properties',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({
      name,city:document.getElementById('cp-city').value.trim(),
      type:document.getElementById('cp-type').value,plan:document.getElementById('cp-plan').value,
      adminEmail:document.getElementById('cp-email').value.trim(),phone:document.getElementById('cp-phone').value.trim(),
      days:document.getElementById('cp-days').value,
    })});
    const d = await r.json();
    if(d.success){ toast('✅ تم إنشاء المنشأة','ok'); closeModal('create-prop-modal'); loadProps(); loadOverview(); }
    else toast('❌ '+d.error,'err');
  }catch(e){ toast('❌ حدث خطأ','err'); }
}

function openExtend(id,name,plan){
  document.getElementById('ext-id').value=id;
  document.getElementById('ext-name').textContent=name;
  document.getElementById('ext-plan').value=plan||'trial';
  document.getElementById('extend-modal').classList.add('open');
}
async function submitExtend(){
  const id=document.getElementById('ext-id').value;
  const plan=document.getElementById('ext-plan').value;
  const days=document.getElementById('ext-days').value;
  try{
    const r=await fetch('/superadmin/api/extend',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id,plan,days})});
    const d=await r.json();
    if(d.success){ toast('✅ تمديد حتى '+new Date(d.newExpiry).toLocaleDateString('ar-SA'),'ok'); closeModal('extend-modal'); loadProps(); loadOverview(); }
    else toast('❌ '+d.error,'err');
  }catch(e){ toast('❌ حدث خطأ','err'); }
}
async function toggleProp(id,btn){
  if(!btn.classList.contains('off')&&!confirm('إيقاف المنشأة سيحجب الموظفين. متأكد؟')) return;
  try{
    const r=await fetch('/superadmin/api/toggle',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id})});
    const d=await r.json();
    if(d.success){ toast(d.active?'✅ تم التفعيل':'🔴 تم الإيقاف',d.active?'ok':'err'); loadProps(); }
    else toast('❌ '+d.error,'err');
  }catch(e){ toast('❌ حدث خطأ','err'); }
}
async function deleteProp(id,name){
  if(!confirm(`حذف "${name}" نهائياً؟\nسيُحذف جميع الموظفين المرتبطين.`)) return;
  try{
    const r=await fetch('/superadmin/api/properties/'+id,{method:'DELETE'});
    const d=await r.json();
    if(d.success){ toast('تم الحذف','ok'); loadProps(); }
    else toast('❌ '+d.error,'err');
  }catch(e){ toast('❌ حدث خطأ','err'); }
}

// ═══════════════════════════════════════════════════════════
//  STAFF
// ═══════════════════════════════════════════════════════════
async function loadStaff(){
  const tbody=document.getElementById('staff-tbody');
  tbody.innerHTML=skelRows(6,'skel-staff-row',6);
  try{
    const propFilter=document.getElementById('staff-prop-filter')?.value||'all';
    const roleFilter=document.getElementById('staff-role-filter')?.value||'all';
    const q=document.getElementById('staff-search')?.value.toLowerCase()||'';
    let staff=[];
    if(propFilter==='all'){
      const res=await Promise.all(_allProps.map(p=>fetch('/superadmin/api/properties/'+p._id+'/staff').then(r=>r.json()).then(l=>l.map(s=>({...s,_propName:p.name}))).catch(()=>[])));
      staff=res.flat();
    }else{
      const prop=_allProps.find(p=>p._id===propFilter);
      const list=await fetch('/superadmin/api/properties/'+propFilter+'/staff').then(r=>r.json());
      staff=list.map(s=>({...s,_propName:prop?.name||''}));
    }
    let filtered=staff;
    if(roleFilter!=='all') filtered=filtered.filter(s=>s.role===roleFilter);
    if(q) filtered=filtered.filter(s=>s.name?.toLowerCase().includes(q)||s.username?.toLowerCase().includes(q));
    document.getElementById('staff-count-sub').textContent=`${filtered.length} موظف`;
    if(!filtered.length){
      tbody.innerHTML=`<tr><td colspan="6"><div class="empty"><div class="empty-ico">👥</div><div class="empty-ttl">لا يوجد موظفون</div></div></td></tr>`;
      return;
    }
    tbody.innerHTML=filtered.map(s=>`<tr>
      <td>
        <div style="display:flex;align-items:center;gap:10px;">
          <div style="width:32px;height:32px;border-radius:8px;background:var(--brand-g);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:800;color:#fff;flex-shrink:0;">${esc(s.name?.charAt(0)||'?')}</div>
          <div>
            <div style="font-weight:700;color:var(--t1);">${esc(s.name)}</div>
            <div style="font-size:10px;color:var(--t4);direction:ltr;text-align:right;">${esc(s.username)}</div>
          </div>
        </div>
      </td>
      <td style="font-size:11px;color:var(--t3);">${esc(s._propName||s.building||'—')}</td>
      <td><span class="role-pill role-${s.role}">${s.role==='manager'?'مدير':'استقبال'}</span></td>
      <td>${badge(s.active?'bdg-active':'bdg-stopped',s.active?'نشط':'موقوف')}</td>
      <td style="font-size:11px;color:var(--t4);">${fDate(s.createdAt)}</td>
      <td>
        <div class="ia-row">
          <button class="ia ia-pwd" data-tip="إعادة تعيين كلمة المرور" onclick="openResetPwd('${s._id}')">
            <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </button>
          <button class="ia ia-tog ${!s.active?'off':''}" data-tip="${s.active?'إيقاف':'تفعيل'}" onclick="toggleStaff('${s._id}')">
            <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18.36 6.64a9 9 0 1 1-12.73 0"/><line x1="12" y1="2" x2="12" y2="12"/></svg>
          </button>
          <button class="ia ia-del" data-tip="حذف الموظف" onclick="deleteStaff('${s._id}','${esc(s.name)}')">
            <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/></svg>
          </button>
        </div>
      </td>
    </tr>`).join('');
  }catch(e){ toast('❌ تعذر تحميل الموظفين','err'); }
}

async function toggleStaff(id){
  try{
    const r=await fetch('/superadmin/api/staff/'+id+'/toggle',{method:'POST'});
    const d=await r.json();
    if(d.success){ toast(d.active?'✅ تم التفعيل':'🔴 تم الإيقاف',d.active?'ok':'err'); loadStaff(); if(document.getElementById('staff-drawer').classList.contains('open')) loadDrawer(_drawerPropId); }
    else toast('❌ '+d.error,'err');
  }catch(e){ toast('❌ حدث خطأ','err'); }
}
async function deleteStaff(id,name){
  if(!confirm(`حذف الموظف "${name}"؟`)) return;
  try{
    const r=await fetch('/superadmin/api/staff/'+id,{method:'DELETE'});
    const d=await r.json();
    if(d.success){ toast('تم الحذف','ok'); loadStaff(); if(_drawerPropId) loadDrawer(_drawerPropId); }
    else toast('❌ '+d.error,'err');
  }catch(e){ toast('❌ حدث خطأ','err'); }
}
function openResetPwd(id){ document.getElementById('rp-id').value=id; document.getElementById('rp-pwd').value=''; document.getElementById('reset-pwd-modal').classList.add('open'); }
async function submitResetPwd(){
  const id=document.getElementById('rp-id').value, pwd=document.getElementById('rp-pwd').value;
  if(pwd.length<8){ toast('كلمة المرور 8 أحرف على الأقل','err'); return; }
  try{
    const r=await fetch('/superadmin/api/staff/'+id+'/reset-password',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({password:pwd})});
    const d=await r.json();
    if(d.success){ toast('✅ تم تغيير كلمة المرور','ok'); closeModal('reset-pwd-modal'); }
    else toast('❌ '+d.error,'err');
  }catch(e){ toast('❌ حدث خطأ','err'); }
}

// ═══════════════════════════════════════════════════════════
//  DRAWER
// ═══════════════════════════════════════════════════════════
async function openDrawer(propId,propName){
  _drawerPropId=propId;
  document.getElementById('drawer-title').textContent='موظفو '+propName;
  document.getElementById('drawer-bg').classList.add('open');
  document.getElementById('staff-drawer').classList.add('open');
  await loadDrawer(propId);
}
function closeDrawer(){ document.getElementById('drawer-bg').classList.remove('open'); document.getElementById('staff-drawer').classList.remove('open'); }

async function loadDrawer(propId){
  const body=document.getElementById('drawer-body');
  body.innerHTML='<div class="empty"><div class="empty-sub">جاري التحميل...</div></div>';
  try{
    const list=await fetch('/superadmin/api/properties/'+propId+'/staff').then(r=>r.json());
    if(!list.length){ body.innerHTML=`<div class="empty"><div class="empty-ico">👥</div><div class="empty-ttl">لا يوجد موظفون</div><div class="empty-sub">اضغط الزر أدناه للإضافة</div></div>`; return; }
    body.innerHTML=list.map(s=>`
      <div class="staff-item">
        <div class="staff-avatar">${esc(s.name?.charAt(0)||'?')}</div>
        <div style="flex:1;min-width:0;">
          <div style="font-size:13px;font-weight:700;color:var(--t1);">${esc(s.name)}</div>
          <div style="font-size:10px;color:var(--t4);direction:ltr;text-align:right;">${esc(s.username)} · ${s.role==='manager'?'مدير':'استقبال'}</div>
        </div>
        ${badge(s.active?'bdg-active':'bdg-stopped',s.active?'نشط':'موقوف')}
        <div class="ia-row">
          <button class="ia ia-pwd" data-tip="إعادة تعيين" onclick="openResetPwd('${s._id}')">
            <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </button>
          <button class="ia ia-del" data-tip="حذف" onclick="deleteStaff('${s._id}','${esc(s.name)}')">
            <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/></svg>
          </button>
        </div>
      </div>`).join('');
  }catch(e){ body.innerHTML='<div class="empty"><div class="empty-sub" style="color:var(--red);">تعذر التحميل</div></div>'; }
}
function openAddStaff(){
  if(!_drawerPropId){ toast('اختر منشأة أولاً','err'); return; }
  const prop=_allProps.find(p=>p._id===_drawerPropId);
  document.getElementById('as-prop-id').value=_drawerPropId;
  document.getElementById('as-prop-name').textContent=prop?.name||'';
  ['as-name','as-username','as-password'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('add-staff-modal').classList.add('open');
}
async function submitAddStaff(){
  const body={name:document.getElementById('as-name').value.trim(),username:document.getElementById('as-username').value.trim(),password:document.getElementById('as-password').value,role:document.getElementById('as-role').value};
  const propId=document.getElementById('as-prop-id').value;
  if(!body.name||!body.username||!body.password){ toast('الحقول المطلوبة ناقصة','err'); return; }
  try{
    const r=await fetch('/superadmin/api/properties/'+propId+'/staff',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
    const d=await r.json();
    if(d.success){ toast('✅ تم إضافة الموظف','ok'); closeModal('add-staff-modal'); loadDrawer(propId); }
    else toast('❌ '+d.error,'err');
  }catch(e){ toast('❌ حدث خطأ','err'); }
}

// ═══════════════════════════════════════════════════════════
//  AUDIT LOG
// ═══════════════════════════════════════════════════════════
async function loadLog(page=1){
  _logPage=page;
  const tbody=document.getElementById('log-tbody');
  tbody.innerHTML=skelRows(8,'skel-log-row',7);
  document.getElementById('log-pag').style.display='none';
  const action=document.getElementById('log-action')?.value||'';
  const user=document.getElementById('log-user')?.value||'';
  try{
    const d=await fetch('/superadmin/api/activity?'+new URLSearchParams({page,limit:20,action,user})).then(r=>r.json());
    const logs=d.logs||[], total=d.total||0, pages=d.pages||1;
    document.getElementById('log-count-sub').textContent=`${total} سجل`;
    const ACT={create:'إنشاء',update:'تعديل',delete:'حذف',login:'دخول',approve:'موافقة',reject:'رفض'};
    if(!logs.length){
      tbody.innerHTML=`<tr><td colspan="7"><div class="empty"><div class="empty-ico">📋</div><div class="empty-ttl">لا توجد سجلات</div></div></td></tr>`;
    }else{
      tbody.innerHTML=logs.map(l=>`<tr>
        <td style="font-weight:700;color:var(--t1);">${esc(l.user)}</td>
        <td><span class="role-pill role-${l.role||'receptionist'}">${l.role==='manager'?'مدير':l.role==='superadmin'?'سوبر':l.role||'—'}</span></td>
        <td><span class="ac ac-${l.action}">${ACT[l.action]||l.action}</span></td>
        <td style="font-size:11px;color:var(--t4);">${esc(l.model||'—')}</td>
        <td style="max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:12px;">${esc(l.summary||'—')}</td>
        <td style="font-size:10.5px;color:var(--t4);direction:ltr;text-align:right;font-variant-numeric:tabular-nums;">${esc(l.ip||'—')}</td>
        <td style="font-size:11px;color:var(--t4);white-space:nowrap;">${new Date(l.createdAt).toLocaleString('ar-SA',{day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit'})}</td>
      </tr>`).join('');
    }
    if(pages>1){
      const pag=document.getElementById('log-pag'); pag.style.display='flex';
      document.getElementById('log-pag-info').textContent=`صفحة ${page} من ${pages} · ${total} سجل`;
      const btns=document.getElementById('log-pag-btns');
      let html=`<button class="pag-btn" onclick="loadLog(${page-1})" ${page<=1?'disabled':''}>‹</button>`;
      const s=Math.max(1,page-3), e=Math.min(pages,s+6);
      for(let i=s;i<=e;i++) html+=`<button class="pag-btn ${i===page?'active':''}" onclick="loadLog(${i})">${i}</button>`;
      html+=`<button class="pag-btn" onclick="loadLog(${page+1})" ${page>=pages?'disabled':''}>›</button>`;
      btns.innerHTML=html;
    }
  }catch(e){ toast('❌ تعذر تحميل السجل','err'); }
}

// ── Init ─────────────────────────────────────────────────
loadOverview();
</script>
</body>
</html>
