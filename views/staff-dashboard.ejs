      <button onclick="closeRoomInfoModal()" style="padding:8px 16px;border-radius:8px;border:1px solid #e2e8f0;background:#f8fafc;color:#64748b;font-family:inherit;font-size:12px;cursor:pointer;">إلغاء</button>
      <button onclick="saveRoomInfo()" style="padding:8px 20px;border-radius:8px;background:var(--brand);border:none;color:#fff;font-family:inherit;font-size:12px;font-weight:700;cursor:pointer;">حفظ</button>
    </div>
