const PER_PAGE=30;
function renderPager(page,total,setPage,pagerId){
  const pages=Math.ceil(total/PER_PAGE);
  const el=document.getElementById(pagerId);
  if(!el)return;
  if(pages<=1){el.style.display='none';return;}
  el.style.display='block';
  let btns='';
  btns+=`<button onclick="${setPage}(${page-1})" ${page===1?'disabled':''}>&#8594;</button>`;
  const delta=2;
  let lo=Math.max(1,page-delta),hi=Math.min(pages,page+delta);
  if(lo>1) btns+=`<button onclick="${setPage}(1)">1</button>${lo>2?'<span class="pager-info">…</span>':''}`;
  for(let p=lo;p<=hi;p++) btns+=`<button class="${p===page?'active':''}" onclick="${setPage}(${p})">${p}</button>`;
  if(hi<pages) btns+=`${hi<pages-1?'<span class="pager-info">…</span>':''}<button onclick="${setPage}(${pages})">${pages}</button>`;
  btns+=`<button onclick="${setPage}(${page+1})" ${page===pages?'disabled':''}>&#8592;</button>`;
  btns+=`<span class="pager-info">${((page-1)*PER_PAGE)+1}–${Math.min(page*PER_PAGE,total)} من ${total}</span>`;
  el.innerHTML=`<div class="pager">${btns}</div>`;
}

