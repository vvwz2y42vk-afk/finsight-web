    <div class="mhd"><div class="mhd-title">➕ حجز جديد</div><button class="mclose" onclick="closeNewBkModal()">×</button></div>
    <div class="mbody" style="max-height:80vh;overflow-y:auto;">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
