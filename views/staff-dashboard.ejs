  document.getElementById('tbTitle').innerHTML=`${esc(BUILDING)} — <span>${labels[id]||id}</span>`;
  if(id==='apartments') loadApartments();
  if(id==='bookings')   loadBookings();
  if(id==='customers')  loadCustomers();
  if(id==='housekeeping') loadHousekeeping();
  if(id==='activity')   loadActivity();
