    <div class="mbody">
      <div style="font-size:13px;font-weight:600;color:#475569;margin-bottom:8px;">اختر حالة الشقة:</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;" id="hkBtns"></div>
      <div style="margin-top:12px;">
        <label style="font-size:12px;font-weight:700;color:#475569;display:block;margin-bottom:6px;">ملاحظات</label>
        <textarea id="hkNotes" rows="2" style="width:100%;padding:9px;border:1.5px solid #e2e8f0;border-radius:10px;font-family:inherit;font-size:13px;outline:none;resize:none;"></textarea>
      </div>
