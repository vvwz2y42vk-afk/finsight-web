async function submitMaintRequest(){
  const apt=document.getElementById('maint-apt').value.trim();
  const desc=document.getElementById('maint-desc').value.trim();
  const errEl=document.getElementById('maint-err');
  errEl.style.display='none';
  if(!apt){ errEl.textContent='رقم الشقة مطلوب'; errEl.style.display='block'; return; }
  if(!desc){ errEl.textContent='وصف المشكلة مطلوب'; errEl.style.display='block'; return; }

  const btn=document.getElementById('maint-submit-btn');
  btn.disabled=true; btn.textContent='⏳ جاري الإرسال...';
