async function toggleBlock(id, currentCat){
  const newCat = currentCat==='blocked' ? 'regular' : 'blocked';
  const label  = newCat==='blocked' ? 'حظر هذا العميل؟' : 'رفع الحظر عن هذا العميل؟';
  if(!confirm(label)) return;
  try{
    const r=await fetch('/staff/api/guests/'+id+'/category',{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({category:newCat})});
    if(!r.ok) throw new Error();
    toast(newCat==='blocked'?'تم حظر العميل ✓':'تم رفع الحظر ✓');
    loadCustomers();
  }catch(e){ toast('❌ تعذر تحديث التصنيف'); }
}

