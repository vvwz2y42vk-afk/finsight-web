function highlightPriority(val){
  const styles={
    urgent:{border:'2px solid #fca5a5',background:'rgba(220,38,38,.18)'},
    medium:{border:'2px solid #fde68a',background:'rgba(180,83,9,.12)'},
    normal:{border:'2px solid #bbf7d0',background:'rgba(21,128,61,.12)'},
  };
  const def={
    urgent:{border:'2px solid #fca5a5',background:'#fff5f5'},
    medium:{border:'2px solid #fde68a',background:'#fffbeb'},
    normal:{border:'2px solid #bbf7d0',background:'#f0fdf4'},
  };
  ['urgent','medium','normal'].forEach(p=>{
