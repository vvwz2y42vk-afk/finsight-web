          <select id="nb-apt" class="f-idle" style="width:100%;padding:9px;border:1.5px solid #e2e8f0;border-radius:10px;font-family:inherit;font-size:13px;outline:none;" onchange="updateNbPrice();validateField('nb-apt','fw-apt','fh-apt','اختر الشقة')"></select>
