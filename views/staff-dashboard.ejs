          <input id="nb-price" type="number" placeholder="0" class="f-idle" oninput="calcNbTotal();validateField('nb-price','fw-price','fh-price','أدخل السعر')" style="width:100%;padding:9px;border:1.5px solid #e2e8f0;border-radius:10px;font-family:inherit;font-size:13px;outline:none;">
