        <div id="vm-check-row1" style="display:none;">
          <label style="font-size:12px;font-weight:700;color:#475569;display:block;margin-bottom:5px;">رقم الشيك</label>
          <input id="vm-checknum" type="text" style="width:100%;padding:9px;border:1.5px solid #e2e8f0;border-radius:10px;font-family:inherit;font-size:13px;outline:none;">
        </div>
