      <thead><tr style="background:#f8fafc;">
        <th style="padding:8px 10px;text-align:right;font-weight:700;color:#475569;">الشقة</th>
        <th style="padding:8px 10px;text-align:right;font-weight:700;color:#475569;">الدخول</th>
        <th style="padding:8px 10px;text-align:right;font-weight:700;color:#475569;">الخروج</th>
        <th style="padding:8px 10px;text-align:right;font-weight:700;color:#475569;">الإجمالي</th>
        <th style="padding:8px 10px;text-align:right;font-weight:700;color:#475569;">المدفوع</th>
        <th style="padding:8px 10px;text-align:right;font-weight:700;color:#475569;">الحالة</th>
      </tr></thead>
      <tbody>
        ${bookings.map(b=>`<tr style="border-bottom:1px solid #f1f5f9;">
