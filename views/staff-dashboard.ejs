function openBkContract(id){
  const b=_bkData.find(x=>x._id===id);
  if(!b){ toast('لم يتم العثور على الحجز'); return; }

  const bkNum='#'+b._id.toString().slice(-5).toUpperCase();
  const today=new Date().toLocaleDateString('ar-SA',{year:'numeric',month:'2-digit',day:'2-digit'});
  const BK_TYPE={daily:'يومي',annual:'شهري',inquiry:'استفسار'};
  const ID_TYPE={national_id:'بطاقة هوية وطنية',passport:'جواز سفر',iqama:'إقامة',family_card:'بطاقة عائلة'};
  const fD=d=>d?new Date(d).toLocaleDateString('ar-SA',{year:'numeric',month:'2-digit',day:'2-digit',weekday:'long'}):'—';
  const fN=n=>(n||0).toLocaleString('ar-SA');
  const nights=b.nights||(b.checkIn&&b.checkOut?Math.round((new Date(b.checkOut)-new Date(b.checkIn))/(864e5)):0);
  const remain=Math.max(0,(b.totalPrice||0)-(b.paidAmount||0));
  const deposits=(b.payments||[]).filter(p=>p.isDeposit).reduce((s,p)=>s+(p.amount||0),0);
  const priceLabel=b.bookingType==='daily'?'الإيجار اليومي':'الإيجار الشهري';
  const durationLabel=b.bookingType==='daily'?`${nights} ليلة`:`${b.nights||nights} شهر`;

  const companions=(b.companions||[]).filter(c=>c.name).map((c,i)=>
    `<tr><td style="padding:5px 8px;border:1px solid #e2e8f0;">${i+1}</td><td style="padding:5px 8px;border:1px solid #e2e8f0;">${esc(c.name)}</td><td style="padding:5px 8px;border:1px solid #e2e8f0;">${esc(c.idType||'')}</td><td style="padding:5px 8px;border:1px solid #e2e8f0;">${esc(c.idNumber||'')}</td></tr>`
  ).join('');

  // ── كشف حساب: دائن/مدين ──
  const PM_LBL={cash:'نقداً',transfer:'تحويل',network:'شبكة',check:'كمبيالة',digital:'رقمي',travel_agent:'وكالة سفر',other:'أخرى'};
  const fDt=d=>d?new Date(d).toLocaleDateString('ar-SA',{year:'numeric',month:'2-digit',day:'2-digit'}):'—';
  const payments=b.payments||[];
  const nonDepPay=payments.filter(p=>!p.isDeposit);
  const depPay=payments.filter(p=>p.isDeposit);
  // دائن = الرسوم المستحقة
  const chargeRows=[
    {date:b.checkIn,desc:'قيمة الإيجار',amount:(b.totalPrice||0)-deposits},
    ...(deposits>0?[{date:b.checkIn,desc:'مبلغ التأمين',amount:deposits}]:[]),
  ];
  // مدين = الدفعات المسددة
  const payRows=[
    ...nonDepPay.map(p=>({date:p.date,desc:PM_LBL[p.paymentMethod]||p.paymentMethod||'دفعة',amount:p.amount||0})),
    ...depPay.map(p=>({date:p.date,desc:'تأمين — '+(PM_LBL[p.paymentMethod]||p.paymentMethod||''),amount:p.amount||0})),
  ];
  const maxLedger=Math.max(chargeRows.length,payRows.length);
  const ledgerRows=Array.from({length:maxLedger},(_,i)=>{
    const c=chargeRows[i];
    const p=payRows[i];
