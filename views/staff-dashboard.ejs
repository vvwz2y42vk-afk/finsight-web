          <select id="vm-expense-select" onchange="if(this.value)document.getElementById('vm-desc').value=this.value;" style="width:100%;padding:9px;border:1.5px solid #e2e8f0;border-radius:10px;font-family:inherit;font-size:13px;outline:none;">
            <option value="">اختر بنداً محدداً...</option>
          </select>
        </div>
        <div style="grid-column:1/-1;">
          <label style="font-size:12px;font-weight:700;color:#475569;display:block;margin-bottom:5px;">البيان / الوصف *</label>
          <input id="vm-desc" type="text" placeholder="وصف الوثيقة" style="width:100%;padding:9px;border:1.5px solid #e2e8f0;border-radius:10px;font-family:inherit;font-size:13px;outline:none;">
        </div>
        <div style="grid-column:1/-1;">
          <label style="font-size:12px;font-weight:700;color:#475569;display:block;margin-bottom:5px;">ملاحظات</label>
          <textarea id="vm-notes" rows="2" style="width:100%;padding:9px;border:1.5px solid #e2e8f0;border-radius:10px;font-family:inherit;font-size:13px;outline:none;resize:none;"></textarea>
