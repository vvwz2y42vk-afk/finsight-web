function calcVmTax(){
  const amt=parseFloat(document.getElementById('vm-amount').value)||0;
  document.getElementById('vm-tax').value=Math.round(amt*0.15)||'';
}
async function submitVoucher(){
  const errEl=document.getElementById('vm-err');
  const amount=parseFloat(document.getElementById('vm-amount').value)||0;
  const description=document.getElementById('vm-desc').value.trim();
  if(!amount||!description){errEl.textContent='المبلغ والبيان مطلوبان';errEl.style.display='block';return;}
  const body={
    type:vouModalType,
    date:document.getElementById('vm-date').value,
    name:document.getElementById('vm-name').value.trim(),
    phone:document.getElementById('vm-phone').value.trim(),
    apt:document.getElementById('vm-apt').value.trim(),
    amount,description,
    notes:document.getElementById('vm-notes').value.trim(),
    checkNumber:document.getElementById('vm-checknum').value.trim(),
    bankName:document.getElementById('vm-bank').value.trim(),
    dueDate:document.getElementById('vm-duedate').value||null,
  };
  try{
    const r=await fetch('/staff/api/vouchers',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
    const d=await r.json();
    if(!r.ok){errEl.textContent=d.error||'حدث خطأ';errEl.style.display='block';return;}
    closeVouModal();
    toast('✅ تم الحفظ — رقم الوثيقة: '+d.number);
    loadVouList(vouModalType);
  }catch(e){errEl.textContent='حدث خطأ';errEl.style.display='block';}
}

