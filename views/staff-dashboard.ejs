async function submitNewBk(){
  const apt=document.getElementById('nb-apt').value;
  const name=document.getElementById('nb-name').value.trim();
  const phone=document.getElementById('nb-phone').value.trim();
  const type=document.getElementById('nb-type').value;
  const checkin=document.getElementById('nb-checkin').value;
  const checkout=type==='daily'?document.getElementById('nb-checkout').value:'';
  const months=type==='annual'?parseInt(document.getElementById('nb-months').value)||1:0;
  const price=parseFloat(document.getElementById('nb-price').value)||0;
  const total=parseFloat(document.getElementById('nb-total').value)||price;
  const paid=parseFloat(document.getElementById('nb-paid').value)||0;
  const idType=document.getElementById('nb-idtype').value;
  const idNumber=document.getElementById('nb-idnum').value.trim();
  const status=document.getElementById('nb-status').value;
  const notes=document.getElementById('nb-notes').value.trim();
  const paymentMethod=document.getElementById('nb-paymethod').value;
  const bookingSource=document.getElementById('nb-source')?.value||'';
  const errEl=document.getElementById('nb-err');
  errEl.style.display='none';
  let valid=true;
  if(!apt)  { shakeField('nb-apt','fw-apt','fh-apt','اختر الشقة'); valid=false; }
  if(!name) { shakeField('nb-name','fw-name','fh-name','أدخل اسم النزيل الكامل'); valid=false; }
  if(!phone||!/^\d{10}$/.test(phone)){ shakeField('nb-phone','fw-phone','fh-phone','رقم جوال صحيح مطلوب (10 أرقام)'); valid=false; }
  if(!checkin){ shakeField('nb-checkin','fw-checkin','fh-checkin','اختر تاريخ الدخول'); valid=false; }
  if(type==='daily'&&!checkout){ shakeField('nb-checkout','nb-checkout-grp','fh-checkout','اختر تاريخ الخروج'); valid=false; }
  if(!price){ shakeField('nb-price','fw-price','fh-price','أدخل سعر الإيجار'); valid=false; }
  // إيصال إلزامي عند الدفع بالشبكة أو التحويل أو النقد
  const needsReceipt = ['network','transfer','cash'].includes(paymentMethod);
  if(needsReceipt && !_receiptAccepted){
    errEl.textContent='يجب رفع إيصال الدفع وقبوله قبل إتمام الحجز';
    errEl.style.display='block';
    document.getElementById('receipt-box').style.border='1.5px solid #dc2626';
    document.getElementById('receipt-box').scrollIntoView({behavior:'smooth',block:'center'});
    valid=false;
  }
  if(!valid) return;
  const companions=_companions.filter(c=>c.name.trim());
  const _bkBody={apt,name,phone,bookingType:type,checkIn:checkin,checkOut:checkout,months,pricePerUnit:price,totalPrice:total,paidAmount:paid,paymentMethod,bookingSource,idType,idNumber,status,notes,companions};
  const url=editBkId?`/staff/api/bookings/${editBkId}/edit`:'/staff/api/bookings/new';
  const method=editBkId?'PUT':'POST';
  try{
    const r=await fetch(url,{method,headers:{'Content-Type':'application/json'},body:JSON.stringify(_bkBody)});
    const d=await r.json();
    if(!r.ok){errEl.textContent=d.error||'حدث خطأ';errEl.style.display='block';return;}
    // حفظ الإيصال مرتبطاً بالحجز
    if(_receiptBase64&&_receiptAccepted){
      fetch('/staff/api/receipts',{
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({bookingId:d._id||d.id||null,building:BUILDING,apt,guestName:name,imageData:_receiptBase64,imageMimeType:_receiptMime||'image/jpeg',analysis:_receiptAnalysis}),
      }).catch(()=>{});
    }
    _clearDraft();
    closeNewBkModal();
    toast(editBkId?'✏️ تم تعديل الحجز':'✅ تم إضافة الحجز بنجاح','success');
    loadApartments(); loadStats(); loadBookings(); _pollKick();
  }catch(e){
    if(!navigator.onLine&&!editBkId){
      _savePending(_bkBody);
      toast('📡 لا يوجد اتصال — سيُرسل الحجز تلقائياً عند عودة الشبكة');
    }else{errEl.textContent='حدث خطأ';errEl.style.display='block';}
  }
}

// ── Vouchers ─────────────────────────────────────────────
const ID_TYPE_L={national_id:'هوية وطنية',passport:'جواز سفر',iqama:'إقامة',family_card:'كرت عائلة'};
const BK_TYPE_L={daily:'يومي',annual:'شهري'};
const VOU_NAMES={receipt:'سند قبض',invoice:'فاتورة',disbursement:'سند صرف',check:'كمبيالة',tax:'إشعار ضريبي'};
const VOU_COLS={receipt:9,invoice:7,disbursement:6,check:8,tax:8};
const PM_LABEL={cash:'نقداً',transfer:'تحويل',network:'شبكة',check:'كمبيالة',digital:'رقمي',travel_agent:'وكالة',other:'أخرى'};

function showVouCards(){
  document.querySelectorAll('.vou-section').forEach(s=>s.classList.remove('active'));
  document.getElementById('vouCards').style.display='flex';
}
function showVouSection(name){
  document.getElementById('vouCards').style.display='none';
  document.querySelectorAll('.vou-section').forEach(s=>s.classList.remove('active'));
  document.getElementById('vou-'+name).classList.add('active');
  loadVouList(name==='receipts'?'receipt':name==='invoices'?'invoice':name==='disbursements'?'disbursement':name==='checks'?'check':name==='tax'?'tax':name);
}

// Load saved vouchers from DB
async function loadVouList(type){
  const tbId='vou-'+type+'-tbody';
  const tb=document.getElementById(tbId); if(!tb)return;
  const cols=VOU_COLS[type]||7;
  tb.innerHTML=`<tr><td colspan="${cols}" style="text-align:center;padding:20px;color:#94a3b8;">جاري التحميل...</td></tr>`;
  try{
    const params=new URLSearchParams({type});
    const pfx=type==='receipt'?'r':type==='invoice'?'i':type==='disbursement'?'d':null;
    if(pfx){
      const from=document.getElementById(`vou-${pfx}-from`)?.value;
      const to=document.getElementById(`vou-${pfx}-to`)?.value;
      const num=document.getElementById(`vou-${pfx}-num`)?.value.trim();
      if(from) params.set('from',from);
      if(to) params.set('to',to);
      if(num) params.set('num',num);
    }
    if(type==='receipt'){
      const bknum=document.getElementById('vou-r-bknum')?.value.trim();
      const method=document.getElementById('vou-r-method')?.value;
      if(bknum) params.set('bknum',bknum);
      if(method) params.set('method',method);
    }
    const r=await fetch('/staff/api/vouchers?'+params);
    const list=await r.json();
    if(!list.length){tb.innerHTML=`<tr><td colspan="${cols}" style="text-align:center;padding:20px;color:#94a3b8;">لا توجد وثائق بعد — اضغط إضافة</td></tr>`;return;}
    tb.innerHTML=list.map((v,i)=>{
      const row=renderVouRow(v,type,i);
      return `<tr>${row}</tr>`;
    }).join('');
  }catch(e){tb.innerHTML=`<tr><td colspan="${cols}" style="text-align:center;padding:20px;color:#ef4444;">خطأ في التحميل</td></tr>`;}
}

function renderVouRow(v,type,i){
  const date=v.date?new Date(v.date).toLocaleDateString('ar-SA'):'—';
  const amt=(v.amount||0).toLocaleString();
  const actions=`<div style="display:flex;gap:4px;">
    <button onclick="printVoucher('${v._id}')" style="padding:3px 8px;background:#1a3d8f;color:#111;border:none;border-radius:6px;font-size:10px;font-weight:700;cursor:pointer;">🖨️ طباعة</button>
    ${isManager?`<button onclick="deleteVou('${v._id}','${type}')" style="padding:3px 8px;background:#fef2f2;color:#dc2626;border:1px solid #fecaca;border-radius:6px;font-size:10px;font-weight:700;cursor:pointer;">🗑️</button>`:''}
  </div>`;
  if(type==='receipt'){
    const bkRef=v.bookingId?'#'+String(v.bookingId).slice(-5).toUpperCase():'—';
    const pm=PM_LABEL[v.paymentMethod]||v.paymentMethod||'—';
    return `<td style="font-size:10px;color:#94a3b8;font-family:monospace;">${esc(v.number||'—')}</td><td style="font-size:11px;font-family:monospace;color:#1a3d8f;">${bkRef}</td><td style="font-size:11px;">${date}</td><td><b>${esc(v.name||'—')}</b></td><td style="text-align:center;">${esc(v.apt||'—')}</td><td style="font-weight:700;">${amt} ر</td><td style="font-size:11px;color:#64748b;">${esc(v.description||'—')}</td><td><span style="padding:2px 8px;border-radius:10px;font-size:10px;font-weight:700;background:#f1f5f9;color:#475569;">${pm}</span></td><td>${actions}</td>`;
  }
  if(type==='invoice')
    return `<td style="font-size:10px;color:#94a3b8;">${esc(v.number||'—')}</td><td>${date}</td><td><b>${esc(v.name||'—')}</b></td><td>${esc(v.apt||'—')}</td><td style="font-size:11px;color:#64748b;">${esc(v.description||'—')}</td><td style="font-weight:700;">${amt} ر</td><td>${actions}</td>`;
  if(type==='disbursement')
    return `<td style="font-size:10px;color:#94a3b8;">${esc(v.number||'—')}</td><td>${date}</td><td><b>${esc(v.name||'—')}</b></td><td style="font-size:11px;color:#64748b;">${esc(v.description||'—')}</td><td style="font-weight:700;">${amt} ر</td><td>${actions}</td>`;
  if(type==='check')
    return `<td style="font-size:10px;color:#94a3b8;">${esc(v.number||'—')}</td><td>${date}</td><td><b>${esc(v.name||'—')}</b></td><td>${esc(v.checkNumber||'—')}</td><td>${esc(v.bankName||'—')}</td><td>${v.dueDate?new Date(v.dueDate).toLocaleDateString('ar-SA'):'—'}</td><td style="font-weight:700;">${amt} ر</td><td>${actions}</td>`;
  if(type==='tax'){
    const rate=(propSettings.vatRate??15)/100;
    const tax=Math.round((v.amount||0)*rate); const total=(v.amount||0)+tax;
    return `<td style="font-size:10px;color:#94a3b8;">${esc(v.number||'—')}</td><td>${date}</td><td><b>${esc(v.name||'—')}</b></td><td>${esc(v.apt||'—')}</td><td>${amt} ر</td><td style="color:#dc2626;">${tax.toLocaleString()} ر</td><td style="font-weight:700;">${total.toLocaleString()} ر</td><td>${actions}</td>`;
  }
  return '';
}

async function deleteVou(id,type){
  if(!confirm('حذف هذه الوثيقة؟'))return;
  try{
    await fetch('/staff/api/vouchers/'+id,{method:'DELETE'});
    toast('🗑️ تم الحذف'); loadVouList(type);
  }catch(e){toast('❌ حدث خطأ');}
}

