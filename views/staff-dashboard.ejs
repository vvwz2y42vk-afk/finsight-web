        </div>
        <div class="apt-bld">
          <div style="font-size:15px;font-weight:800;color:#1e293b;margin-bottom:14px;">الفواتير</div>
          <div class="tbl-wrap"><table class="stbl">
            <thead><tr><th>الرقم</th><th>التاريخ</th><th>الاسم</th><th>الشقة</th><th>البيان</th><th>المبلغ</th><th>إجراء</th></tr></thead>
            <tbody id="vou-invoice-tbody"><tr><td colspan="7" style="text-align:center;padding:20px;color:#94a3b8;">اضغط تحديث لتحميل البيانات</td></tr></tbody>
