let _waType = 'free';
const WA_TEMPLATES = {
  booking_confirmed: (name, apt) => `مرحباً ${name} 👋\nتم تأكيد حجزك في شقة ${apt}.\nشكراً لاختيارك بارز للشقق المفروشة.`,
  check_in:  (name, apt) => `أهلاً وسهلاً ${name} 🏠\nنتمنى لك إقامة سعيدة في شقة ${apt}.\nفريق بارز في خدمتك.`,
  check_out: (name, apt) => `شكراً ${name} على اختيارك بارز 🌟\nنتطلع لاستقبالك مجدداً.`,
};

function openWaSend(phone, name, apt, bkId, checkIn, checkOut, total) {
  document.getElementById('waPhone').value   = phone;
  document.getElementById('waName').value    = name;
  document.getElementById('waApt').value     = apt;
  document.getElementById('waBkId').value    = bkId;
  document.getElementById('waCheckIn').value  = checkIn  || '';
  document.getElementById('waCheckOut').value = checkOut || '';
  document.getElementById('waTotal').value    = total    || 0;
  document.getElementById('waSendSub').textContent = name + ' · ' + phone;
  document.getElementById('waMessage').value = '';
  document.getElementById('waStatus').textContent = '';
  document.querySelector('input[name="waType"][value="free"]').checked = true;
  switchWaType('free');
  document.getElementById('waSendOverlay').style.display = 'flex';
}

function switchWaType(type) {
  _waType = type;
  const name = document.getElementById('waName').value;
  const apt  = document.getElementById('waApt').value;
  const free = document.getElementById('waFreeSection');
  const tmpl = document.getElementById('waTemplateSection');
  if (type === 'free') {
    free.style.display = 'block';
    tmpl.style.display = 'none';
  } else {
    free.style.display = 'none';
    tmpl.style.display = 'block';
    tmpl.innerHTML = '📋 <b>معاينة:</b><br>' + (WA_TEMPLATES[type]?.(name, apt) || '').replace(/\n/g,'<br>');
  }
}

function sendWaMessage() {
  const phone = document.getElementById('waPhone').value;
  const name  = document.getElementById('waName').value;
  const apt   = document.getElementById('waApt').value;
  let msg;
  if (_waType === 'free') {
    msg = document.getElementById('waMessage').value.trim();
    if (!msg) { document.getElementById('waStatus').textContent = 'اكتب الرسالة أولاً'; return; }
  } else {
    msg = WA_TEMPLATES[_waType]?.(name, apt) || '';
  }
  window.open('https://wa.me/' + waPhone(phone) + '?text=' + encodeURIComponent(msg), '_blank');
  closeWaSend();
}

function closeWaSend() { document.getElementById('waSendOverlay').style.display = 'none'; }

