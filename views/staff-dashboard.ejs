            <div id="plan-expiry" style="font-size:12px;opacity:.8;"></div>
          </div>
          <div style="text-align:left;">
            <div style="font-size:11px;opacity:.7;margin-bottom:4px;">المنشأة</div>
            <div id="plan-prop-name" style="font-size:14px;font-weight:700;"></div>
            <div id="plan-prop-type" style="font-size:11px;opacity:.7;margin-top:2px;"></div>
          </div>
        </div>
      </div>

      <div style="margin-top:16px;background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:16px 20px;">
        <div style="font-size:12px;font-weight:700;color:var(--t2);margin-bottom:8px;">أدوات المدير</div>
        <div style="display:flex;gap:10px;flex-wrap:wrap;">
          <button onclick="runMigration()" style="padding:9px 18px;border-radius:9px;border:1px solid #C7D9FF;background:#EEF4FF;color:#1a3d8f;font-family:inherit;font-size:12px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:6px;">
            🔄 ربط البيانات القديمة بالمنشأة
          </button>
        </div>
        <div style="font-size:11px;color:var(--t4);margin-top:8px;">يُشغَّل مرة واحدة فقط لربط الحجوزات والسجلات القديمة بحساب منشأتك.</div>
      </div>
      <% } %>
    </div>

    <!-- ── Activity ── -->
    <div class="tab-section" id="tab-activity">
      <div class="apt-bld">
        <div id="actList" style="padding:0 4px;"></div>
      </div>
    </div>

