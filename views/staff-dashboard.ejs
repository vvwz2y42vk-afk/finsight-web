      </div>

      <% if(staff.role === 'manager'){ %>
      <!-- Plan & Migration — managers only -->
      <div id="plan-card" style="margin-top:28px;background:linear-gradient(135deg,#1a3d8f 0%,#2563eb 100%);border-radius:16px;padding:20px 24px;color:#fff;">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:12px;">
