    <div style="display:flex;align-items:center;gap:14px;margin-bottom:20px;">
      <div style="width:52px;height:52px;border-radius:50%;background:linear-gradient(135deg,#1a3d8f,#2563eb);display:flex;align-items:center;justify-content:center;color:#fff;font-size:22px;font-weight:700;flex-shrink:0;">${(g.name||'?')[0]}</div>
