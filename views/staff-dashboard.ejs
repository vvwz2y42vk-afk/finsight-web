    const row = (lbl, val) => val ? `<div style="display:flex;gap:8px;padding:6px 0;border-bottom:1px solid #f1f5f9;font-size:13px;"><span style="color:#64748b;min-width:120px;">${lbl}</span><b>${val}</b></div>` : '';

