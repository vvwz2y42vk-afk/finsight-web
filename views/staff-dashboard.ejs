let editBkId=null;
async function editBk(id){
  try{
    const r=await fetch('/staff/api/bookings/'+id);
    if(!r.ok){ toast('❌ تعذر تحميل الحجز'); return; }
    const b=await r.json();
    editBkId=id;
    // populate form
    await openNewBkModal(true);
    document.querySelector('#newBkModal .mhd-title').textContent='✏️ تعديل الحجز';
    document.getElementById('nb-apt').innerHTML=`<option value="${esc(b.apt)}">${esc(b.apt)}</option>`;
    document.getElementById('nb-apt').value=b.apt;
    document.getElementById('nb-apt').disabled=true;
    document.getElementById('nb-name').value=b.name||'';
    document.getElementById('nb-phone').value=b.phone||'';
    document.getElementById('nb-type').value=b.bookingType||'daily';
    toggleNbType();
    if(b.checkIn) document.getElementById('nb-checkin').value=new Date(b.checkIn).toISOString().split('T')[0];
    if(b.checkOut) document.getElementById('nb-checkout').value=new Date(b.checkOut).toISOString().split('T')[0];
    document.getElementById('nb-price').value=b.pricePerNight||b.pricePerMonth||0;
    document.getElementById('nb-total').value=b.totalPrice||0;
    document.getElementById('nb-paid').value=b.paidAmount||0;
    document.getElementById('nb-remain').value=Math.max(0,(b.totalPrice||0)-(b.paidAmount||0))||'';
    document.getElementById('nb-idtype').value=b.idType||'';
    document.getElementById('nb-idnum').value=b.idNumber||'';
    document.getElementById('nb-status').value=b.status||'awaiting_checkin';
    document.getElementById('nb-notes').value=b.notes||'';
  }catch(e){ toast('❌ حدث خطأ'); }
}

async function cancelBk(id){
  if(!confirm('هل أنت متأكد من إلغاء هذا الحجز؟')) return;
  try{
    const r=await fetch('/staff/api/bookings/'+id+'/status',{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({status:'cancelled'})});
    const d=await r.json();
    if(d.success){ toast('🗑️ تم إلغاء الحجز','success'); closeBkModal(); loadApartments(); loadStats(); loadBookings(); }
    else toast('❌ '+d.error,'error');
  }catch(e){ toast('❌ حدث خطأ'); }
}

async function changeStatus(id,status){
  if(status==='checkout' && !confirm('تأكيد تسجيل خروج النزيل من الشقة؟')) return;
  try{
    const r=await fetch('/staff/api/bookings/'+id+'/status',{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({status})});
    const d=await r.json();
    if(d.success){ toast(status==='active'?'✅ تم تسجيل الدخول':'🚪 تم تسجيل الخروج','success'); closeBkModal(); loadApartments(); loadStats(); }
    else toast('❌ '+d.error,'error');
  }catch(e){ toast('❌ حدث خطأ'); }
}

