<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
<title><%= staff.building %> — بوابة الموظفين</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/ar.js"></script>
<style>
/* ═══ BAREZ — DASHBOARD (هيكلة نزيل) ═══ */
:root{
  --bg:#F0F2F5;--surface:#FFFFFF;--s2:#F1F5F9;--s3:#E8EEF8;
  --border:#E2E8F0;--border-s:#EEF2F8;
  --t1:#0F172A;--t2:#334155;--t3:#64748B;--t4:#94A3B8;
  --brand:#1a3d8f;--brand-l:#2563eb;--brand-m:rgba(26,61,143,.08);
  --naz:var(--brand);--naz-d:var(--brand);--naz-bg:var(--brand-m);
  --green:#047857;--green-bg:rgba(4,120,87,.08);--green-b:rgba(4,120,87,.2);
  --amber:#B45309;--amber-bg:rgba(180,83,9,.08);--amber-b:rgba(180,83,9,.2);
  --red:#B91C1C;--red-bg:rgba(185,28,28,.08);--red-b:rgba(185,28,28,.2);
  --blue:#1D4ED8;--blue-bg:rgba(29,78,216,.08);
  --purple:#5B21B6;--purple-bg:rgba(91,33,182,.08);
  --r:10px;--r-lg:14px;
  --sh-xs:0 1px 2px rgba(15,23,42,.04);
  --sh-sm:0 2px 8px rgba(15,23,42,.06),0 1px 2px rgba(15,23,42,.04);
  --sh:0 4px 20px rgba(15,23,42,.08),0 2px 4px rgba(15,23,42,.04);
  --sh-lg:0 20px 50px rgba(15,23,42,.12),0 6px 12px rgba(15,23,42,.05);
  --ease:cubic-bezier(.4,0,.2,1);
  --sb:72px;--sb-exp:220px;
  --glass-border:1px solid rgba(255,255,255,.8);
  --glass-sh:0 2px 16px rgba(15,23,42,.06),inset 0 1px 0 rgba(255,255,255,.95);
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Cairo',sans-serif;background:var(--bg);direction:rtl;display:flex;min-height:100vh;color:var(--t1);-webkit-font-smoothing:antialiased;font-weight:400;}

/* ══ Sidebar — هيكلة نزيل ══ */
.sb{
  width:var(--sb);
  background:linear-gradient(180deg,#0D1B2E 0%,#091526 100%);
  border-left:1px solid rgba(255,255,255,.06);
  display:flex;flex-direction:column;align-items:center;
  padding:0;position:fixed;top:0;right:0;bottom:0;z-index:100;
  box-shadow:-2px 0 16px rgba(0,0,0,.25);overflow:hidden;
  transition:width .22s var(--ease);
}
.sb:hover{width:var(--sb-exp);}
.sb-logo{
  display:flex;align-items:center;justify-content:center;
  padding:16px 0 12px;width:100%;
  border-bottom:1px solid rgba(255,255,255,.06);
  transition:padding .22s var(--ease);
}
.sb:hover .sb-logo{justify-content:flex-start;padding:16px 16px 12px;}
.sb-logo img{filter:brightness(0) invert(1);opacity:.85;height:36px;width:auto;flex-shrink:0;}
.sb-bld{display:none;}
.sb-occ{display:none;}
.sb-nav{
  flex:1;width:100%;display:flex;flex-direction:column;
  gap:2px;padding:8px 6px;overflow-y:auto;overflow-x:hidden;
}
.sb-nav::-webkit-scrollbar{width:3px;}
.sb-nav::-webkit-scrollbar-thumb{background:rgba(255,255,255,.1);border-radius:3px;}
.sn{
  display:flex;flex-direction:row;align-items:center;justify-content:flex-start;
  gap:10px;padding:10px 14px 10px;border-radius:8px;
  cursor:pointer;color:rgba(255,255,255,.42);
  transition:background .18s var(--ease),color .18s var(--ease);
  position:relative;text-align:right;
}
.sn:hover{background:rgba(255,255,255,.07);color:rgba(255,255,255,.85);}
.sn.active{
  background:linear-gradient(270deg,rgba(59,130,246,.28) 0%,rgba(59,130,246,.08) 100%);
  color:#93c5fd;
}
.sn.active .sn-ico{
  color:#93c5fd;
  filter:drop-shadow(0 0 5px rgba(147,197,253,.55));
}
.sn.active::after{
  content:'';position:absolute;right:0;top:12%;bottom:12%;
  width:3px;border-radius:2px 0 0 2px;
  background:linear-gradient(180deg,#60a5fa,#2563eb);
  box-shadow:0 0 8px rgba(96,165,250,.9),0 0 18px rgba(96,165,250,.35);
}
.sn-ico{
  width:24px;height:24px;display:flex;align-items:center;justify-content:center;flex-shrink:0;
}
.sn-lbl{
  font-size:12px;font-weight:600;white-space:nowrap;line-height:1.2;
  max-width:0;overflow:hidden;opacity:0;
  transition:max-width .22s var(--ease),opacity .18s var(--ease);
}
.sb:hover .sn-lbl{max-width:150px;opacity:1;}
.sb-foot{width:100%;padding:0 6px 10px;}
.sb-logout{
  display:flex;flex-direction:row;align-items:center;justify-content:flex-start;
  gap:10px;padding:10px 14px;border-radius:8px;
  cursor:pointer;color:rgba(248,113,113,.6);background:transparent;
  transition:background .18s var(--ease),color .18s var(--ease);text-align:right;
}
.sb-logout:hover{background:rgba(239,68,68,.1);color:#FCA5A5;}
.sb-logout-ico{width:20px;height:20px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.sb-logout-lbl{
  font-size:12px;font-weight:600;white-space:nowrap;line-height:1.2;
  max-width:0;overflow:hidden;opacity:0;
  transition:max-width .22s var(--ease),opacity .18s var(--ease);
}
.sb:hover .sb-logout-lbl{max-width:120px;opacity:1;}

/* ══ Mobile overlay ══ */
#sb-overlay{
  display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:99;
  backdrop-filter:blur(2px);-webkit-backdrop-filter:blur(2px);
  opacity:0;transition:opacity .25s var(--ease);
  pointer-events:none;
}
#sb-overlay.show{opacity:1;pointer-events:auto;}

/* ══ Hamburger ══ */
#hamburger{
  display:none;align-items:center;justify-content:center;
  width:38px;height:38px;border-radius:10px;border:none;
  background:var(--s2);color:var(--t2);cursor:pointer;flex-shrink:0;
  transition:background .15s;
}
#hamburger:hover{background:var(--s3);}
#hamburger svg{pointer-events:none;}

/* ══ Main ══ */
.main{margin-right:var(--sb);flex:1;display:flex;flex-direction:column;min-height:100vh;}

/* شريط علوي — صف 1: معلومات المبنى (نزيل) */
.topbar-bld{
  background:linear-gradient(135deg,#0D1B2E,#112440);
  padding:8px 24px;display:flex;align-items:center;justify-content:space-between;
  min-height:44px;
}
.tb-bld-name{font-size:14px;font-weight:700;color:#fff;display:flex;align-items:center;gap:8px;}
.tb-bld-name svg{opacity:.7;flex-shrink:0;}
.tb-bld-sub{font-size:10px;color:rgba(255,255,255,.4);margin-top:2px;letter-spacing:.03em;}
.tb-clock{font-size:12px;color:rgba(255,255,255,.5);letter-spacing:.05em;font-variant-numeric:tabular-nums;}

/* شريط علوي — صف 2: المستخدم والصفحة */
.topbar{
  background:rgba(255,255,255,.98);
  padding:10px 24px;display:flex;align-items:center;justify-content:space-between;
  border-bottom:1px solid var(--border-s);position:sticky;top:0;z-index:50;
  box-shadow:0 2px 8px rgba(15,23,42,.06);
}
.tb-left{display:flex;align-items:center;gap:10px;}
.tb-title{font-size:14px;font-weight:700;color:var(--t1);letter-spacing:-.01em;}
.tb-title span{color:var(--brand);}
.tb-meta{font-size:11px;color:var(--t4);margin-top:1px;font-weight:400;}
.tb-right{display:flex;align-items:center;gap:10px;}
.tb-avatar{
  width:32px;height:32px;border-radius:8px;
  background:var(--brand);
  display:flex;align-items:center;justify-content:center;
  font-size:13px;font-weight:700;color:#fff;flex-shrink:0;
}
.tb-info{text-align:right;}
.tb-info-name{font-size:13px;font-weight:600;color:var(--t2);}
.tb-info-role{font-size:10px;color:var(--t4);margin-top:1px;}
.tb-occ-badge{
  display:flex;align-items:center;gap:6px;padding:5px 12px;
  background:var(--brand-m);border:1px solid rgba(26,61,143,.2);
  border-radius:20px;
}
.tb-occ-dot{width:7px;height:7px;border-radius:50%;background:var(--brand);box-shadow:0 0 6px rgba(26,61,143,.3);}
.tb-occ-txt{font-size:11px;font-weight:600;color:var(--brand);}
.content{padding:20px 24px;flex:1;}
/* ══ KPI Cards — نمط نزيل ══ */
.kpi-row{display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:12px;margin-bottom:20px;}
.kpi-c{
  background:#fff;
  border-radius:10px;padding:18px 16px;
  border:1px solid var(--border);
  box-shadow:var(--sh-sm);
  transition:all .2s var(--ease);cursor:default;
  display:flex;flex-direction:column;
  position:relative;overflow:hidden;
}
.kpi-c::before{content:'';position:absolute;top:0;right:0;left:0;height:3px;background:var(--brand);border-radius:10px 10px 0 0;pointer-events:none;}
.kpi-c:hover{box-shadow:var(--sh);transform:translateY(-2px);border-color:rgba(26,61,143,.25);}
.kpi-ico{
  width:44px;height:44px;border-radius:10px;
  display:flex;align-items:center;justify-content:center;
  margin-bottom:12px;flex-shrink:0;
}
.kpi-num{font-size:32px;font-weight:800;line-height:1;letter-spacing:-.04em;color:var(--t1);}
.kpi-lbl{font-size:11px;color:var(--t3);font-weight:600;margin-top:6px;letter-spacing:.02em;}

/* ══ Charts ══ */
.charts-row{display:grid;grid-template-columns:1fr 190px 190px 190px;gap:12px;margin-bottom:20px;}
.chart-card{
  background:#fff;
  border-radius:10px;padding:18px;
  border:1px solid var(--border);
  box-shadow:var(--sh-sm);
}
.chart-title{
  font-size:13px;font-weight:700;margin-bottom:16px;color:var(--t1);
  display:flex;align-items:center;gap:8px;
  padding-bottom:10px;border-bottom:2px solid var(--brand);
}
.chart-title::before{content:'';display:block;width:3px;height:14px;background:var(--brand);border-radius:3px;flex-shrink:0;}
.donut-wrap{position:relative;display:inline-flex;align-items:center;justify-content:center;}
.donut-center{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;pointer-events:none;}
.donut-pct{font-size:24px;font-weight:700;color:var(--t1);letter-spacing:-.03em;line-height:1;}
.donut-pct-sub{font-size:10px;color:var(--t4);margin-top:3px;letter-spacing:.04em;}

/* ══ Apt Grid ══ */
.apt-filters{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px;align-items:center;}
.af{padding:5px 12px;border-radius:20px;border:1px solid var(--border);background:var(--surface);font-family:inherit;font-size:11px;font-weight:600;cursor:pointer;color:var(--t3);transition:all .18s var(--ease);white-space:nowrap;display:inline-flex;align-items:center;gap:4px;}
.af:hover{background:var(--s2);color:var(--t2);border-color:rgba(26,61,143,.2);}
.af.active{background:var(--brand);border-color:transparent;color:#fff;box-shadow:0 2px 10px rgba(26,61,143,.28);}
.af .af-cnt{font-size:10px;background:rgba(255,255,255,.25);border-radius:10px;padding:0 5px;min-width:18px;text-align:center;display:inline-block;}
.af:not(.active) .af-cnt{background:var(--s3);color:var(--brand);}
.apt-bld{background:#fff;border-radius:10px;border:1px solid var(--border);box-shadow:var(--sh-sm);margin-bottom:12px;overflow:hidden;}
.apt-bld-hd{display:flex;align-items:center;justify-content:space-between;padding:12px 16px;background:linear-gradient(135deg,#1a3d8f,#1a3d8f);margin-bottom:0;}
.apt-bld-name{font-size:14px;font-weight:700;color:#fff;letter-spacing:-.01em;}
.apt-bld-inner{padding:14px 16px;}
.apt-floor-row{display:flex;align-items:center;gap:10px;margin-bottom:8px;margin-top:4px;}
.apt-floor-lbl{font-size:11px;font-weight:700;color:var(--brand);letter-spacing:.05em;text-transform:uppercase;white-space:nowrap;}
.apt-floor-stats{font-size:10px;font-weight:700;padding:2px 9px;background:rgba(26,61,143,.08);color:var(--brand);border-radius:20px;white-space:nowrap;flex-shrink:0;}
.apt-floor-line{flex:1;height:1px;background:rgba(26,61,143,.1);}
.apt-grid{display:flex;flex-wrap:wrap;gap:9px;margin-bottom:16px;}
.apt{width:116px;border-radius:13px;padding:12px 8px 10px;text-align:center;cursor:pointer;transition:all .22s var(--ease);user-select:none;position:relative;border:1.5px solid var(--border);background:var(--surface);}
.apt:hover{transform:translateY(-3px);box-shadow:0 8px 20px rgba(0,0,0,.1);}
.apt-type{font-size:9px;margin-top:3px;opacity:.75;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;line-height:1.3;}
.apt-n{font-size:20px;font-weight:900;line-height:1;letter-spacing:-.03em;}
.apt-s{font-size:10px;margin-top:4px;font-weight:700;letter-spacing:.01em;opacity:.9;}
.apt-g{font-size:10px;margin-top:2px;opacity:.8;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-weight:500;}
.apt-nights{display:inline-block;margin-top:5px;font-size:9px;background:rgba(0,0,0,.1);padding:1px 7px;border-radius:20px;font-weight:800;letter-spacing:.02em;}

/* Soft muted apartment colors */
.apt.vac{background:linear-gradient(145deg,#F0FDF4,#DCFCE7);color:#14532D;border-color:rgba(34,197,94,.25);}
.apt.occ{background:linear-gradient(145deg,#FFF1F2,#FFE4E6);color:#9F1239;border-color:rgba(244,63,94,.25);}
.apt.cin{background:linear-gradient(145deg,#EFF6FF,#DBEAFE);color:#1E3A8A;border-color:rgba(59,130,246,.28);}
.apt.cout{background:linear-gradient(145deg,#FFFBEB,#FEF3C7);color:#78350F;border-color:rgba(245,158,11,.28);}
.apt.awt{background:linear-gradient(145deg,#F5F3FF,#EDE9FE);color:#3B0764;border-color:rgba(139,92,246,.25);}
.apt.awp{background:linear-gradient(145deg,#FEFCE8,#FEF9C3);color:#713F12;border-color:rgba(202,138,4,.25);}
.apt.dirty{outline:2px solid rgba(234,179,8,.6);outline-offset:2px;}
.apt.maintenance{outline:2px solid rgba(107,114,128,.5);outline-offset:2px;}

@keyframes urgentPulse{0%,100%{box-shadow:0 0 0 0 rgba(59,130,246,.2);}50%{box-shadow:0 0 0 5px rgba(59,130,246,.08);}}
.apt.cin,.apt.cout{animation:urgentPulse 2s ease-in-out infinite;}
@keyframes kpiIn{from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:translateY(0);}}
.kpi-c{animation:kpiIn .45s ease both;}

/* ══ Table ══ */
.tbl-wrap{overflow-x:auto;border-radius:12px;border:1px solid var(--border);box-shadow:var(--sh-sm);}
.pager{display:flex;align-items:center;justify-content:center;gap:4px;padding:10px 0;flex-wrap:wrap;}
.pager button{min-width:32px;height:32px;padding:0 8px;border-radius:8px;border:1px solid #e2e8f0;background:#fff;color:#475569;font-family:inherit;font-size:12px;font-weight:600;cursor:pointer;transition:all .15s;}
.pager button:hover{background:#f1f5f9;}
.pager button.active{background:#1a3d8f;color:#fff;border-color:#1a3d8f;}
.pager button:disabled{opacity:.4;cursor:default;}
.pager-info{font-size:11px;color:var(--t4);margin:0 6px;}
.stbl{width:100%;border-collapse:collapse;font-size:13px;}
.stbl th{background:var(--brand);color:#fff;padding:10px 12px;text-align:right;font-weight:600;font-size:11px;letter-spacing:.04em;border-bottom:none;}
.stbl th:first-child{border-radius:0 6px 0 0;}
.stbl th:last-child{border-radius:6px 0 0 0;}
.stbl td{padding:9px 12px;border-bottom:1px solid var(--border-s);color:var(--t2);}
.stbl tbody tr:hover td{background:rgba(26,61,143,.07)!important;}
.stbl tbody tr.co-row td{background:rgba(26,61,143,.08)!important;}
.stbl tbody tr.co-row:hover td{background:rgba(26,61,143,.12)!important;}
.stbl tbody tr{transition:background .12s;}

/* Tbl action icon buttons */
.tbl-act{display:inline-flex;gap:3px;align-items:center;flex-wrap:wrap;}
.ia{width:27px;height:27px;border-radius:7px;border:none;cursor:pointer;display:inline-flex;align-items:center;justify-content:center;font-size:13px;transition:all .15s;position:relative;flex-shrink:0;}
.ia:hover{transform:scale(1.15);}
.ia::after{content:attr(data-tip);position:absolute;bottom:calc(100%+5px);left:50%;transform:translateX(-50%);background:rgba(15,23,42,.88);color:#fff;font-size:10px;font-weight:600;padding:3px 8px;border-radius:6px;white-space:nowrap;pointer-events:none;opacity:0;transition:opacity .15s;font-family:'Cairo',sans-serif;z-index:10;}
.ia:hover::after{opacity:1;}
.ia-in{background:#DCFCE7;color:#16A34A;}.ia-out{background:#FFEDD5;color:#EA580C;}
.ia-edit{background:#EFF6FF;color:#2563EB;}.ia-cancel{background:#FEF2F2;color:#DC2626;}
.ia-print{background:#F0FDF4;color:#16A34A;}.ia-contract{background:#FEFCE8;color:#854D0E;}
.ia-wa{background:#DCFCE7;color:#15803D;}.ia-view{background:#F0F4FF;color:#1a3d8f;}

/* Status badges */
.badge{display:inline-flex;padding:3px 9px;border-radius:20px;font-size:10px;font-weight:700;letter-spacing:.02em;white-space:nowrap;}
.b-active{background:rgba(4,120,87,.1);color:#047857;}
.b-awaiting{background:rgba(91,33,182,.09);color:#5B21B6;}
.b-checkout{background:rgba(180,83,9,.09);color:#B45309;}
.b-pending{background:rgba(146,64,14,.09);color:#92400E;}
.b-cancelled{background:rgba(185,28,28,.08);color:#B91C1C;}
.b-awaiting_payment{background:rgba(29,78,216,.09);color:#1D4ED8;}

/* Skeleton loader */
@keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}
.skel{background:linear-gradient(90deg,#f1f5f9 25%,#e8eef5 50%,#f1f5f9 75%);background-size:200% 100%;animation:shimmer 1.6s infinite;border-radius:6px;display:inline-block;}

/* Calendar layout */
.cal-layout{display:flex;gap:16px;align-items:flex-start;}
.cal-main{flex:1;min-width:0;}
.cal-panel{width:232px;flex-shrink:0;background:var(--surface);border-radius:var(--r);border:1px solid var(--border);box-shadow:var(--sh-sm);overflow:hidden;position:sticky;top:70px;}
.cal-panel-hd{padding:12px 14px;background:linear-gradient(135deg,var(--brand),var(--brand-l));color:#fff;}
.cal-panel-ttl{font-size:12px;font-weight:700;}
.cal-panel-sub{font-size:10px;opacity:.75;margin-top:1px;}
.cal-panel-body{padding:10px;max-height:460px;overflow-y:auto;}
.cal-pi{display:flex;align-items:center;gap:8px;padding:7px 6px;border-radius:8px;transition:background .12s;cursor:default;}
.cal-pi:hover{background:var(--s2);}
.cal-pi-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.cal-pi-info{flex:1;min-width:0;}
.cal-pi-apt{font-size:11px;font-weight:700;color:var(--t1);}
.cal-pi-name{font-size:10px;color:var(--t4);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.cal-pi-type{font-size:9px;font-weight:700;padding:1px 5px;border-radius:8px;}

/* Calendar table */
.cal-table-wrap{overflow-x:auto;border-radius:12px;border:1px solid var(--border);}
.cal-table{border-collapse:collapse;min-width:900px;font-size:12px;}
.cal-table th,.cal-table td{border:1px solid var(--border-s);text-align:center;padding:0;}
.cal-apt-col{min-width:80px;padding:6px 10px;background:var(--s2);color:var(--brand);font-weight:700;position:sticky;right:0;z-index:2;}
.cal-day-col{min-width:28px;max-width:28px;padding:5px 2px;background:var(--s2);color:var(--t3);font-size:10px;font-weight:600;}
.cal-apt-label{padding:6px 10px;background:var(--surface);font-weight:600;color:var(--t1);position:sticky;right:0;z-index:1;white-space:nowrap;font-size:12px;}
.cal-floor-row td{padding:5px 12px;background:var(--s3);color:var(--brand);font-weight:700;font-size:10px;letter-spacing:.05em;text-transform:uppercase;}
.cal-v{background:var(--surface);}
.cal-o{background:#FFE4E6;}
.cal-i{background:#DBEAFE;}
.cal-x{background:#FEF3C7;}
.cal-v,.cal-o,.cal-i,.cal-x{width:28px;height:28px;cursor:default;transition:opacity .15s;}
.cal-o{border-radius:0;}
.cal-i:first-of-type,.cal-i+.cal-x{border-radius:8px 0 0 8px;}
.cal-v,.cal-o,.cal-i,.cal-x{position:relative;}
.cal-o::after,.cal-i::after,.cal-x::after{content:'';position:absolute;inset:2px 0;border-radius:0;}

/* ══ Search ══ */
.search-bar{display:flex;gap:10px;margin-bottom:18px;flex-wrap:wrap;}
.sinp{padding:9px 14px;border:1.5px solid var(--border);border-radius:10px;font-family:inherit;font-size:13px;outline:none;flex:1;min-width:180px;background:var(--surface);color:var(--t1);transition:border-color .2s,box-shadow .2s;}
.sinp:focus{border-color:var(--brand);box-shadow:0 0 0 3px rgba(26,61,143,.08);}
.sbtn{padding:9px 20px;background:linear-gradient(135deg,var(--brand),var(--brand-l));border:none;border-radius:10px;font-family:inherit;font-size:13px;font-weight:600;cursor:pointer;color:#fff;box-shadow:0 2px 8px rgba(26,61,143,.22);transition:all .2s var(--ease);}
.sbtn:hover{transform:translateY(-1px);box-shadow:0 4px 16px rgba(26,61,143,.32);}

/* ══ HK Grid ══ */
.hk-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(82px,1fr));gap:7px;}
.hk-card{background:var(--surface);border-radius:11px;border:1.5px solid var(--border);padding:12px 6px 10px;text-align:center;cursor:pointer;transition:all .18s var(--ease);position:relative;}
.hk-card:hover{transform:translateY(-3px);box-shadow:var(--sh-sm);}
.hk-apt{font-size:18px;font-weight:900;color:var(--t1);letter-spacing:-.04em;line-height:1;}
.hk-badge{display:inline-flex;align-items:center;gap:3px;padding:2px 7px;border-radius:20px;font-size:9px;font-weight:700;margin-top:5px;white-space:nowrap;}
/* HK status colors applied to badge */
.hk-card.hk-clean-c  .hk-badge{background:rgba(4,120,87,.1);color:#047857;}
.hk-card.hk-dirty-c  .hk-badge{background:rgba(185,28,28,.1);color:#B91C1C;}
.hk-card.hk-inspect-c .hk-badge{background:rgba(202,138,4,.1);color:#B45309;}
.hk-card.hk-maint-c  .hk-badge{background:rgba(91,33,182,.1);color:#5B21B6;}
.hk-card.hk-dirty-c{border-color:rgba(185,28,28,.3);background:rgba(254,242,242,.6);}
.hk-card.hk-maint-c{border-color:rgba(91,33,182,.25);background:rgba(245,243,255,.6);}
.hk-card.hk-inspect-c{border-color:rgba(202,138,4,.25);background:rgba(255,251,235,.6);}
.hk-card.hk-clean-c{border-color:rgba(4,120,87,.2);}
.hk-notes{font-size:9px;color:var(--t4);margin-top:3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;padding:0 4px;}

/* ══ Activity ══ */
.act-row{display:flex;align-items:center;gap:14px;padding:14px 0;border-bottom:1px solid var(--border-s);}
.act-ico{width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.act-in{background:var(--green-bg);color:var(--green);}
.act-out{background:var(--amber-bg);color:var(--amber);}
.act-hk{background:var(--blue-bg);color:var(--blue);}
.act-info{flex:1;}
.act-main{font-size:13px;font-weight:600;color:var(--t1);}
.act-sub{font-size:11px;color:var(--t4);margin-top:2px;}
.act-time{font-size:11px;color:var(--t4);text-align:left;}

/* ══ Modal ══ */
.overlay{position:fixed;inset:0;background:rgba(15,23,42,.5);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);display:flex;align-items:center;justify-content:center;z-index:1000;}
.modal{background:var(--surface);border-radius:var(--r-lg);width:90%;max-width:440px;overflow:hidden;box-shadow:var(--sh-lg);border:1px solid var(--border);}
.mhd{background:linear-gradient(135deg,#060E1F,var(--brand));color:#fff;padding:18px 22px;display:flex;align-items:center;justify-content:space-between;}
.mhd-title{font-size:14px;font-weight:600;letter-spacing:.01em;}
.mclose{background:none;border:none;color:rgba(255,255,255,.45);font-size:20px;cursor:pointer;line-height:1;transition:color .15s;}
.mclose:hover{color:#fff;}
.mbody{padding:22px;display:flex;flex-direction:column;gap:12px;font-size:13px;}
.mrow{display:flex;justify-content:space-between;padding:9px 0;border-bottom:1px solid var(--border-s);color:var(--t3);}
.mrow b{color:var(--t1);font-weight:600;}
.mbtn{padding:11px;border:none;border-radius:10px;font-family:inherit;font-size:13px;font-weight:600;cursor:pointer;flex:1;transition:all .2s var(--ease);}
.mbtn-in{background:var(--green);color:#fff;}.mbtn-in:hover{background:#036046;box-shadow:0 4px 14px rgba(4,120,87,.3);}
.mbtn-out{background:var(--amber);color:#fff;}.mbtn-out:hover{background:#92400E;box-shadow:0 4px 14px rgba(180,83,9,.3);}
.mbtn-cancel{background:var(--s2);color:var(--t3);}.mbtn-cancel:hover{background:var(--border);color:var(--t2);}
.occ-stat{display:flex;align-items:center;gap:6px;font-size:12px;font-weight:500;}

/* ══ Toast ══ */
#toast{position:fixed;bottom:28px;left:50%;transform:translateX(-50%) translateY(8px);background:rgba(15,23,42,.93);backdrop-filter:blur(16px);color:#fff;padding:13px 26px;border-radius:14px;font-size:13px;font-weight:600;opacity:0;transition:opacity .28s,transform .28s cubic-bezier(.34,1.56,.64,1);z-index:9999;pointer-events:none;box-shadow:0 12px 32px rgba(0,0,0,.28);letter-spacing:.01em;border:1px solid rgba(255,255,255,.1);display:flex;align-items:center;gap:8px;}
#toast.show{opacity:1;transform:translateX(-50%) translateY(0);}
#toast.toast-success{background:linear-gradient(135deg,rgba(4,120,87,.95),rgba(5,150,105,.95));border-color:rgba(52,211,153,.3);}
#toast.toast-error{background:linear-gradient(135deg,rgba(185,28,28,.95),rgba(220,38,38,.95));border-color:rgba(252,165,165,.3);}

/* ══ Success Overlay ══ */
#successOverlay{position:fixed;inset:0;z-index:10000;display:flex;align-items:center;justify-content:center;pointer-events:none;}
.success-burst{
  display:flex;flex-direction:column;align-items:center;gap:10px;
  background:rgba(255,255,255,.96);backdrop-filter:blur(20px);
  border-radius:24px;padding:28px 40px;
  box-shadow:0 24px 60px rgba(4,120,87,.2), 0 0 0 1px rgba(4,120,87,.15);
  transform:scale(.7);opacity:0;
  transition:all .3s cubic-bezier(.34,1.56,.64,1);
}
.success-burst.show{transform:scale(1);opacity:1;}
.success-burst svg{filter:drop-shadow(0 4px 12px rgba(4,120,87,.4));}
.success-burst span{font-size:14px;font-weight:700;color:#047857;}

/* ══ Smart Form Validation ══ */
@keyframes shake{
  0%,100%{transform:translateX(0);}
  15%{transform:translateX(-7px);}
  30%{transform:translateX(6px);}
  45%{transform:translateX(-5px);}
  60%{transform:translateX(4px);}
  75%{transform:translateX(-3px);}
  90%{transform:translateX(2px);}
}
@keyframes fieldGlow{
  0%,100%{box-shadow:0 0 0 3px rgba(220,38,38,.08);}
  50%{box-shadow:0 0 0 5px rgba(220,38,38,.14);}
}
.f-req-star{color:#EF4444;font-size:14px;margin-right:2px;line-height:1;}
.field-wrap{position:relative;}
.field-hint{font-size:11px;font-weight:600;padding:4px 0 0 2px;min-height:18px;transition:all .2s;}
.field-hint.err{color:#EF4444;}
.field-hint.ok {color:#059669;}

/* Valid state */
.f-valid{border-color:#10B981 !important;background:rgba(16,185,129,.03) !important;box-shadow:0 0 0 3px rgba(16,185,129,.1) !important;}
/* Error state */
.f-error{border-color:#EF4444 !important;background:rgba(239,68,68,.03) !important;animation:shake .45s ease, fieldGlow 1.2s ease 2 !important;}
/* Idle required */
.f-idle{border-color:#E2E8F0 !important;}

/* ══ Tab Transition ══ */
.tab-section{display:none;}
.tab-section.active{display:block;animation:tabFadeIn .22s ease both;}
@keyframes tabFadeIn{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}

/* ══ Modal Animate ══ */
@keyframes modalIn{from{opacity:0;transform:scale(.94) translateY(12px);}to{opacity:1;transform:scale(1) translateY(0);}}
.overlay .modal,.overlay>div{animation:modalIn .25s cubic-bezier(.34,1.2,.64,1) both;}

/* ══ Vouchers ══ */
.vou-cards{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:24px;}
.vou-card{
  flex:1;min-width:130px;max-width:190px;border-radius:16px;padding:20px 16px 18px;text-align:center;
  cursor:pointer;transition:all .24s var(--ease);user-select:none;
  background:rgba(255,255,255,.97);border:1px solid var(--border);
  box-shadow:var(--sh-sm);position:relative;overflow:hidden;
}
.vou-card::before{content:'';position:absolute;top:-24px;right:-24px;width:80px;height:80px;border-radius:50%;opacity:.06;pointer-events:none;}
.vou-card:hover{transform:translateY(-5px);box-shadow:var(--sh);border-color:rgba(26,61,143,.18);}
.vou-ico-w{width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;margin:0 auto 12px;box-shadow:0 4px 14px rgba(0,0,0,.1);}
.vou-lbl{font-size:12px;font-weight:700;color:var(--t1);letter-spacing:.01em;}
.vou-sublbl{font-size:10px;color:var(--t4);margin-top:3px;}
.vou-section{display:none;}.vou-section.active{display:block;}

/* ══ Modal inputs ══ */
.modal input,.modal select,.modal textarea{background:var(--s2);border:1.5px solid var(--border);color:var(--t1);border-radius:8px;padding:9px 12px;font-family:inherit;font-size:13px;width:100%;transition:border-color .2s,box-shadow .2s;outline:none;}
.modal input:focus,.modal select:focus,.modal textarea:focus{border-color:var(--brand);box-shadow:0 0 0 3px rgba(26,61,143,.08);background:var(--surface);}
.modal input::placeholder,.modal textarea::placeholder{color:var(--t4);}
.modal label{color:var(--t3);font-size:12px;font-weight:600;}
.modal select option{background:#fff;color:var(--t1);}

@keyframes dot-pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.75)}}
.flatpickr-calendar{border-radius:14px!important;box-shadow:0 8px 28px rgba(15,23,42,.13)!important;border:1px solid #e2e8f0!important;font-family:'Cairo',sans-serif!important;direction:rtl!important;}
.flatpickr-months{background:var(--brand)!important;border-radius:13px 13px 0 0!important;padding:4px 0!important;}
.flatpickr-month,.flatpickr-current-month,.flatpickr-current-month .cur-month{color:#fff!important;}
.flatpickr-current-month .flatpickr-monthDropdown-months{color:#fff!important;font-weight:700!important;font-size:14px!important;font-family:'Cairo',sans-serif!important;border:none!important;background:transparent!important;cursor:pointer!important;}
.flatpickr-current-month .flatpickr-monthDropdown-months option{color:#0f172a!important;background:#fff!important;}
.flatpickr-current-month input.cur-year{color:#fff!important;font-weight:800!important;font-size:14px!important;}
.numInputWrapper:hover{background:rgba(255,255,255,.1)!important;}
.arrowUp:after{border-bottom-color:#fff!important;} .arrowDown:after{border-top-color:#fff!important;}
.flatpickr-prev-month svg,.flatpickr-next-month svg{fill:#fff!important;}
.flatpickr-prev-month:hover,.flatpickr-next-month:hover{background:rgba(255,255,255,.15)!important;}
.flatpickr-weekday{color:var(--brand)!important;font-weight:700!important;}
.flatpickr-day.selected{background:var(--brand)!important;border-color:var(--brand)!important;border-radius:8px!important;}
.flatpickr-day:hover{background:var(--brand-m)!important;border-radius:8px!important;}
.flatpickr-day.today{border-color:var(--brand)!important;font-weight:700!important;}
.cust-ff{display:flex;flex-direction:column;gap:3px;}
.cust-ff label{font-size:10px;font-weight:700;color:#1a3d8f;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.cff{padding:6px 10px;border-radius:7px;border:1px solid #dde4f0;background:#f7f9ff;color:#1a1a2e;font-family:inherit;font-size:12px;outline:none;width:100%;}
.cff:focus{border-color:#1a3d8f;background:#fff;}

/* ══ Print ══ */
@media print{.sb,.topbar,.apt-filters,.search-bar,button,.overlay{display:none!important;}.main{margin:0!important;}.content{padding:0!important;}#printArea{display:block!important;}}
#printArea{display:none;position:fixed;inset:0;background:#fff;z-index:9999;padding:32px;overflow:auto;}
.print-doc{max-width:700px;margin:0 auto;font-family:'Cairo',sans-serif;direction:rtl;}
.print-hd{display:flex;justify-content:space-between;align-items:flex-start;border-bottom:3px solid var(--brand);padding-bottom:16px;margin-bottom:20px;}
.print-logo{font-size:22px;font-weight:700;color:#0f172a;}.print-logo span{color:var(--brand);}
.print-type{font-size:18px;font-weight:700;color:#fff;padding:6px 18px;border-radius:8px;}
.print-meta{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:20px;font-size:13px;}
.print-meta-row{display:flex;gap:6px;padding:6px 0;border-bottom:1px solid #f1f5f9;}
.print-meta-row span{color:#64748b;min-width:110px;}.print-meta-row b{color:#0f172a;}
.print-total{background:#f8fafc;border:2px solid var(--brand);border-radius:12px;padding:14px 20px;display:flex;justify-content:space-between;align-items:center;margin-top:16px;}
.print-total-lbl{font-size:14px;font-weight:600;color:#475569;}.print-total-val{font-size:22px;font-weight:700;color:var(--brand);}
.print-footer{text-align:center;margin-top:24px;font-size:11px;color:#94a3b8;border-top:1px solid #e2e8f0;padding-top:12px;}
.print-btns{display:flex;gap:8px;margin-bottom:16px;}
/* ── Mobile UX — global touch/tap hardening ── */
*{-webkit-tap-highlight-color:transparent;}
button,.apt,.sn,.ia,.af,.tab-btn,.pager-btn,[onclick]{touch-action:manipulation;}
.apt{transition:transform .12s ease,box-shadow .12s ease;}
.apt:active{transform:scale(.95)!important;box-shadow:0 2px 8px rgba(0,0,0,.15)!important;}
.ia{will-change:transform;}
/* Bottom sheet */
#bsOverlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:1200;opacity:0;transition:opacity .25s;}
#bsOverlay.open{display:block;opacity:1;}
#bottomSheet{position:fixed;bottom:0;right:0;left:0;background:#fff;border-radius:22px 22px 0 0;padding:0 0 env(safe-area-inset-bottom);z-index:1201;transform:translateY(100%);transition:transform .3s cubic-bezier(.32,.72,0,1);max-height:80dvh;overflow-y:auto;}
#bottomSheet.open{transform:translateY(0);}
.bs-handle{width:40px;height:4px;background:#e2e8f0;border-radius:4px;margin:14px auto 6px;flex-shrink:0;}
.bs-title{font-size:13px;font-weight:700;color:#64748b;text-align:center;padding:0 16px 12px;border-bottom:1px solid #f1f5f9;}
.bs-btn{display:flex;align-items:center;gap:12px;width:100%;padding:14px 20px;background:none;border:none;border-bottom:1px solid #f1f5f9;font-family:'Cairo',sans-serif;font-size:14px;font-weight:600;color:#1e293b;cursor:pointer;text-align:right;touch-action:manipulation;}
.bs-btn:active{background:#f8fafc;}
.bs-btn.danger{color:#dc2626;}
.bs-btn.success{color:#16a34a;}
.bs-btn-ico{font-size:18px;width:28px;text-align:center;flex-shrink:0;}
.bs-sep{height:8px;background:#f8fafc;flex-shrink:0;}
.ia-mob{display:none;}
@media(max-width:768px){
  .main{margin-right:var(--sb);}
  .charts-row{grid-template-columns:1fr 1fr;}
  .kpi-row{grid-template-columns:repeat(2,1fr);gap:8px;}
  .vou-cards{gap:10px;}
  .cust-ff{min-width:140px;}
  [style*="grid-template-columns:repeat(7"]{grid-template-columns:repeat(2,1fr)!important;}
  [style*="grid-template-columns:2fr 1.5fr"]{grid-template-columns:1fr 1fr!important;flex-wrap:wrap!important;}
  .stbl thead{display:none!important;}
  .stbl tr{display:block!important;background:#fff;border-radius:12px;margin-bottom:10px;padding:12px;box-shadow:var(--sh-sm);border:1px solid var(--border);}
  .stbl td{display:flex!important;justify-content:space-between;align-items:center;padding:5px 0!important;border:none!important;font-size:12px;}
  .stbl td::before{content:attr(data-label);color:var(--t3);font-size:11px;font-weight:600;margin-left:8px;white-space:nowrap;}
  .stbl td[data-label=""]{justify-content:flex-end;}
  .stbl td[data-label=""]::before{display:none;}
  .kpi{padding:12px 10px;}
  .content{padding:12px;}
  /* أزرار الإجراءات: إخفاء على الجوال مع إظهار زر ⋮ */
  .stbl .ia:not(.ia-mob){display:none!important;}
  .ia-mob{display:inline-flex!important;align-items:center;justify-content:center;width:34px;height:34px;background:rgba(26,61,143,.07);border-radius:9px;border:none;font-size:18px;cursor:pointer;color:var(--brand);font-weight:700;}
}
@media(max-width:480px){
  .main{margin-right:0!important;}
  .kpi-row{grid-template-columns:repeat(2,1fr);}
  .modal-box{width:calc(100vw - 16px)!important;max-height:90dvh!important;overflow-y:auto;}
  .content{padding:8px 6px;}
  .apt{min-width:calc(50% - 8px);}
}
/* ══ Channel Manager ══ */
.ch-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px;margin-bottom:28px;}
.ch-card{background:#fff;border-radius:18px;border:1.5px solid var(--border);box-shadow:var(--sh-sm);overflow:hidden;transition:all .25s var(--ease);}
.ch-card:hover{box-shadow:var(--sh);transform:translateY(-2px);}
.ch-card.ch-active{border-color:transparent;}
.ch-card-hd{padding:18px 20px 14px;display:flex;align-items:center;gap:14px;position:relative;}
.ch-logo{width:48px;height:48px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;font-weight:900;}
.ch-info{flex:1;min-width:0;}
.ch-name{font-size:15px;font-weight:800;color:var(--t1);letter-spacing:-.01em;}
.ch-sub{font-size:11px;color:var(--t4);margin-top:2px;}
.ch-toggle{position:relative;width:42px;height:24px;flex-shrink:0;}
.ch-toggle input{opacity:0;width:0;height:0;}
.ch-toggle-slider{position:absolute;inset:0;background:#cbd5e1;border-radius:24px;cursor:pointer;transition:background .2s;}
.ch-toggle input:checked+.ch-toggle-slider{background:var(--green);}
.ch-toggle-slider::before{content:'';position:absolute;width:18px;height:18px;border-radius:50%;background:#fff;top:3px;right:3px;transition:transform .2s;box-shadow:0 1px 4px rgba(0,0,0,.15);}
.ch-toggle input:checked+.ch-toggle-slider::before{transform:translateX(-18px);}
.ch-status{display:flex;align-items:center;gap:6px;padding:8px 20px;background:var(--s2);border-top:1px solid var(--border-s);font-size:11px;font-weight:700;}
.ch-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;}
.ch-dot.ok{background:#16a34a;}
.ch-dot.error{background:#dc2626;}
.ch-dot.never{background:#94a3b8;}
.ch-body{padding:14px 20px 18px;}
.ch-field{margin-bottom:12px;}
.ch-label{font-size:10px;font-weight:700;color:var(--t3);letter-spacing:.05em;text-transform:uppercase;margin-bottom:5px;}
.ch-input{width:100%;padding:8px 12px;border:1.5px solid var(--border);border-radius:10px;font-family:inherit;font-size:12px;outline:none;color:var(--t1);background:var(--surface);transition:border-color .2s;}
.ch-input:focus{border-color:var(--brand);box-shadow:0 0 0 3px rgba(26,61,143,.08);}
.ch-export-box{background:var(--s2);border-radius:10px;padding:10px 12px;display:flex;align-items:center;gap:8px;border:1px dashed var(--border);}
.ch-export-url{font-size:11px;color:var(--t3);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-family:monospace;}
.ch-copy-btn{flex-shrink:0;background:var(--brand);color:#fff;border:none;border-radius:7px;padding:4px 10px;font-size:10px;font-weight:700;cursor:pointer;font-family:inherit;white-space:nowrap;}
.ch-actions{display:flex;gap:8px;margin-top:14px;}
.ch-save-btn{flex:1;padding:9px;background:linear-gradient(135deg,var(--brand),var(--brand-l));color:#fff;border:none;border-radius:10px;font-family:inherit;font-size:12px;font-weight:700;cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:6px;}
.ch-save-btn:hover{transform:translateY(-1px);box-shadow:0 4px 14px rgba(26,61,143,.3);}
.ch-sync-btn{padding:9px 14px;background:var(--s2);color:var(--t2);border:1.5px solid var(--border);border-radius:10px;font-family:inherit;font-size:12px;font-weight:700;cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:6px;}
.ch-sync-btn:hover{background:var(--s3);}
.ch-sync-btn.spinning svg{animation:spin .7s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}

/* Channel Feed */
.ch-feed{background:#fff;border-radius:18px;border:1px solid var(--border);box-shadow:var(--sh-sm);overflow:hidden;}
.ch-feed-hd{padding:16px 22px;border-bottom:1px solid var(--border-s);display:flex;align-items:center;justify-content:space-between;}
.ch-feed-title{font-size:14px;font-weight:800;color:var(--t1);display:flex;align-items:center;gap:8px;}
.ch-feed-title::before{content:'';display:block;width:4px;height:16px;background:linear-gradient(180deg,var(--brand-l),var(--brand));border-radius:3px;}
.ch-feed-row{display:flex;align-items:center;gap:12px;padding:12px 22px;border-bottom:1px solid var(--border-s);transition:background .12s;}
.ch-feed-row:last-child{border-bottom:none;}
.ch-feed-row:hover{background:var(--s2);}
.ch-plat-badge{font-size:10px;font-weight:800;padding:3px 9px;border-radius:20px;white-space:nowrap;flex-shrink:0;}
.ch-plat-airbnb{background:#fff0f0;color:#FF5A5F;}
.ch-plat-booking{background:#e8f0fa;color:#003580;}
.ch-plat-gathering{background:#eafaf1;color:#1a6b3c;}
.ch-plat-website{background:var(--brand-m);color:var(--brand);}
.ch-feed-apt{font-size:14px;font-weight:800;color:var(--t1);min-width:44px;}
.ch-feed-info{flex:1;min-width:0;}
.ch-feed-name{font-size:13px;font-weight:600;color:var(--t1);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.ch-feed-dates{font-size:11px;color:var(--t3);margin-top:2px;}
.ch-feed-price{font-size:13px;font-weight:700;color:var(--green);white-space:nowrap;}
.ch-empty{padding:48px;text-align:center;color:var(--t4);font-size:13px;}

/* Airbnb #FF5A5F, Booking #003580, Gathering green, Website brand */
.ch-card[data-platform="airbnb"] .ch-logo{background:#fff0f0;color:#FF5A5F;}
.ch-card[data-platform="airbnb"].ch-active{border-color:#FF5A5F40;box-shadow:0 4px 24px #FF5A5F18;}
.ch-card[data-platform="booking"] .ch-logo{background:#e8f0fa;color:#003580;}
.ch-card[data-platform="booking"].ch-active{border-color:#00358040;box-shadow:0 4px 24px #00358018;}
.ch-card[data-platform="gathering"] .ch-logo{background:#eafaf1;color:#1a6b3c;}
.ch-card[data-platform="gathering"].ch-active{border-color:#1a6b3c40;box-shadow:0 4px 24px #1a6b3c18;}
.ch-card[data-platform="website"] .ch-logo{background:var(--brand-m);color:var(--brand);}
.ch-card[data-platform="website"].ch-active{border-color:rgba(26,61,143,.25);box-shadow:0 4px 24px rgba(26,61,143,.1);}

/* How-to accordion */
.ch-how{background:#fff;border-radius:18px;border:1px solid var(--border);box-shadow:var(--sh-sm);overflow:hidden;margin-top:20px;}
.ch-how-hd{padding:16px 22px;border-bottom:1px solid var(--border-s);display:flex;align-items:center;gap:8px;cursor:pointer;user-select:none;}
.ch-how-hd-title{font-size:14px;font-weight:800;color:var(--t1);flex:1;}
.ch-how-body{padding:0 22px;max-height:0;overflow:hidden;transition:max-height .35s var(--ease),padding .35s;}
.ch-how-body.open{max-height:1200px;padding:20px 22px;}
.ch-how-step{display:flex;gap:14px;padding:12px 0;border-bottom:1px solid var(--border-s);}
.ch-how-step:last-child{border-bottom:none;}
.ch-how-num{width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,var(--brand),var(--brand-l));color:#fff;font-size:12px;font-weight:800;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px;}
.ch-how-text{flex:1;}
.ch-how-text strong{display:block;font-size:13px;font-weight:700;color:var(--t1);margin-bottom:3px;}
.ch-how-text p{font-size:12px;color:var(--t3);line-height:1.6;margin:0;}
.ch-how-text code{background:var(--s2);color:var(--brand);padding:2px 7px;border-radius:6px;font-family:monospace;font-size:11px;}

/* ══ Mobile — يجب أن يكون آخر شيء في الـ CSS ══ */
@media(max-width:767px){
  html{overscroll-behavior:none;-webkit-text-size-adjust:100%;overflow-x:hidden;}
  body{overscroll-behavior:none;-webkit-tap-highlight-color:transparent;-webkit-touch-callout:none;overflow-x:hidden;}
  button,a,.sn,.kpi-c,.apt-card{-webkit-tap-highlight-color:transparent;touch-action:manipulation;}

  /* Layout — الأساس */
  html,body{max-width:100vw;overflow-x:hidden;}
  .main{margin-right:0;max-width:100vw;overflow-x:hidden;}
  .content{padding:10px 12px;max-width:100%;overflow-x:hidden;}
  .tab-section{max-width:100%;overflow-x:hidden;}
  .topbar-bld{padding:8px 14px;}
  .topbar{padding:9px 14px;padding-top:calc(9px + env(safe-area-inset-top));}
  .tb-bld-sub,.tb-clock,.tb-info,.topbar-occ-badge{display:none!important;}
  .tb-title{font-size:13px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:50vw;}
  #sb-overlay{display:block;}
  #hamburger{display:flex;}

  /* Sidebar — مخفي افتراضياً */
  .sb{
    right:0;transform:translateX(100%);width:210px!important;
    transition:transform .28s var(--ease);box-shadow:none;
    padding-top:calc(16px + env(safe-area-inset-top));
    padding-bottom:calc(10px + env(safe-area-inset-bottom));
  }
  .sb.open{transform:translateX(0);box-shadow:-8px 0 40px rgba(0,0,0,.35);}
  .sb-nav{padding:4px 8px;gap:1px;}
  .sn{gap:10px;padding:10px 12px;}
  .sn-lbl{font-size:12px;max-width:150px!important;opacity:1!important;}
  .sb-logout{gap:10px;padding:10px 12px;}
  .sb-logout-lbl{font-size:12px;max-width:120px!important;opacity:1!important;}

  /* KPI — 3 أعمدة */
  .kpi-row{grid-template-columns:repeat(3,1fr)!important;gap:8px!important;margin-bottom:12px;}
  .kpi-c{padding:12px 8px;}
  .kpi-ico{width:32px;height:32px;margin-bottom:8px;border-radius:8px;}
  .kpi-num{font-size:20px;}
  .kpi-lbl{font-size:9px;margin-top:4px;}

  /* Charts — تمرير أفقي */
  .charts-row{display:flex!important;gap:10px;overflow-x:auto;-webkit-overflow-scrolling:touch;padding-bottom:6px;scroll-snap-type:x mandatory;margin-bottom:12px;grid-template-columns:unset!important;}
  .charts-row .chart-card{flex:0 0 82vw;scroll-snap-align:start;min-width:0;}
  .charts-row .chart-card:first-child{flex:0 0 88vw;}

  /* Apt grid — 4 بالصف */
  .apt{width:calc(25% - 7px);min-width:0;border-radius:8px;padding:8px 4px 7px;}
  .apt-n{font-size:14px;}
  .apt-s,.apt-g,.apt-type{font-size:9px;}
  .apt-bld-inner{padding:10px 12px;}

  /* Tables */
  .tbl-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch;}

  /* Calendar */
  .cal-panel{display:none;}
  .cal-layout{display:block;}
  .cal-table-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch;}

  /* Modals — bottom sheet */
  .overlay{align-items:flex-end;padding:0;}
  .modal{width:100%;max-width:100%;border-radius:20px 20px 0 0;max-height:90vh;overflow-y:auto;}
  .mbody{padding:14px 16px;}
  .mhd{padding:12px 16px;}

  /* Toast */
  #toast{bottom:calc(14px + env(safe-area-inset-bottom));font-size:12px;padding:10px 16px;}
}
</style>
