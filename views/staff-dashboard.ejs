            </div>
          </div>
          ${isManager?`<button onclick="delPayment('${p._id}')" style="border:none;background:#fee2e2;color:#dc2626;border-radius:7px;padding:4px 9px;cursor:pointer;font-size:12px;font-weight:700;flex-shrink:0;">×</button>`:''}
        </div>`;
      });
    } else {
      html+=`<div style="color:var(--t4);font-size:12px;padding:8px 0;">لا توجد دفعات مسجّلة بعد</div>`;
    }
    html+=`<button onclick="togglePayForm()" style="margin-top:6px;padding:7px 16px;background:linear-gradient(135deg,#047857,#059669);border:none;border-radius:9px;color:#fff;font-family:inherit;font-size:12px;font-weight:700;cursor:pointer;">+ تسجيل دفعة جديدة</button>
    <div id="payForm" style="display:none;margin-top:10px;background:#f0fdf4;border:1.5px solid #bbf7d0;border-radius:12px;padding:14px;">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px;">
        <div>
          <label style="font-size:11px;font-weight:600;color:var(--t3);display:block;margin-bottom:3px;">التاريخ والوقت</label>
          <input type="datetime-local" id="pay-date" style="width:100%;padding:7px;border:1.5px solid #e2e8f0;border-radius:8px;font-family:inherit;font-size:12px;outline:none;">
        </div>
        <div>
          <label style="font-size:11px;font-weight:600;color:var(--t3);display:block;margin-bottom:3px;">المبلغ (ريال) *</label>
          <input type="number" id="pay-amount" placeholder="0" min="1" style="width:100%;padding:7px;border:1.5px solid #e2e8f0;border-radius:8px;font-family:inherit;font-size:12px;outline:none;">
        </div>
        <div>
          <label style="font-size:11px;font-weight:600;color:var(--t3);display:block;margin-bottom:3px;">طريقة الدفع</label>
          <select id="pay-method" style="width:100%;padding:7px;border:1.5px solid #e2e8f0;border-radius:8px;font-family:inherit;font-size:12px;outline:none;">
            <option value="cash">نقداً</option>
            <option value="transfer">تحويل بنكي</option>
            <option value="network">شبكة</option>
            <option value="check">كمبيالة</option>
            <option value="digital">دفع رقمي</option>
            <option value="travel_agent">وكيل سفر</option>
            <option value="other">أخرى</option>
          </select>
        </div>
        <div>
          <label style="font-size:11px;font-weight:600;color:var(--t3);display:block;margin-bottom:3px;">ملاحظات</label>
          <input type="text" id="pay-notes" placeholder="اختياري" style="width:100%;padding:7px;border:1.5px solid #e2e8f0;border-radius:8px;font-family:inherit;font-size:12px;outline:none;">
        </div>
      </div>
      <label style="display:flex;align-items:center;gap:7px;font-size:12px;color:var(--t2);cursor:pointer;margin-bottom:10px;">
        <input type="checkbox" id="pay-deposit" style="cursor:pointer;accent-color:#f59e0b;"> هذه الدفعة تأمين (ضمان)
      </label>
      <div style="display:flex;gap:8px;">
        <button onclick="submitPayment()" style="flex:1;padding:8px;background:linear-gradient(135deg,#047857,#059669);border:none;border-radius:9px;color:#fff;font-family:inherit;font-size:12px;font-weight:800;cursor:pointer;">✅ حفظ الدفعة وإنشاء السند</button>
        <button onclick="togglePayForm()" style="padding:8px 14px;background:#f8fafc;border:1.5px solid #e2e8f0;border-radius:9px;font-family:inherit;font-size:12px;cursor:pointer;">إلغاء</button>
      </div>
    </div>`;

    if(b.companions&&b.companions.length){
      html += sec('👥 المرافقون');
      const idL={national_id:'هوية',passport:'جواز',iqama:'إقامة',family_card:'كرت عائلة'};
      b.companions.forEach((c,i)=>{
        html+=`<div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:9px;padding:8px 12px;margin-bottom:6px;font-size:12px;">
          <b style="color:#0f172a;">${i+1}. ${esc(c.name)}</b>
          ${c.idType||c.idNumber?`<span style="color:#64748b;margin-right:8px;">${idL[c.idType]||c.idType||''} ${c.idNumber?'— '+esc(c.idNumber):''}</span>`:''}
        </div>`;
      });
    }

    if (b.notes) html += `<div style="margin:12px 0 4px;padding:10px 12px;background:#f8fafc;border-radius:10px;font-size:12px;color:#475569;line-height:1.6;"><b>ملاحظات:</b> ${esc(b.notes)}</div>`;

    html += `<div style="display:flex;gap:8px;margin-top:16px;flex-wrap:wrap;">`;
    if (['pending','awaiting_payment','awaiting_checkin'].includes(b.status))
      html += `<button class="mbtn mbtn-in" onclick="changeStatus('${bookingId}','active')">✅ تسجيل الدخول</button>`;
    if (b.status === 'active')
      html += `<button class="mbtn mbtn-out" onclick="changeStatus('${bookingId}','checkout')">🚪 تسجيل الخروج</button>`;
    if (!['cancelled','checkout'].includes(b.status) && can('edit_booking'))
      html += `<button class="mbtn" style="background:#eff6ff;color:#2563eb;" onclick="closeBkModal();editBk('${bookingId}')">✏️ تعديل</button>`;
    if (can('cancel_booking') && !['cancelled','checkout'].includes(b.status))
      html += `<button class="mbtn" style="background:#fef2f2;color:#dc2626;" onclick="cancelBk('${bookingId}')">🗑️ إلغاء</button>`;
    html += `<button class="mbtn" style="background:#f0fdf4;color:#16a34a;" onclick="closeBkModal();printBkInvoice('${bookingId}')">🖨️ فاتورة</button>`;
    html += `<button class="mbtn" style="background:#fef9c3;color:#92400e;" onclick="closeBkModal();printContract('${bookingId}')">📄 عقد</button>`;
    html += `<button class="mbtn mbtn-cancel" onclick="closeBkModal()">إغلاق</button></div>`;

    document.getElementById('bkModalBody').innerHTML = html;
    // تعيين التاريخ الحالي لحقل الدفعة
    const now=new Date(), pd=document.getElementById('pay-date');
    if(pd){ const pad=n=>String(n).padStart(2,'0'); pd.value=`${now.getFullYear()}-${pad(now.getMonth()+1)}-${pad(now.getDate())}T${pad(now.getHours())}:${pad(now.getMinutes())}`; }
  } catch(e) {
    document.getElementById('bkModalBody').innerHTML = '<div style="color:#dc2626;padding:20px;">❌ حدث خطأ في تحميل البيانات</div>';
  }
}
function closeBkModal(){ document.getElementById('bkModal').style.display='none'; }

function togglePayForm(){
  const f=document.getElementById('payForm');
  if(f) f.style.display=f.style.display==='none'?'block':'none';
}

async function submitPayment(){
  const amount=parseFloat(document.getElementById('pay-amount')?.value)||0;
  const paymentMethod=document.getElementById('pay-method')?.value||'cash';
  const isDeposit=document.getElementById('pay-deposit')?.checked||false;
  const date=document.getElementById('pay-date')?.value||'';
  const notes=document.getElementById('pay-notes')?.value||'';
  if(!amount||amount<=0){showToast('أدخل مبلغاً صحيحاً');return;}
  try{
    const r=await fetch(`/staff/api/bookings/${_curBkId}/payments`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({amount,paymentMethod,isDeposit,date,notes})});
    const d=await r.json();
    if(!r.ok){showToast('❌ '+(d.error||'خطأ'),'error');return;}
    toast(`✅ تم تسجيل الدفعة — سند رقم ${d.voucherNumber}`,'success');
    openBkModal(_curBkId,_curBkApt,'active');
    loadBookings(); loadStats();
  }catch(e){showToast('❌ حدث خطأ','error');}
}

async function delPayment(paymentId){
  if(!confirm('حذف هذه الدفعة وسندها؟')) return;
  try{
    const r=await fetch(`/staff/api/bookings/${_curBkId}/payments/${paymentId}`,{method:'DELETE'});
    const d=await r.json();
    if(!d.success){showToast('❌ '+(d.error||'خطأ'),'error');return;}
    toast('🗑️ تم حذف الدفعة والسند','success');
    openBkModal(_curBkId,_curBkApt,'active');
    loadBookings(); loadStats();
  }catch(e){showToast('❌ حدث خطأ','error');}
}

