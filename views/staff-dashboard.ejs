    const idL = { national_id:'هوية وطنية', passport:'جواز سفر', residence:'إقامة', gcc:'هوية خليجي', other:'أخرى' };
    const ST  = { pending:'معلّق', awaiting_payment:'بانتظار الدفع', awaiting_checkin:'بانتظار الدخول', active:'مقيم', checkout:'خرج', cancelled:'ملغي' };
