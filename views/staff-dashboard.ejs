// ── Booking Modal ────────────────────────────────────────
function openBkModal(bookingId,apt,status){
  if(!bookingId||status==='vacant'){
    toast('🟢 الشقة '+apt+' — شاغرة');return;
  }
  const room=aptsRawData?.floors.flatMap(f=>f.rooms).find(r=>r.apt===apt);
  if(!room) return;
  document.getElementById('bkModalTitle').textContent='شقة '+apt+' — '+esc(BUILDING);
  const s=APT_MAP[status]||{lbl:status};
  let html=`
    <div class="mrow"><span>الحالة</span><b>${s.lbl}</b></div>
    ${room.name?`<div class="mrow"><span>النزيل</span><b>${esc(room.name)}</b></div>`:''}
    ${room.phone?`<div class="mrow"><span>الجوال</span><b><a href="https://wa.me/${room.phone.replace(/^0/,'966')}" style="color:#1a3d8f;">${esc(room.phone)}</a></b></div>`:''}
    ${room.checkIn?`<div class="mrow"><span>تاريخ الدخول</span><b>${fDate(room.checkIn)}</b></div>`:''}
    ${room.checkOut?`<div class="mrow"><span>تاريخ الخروج</span><b>${fDate(room.checkOut)}</b></div>`:''}
    ${room.nights?`<div class="mrow"><span>عدد الليالي</span><b>${room.nights}</b></div>`:''}
    ${room.totalPrice?`<div class="mrow"><span>الإجمالي</span><b>${room.totalPrice.toLocaleString()} ريال</b></div>`:''}
    ${room.totalPrice?`<div class="mrow"><span>المدفوع</span><b style="color:#16a34a;">${(room.paidAmount||0).toLocaleString()} ريال</b></div>`:''}
    ${room.totalPrice?`<div class="mrow"><span>المتبقي</span><b style="color:${(room.totalPrice-(room.paidAmount||0))>0?'#dc2626':'#16a34a'};">${Math.max(0,room.totalPrice-(room.paidAmount||0)).toLocaleString()} ريال</b></div>`:''}
    ${room.idType?`<div class="mrow"><span>نوع الإثبات</span><b>${{national_id:'هوية وطنية',passport:'جواز سفر',iqama:'إقامة',family_card:'كرت عائلة'}[room.idType]||room.idType}</b></div>`:''}
    ${room.idNumber?`<div class="mrow"><span>رقم الإثبات</span><b>${esc(room.idNumber)}</b></div>`:''}
    <div style="display:flex;gap:8px;margin-top:4px;flex-wrap:wrap;">`;
  if(['awaiting','checkin_today','awaiting_checkin'].includes(status))
    html+=`<button class="mbtn mbtn-in" onclick="changeStatus('${bookingId}','active')">✅ تسجيل الدخول</button>`;
  if(['occupied','checkout_today'].includes(status))
    html+=`<button class="mbtn mbtn-out" onclick="changeStatus('${bookingId}','checkout')">🚪 تسجيل الخروج</button>`;
  if(!['cancelled','checkout'].includes(status)&&can('edit_booking'))
    html+=`<button class="mbtn" style="background:#eff6ff;color:#2563eb;" onclick="closeBkModal();editBk('${bookingId}')">✏️ تعديل</button>`;
  if(can('cancel_booking'))
    html+=`<button class="mbtn" style="background:#fef2f2;color:#dc2626;" onclick="cancelBk('${bookingId}')">🗑️ إلغاء</button>`;
  html+=`<button class="mbtn mbtn-cancel" onclick="closeBkModal()">إغلاق</button></div>`;
  document.getElementById('bkModalBody').innerHTML=html;
  document.getElementById('bkModal').style.display='flex';
}
function closeBkModal(){ document.getElementById('bkModal').style.display='none'; }

let editBkId=null;
async function editBk(id){
  try{
    const r=await fetch('/staff/api/bookings/'+id);
    if(!r.ok){ toast('❌ تعذر تحميل الحجز'); return; }
    const b=await r.json();
    editBkId=id;
    // populate form
    await openNewBkModal(true);
    document.querySelector('#newBkModal .mhd-title').textContent='✏️ تعديل الحجز';
    document.getElementById('nb-apt').innerHTML=`<option value="${esc(b.apt)}">${esc(b.apt)}</option>`;
    document.getElementById('nb-apt').value=b.apt;
    document.getElementById('nb-apt').disabled=true;
    document.getElementById('nb-name').value=b.name||'';
    document.getElementById('nb-phone').value=b.phone||'';
    document.getElementById('nb-type').value=b.bookingType||'daily';
    toggleNbType();
    if(b.checkIn) document.getElementById('nb-checkin').value=new Date(b.checkIn).toISOString().split('T')[0];
    if(b.checkOut) document.getElementById('nb-checkout').value=new Date(b.checkOut).toISOString().split('T')[0];
    document.getElementById('nb-price').value=b.pricePerNight||b.pricePerMonth||0;
    document.getElementById('nb-total').value=b.totalPrice||0;
    document.getElementById('nb-paid').value=b.paidAmount||0;
    document.getElementById('nb-remain').value=Math.max(0,(b.totalPrice||0)-(b.paidAmount||0))||'';
    document.getElementById('nb-idtype').value=b.idType||'';
    document.getElementById('nb-idnum').value=b.idNumber||'';
    document.getElementById('nb-status').value=b.status||'awaiting_checkin';
    document.getElementById('nb-notes').value=b.notes||'';
  }catch(e){ toast('❌ حدث خطأ'); }
}

async function cancelBk(id){
  if(!confirm('هل أنت متأكد من إلغاء هذا الحجز؟')) return;
  try{
    const r=await fetch('/staff/api/bookings/'+id+'/status',{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({status:'cancelled'})});
    const d=await r.json();
    if(d.success){ toast('🗑️ تم إلغاء الحجز'); closeBkModal(); loadApartments(); loadStats(); loadBookings(); }
    else toast('❌ '+d.error);
  }catch(e){ toast('❌ حدث خطأ'); }
}

async function changeStatus(id,status){
  try{
    const r=await fetch('/staff/api/bookings/'+id+'/status',{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({status})});
    const d=await r.json();
    if(d.success){ toast(status==='active'?'✅ تم تسجيل الدخول':'🚪 تم تسجيل الخروج'); closeBkModal(); loadApartments(); loadStats(); }
    else toast('❌ '+d.error);
  }catch(e){ toast('❌ حدث خطأ'); }
}

