function initFP(){
  ['bkDateFrom','bkDateTo','custDateFrom','custDateTo','nb-checkin','nb-checkout'].forEach(id=>{
    const el=document.getElementById(id);
    if(!el||el._flatpickr)return;
    flatpickr(el,{locale:'ar',dateFormat:'Y-m-d',disableMobile:true,
      onChange(){el.dispatchEvent(new Event('change'));}
    });
  });
}

// ── Offline Draft System ─────────────────────────────────
const _DRAFT_KEY   = 'barez_bk_draft';
const _PENDING_KEY = 'barez_bk_pending';
const _DRAFT_IDS   = ['nb-apt','nb-name','nb-phone','nb-type','nb-checkin','nb-checkout','nb-months','nb-price','nb-paid','nb-idtype','nb-idnum','nb-status','nb-notes'];

let _draftTimer;
function _saveDraft(){
  if(typeof editBkId!=='undefined'&&editBkId) return;
  const data={};
  _DRAFT_IDS.forEach(id=>{const el=document.getElementById(id);if(el)data[id]=el.value;});
  if(!data['nb-name']&&!data['nb-phone']) return;
  data._at=Date.now();
  try{localStorage.setItem(_DRAFT_KEY,JSON.stringify(data));}catch(e){}
}

function _loadDraft(){
  try{
    const raw=localStorage.getItem(_DRAFT_KEY);
    if(!raw) return;
    const data=JSON.parse(raw);
    if(!data._at||Date.now()-data._at>8*60*60*1000){_clearDraft();return;}
    let ok=false;
    _DRAFT_IDS.forEach(id=>{
      if(data[id]){const el=document.getElementById(id);if(el){el.value=data[id];ok=true;}}
    });
    if(ok){calcNbTotal();calcNbRemain();toast('📋 تم استعادة مسودة محفوظة — تحقق قبل الحفظ');}
  }catch(e){}
}

function _clearDraft(){try{localStorage.removeItem(_DRAFT_KEY);}catch(e){}}
function _clearPending(){try{localStorage.removeItem(_PENDING_KEY);}catch(e){}}

function _savePending(body){
  try{localStorage.setItem(_PENDING_KEY,JSON.stringify({body,_at:Date.now()}));}catch(e){}
}

async function _flushPending(){
  try{
    const raw=localStorage.getItem(_PENDING_KEY);
    if(!raw) return;
    const{body,_at}=JSON.parse(raw);
    if(Date.now()-_at>24*60*60*1000){_clearPending();return;}
    const r=await fetch('/staff/api/bookings/new',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
    if(r.ok){
      _clearPending();_clearDraft();
      toast('✅ تم إرسال الحجز المعلّق بعد استعادة الاتصال','success');
      loadApartments();loadStats();loadBookings();
    }
  }catch(e){}
}

window.addEventListener('online',()=>{toast('📶 الاتصال عاد');_flushPending();});
window.addEventListener('offline',()=>{toast('📡 انقطع الاتصال — مدخلاتك محفوظة محلياً');});

// ── Init ─────────────────────────────────────────────────
let _ivClock,_ivStats,_ivApts;
function _stopIntervals(){ clearInterval(_ivClock); clearInterval(_ivStats); clearInterval(_ivApts); }
function _startIntervals(){ _stopIntervals(); _ivClock=setInterval(updateClock,1000); _ivStats=setInterval(loadStats,30000); _ivApts=setInterval(loadApartments,15000); }
// إعادة ضبط العداد بعد أي تعديل — تجنب الانتظار 15 ثانية للـ refresh
function _pollKick(){ clearInterval(_ivApts);clearInterval(_ivStats); _ivApts=setInterval(loadApartments,15000); _ivStats=setInterval(loadStats,30000); }

window.addEventListener('load',()=>{
  loadStats();
  loadApartments();
  loadPropSettings();
  updateClock();
  setTimeout(initFP,300);
  _startIntervals();
  // إلغاء تسجيل أي Service Worker قديم لمنع تقديم نسخ قديمة من الصفحة
  if('serviceWorker' in navigator)
    navigator.serviceWorker.getRegistrations().then(regs => regs.forEach(r => r.unregister()));
  // Auto-save draft on any modal input/change
  const _modal=document.getElementById('newBkModal');
  if(_modal){
    const _onDraftInput=()=>{clearTimeout(_draftTimer);_draftTimer=setTimeout(_saveDraft,300);};
    _modal.addEventListener('input',_onDraftInput);
    _modal.addEventListener('change',_onDraftInput);
  }
});

document.addEventListener('visibilitychange',()=>{
  if(document.hidden){ _stopIntervals(); }
  else{ loadStats(); loadApartments(); _startIntervals(); }
});
window.addEventListener('pagehide',_stopIntervals);
