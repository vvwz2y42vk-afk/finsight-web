  const errEl=document.getElementById('riErr');
  try{
    const r=await fetch('/staff/api/room-info/'+riCurrentApt,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({roomType,beds})});
    const d=await r.json();
    if(!r.ok){errEl.textContent=d.error||'حدث خطأ';errEl.style.display='block';return;}
    roomInfoMap[riCurrentApt]={roomType,beds};
    closeRoomInfoModal();
    renderAptGrid();
    toast('تم حفظ بيانات الشقة '+riCurrentApt);
  }catch(e){errEl.textContent='حدث خطأ';errEl.style.display='block';}
}


// ── Guests ───────────────────────────────────────────────
let allGuests = [];
async function loadGuests() {
  try {
    const r = await fetch('/staff/api/guests');
    if (!r.ok) return;
    allGuests = await r.json();
    renderGuests(allGuests);
  } catch(e) {}
}

function renderGuests(list) {
  const tb = document.getElementById('guests-tbody');
  const lbl = document.getElementById('guests-count');
  if (lbl) lbl.textContent = list.length + ' ضيف مسجّل';
  if (!list.length) {
    tb.innerHTML = '<tr><td colspan="8" style="text-align:center;padding:30px;color:var(--t4);">لا يوجد ضيوف مسجّلون بعد — سيُضافون تلقائياً عند إنشاء الحجوزات</td></tr>';
    return;
  }
  const idLabels = { national_id: 'هوية وطنية', passport: 'جواز سفر', residence: 'إقامة', other: 'أخرى' };
  const catColors = { vip: { bg:'#FEF3C7', color:'#D97706' }, blocked: { bg:'#FEE2E2', color:'#DC2626' }, regular: { bg:'#F0F4FF', color:'#1a3d8f' } };
  tb.innerHTML = list.map(g => {
    const last = g.lastSeen ? new Date(g.lastSeen).toLocaleDateString('ar-SA', { year:'numeric', month:'short', day:'numeric' }) : '—';
    const cat = g.category || 'regular';
    const cc = catColors[cat] || catColors.regular;
    return `<tr>
      <td><div style="font-weight:600;color:#1a3d8f;cursor:pointer;text-decoration:underline dotted;" onclick="openCustomerProfile('${g._id}')">${esc(g.name)}</div></td>
      <td style="font-family:monospace;">${esc(g.phone)}</td>
      <td style="font-size:12px;color:var(--t3);">${idLabels[g.idType] || g.idType || '—'}</td>
      <td style="font-family:monospace;font-size:12px;">${esc(g.idNumber) || '—'}</td>
      <td style="font-size:12px;color:var(--t3);">${esc(g.building) || '—'}</td>
      <td style="text-align:center;"><span class="badge b-active">${g.totalBookings}</span></td>
      <td style="text-align:center;">
        <select onchange="setGuestCategory('${g._id}',this.value)" style="padding:3px 8px;border:1px solid ${cc.bg};border-radius:6px;font-size:11px;font-family:inherit;cursor:pointer;background:${cc.bg};color:${cc.color};font-weight:700;">
          <option value="regular" ${cat==='regular'?'selected':''}>عادي</option>
          <option value="vip" ${cat==='vip'?'selected':''}>⭐ VIP</option>
          <option value="blocked" ${cat==='blocked'?'selected':''}>🚫 محظور</option>
        </select>
      </td>
      <td style="font-size:12px;color:var(--t4);">${last}</td>
    </tr>`;
  }).join('');
}

let guestSearchTimer;
function searchGuests(q) {
  clearTimeout(guestSearchTimer);
  guestSearchTimer = setTimeout(() => {
    if (!q.trim()) return renderGuests(allGuests);
    const re = new RegExp(q.trim().replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'i');
    renderGuests(allGuests.filter(g => re.test(g.name) || re.test(g.phone) || re.test(g.idNumber || '')));
  }, 250);
}

// ── Phone auto-fill in new booking ───────────────────────
let phoneTimer;
async function onPhoneInput(val) {
  clearTimeout(phoneTimer);
  const badge = document.getElementById('nb-guest-badge');
  if (badge) badge.style.display = 'none';
  if (val.length < 10) return;
  phoneTimer = setTimeout(async () => {
    try {
      const r = await fetch('/staff/api/guests/search?phone=' + val);
      if (!r.ok) return;
      const g = await r.json();
      if (!g) return;
      // Auto-fill
      const nameEl = document.getElementById('nb-name');
      const idTypeEl = document.getElementById('nb-idtype');
      const idNumEl = document.getElementById('nb-idnumber');
      if (nameEl && !nameEl.value) nameEl.value = g.name;
      if (idTypeEl && g.idType) idTypeEl.value = g.idType;
      if (idNumEl && !idNumEl.value) idNumEl.value = g.idNumber || '';
      if (badge) badge.style.display = 'inline-block';
      toast('تم تعبئة بيانات الضيف تلقائياً ✓');
    } catch(e) {}
  }, 400);
}

// ── Settings (Building Config) ────────────────────────────
let propBuildings = [];
let isInternalProp = false;

async function loadSettings() {
  try {
    const r = await fetch('/staff/api/property');
    if (!r.ok) return;
    const prop = await r.json();
    isInternalProp = !!prop.isInternal;
    propBuildings = (prop.buildings || []).map(b => ({
      name: b.name,
      floors: (b.floors || []).map(f => ({ label: f.label || f.l || '', rooms: (f.rooms || f.r || []).join(', ') }))
    }));
    document.getElementById('settings-internal-note').style.display = isInternalProp ? 'block' : 'none';
    document.getElementById('add-bld-btn').style.display = isInternalProp ? 'none' : 'flex';
    renderSettings();
    renderPlanCard(prop);
    loadPropSettings();
    loadRoomPrices();
  } catch(e) {}
}

function renderPlanCard(prop) {
  const planNames = { trial:'تجريبية مجانية', basic:'أساسية', pro:'احترافية' };
  const typeNames  = { apartment:'شقق فندقية', hotel:'فندق', mixed:'مختلط' };
  const pn = document.getElementById('plan-name');
  const pe = document.getElementById('plan-expiry');
  const pp = document.getElementById('plan-prop-name');
  const pt = document.getElementById('plan-prop-type');
  if (!pn) return;
  pn.textContent = planNames[prop.plan] || prop.plan || '—';
  if (prop.planExpiry) {
    const exp = new Date(prop.planExpiry);
    const days = Math.ceil((exp - Date.now()) / 86400000);
    pe.textContent = days > 0 ? `تنتهي خلال ${days} يوم (${exp.toLocaleDateString('ar-SA')})` : '⚠️ انتهت الخطة';
    if (days <= 7) pe.style.color = '#FCA5A5';
  }
  if (pp) pp.textContent = prop.name || '—';
  if (pt) pt.textContent = typeNames[prop.type] || '';
}

async function runMigration() {
  if (!confirm('هذا سيربط جميع البيانات القديمة بمنشأتك. هل أنت متأكد؟')) return;
  try {
    const r = await fetch('/staff/api/admin/migrate-tenant', { method:'POST', headers:{'Content-Type':'application/json'} });
    const d = await r.json();
    if (d.success) {
      toast(`✅ تم الربط: ${d.updated.bookings} حجز، ${d.updated.vouchers} سند، ${d.updated.housekeeping} خدمة غرف`);
    } else { toast('❌ ' + (d.error||'حدث خطأ')); }
  } catch(e) { toast('❌ تعذر تنفيذ العملية'); }
}

function renderSettings() {
  const wrap = document.getElementById('buildings-wrap');
  if (!wrap) return;
  if (!propBuildings.length) {
    wrap.innerHTML = '<div style="text-align:center;padding:30px;color:var(--t4);font-size:13px;">لا توجد مباني — اضغط "+ إضافة مبنى" للبدء</div>';
    return;
  }
  wrap.innerHTML = propBuildings.map((b, bi) => `
    <div style="background:#fff;border:1px solid #E2E8F0;border-radius:14px;padding:20px;margin-bottom:14px;box-shadow:0 2px 8px rgba(15,23,42,.04);">
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;">
        <div style="width:8px;height:8px;border-radius:50%;background:#1a3d8f;flex-shrink:0;"></div>
        <input value="${esc(b.name)}" onchange="propBuildings[${bi}].name=this.value" placeholder="اسم المبنى" style="flex:1;font-size:14px;font-weight:700;border:none;outline:none;color:#0F172A;background:transparent;" ${isInternalProp ? 'disabled' : ''}>
        ${!isInternalProp ? `<button onclick="removeBuilding(${bi})" style="background:none;border:none;color:#B91C1C;cursor:pointer;font-size:18px;padding:0 4px;" title="حذف المبنى">×</button>` : ''}
      </div>
      ${b.floors.map((f, fi) => `
        <div style="background:#F8FAFC;border:1px solid #EEF2F8;border-radius:10px;padding:14px;margin-bottom:8px;">
          <div style="display:flex;gap:8px;align-items:center;margin-bottom:8px;">
            <input value="${esc(f.label)}" onchange="propBuildings[${bi}].floors[${fi}].label=this.value" placeholder="اسم الطابق (مثال: الأرضي، الأول)" style="flex:1;padding:7px 10px;border:1.5px solid #E2E8F0;border-radius:8px;font-family:'Cairo',sans-serif;font-size:13px;outline:none;" ${isInternalProp ? 'disabled' : ''}>
            ${!isInternalProp ? `<button onclick="removeFloor(${bi},${fi})" style="background:none;border:none;color:#B91C1C;cursor:pointer;font-size:16px;flex-shrink:0;">×</button>` : ''}
          </div>
          <div style="display:flex;gap:8px;align-items:center;">
            <div style="font-size:11px;color:#64748B;flex-shrink:0;">أرقام الشقق:</div>
            <input value="${esc(f.rooms)}" onchange="propBuildings[${bi}].floors[${fi}].rooms=this.value" placeholder="101, 102, 103, 104" style="flex:1;padding:6px 10px;border:1.5px solid #E2E8F0;border-radius:8px;font-family:monospace;font-size:12px;outline:none;" ${isInternalProp ? 'disabled' : ''}>
            ${!isInternalProp ? `<button onclick="autoGenRooms(${bi},${fi})" style="padding:5px 10px;background:#1a3d8f;border:none;border-radius:7px;color:#fff;font-family:'Cairo',sans-serif;font-size:11px;cursor:pointer;flex-shrink:0;">توليد</button>` : ''}
          </div>
        </div>
      `).join('')}
      ${!isInternalProp ? `<button onclick="addFloor(${bi})" style="display:flex;align-items:center;gap:6px;padding:7px 14px;border:1.5px dashed #C7D9FF;border-radius:8px;background:transparent;color:#1a3d8f;font-family:inherit;font-size:12px;font-weight:600;cursor:pointer;margin-top:4px;">+ إضافة طابق</button>` : ''}
    </div>
  `).join('');
}

function addBuilding() {
  propBuildings.push({ name: '', floors: [{ label: '', rooms: '' }] });
  renderSettings();
  // focus last building name input
  setTimeout(() => { const inputs = document.querySelectorAll('#buildings-wrap input[placeholder="اسم المبنى"]'); if (inputs.length) inputs[inputs.length-1].focus(); }, 50);
}

function removeBuilding(i) {
  if (!confirm('هل تريد حذف هذا المبنى وكل طوابقه؟')) return;
  propBuildings.splice(i, 1);
  renderSettings();
}

function addFloor(bi) {
  propBuildings[bi].floors.push({ label: '', rooms: '' });
  renderSettings();
}

function removeFloor(bi, fi) {
  propBuildings[bi].floors.splice(fi, 1);
  renderSettings();
}

function autoGenRooms(bi, fi) {
  const prefix = prompt('رمز الطابق (مثال: 1 للطابق الأول، اتركه فارغاً للأرضي):') || '';
  const countStr = prompt('كم عدد الشقق في هذا الطابق؟');
  const count = parseInt(countStr);
  if (!count || count < 1 || count > 50) return;
  const rooms = [];
  for (let i = 1; i <= count; i++) {
    rooms.push(prefix + String(i).padStart(2, '0'));
  }
  propBuildings[bi].floors[fi].rooms = rooms.join(', ');
  renderSettings();
}

async function saveSettings() {
  if (isInternalProp) return;
  const errEl = document.getElementById('settings-err');
  errEl.style.display = 'none';
  const buildings = propBuildings.map(b => ({
    name: b.name.trim(),
    floors: b.floors.map(f => ({
      label: f.label.trim(),
      rooms: f.rooms.split(',').map(r => r.trim()).filter(Boolean)
    }))
  }));
  for (const b of buildings) {
    if (!b.name) { errEl.textContent = 'كل مبنى يجب أن يكون له اسم'; errEl.style.display = 'block'; return; }
  }
  try {
    const r = await fetch('/staff/api/property/buildings', { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ buildings }) });
    const d = await r.json();
    if (!r.ok) { errEl.textContent = d.error || 'خطأ في الحفظ'; errEl.style.display = 'block'; return; }
    toast('تم حفظ إعدادات المباني بنجاح ✓');
  } catch(e) { errEl.textContent = 'خطأ في الاتصال'; errEl.style.display = 'block'; }
}

// ── Prop Settings ────────────────────────────────────────
let propSettings = { vatRate: 15, contractTerms: '', expenseItems: [], peakPeriods: [] };
const DEFAULT_CONTRACT_TERMS = `يلتزم المستأجر بسداد قيمة الإيجار كاملةً عند توقيع العقد أو وفق الاتفاق المحدد.
لا يحق للمستأجر التنازل عن الوحدة أو تأجيرها من الباطن لأي طرف آخر دون موافقة خطية من المؤجر.
يُسلَّم المستأجر الوحدة بحالة جيدة ويلتزم بإعادتها بالحالة ذاتها عند انتهاء مدة الإيجار.
يتحمل المستأجر تكلفة إصلاح أي أضرار تلحق بالوحدة أو محتوياتها جراء الإهمال أو سوء الاستخدام.
يُمنع منعاً باتاً التدخين داخل الوحدة؛ وفي حال المخالفة تُطبَّق غرامة تنظيف.
يلتزم المستأجر بعدم إزعاج الجيران واحترام أنظمة المبنى وساعات الهدوء.
في حال الإخلاء المبكر قبل انتهاء المدة المتفق عليها، لا يُستردّ المبلغ المدفوع إلا باتفاق مسبق.
يحق للمؤجر فسخ العقد فوراً في حال ثبوت مخالفة أي بند من بنود هذا العقد.
جميع الخلافات الناشئة عن هذا العقد تخضع لأنظمة المملكة العربية السعودية المعمول بها.
يُعدّ توقيع هذا العقد إقراراً بالاطلاع على جميع بنوده والموافقة عليها.`;

async function loadPropSettings() {
  try {
    const r = await fetch('/staff/api/prop-settings');
    if (!r.ok) return;
    const data = await r.json();
    propSettings = data;
    renderPropSettings();
  } catch(e) {}
}

function renderPropSettings() {
  const vat = document.getElementById('ps-vat');
  if (vat) vat.value = propSettings.vatRate ?? 15;
  const terms = document.getElementById('ps-terms');
  if (terms) terms.value = propSettings.contractTerms || DEFAULT_CONTRACT_TERMS;
  renderExpenseItems();
  renderPeakPeriods();
}

function renderExpenseItems() {
  const list = document.getElementById('ps-expense-list');
  if (!list) return;
  if (!propSettings.expenseItems?.length) {
    list.innerHTML = '<div style="font-size:12px;color:var(--t4);padding:4px 0;">لا توجد بنود بعد — أضف أول بند أدناه</div>';
    return;
  }
  list.innerHTML = propSettings.expenseItems.map((item, i) => `
    <div style="display:flex;align-items:center;gap:8px;padding:7px 12px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;margin-bottom:6px;">
      <span style="flex:1;font-size:13px;">${esc(item)}</span>
      <button onclick="removeExpenseItem(${i})" style="background:none;border:none;color:#dc2626;cursor:pointer;font-size:16px;line-height:1;flex-shrink:0;" title="حذف">×</button>
    </div>`).join('');
}

function addExpenseItem() {
  const inp = document.getElementById('ps-expense-new');
  const val = (inp?.value || '').trim();
  if (!val) return;
  if (!propSettings.expenseItems) propSettings.expenseItems = [];
  propSettings.expenseItems.push(val);
  inp.value = '';
  renderExpenseItems();
}

function removeExpenseItem(i) {
  propSettings.expenseItems.splice(i, 1);
  renderExpenseItems();
}

function renderPeakPeriods() {
  const list = document.getElementById('ps-peak-list');
  if (!list) return;
  if (!propSettings.peakPeriods?.length) {
    list.innerHTML = '<div style="font-size:12px;color:var(--t4);padding:4px 0;">لا توجد فترات ذروة</div>';
    return;
  }
  const mults = [1.25,1.5,1.75,2,2.5,3];
  list.innerHTML = propSettings.peakPeriods.map((p, i) => `
    <div style="display:flex;align-items:center;gap:8px;padding:10px 12px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;margin-bottom:8px;flex-wrap:wrap;">
      <input value="${esc(p.name||'')}" onchange="propSettings.peakPeriods[${i}].name=this.value" placeholder="اسم الفترة" style="width:110px;padding:6px 8px;border:1.5px solid #e2e8f0;border-radius:8px;font-family:inherit;font-size:12px;outline:none;">
      <input type="date" value="${p.startDate?new Date(p.startDate).toISOString().split('T')[0]:''}" onchange="propSettings.peakPeriods[${i}].startDate=this.value" style="padding:6px 8px;border:1.5px solid #e2e8f0;border-radius:8px;font-size:12px;outline:none;">
      <span style="font-size:11px;color:var(--t4);">←</span>
      <input type="date" value="${p.endDate?new Date(p.endDate).toISOString().split('T')[0]:''}" onchange="propSettings.peakPeriods[${i}].endDate=this.value" style="padding:6px 8px;border:1.5px solid #e2e8f0;border-radius:8px;font-size:12px;outline:none;">
      <select onchange="propSettings.peakPeriods[${i}].multiplier=parseFloat(this.value)" style="padding:6px 8px;border:1.5px solid #e2e8f0;border-radius:8px;font-family:inherit;font-size:12px;outline:none;">
        ${mults.map(m=>`<option value="${m}" ${Math.abs(parseFloat(p.multiplier||1.5)-m)<0.01?'selected':''}>×${m}</option>`).join('')}
      </select>
      <button onclick="removePeakPeriod(${i})" style="background:none;border:none;color:#dc2626;cursor:pointer;font-size:18px;line-height:1;margin-right:auto;" title="حذف">×</button>
    </div>`).join('');
}

function addPeakPeriod() {
  if (!propSettings.peakPeriods) propSettings.peakPeriods = [];
  propSettings.peakPeriods.push({ name: '', startDate: '', endDate: '', multiplier: 1.5 });
  renderPeakPeriods();
}

function removePeakPeriod(i) {
  propSettings.peakPeriods.splice(i, 1);
  renderPeakPeriods();
}

async function savePropSettings() {
  try {
    const vatVal = parseFloat(document.getElementById('ps-vat')?.value) || 15;
    const termsVal = document.getElementById('ps-terms')?.value?.trim() || '';
    const body = { vatRate: vatVal, contractTerms: termsVal, expenseItems: propSettings.expenseItems || [], peakPeriods: propSettings.peakPeriods || [] };
    const r = await fetch('/staff/api/prop-settings', { method:'PUT', headers:{'Content-Type':'application/json'}, body:JSON.stringify(body) });
    const d = await r.json();
    if (!r.ok) { toast('❌ ' + (d.error||'حدث خطأ')); return; }
    propSettings.vatRate = vatVal;
    propSettings.contractTerms = termsVal;
    toast('✅ تم حفظ إعدادات المنشأة');
  } catch(e) { toast('❌ حدث خطأ'); }
}

// ── Room Prices ──────────────────────────────────────────
let roomPriceEdits = {};

async function loadRoomPrices() {
  try {
    const r = await fetch('/staff/api/room-info');
    if (!r.ok) return;
    roomInfoMap = await r.json();
    renderRoomPrices();
  } catch(e) {}
}

function renderRoomPrices() {
  const wrap = document.getElementById('room-prices-wrap');
  if (!wrap) return;
  const apts = Object.keys(roomInfoMap);
  if (!apts.length) {
    wrap.innerHTML = '<div style="padding:20px;color:var(--t4);font-size:13px;text-align:center;">لا توجد بيانات وحدات بعد — تُنشأ تلقائياً عند أول حجز أو عند تحديث معلومات الوحدة</div>';
    return;
  }
  const sorted = apts.slice().sort((a,b)=>a.localeCompare(b,'ar'));
  wrap.innerHTML = `<table style="width:100%;border-collapse:collapse;font-size:13px;">
    <thead><tr style="background:#f8fafc;border-bottom:2px solid var(--border);">
      <th style="padding:10px 14px;text-align:right;font-size:11px;color:var(--t3);font-weight:700;">الوحدة</th>
      <th style="padding:10px 14px;text-align:right;font-size:11px;color:var(--t3);font-weight:700;">النوع</th>
      <th style="padding:10px 14px;text-align:right;font-size:11px;color:var(--t3);font-weight:700;">سعر الليلة (ريال)</th>
      <th style="padding:10px 14px;text-align:right;font-size:11px;color:var(--t3);font-weight:700;">سعر الشهر (ريال)</th>
    </tr></thead>
    <tbody>${sorted.map(apt=>{
      const info=roomInfoMap[apt]||{};
      return `<tr style="border-bottom:1px solid var(--border);">
        <td style="padding:8px 14px;font-weight:700;">${esc(apt)}</td>
        <td style="padding:8px 14px;color:var(--t3);font-size:12px;">${esc(info.roomType||'—')}</td>
        <td style="padding:8px 14px;"><input type="number" min="0" step="1" data-apt="${esc(apt)}" data-field="pricePerNight" value="${info.pricePerNight||''}" placeholder="0" oninput="markRoomEdit(this)" style="width:110px;padding:5px 8px;border:1.5px solid #e2e8f0;border-radius:8px;font-size:13px;outline:none;" onfocus="this.style.borderColor='#1a3d8f'" onblur="this.style.borderColor='#e2e8f0'"></td>
        <td style="padding:8px 14px;"><input type="number" min="0" step="1" data-apt="${esc(apt)}" data-field="pricePerMonth" value="${info.pricePerMonth||''}" placeholder="0" oninput="markRoomEdit(this)" style="width:110px;padding:5px 8px;border:1.5px solid #e2e8f0;border-radius:8px;font-size:13px;outline:none;" onfocus="this.style.borderColor='#1a3d8f'" onblur="this.style.borderColor='#e2e8f0'"></td>
      </tr>`;
    }).join('')}</tbody>
  </table>`;
}

function markRoomEdit(inp) {
  const apt = inp.dataset.apt;
  const field = inp.dataset.field;
  if (!roomPriceEdits[apt]) roomPriceEdits[apt] = {};
  roomPriceEdits[apt][field] = parseFloat(inp.value) || 0;
}

async function saveRoomPrices() {
  const apts = Object.keys(roomPriceEdits);
  if (!apts.length) { toast('لا توجد تغييرات للحفظ'); return; }
  const prices = apts.map(apt => ({
    apt,
    building: roomInfoMap[apt]?.building || BUILDING,
    pricePerNight: roomPriceEdits[apt].pricePerNight ?? roomInfoMap[apt]?.pricePerNight ?? 0,
    pricePerMonth: roomPriceEdits[apt].pricePerMonth ?? roomInfoMap[apt]?.pricePerMonth ?? 0,
  }));
  try {
    const r = await fetch('/staff/api/room-prices', { method:'PUT', headers:{'Content-Type':'application/json'}, body:JSON.stringify({ prices }) });
    const d = await r.json();
    if (!r.ok) { toast('❌ ' + (d.error||'حدث خطأ')); return; }
    apts.forEach(apt => { if (!roomInfoMap[apt]) roomInfoMap[apt]={}; Object.assign(roomInfoMap[apt], roomPriceEdits[apt]); });
    roomPriceEdits = {};
    toast('✅ تم حفظ الأسعار');
  } catch(e) { toast('❌ حدث خطأ'); }
}

