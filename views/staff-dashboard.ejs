          <div class="print-meta-row"><span>نوع الحجز:</span><b>${BK_L[b.bookingType]||b.bookingType||'—'}</b></div>
          ${b.checkIn?`<div class="print-meta-row"><span>تاريخ الدخول:</span><b>${fDate(b.checkIn)}</b></div>`:''}
          ${b.checkOut?`<div class="print-meta-row"><span>تاريخ الخروج:</span><b>${fDate(b.checkOut)}</b></div>`:''}
