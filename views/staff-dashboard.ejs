        <div id="vm-check-row2" style="display:none;">
          <label style="font-size:12px;font-weight:700;color:#475569;display:block;margin-bottom:5px;">اسم البنك</label>
          <input id="vm-bank" type="text" style="width:100%;padding:9px;border:1.5px solid #e2e8f0;border-radius:10px;font-family:inherit;font-size:13px;outline:none;">
        </div>
        <div id="vm-check-row3" style="display:none;grid-column:1/-1;">
          <label style="font-size:12px;font-weight:700;color:#475569;display:block;margin-bottom:5px;">تاريخ الاستحقاق</label>
