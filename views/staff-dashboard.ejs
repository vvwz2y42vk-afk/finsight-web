      </div>

      <div class="apt-bld">
        <div class="tbl-wrap">
          <table class="stbl">
            <thead><tr><th>#</th><th>الشقة</th><th>النزيل</th><th>الجوال</th><th>نوع الإيجار</th><th>الدخول</th><th>الخروج</th><th>الإجمالي</th><th>الحالة</th><th>إجراء</th></tr></thead>
            <tbody id="bkTbody"><tr><td colspan="10" style="text-align:center;padding:30px;color:#94a3b8;">جاري التحميل...</td></tr></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ── Customers ── -->
    <div class="tab-section" id="tab-customers">

      <!-- رأس إدارة العملاء -->
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
        <div style="font-size:11px;color:#64748b;" id="custDateTime"></div>
        <div style="font-size:14px;font-weight:700;color:#0891b2;">إدارة العملاء</div>
      </div>

      <!-- شريط الفلترة -->
      <div style="background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:10px 14px;margin-bottom:10px;display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
        <input type="text" id="custIdNum" class="cff" placeholder="رقم الإثبات" style="width:130px;">
        <input type="text" id="custSearch" class="cff" placeholder="الاسم" style="width:140px;">
        <input type="text" id="custPhone" class="cff" placeholder="جوال" style="width:130px;">
        <select id="custSF" class="cff" style="width:170px;">
          <option value="open">الحجوزات المفتوحة</option>
          <option value="active">النزلاء المقيمين</option>
          <option value="pending_checkin">بدون دخول</option>
          <option value="today_arrival_all">وصول اليوم</option>
          <option value="today_dep_all">مغادرة اليوم</option>
          <option value="closed">مغلقة</option>
          <option value="cancelled">ملغاة</option>
          <option value="all">الجميع</option>
        </select>
        <button onclick="loadCustomers()" style="padding:7px 20px;border-radius:8px;background:#1a3d8f;border:none;color:#fff;font-family:inherit;font-size:12px;font-weight:700;cursor:pointer;">بحث</button>
        <button onclick="clearCustFilters()" style="padding:7px 14px;border-radius:8px;border:1px solid #e2e8f0;background:#f8fafc;color:#64748b;font-family:inherit;font-size:12px;cursor:pointer;">مسح</button>
        <span style="font-size:11px;color:#94a3b8;margin-right:auto;" id="custCount"></span>
      </div>

      <!-- زر إضافة -->
      <div style="margin-bottom:10px;">
        <% if(P.includes('new_booking')){ %>
        <button onclick="openNewBkModal()" style="display:inline-flex;align-items:center;gap:6px;padding:7px 16px;border-radius:8px;background:#0891b2;border:none;color:#fff;font-family:inherit;font-size:12px;font-weight:700;cursor:pointer;">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          إضافة عميل
        </button>
        <% } %>
      </div>

      <!-- الجدول -->
      <div class="tbl-wrap">
        <table class="stbl">
          <thead style="background:#0891b2;"><tr style="background:#0891b2;">
            <th style="background:#0891b2;color:#fff;">الاسم</th>
            <th style="background:#0891b2;color:#fff;">نوع الإثبات</th>
            <th style="background:#0891b2;color:#fff;">رقم الإثبات</th>
            <th style="background:#0891b2;color:#fff;">الشقة</th>
            <th style="background:#0891b2;color:#fff;">الجوال</th>
            <th style="background:#0891b2;color:#fff;">الدخول</th>
            <th style="background:#0891b2;color:#fff;">الخروج</th>
            <th style="background:#0891b2;color:#fff;">نوع الإيجار</th>
            <th style="background:#0891b2;color:#fff;">الحالة</th>
            <th style="background:#0891b2;color:#fff;">المعاملات</th>
          </tr></thead>
          <tbody id="custTbody"><tr><td colspan="10" style="text-align:center;padding:30px;color:#94a3b8;">جاري التحميل...</td></tr></tbody>
        </table>
      </div>
    </div>

    <!-- ── Housekeeping ── -->
    <div class="tab-section" id="tab-housekeeping">
      <div style="display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap;align-items:center;">
        <span style="font-size:13px;font-weight:700;color:#475569;">حالة النظافة:</span>
        <span style="font-size:12px;font-weight:700;background:rgba(34,197,94,.1);color:#16a34a;padding:3px 10px;border-radius:8px;">نظيف</span>
        <span style="font-size:12px;font-weight:700;background:rgba(239,68,68,.1);color:#dc2626;padding:3px 10px;border-radius:8px;">غير نظيف</span>
        <span style="font-size:12px;font-weight:700;background:rgba(234,179,8,.1);color:#ca8a04;padding:3px 10px;border-radius:8px;">🟡 قيد الفحص</span>
        <span style="font-size:12px;font-weight:700;background:rgba(168,85,247,.1);color:#9333ea;padding:3px 10px;border-radius:8px;">صيانة</span>
      </div>
      <div class="hk-grid" id="hkGrid"></div>
