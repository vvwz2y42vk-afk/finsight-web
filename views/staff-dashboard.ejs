<!-- Voucher Form Modal -->
<div class="overlay" id="vouModal" style="display:none;" onclick="if(event.target===this)closeVouModal()">
  <div class="modal" style="max-width:460px;">
    <div class="mhd"><div class="mhd-title" id="vouModalTitle">+ إضافة وثيقة</div><button class="mclose" onclick="closeVouModal()">×</button></div>
    <div class="mbody" style="max-height:80vh;overflow-y:auto;">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
        <div style="grid-column:1/-1;">
          <label style="font-size:12px;font-weight:700;color:#475569;display:block;margin-bottom:5px;">التاريخ</label>
          <input id="vm-date" type="date" style="width:100%;padding:9px;border:1.5px solid #e2e8f0;border-radius:10px;font-family:inherit;font-size:13px;outline:none;">
        </div>
        <div>
          <label style="font-size:12px;font-weight:700;color:#475569;display:block;margin-bottom:5px;">الاسم</label>
          <input id="vm-name" type="text" placeholder="اسم الشخص" style="width:100%;padding:9px;border:1.5px solid #e2e8f0;border-radius:10px;font-family:inherit;font-size:13px;outline:none;">
        </div>
        <div>
          <label style="font-size:12px;font-weight:700;color:#475569;display:block;margin-bottom:5px;">الجوال</label>
          <input id="vm-phone" type="tel" inputmode="numeric" maxlength="10" placeholder="05xxxxxxxx" oninput="this.value=this.value.replace(/[^0-9]/g,'').slice(0,10)" style="width:100%;padding:9px;border:1.5px solid #e2e8f0;border-radius:10px;font-family:inherit;font-size:13px;outline:none;">
        </div>
        <div>
          <label style="font-size:12px;font-weight:700;color:#475569;display:block;margin-bottom:5px;">رقم الشقة</label>
          <input id="vm-apt" type="text" placeholder="101" style="width:100%;padding:9px;border:1.5px solid #e2e8f0;border-radius:10px;font-family:inherit;font-size:13px;outline:none;">
        </div>
        <div>
          <label style="font-size:12px;font-weight:700;color:#475569;display:block;margin-bottom:5px;">المبلغ (ريال) *</label>
          <input id="vm-amount" type="number" placeholder="0" onchange="calcVmTax()" style="width:100%;padding:9px;border:1.5px solid #e2e8f0;border-radius:10px;font-family:inherit;font-size:13px;outline:none;">
        </div>
        <!-- Tax only -->
        <div id="vm-tax-row" style="display:none;">
          <label style="font-size:12px;font-weight:700;color:#475569;display:block;margin-bottom:5px;">الضريبة 15%</label>
          <input id="vm-tax" type="number" readonly style="width:100%;padding:9px;border:1.5px solid #e2e8f0;border-radius:10px;font-family:inherit;font-size:13px;outline:none;background:#f8fafc;color:#dc2626;">
        </div>
