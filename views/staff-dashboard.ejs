  .section{margin-bottom:18px;}
  .section-title{font-size:13px;font-weight:800;color:#fff;background:#1a3d8f;padding:6px 14px;border-radius:6px;margin-bottom:10px;display:inline-block;}
  .info-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px 20px;}
  .info-row{display:flex;gap:8px;font-size:13px;padding:5px 0;border-bottom:1px dashed #e2e8f0;}
  .info-row span{color:#64748b;min-width:130px;}
  .info-row b{flex:1;}
  .price-table{width:100%;border-collapse:collapse;font-size:13px;}
  .price-table th{background:#1e293b;color:#fff;padding:9px 12px;text-align:right;}
  .price-table td{padding:9px 12px;border-bottom:1px solid #f1f5f9;}
  .price-table tr:last-child td{border-bottom:none;}
  .total-row td{font-weight:800;font-size:14px;background:#f8fafc;}
  .terms-list{list-style:none;padding:0;}
  .terms-list li{padding:5px 0 5px 14px;border-bottom:1px dashed #f1f5f9;font-size:12px;color:#475569;position:relative;}
  .terms-list li::before{content:'•';position:absolute;right:0;color:#1a3d8f;}
