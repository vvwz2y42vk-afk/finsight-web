        </div>
        <div class="vou-card" style="background:linear-gradient(135deg,#f59e0b,#d97706);" onclick="showVouSection('disbursements')">
          <div class="vou-ico"><svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></div><div class="vou-lbl">سندات الصرف</div>
        </div>
        <div class="vou-card" style="background:linear-gradient(135deg,#22c55e,#15803d);" onclick="showVouSection('checks')">
          <div class="vou-ico"><svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg></div><div class="vou-lbl">سندات الكمبيالات</div>
