function renderAptGrid(){
  if(!aptsRawData){return;}
  const container=document.getElementById('aptsContainer');
  const today=new Date(); today.setHours(0,0,0,0);
  let html='<div class="apt-bld"><div class="apt-bld-hd"><div class="apt-bld-name">'+esc(aptsRawData.building)+'</div></div><div class="apt-bld-inner">';
  aptsRawData.floors.forEach(floor=>{
    const allRooms=floor.rooms;
    const rooms=allRooms.filter(r=>aptsFilter==='all'||r.status===aptsFilter);
    if(!rooms.length) return;
    const floorOcc=allRooms.filter(r=>['occupied','checkout_today','checkin_today','awaiting','awaiting_payment'].includes(r.status)).length;
    const pct=allRooms.length?Math.round(floorOcc/allRooms.length*100):0;
    html+=`<div class="apt-floor-row">
      <div class="apt-floor-lbl">${esc(floor.label)}</div>
      <div class="apt-floor-stats">${floorOcc}/${allRooms.length} · ${pct}%</div>
      <div class="apt-floor-line"></div>
    </div>
    <div class="apt-grid">`;
    rooms.forEach(r=>{
      const s=APT_MAP[r.status]||{cls:'',lbl:r.status};
      const hkClass=r.housekeeping==='dirty'?'dirty':r.housekeeping==='maintenance'?'maintenance':'';
      const dbInfo=roomInfoMap[r.apt]||null;
      const fbInfo=(APT_TYPES[BUILDING]||{})[r.apt]||null;
      const rt=dbInfo?.roomType||fbInfo?.t||'';
      const bd=dbInfo?.beds||fbInfo?.b||'';
      const editBtn=can('edit_room_info')?`<div onclick="event.stopPropagation();openRoomInfoModal('${r.apt}','${esc(rt)}','${esc(bd)}')" style="position:absolute;top:4px;left:4px;width:15px;height:15px;background:rgba(255,255,255,.2);border-radius:4px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:8px;" title="تعديل">✏️</div>`:'';
      const maintBtn=canMaintenance()?`<div onclick="event.stopPropagation();openMaintModal('${r.apt}')" style="position:absolute;bottom:4px;left:4px;width:17px;height:17px;background:rgba(220,38,38,.15);border-radius:4px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:10px;" title="إبلاغ عن عطل">🔧</div>`:'';
      let nightsHtml='';
      if(r.checkOut&&['occupied','checkout_today'].includes(r.status)){
        const co=new Date(r.checkOut); co.setHours(0,0,0,0);
        const days=Math.round((co-today)/(86400000));
        nightsHtml=days<=0?`<div class="apt-nights">خروج اليوم</div>`:days===1?`<div class="apt-nights">غداً</div>`:`<div class="apt-nights">${days} يوم</div>`;
      }
      html+=`<div class="apt ${s.cls} ${hkClass}" onclick="openBkModal('${r.bookingId||''}','${r.apt}','${r.status}')">
        ${editBtn}${maintBtn}
        <div class="apt-n">${esc(r.apt)}</div>
        ${rt?`<div class="apt-type">${esc(rt)}${bd?' · '+esc(bd)+' سرير':''}</div>`:''}
        <div class="apt-s">${s.lbl}</div>
        ${r.name?'<div class="apt-g">'+esc(r.name)+'</div>':''}
        ${nightsHtml}
      </div>`;
    });
    html+='</div>';
  });
  html+='</div></div>';
  container.innerHTML=html;

  // ── قسم الصيانة ──
  const maintStrip = document.getElementById('apt-maintenance-strip');
  if(maintStrip){
    const maintRooms=[], dirtyRooms=[];
    aptsRawData.floors.forEach(floor=>{
      floor.rooms.forEach(r=>{
        if(r.housekeeping==='maintenance') maintRooms.push(r);
        else if(r.housekeeping==='dirty') dirtyRooms.push(r);
      });
    });
    const mkCards=(rooms,bg,border,color,icon,label)=>rooms.length
      ?rooms.map(r=>`<div onclick="openBkModal('${r.bookingId||''}','${r.apt}','${r.status}')" style="cursor:pointer;min-width:110px;padding:10px 14px;background:${bg};border:1.5px solid ${border};border-radius:12px;display:flex;flex-direction:column;gap:4px;">
          <div style="font-size:18px;font-weight:800;color:${color};">${esc(r.apt)}</div>
          <div style="font-size:10px;font-weight:700;color:${color};background:${border};padding:2px 7px;border-radius:20px;align-self:flex-start;">${icon} ${label}</div>
          ${r.notes?`<div style="font-size:11px;color:#64748b;margin-top:2px;">${esc(r.notes)}</div>`:''}
        </div>`).join('')
      :`<div style="font-size:12px;color:#94a3b8;">لا يوجد</div>`;
    maintStrip.style.display='block';
    maintStrip.innerHTML=`
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
        <div style="background:#fff;border:1px solid rgba(124,58,237,.2);border-radius:12px;padding:14px 16px;">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;">
            <span style="width:9px;height:9px;border-radius:50%;background:#7C3AED;display:inline-block;flex-shrink:0;"></span>
            <span style="font-size:13px;font-weight:700;color:#7C3AED;">الصيانة${maintRooms.length?' ('+maintRooms.length+')':''}</span>
          </div>
          <div style="display:flex;flex-wrap:wrap;gap:8px;">${mkCards(maintRooms,'#faf5ff','rgba(124,58,237,.15)','#7C3AED','🔧','صيانة')}</div>
        </div>
        <div style="background:#fff;border:1px solid rgba(185,28,28,.15);border-radius:12px;padding:14px 16px;">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;">
            <span style="width:9px;height:9px;border-radius:50%;background:#B91C1C;display:inline-block;flex-shrink:0;"></span>
            <span style="font-size:13px;font-weight:700;color:#B91C1C;">غير نظيف${dirtyRooms.length?' ('+dirtyRooms.length+')':''}</span>
          </div>
          <div style="display:flex;flex-wrap:wrap;gap:8px;">${mkCards(dirtyRooms,'#fff5f5','rgba(185,28,28,.12)','#B91C1C','🔴','غير نظيف')}</div>
        </div>
      </div>`;
  }
}

