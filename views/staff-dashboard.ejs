    '303':{t:'',b:''},
    '304':{t:'',b:''},
    '305':{t:'',b:''},
    '306':{t:'جناح ديلوكس',b:'1 سرير'},
    '401':{t:'',b:''},
    '402':{t:'جناح جونيور',b:'توأم'},
    '403':{t:'جناح عائلي',b:'5 بالغين'},
    '404':{t:'جناح ديلوكس',b:'2 سرير'},
    '405':{t:'جناح ديلوكس',b:'2 سرير'},
    '406':{t:'',b:''},
    '501':{t:'',b:''},
