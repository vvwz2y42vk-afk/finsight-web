  const sheet=document.getElementById('bottomSheet');
  const overlay=document.getElementById('bsOverlay');
  let h=`<div class="bs-handle"></div><div class="bs-title">${apt} — ${name}</div>`;
  if(status==='awaiting_checkin') h+=`<button class="bs-btn success" onclick="changeStatus('${bId}','active');closeBottomSheet()"><span class="bs-btn-ico">✅</span>تسجيل الدخول</button>`;
  if(status==='active') h+=`<button class="bs-btn danger" onclick="changeStatus('${bId}','checkout');closeBottomSheet()"><span class="bs-btn-ico">🚪</span>تسجيل الخروج</button>`;
  if(!['cancelled','checkout'].includes(status)&&can('edit_booking')) h+=`<button class="bs-btn" onclick="editBk('${bId}');closeBottomSheet()"><span class="bs-btn-ico">✏️</span>تعديل الحجز</button>`;
  if(!['cancelled','checkout'].includes(status)&&can('cancel_booking')){h+=`<div class="bs-sep"></div>`;h+=`<button class="bs-btn danger" onclick="cancelBk('${bId}');closeBottomSheet()"><span class="bs-btn-ico">❌</span>إلغاء الحجز</button>`;}
  h+=`<div class="bs-sep"></div>`;
  h+=`<button class="bs-btn" onclick="printBkInvoice('${bId}');closeBottomSheet()"><span class="bs-btn-ico">🧾</span>طباعة فاتورة</button>`;
  h+=`<button class="bs-btn" onclick="printContract('${bId}');closeBottomSheet()"><span class="bs-btn-ico">📄</span>طباعة عقد</button>`;
  h+=`<div class="bs-sep"></div><button class="bs-btn" onclick="closeBottomSheet()" style="color:#94a3b8;justify-content:center;">إغلاق</button>`;
  sheet.innerHTML=h;
  sheet.classList.add('open');
  overlay.classList.add('open');
}
function closeBottomSheet(){
  document.getElementById('bottomSheet').classList.remove('open');
  document.getElementById('bsOverlay').classList.remove('open');
}

// ════════════════════════════════════════════════
// CHANNEL MANAGER
// ════════════════════════════════════════════════

const PLATFORM_META = {
  airbnb:   { label:'Airbnb',       icon:'🏡', color:'#FF5A5F' },
  booking:  { label:'Booking.com',  icon:'🌐', color:'#003580' },
  gathering:{ label:'Gathering',    icon:'🏘️', color:'#1a6b3c' },
  website:  { label:'موقعنا',       icon:'✅', color:'#1a3d8f' },
};

let _chConfigs = [];

async function loadChannels() {
  try {
    const r = await fetch('/staff/api/channels');
    if (!r.ok) throw new Error('فشل التحميل');
    const data = await r.json();
    _chConfigs = data.configs || [];
    renderChannelCards(_chConfigs);
    updateChannelKPIs(_chConfigs);
    loadChannelFeed();
    // Set webhook example URL
    const wEl = document.getElementById('ch-webhook-url-g');
    if (wEl) wEl.textContent = `${location.origin}/staff/api/channels/webhook/gathering?secret=SECRET`;
  } catch(e) {
    document.getElementById('ch-cards-container').innerHTML = `<div class="ch-empty">⚠️ ${e.message}</div>`;
  }
}

function updateChannelKPIs(configs) {
  const active = configs.filter(c => c.enabled).length;
  const el = n => document.getElementById(n);
  el('ch-kpi-active').textContent = active + ' / 4';
  const lastSyncs = configs.filter(c=>c.lastSync).map(c=>new Date(c.lastSync));
  if (lastSyncs.length) {
    const latest = new Date(Math.max(...lastSyncs));
    el('ch-kpi-sync').textContent = latest.toLocaleString('ar-SA',{month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'});
  }
  const emails = [...new Set(configs.filter(c=>c.notifyEmail).map(c=>c.notifyEmail))];
  el('ch-kpi-email').textContent = emails.length ? emails[0] : '—';
}

function renderChannelCards(configs) {
  const container = document.getElementById('ch-cards-container');
  container.innerHTML = '';
  for (const cfg of configs) {
    const m = PLATFORM_META[cfg.platform] || {};
    const statusDot = cfg.lastSyncStatus === 'ok' ? 'ok' : cfg.lastSyncStatus === 'error' ? 'error' : 'never';
    const statusText = cfg.lastSyncStatus === 'ok'
      ? `آخر مزامنة: ${cfg.lastSync ? new Date(cfg.lastSync).toLocaleString('ar-SA',{month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}) : '—'}`
      : cfg.lastSyncStatus === 'error' ? `خطأ: ${cfg.lastSyncMsg||''}` : 'لم تتم المزامنة بعد';
    const isWebsite = cfg.platform === 'website';

    const card = document.createElement('div');
    card.className = 'ch-card' + (cfg.enabled ? ' ch-active' : '');
    card.dataset.platform = cfg.platform;
    card.innerHTML = `
      <div class="ch-card-hd">
        <div class="ch-logo">${m.icon||'📡'}</div>
        <div class="ch-info">
          <div class="ch-name">${m.label||cfg.platform}</div>
          <div class="ch-sub">${isWebsite ? 'متصل تلقائياً' : 'ربط خارجي'}</div>
        </div>
        <label class="ch-toggle">
          <input type="checkbox" ${cfg.enabled?'checked':''} onchange="toggleChannel('${cfg.platform}',this.checked)">
          <span class="ch-toggle-slider"></span>
        </label>
      </div>
      <div class="ch-status">
        <div class="ch-dot ${statusDot}"></div>
        <span style="color:${statusDot==='ok'?'#16a34a':statusDot==='error'?'#dc2626':'#94a3b8'}">${statusText}</span>
      </div>
      <div class="ch-body">
        ${isWebsite ? `
          <div class="ch-field">
            <div class="ch-label">إيميل الإشعارات</div>
            <input class="ch-input" type="email" id="ch-notify-${cfg.platform}" value="${esc(cfg.notifyEmail||'')}" placeholder="admin@example.com">
          </div>
        ` : `
          <div class="ch-field">
            <div class="ch-label">رابط iCal للاستيراد (من المنصة)</div>
            <input class="ch-input" type="url" id="ch-ical-${cfg.platform}" value="${esc(cfg.icalImport||'')}" placeholder="https://…">
          </div>
          ${cfg.icalExportUrl ? `
          <div class="ch-field">
            <div class="ch-label">رابط iCal الخاص بنا (الصقه في المنصة)</div>
            <div class="ch-export-box">
              <span class="ch-export-url" id="ch-export-url-${cfg.platform}">${esc(cfg.icalExportUrl)}</span>
              <button class="ch-copy-btn" onclick="copyChUrl('${cfg.platform}')">نسخ</button>
            </div>
          </div>` : ''}
          <div class="ch-field">
            <div class="ch-label">إيميل الإشعارات</div>
            <input class="ch-input" type="email" id="ch-notify-${cfg.platform}" value="${esc(cfg.notifyEmail||'')}" placeholder="admin@example.com">
          </div>
          ${cfg.platform !== 'gathering' ? `
          <div class="ch-field">
            <div class="ch-label">${cfg.platform==='booking'?'Hotel ID (Booking.com)':'Property ID'}</div>
            <input class="ch-input" type="text" id="ch-hotel-${cfg.platform}" value="${esc(cfg.hotelId||'')}" placeholder="اختياري">
          </div>` : ''}
        `}
        <div class="ch-actions">
          <button class="ch-save-btn" onclick="saveChannel('${cfg.platform}',this)">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
            حفظ
          </button>
          ${!isWebsite ? `
          <button class="ch-sync-btn" id="ch-sync-btn-${cfg.platform}" onclick="syncChannel('${cfg.platform}',this)">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="1 4 1 10 7 10"/><polyline points="23 20 23 14 17 14"/><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15"/></svg>
            مزامنة
          </button>` : ''}
        </div>
        <div id="ch-msg-${cfg.platform}" style="font-size:11px;margin-top:8px;min-height:16px;font-weight:700;"></div>
      </div>
    `;
    container.appendChild(card);
  }
}

async function toggleChannel(platform, enabled) {
  await saveChannelData(platform, { enabled });
  const card = document.querySelector(`.ch-card[data-platform="${platform}"]`);
  if (card) card.classList.toggle('ch-active', enabled);
  updateChannelKPIs(_chConfigs.map(c => c.platform===platform ? {...c, enabled} : c));
}

async function saveChannel(platform, btn) {
  const val = id => { const el = document.getElementById(id); return el ? el.value.trim() : ''; };
  const body = {
    icalImport:  val(`ch-ical-${platform}`),
    notifyEmail: val(`ch-notify-${platform}`),
    hotelId:     val(`ch-hotel-${platform}`),
  };
  const origText = btn.innerHTML;
  btn.disabled = true; btn.innerHTML = '…';
  await saveChannelData(platform, body);
  btn.disabled = false; btn.innerHTML = origText;
  const msg = document.getElementById(`ch-msg-${platform}`);
  if (msg) { msg.textContent = '✅ تم الحفظ'; msg.style.color='#16a34a'; setTimeout(()=>{msg.textContent='';},2500); }
}

async function saveChannelData(platform, body) {
  try {
    const r = await fetch(`/staff/api/channels/${platform}`, {
      method: 'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body)
    });
    const data = await r.json();
    if (data.icalExportUrl) {
      const urlEl = document.getElementById(`ch-export-url-${platform}`);
      if (urlEl) urlEl.textContent = data.icalExportUrl;
    }
    // Refresh config cache
    const idx = _chConfigs.findIndex(c=>c.platform===platform);
    if (idx>=0) _chConfigs[idx] = {..._chConfigs[idx], ...body, ...data};
  } catch(e) {
    const msg = document.getElementById(`ch-msg-${platform}`);
    if (msg) { msg.textContent = '❌ '+e.message; msg.style.color='#dc2626'; }
  }
}

function copyChUrl(platform) {
  const el = document.getElementById(`ch-export-url-${platform}`);
  if (!el) return;
  navigator.clipboard.writeText(el.textContent).then(() => {
    const btn = el.nextElementSibling;
    const orig = btn.textContent;
    btn.textContent = 'تم!'; btn.style.background='#16a34a';
    setTimeout(()=>{ btn.textContent=orig; btn.style.background=''; },1800);
  });
}

async function syncChannel(platform, btn) {
  const msgEl = document.getElementById(`ch-msg-${platform}`);
  btn.classList.add('spinning'); btn.disabled = true;
  if (msgEl) { msgEl.textContent = 'جاري المزامنة…'; msgEl.style.color='#64748b'; }
  try {
    const r = await fetch(`/staff/api/channels/${platform}/sync`, { method:'POST' });
    const data = await r.json();
    if (msgEl) {
      msgEl.textContent = data.msg || (data.success ? '✅ تمت المزامنة' : data.error || 'خطأ');
      msgEl.style.color = data.success ? '#16a34a' : '#dc2626';
    }
    if (data.newBookings > 0) loadChannelFeed();
    // Update card status dot
    await loadChannels();
  } catch(e) {
    if (msgEl) { msgEl.textContent = '❌ ' + e.message; msgEl.style.color='#dc2626'; }
  } finally {
    btn.classList.remove('spinning'); btn.disabled = false;
  }
}

async function syncAllChannels(btn) {
  const origText = btn.innerHTML;
  btn.disabled = true; btn.innerHTML = '<span style="display:flex;align-items:center;gap:8px;"><svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="animation:spin .7s linear infinite"><polyline points="1 4 1 10 7 10"/><polyline points="23 20 23 14 17 14"/><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15"/></svg>جاري المزامنة…</span>';
  let total = 0;
  for (const p of ['airbnb','booking','gathering']) {
    try {
      const r = await fetch(`/staff/api/channels/${p}/sync`, { method:'POST' });
      const d = await r.json();
      total += d.newBookings || 0;
    } catch(e) {}
  }
  btn.disabled = false; btn.innerHTML = origText;
  if (total > 0) { loadChannels(); showToast(`تمت المزامنة — ${total} حجز جديد`); }
  else showToast('تمت مزامنة جميع القنوات');
}

async function loadChannelFeed() {
  const body = document.getElementById('ch-feed-body');
  if (!body) return;
  try {
    const r = await fetch('/staff/api/channels/feed');
    const data = await r.json();
    const bookings = data.bookings || [];
    // Also count for KPI
    document.getElementById('ch-kpi-total').textContent = bookings.length;
    if (!bookings.length) { body.innerHTML = '<div class="ch-empty">لا توجد حجوزات من القنوات الخارجية بعد</div>'; return; }
    const platFromSource = src => {
      const m = (src||'').match(/^ch-(\w+)-/);
      return m ? m[1] : 'website';
    };
    body.innerHTML = bookings.map(b => {
      const plat = platFromSource(b.source);
      const m = PLATFORM_META[plat] || {};
      const nights = b.nights || (b.checkIn && b.checkOut ? Math.round((new Date(b.checkOut)-new Date(b.checkIn))/86400000) : 0);
      return `
        <div class="ch-feed-row">
          <span class="ch-plat-badge ch-plat-${plat}">${m.icon||''} ${m.label||plat}</span>
          <span class="ch-feed-apt">${esc(b.apt||'—')}</span>
          <div class="ch-feed-info">
            <div class="ch-feed-name">${esc(b.name||'—')}</div>
            <div class="ch-feed-dates">${fDate(b.checkIn)} ← ${fDate(b.checkOut)} · ${nights} ليلة</div>
          </div>
          <span class="ch-feed-price">${b.totalPrice ? b.totalPrice.toLocaleString('ar-SA')+' ر' : '—'}</span>
          ${statusBadge(b.status)}
        </div>`;
    }).join('');
  } catch(e) {
    body.innerHTML = `<div class="ch-empty">⚠️ ${e.message}</div>`;
  }
}

function toggleChHow() {
  const body = document.getElementById('ch-how-body');
  const arrow = document.getElementById('ch-how-arrow');
  body.classList.toggle('open');
  if (arrow) arrow.style.transform = body.classList.contains('open') ? 'rotate(180deg)' : '';
}

function showToast(msg) {
  let t = document.getElementById('ch-toast');
  if (!t) {
    t = document.createElement('div');
    t.id = 'ch-toast';
    t.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(60px);background:#0f172a;color:#fff;padding:12px 24px;border-radius:12px;font-size:13px;font-weight:600;z-index:9999;transition:transform .3s,opacity .3s;opacity:0;font-family:Cairo,sans-serif;';
    document.body.appendChild(t);
  }
  t.textContent = msg;
  requestAnimationFrame(() => { t.style.transform='translateX(-50%) translateY(0)'; t.style.opacity='1'; });
  setTimeout(() => { t.style.transform='translateX(-50%) translateY(60px)'; t.style.opacity='0'; }, 3000);
}
</script>
