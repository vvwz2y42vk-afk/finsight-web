      <div id="nb-err" style="color:#dc2626;font-size:12px;font-weight:600;margin-top:8px;display:none;"></div>
      <button onclick="submitNewBk()" style="width:100%;margin-top:14px;padding:12px;background:linear-gradient(135deg,#1a3d8f,#2a5cc7);border:none;border-radius:12px;font-family:inherit;font-size:14px;font-weight:800;cursor:pointer;color:#111;">حفظ الحجز</button>
