</div>
</body></html>`);
  w.document.close();
}

async function loadBookings(){
  const sf          = document.getElementById('bk-status-filter')?.value||'open';
  const date_from   = document.getElementById('bkDateFrom')?.value||'';
  const date_to     = document.getElementById('bkDateTo')?.value||'';
  const booking_num = (document.getElementById('bkNum')?.value||'').trim();
  const apt         = (document.getElementById('bkApt')?.value||'').trim();
  const name        = (document.getElementById('bkName')?.value||'').trim();
  const phone       = (document.getElementById('bkPhone')?.value||'').trim();
  const booking_type= document.getElementById('bkType')?.value||'';
  const source      = document.getElementById('bkSource')?.value||'';
  const q           = name||(phone||'');

  const params=new URLSearchParams({sf,date_from,date_to,booking_num,apt,booking_type,source,q});
  try{
    const r=await fetch('/staff/api/bookings?'+params);
    _bkData=await r.json();
    _bkPage=1;
    renderBkRows();
  }catch(e){
    const tb=document.getElementById('bkTbody');
    if(tb) tb.innerHTML='<tr><td colspan="12" style="text-align:center;padding:30px;color:#dc2626;">❌ تعذر تحميل الحجوزات — تحقق من الاتصال</td></tr>';
  }
}

// ── Analytics ────────────────────────────────────────────
let anYear=new Date().getFullYear();
let _anCharts={};
const AN_MONTHS=['يناير','فبراير','مارس','أبريل','مايو','يونيو','يوليو','أغسطس','سبتمبر','أكتوبر','نوفمبر','ديسمبر'];

function anFmt(n){return n>=1000000?(n/1000000).toFixed(1)+'م':n>=1000?(n/1000).toFixed(0)+'ك':n.toLocaleString();}

function destroyChart(id){ if(_anCharts[id]){_anCharts[id].destroy();delete _anCharts[id];} }

let _chartJsP=null;
function _ensureChartJs(){
  if(window.Chart) return Promise.resolve();
  if(_chartJsP) return _chartJsP;
  _chartJsP=new Promise((res,rej)=>{
    const s=document.createElement('script');
    s.src='https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js';
    s.onload=()=>{_chartJsP=null;res();};
    s.onerror=()=>{_chartJsP=null;rej(new Error('Chart.js load failed'));};
    document.head.appendChild(s);
  });
  return _chartJsP;
}

async function loadAnalytics(){
  document.getElementById('an-year-lbl').textContent=anYear;
  await _ensureChartJs();
  try{
    const r=await fetch('/staff/api/analytics?year='+anYear);
    const d=await r.json();

    // ── KPI Cards ──
    const bestName=d.bestMonth>=0?AN_MONTHS[d.bestMonth]:'—';
    document.getElementById('an-kpis').innerHTML=[
      {lbl:'إجمالي الإيرادات',val:anFmt(d.totalRevenue)+' ﷼',c:'#1a3d8f',bg:'rgba(26,61,143,.06)'},
      {lbl:'إجمالي المحصّل',val:anFmt(d.totalPaid)+' ﷼',c:'#16a34a',bg:'rgba(22,163,74,.06)'},
      {lbl:'المتبقي',val:anFmt(d.totalRemaining)+' ﷼',c:'#dc2626',bg:'rgba(220,38,38,.06)'},
      {lbl:'إجمالي الحجوزات',val:d.totalBookings.toLocaleString(),c:'#7c3aed',bg:'rgba(124,58,237,.06)'},
      {lbl:'إيرادات '+anYear,val:anFmt(d.yearRevenue)+' ﷼',c:'#b45309',bg:'rgba(180,83,9,.06)'},
      {lbl:'أفضل شهر '+anYear,val:bestName,c:'#0891b2',bg:'rgba(8,145,178,.06)'},
    ].map(k=>`<div style="background:${k.bg};border:1px solid ${k.c}22;border-radius:12px;padding:12px 14px;">
      <div style="font-size:11px;color:var(--t4);margin-bottom:4px;">${k.lbl}</div>
      <div style="font-size:18px;font-weight:800;color:${k.c};">${k.val}</div>
    </div>`).join('');

    // ── Chart defaults ──
    Chart.defaults.font.family="'Cairo',sans-serif";
    Chart.defaults.color='#64748b';

    // 1. إيرادات شهرية
    destroyChart('rev');
    _anCharts['rev']=new Chart(document.getElementById('an-revenue-chart'),{
      type:'bar',
      data:{labels:AN_MONTHS,datasets:[{label:'الإيرادات',data:d.monthlyRevenue,backgroundColor:'rgba(26,61,143,.75)',borderRadius:6,borderSkipped:false}]},
      options:{responsive:true,plugins:{legend:{display:false},tooltip:{callbacks:{label:ctx=>ctx.parsed.y.toLocaleString()+' ﷼'}}},scales:{y:{ticks:{callback:v=>anFmt(v)},grid:{color:'#f1f5f9'}},x:{grid:{display:false}}}}
    });

    // 2. حجوزات شهرية
    destroyChart('bk');
    _anCharts['bk']=new Chart(document.getElementById('an-bookings-chart'),{
      type:'line',
      data:{labels:AN_MONTHS,datasets:[{label:'الحجوزات',data:d.monthlyBookings,borderColor:'#7c3aed',backgroundColor:'rgba(124,58,237,.08)',tension:.4,fill:true,pointBackgroundColor:'#7c3aed',pointRadius:4}]},
      options:{responsive:true,plugins:{legend:{display:false}},scales:{y:{ticks:{stepSize:1},grid:{color:'#f1f5f9'}},x:{grid:{display:false}}}}
    });

    // 3. أفضل الشقق
    destroyChart('apts');
    _anCharts['apts']=new Chart(document.getElementById('an-apts-chart'),{
      type:'bar',
      data:{
        labels:d.topApts.map(a=>a.apt),
        datasets:[{label:'الإيرادات',data:d.topApts.map(a=>a.revenue),backgroundColor:d.topApts.map((_,i)=>`hsla(${220+i*8},70%,${48+i*2}%,.8)`),borderRadius:4,borderSkipped:false}]
      },
      options:{indexAxis:'y',responsive:true,plugins:{legend:{display:false},tooltip:{callbacks:{label:ctx=>ctx.parsed.x.toLocaleString()+' ﷼'}}},scales:{x:{ticks:{callback:v=>anFmt(v)},grid:{color:'#f1f5f9'}},y:{grid:{display:false}}}}
    });

    // 4. توزيع نوع الحجز
    destroyChart('type');
    const typeLabels={daily:'يومي',annual:'شهري',inquiry:'استفسار'};
    const typeColors=['#1a3d8f','#16a34a','#f59e0b'];
    const typeKeys=Object.keys(d.byType);
    _anCharts['type']=new Chart(document.getElementById('an-type-chart'),{
      type:'doughnut',
      data:{
        labels:typeKeys.map(k=>typeLabels[k]||k),
        datasets:[{data:typeKeys.map(k=>d.byType[k].count),backgroundColor:typeColors,borderWidth:0,hoverOffset:6}]
      },
      options:{responsive:true,cutout:'65%',plugins:{legend:{position:'bottom',labels:{padding:12,font:{size:12}}}}}
    });

  }catch(e){ toast('❌ تعذر تحميل التحليلات'); }
}

