    const tdP=p?`<td style="padding:5px 8px;border:1px solid #e2e8f0;font-size:11px;color:#475569;">${fDt(p.date)}</td><td style="padding:5px 8px;border:1px solid #e2e8f0;">${esc(p.desc)}</td><td style="padding:5px 8px;border:1px solid #e2e8f0;font-weight:700;color:#047857;text-align:left;">${fN(p.amount)}</td>`
                :`<td colspan="3" style="border:1px solid #e2e8f0;"></td>`;
    return `<tr>${tdC}<td style="width:2px;padding:0;background:#cbd5e1;"></td>${tdP}</tr>`;
  }).join('');
  const totalCharges=(b.totalPrice||0);
  const totalPaid=(b.paidAmount||0);
  const balance=Math.max(0,totalCharges-totalPaid);

  const terms = [
    'بأمر من وزارة الداخلية يُمنع رهن أي مستندات رسمية.',
    'على المستأجر مراعاة السلوك والآداب الإسلامية خلال فترة تواجده في الوحدة، وعدم السماح بإقامة أشخاص آخرين من غير المرافقين المسجّلين.',
    'الرجاء المحافظة على النظام والآداب العامة.',
    'في حالة الإخلال بالنظام، يحق للإدارة فسخ العقد دون إعادة المبلغ المدفوع.',
    'في حالة الخروج خارج الوحدة، يُرجى التأكد من إغلاق الغاز والمكيفات والترشيد في استخدام الماء.',
    'يمنع دخول الطيور والحيوانات منعًا باتًا.',
    'لا يحق للمستأجر تحويل العقد أو تأجير الوحدة لشخص آخر.',
    'في حالة رغبة المستأجر في تجديد المدة، عليه إشعار الاستقبال قبل انتهاء المدة بيوم كامل على الأقل.',
    'يُعتبر العقد لاغيًا في حالة الإخلال بأي من الشروط المذكورة.',
