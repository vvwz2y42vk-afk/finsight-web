        </div>
        <div>
          <label style="font-size:12px;font-weight:700;color:#475569;display:block;margin-bottom:5px;">نوع الإثبات</label>
          <select id="nb-idtype" style="width:100%;padding:9px;border:1.5px solid #e2e8f0;border-radius:10px;font-family:inherit;font-size:13px;outline:none;">
            <option value="">— اختر —</option>
            <option value="national_id">هوية وطنية</option>
            <option value="passport">جواز سفر</option>
            <option value="iqama">إقامة</option>
            <option value="family_card">كرت عائلة</option>
          </select>
        </div>
        <div>
          <label style="font-size:12px;font-weight:700;color:#475569;display:block;margin-bottom:5px;">رقم الإثبات</label>
          <div style="position:relative;">
            <input id="nb-idnum" type="text" placeholder="رقم الوثيقة" oninput="onIdNumInput(this.value)" style="width:100%;padding:9px;border:1.5px solid #e2e8f0;border-radius:10px;font-family:inherit;font-size:13px;outline:none;">
            <span id="nb-idnum-badge" style="display:none;position:absolute;left:8px;top:50%;transform:translateY(-50%);background:#047857;color:#fff;font-size:10px;font-weight:700;padding:2px 8px;border-radius:20px;">ضيف سابق ✓</span>
          </div>
        </div>
        <div style="grid-column:1/-1;">
          <label style="font-size:12px;font-weight:700;color:#475569;display:block;margin-bottom:5px;">الحالة</label>
          <select id="nb-status" style="width:100%;padding:9px;border:1.5px solid #e2e8f0;border-radius:10px;font-family:inherit;font-size:13px;outline:none;">
