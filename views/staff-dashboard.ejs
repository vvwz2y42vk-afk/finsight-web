      <button onclick="submitVoucher()" style="width:100%;margin-top:14px;padding:12px;background:linear-gradient(135deg,#1a3d8f,#2a5cc7);border:none;border-radius:12px;font-family:inherit;font-size:14px;font-weight:800;cursor:pointer;color:#111;" id="vm-submit-btn">حفظ</button>
    </div>
  </div>
