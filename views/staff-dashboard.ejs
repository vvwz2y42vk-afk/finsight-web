    const priority=document.querySelector('input[name="maint-priority"]:checked')?.value||'normal';
    const r=await fetch('/staff/api/maintenance',{
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({
        apt,
        type:        document.getElementById('maint-type').value,
