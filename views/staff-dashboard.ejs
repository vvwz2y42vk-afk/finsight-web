const BK_TYPE_L={daily:'يومي',annual:'شهري'};
const VOU_NAMES={receipt:'سند قبض',invoice:'فاتورة',disbursement:'سند صرف',check:'كمبيالة',tax:'إشعار ضريبي'};
const VOU_COLS={receipt:7,invoice:7,disbursement:6,check:8,tax:8};

function showVouCards(){
