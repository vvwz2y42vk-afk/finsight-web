<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title><%= staff.building %> — بوابة الموظفين</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/ar.js"></script>
<style>
/* ═══ BAREZ — LUXURY DASHBOARD SYSTEM ═══ */
:root{
  --bg:#F8FAFC;--surface:#FFFFFF;--s2:#F1F5F9;--s3:#E8EEF8;
  --border:#E2E8F0;--border-s:#EEF2F8;
  --t1:#0F172A;--t2:#334155;--t3:#64748B;--t4:#94A3B8;
  --brand:#1a3d8f;--brand-l:#2563eb;--brand-m:rgba(26,61,143,.08);
  --green:#047857;--green-bg:rgba(4,120,87,.08);--green-b:rgba(4,120,87,.2);
  --amber:#B45309;--amber-bg:rgba(180,83,9,.08);--amber-b:rgba(180,83,9,.2);
  --red:#B91C1C;--red-bg:rgba(185,28,28,.08);--red-b:rgba(185,28,28,.2);
  --blue:#1D4ED8;--blue-bg:rgba(29,78,216,.08);
  --purple:#5B21B6;--purple-bg:rgba(91,33,182,.08);
  --r:14px;--r-lg:18px;
  --sh-xs:0 1px 2px rgba(15,23,42,.04);
  --sh-sm:0 2px 8px rgba(15,23,42,.05),0 1px 2px rgba(15,23,42,.03);
  --sh:0 4px 20px rgba(15,23,42,.08),0 2px 4px rgba(15,23,42,.04);
  --sh-lg:0 20px 50px rgba(15,23,42,.12),0 6px 12px rgba(15,23,42,.05);
  --ease:cubic-bezier(.4,0,.2,1);
  --sb:72px;--sb-exp:214px;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Cairo',sans-serif;background:var(--bg);direction:rtl;display:flex;min-height:100vh;color:var(--t1);-webkit-font-smoothing:antialiased;font-weight:400;}

/* ══ Sidebar ══ */
.sb{
  width:var(--sb);
  background:linear-gradient(180deg,#0A1628 0%,#071530 55%,#050D1A 100%);
  border-left:1px solid rgba(255,255,255,.05);
  display:flex;flex-direction:column;align-items:center;
  padding:20px 0;position:fixed;top:0;right:0;bottom:0;z-index:100;
  transition:width .28s var(--ease);
  box-shadow:-4px 0 28px rgba(0,0,0,.18);
}
.sb:hover{width:var(--sb-exp);}
.sb-logo{display:flex;align-items:center;justify-content:center;margin-bottom:4px;padding:8px 0;width:100%;}
.sb-logo img{filter:brightness(0) invert(1);opacity:.9;}
.sb-bld{font-size:10px;color:rgba(255,255,255,.3);text-align:center;padding:0 10px;white-space:nowrap;overflow:hidden;margin-bottom:22px;max-width:0;opacity:0;transition:all .28s var(--ease);letter-spacing:.1em;text-transform:uppercase;}
.sb:hover .sb-bld{max-width:200px;opacity:1;}
.sb-nav{flex:1;width:100%;display:flex;flex-direction:column;gap:2px;padding:0 10px;}
.sn{
  display:flex;align-items:center;gap:11px;padding:10px 10px;border-radius:10px;
  cursor:pointer;color:rgba(255,255,255,.4);
  transition:all .2s var(--ease);white-space:nowrap;overflow:hidden;position:relative;
}
.sn:hover{background:rgba(255,255,255,.06);color:rgba(255,255,255,.82);}
.sn.active{
  background:linear-gradient(135deg,rgba(37,99,235,.22),rgba(26,61,143,.14));
  color:#93C5FD;
  box-shadow:inset 0 0 0 1px rgba(37,99,235,.2);
}
.sn.active::after{
  content:'';position:absolute;right:0;top:22%;bottom:22%;
  width:3px;border-radius:2px 0 0 2px;
  background:linear-gradient(180deg,#60A5FA,#3B82F6);
  box-shadow:0 0 10px rgba(96,165,250,.5);
}
.sn-ico{flex-shrink:0;width:22px;display:flex;align-items:center;justify-content:center;}
.sn-lbl{font-size:13px;font-weight:500;opacity:0;transition:opacity .2s var(--ease);}
.sb:hover .sn-lbl{opacity:1;}
.sb-foot{width:100%;padding:0 10px 10px;}
.sb-logout{
  display:flex;align-items:center;gap:11px;padding:10px;border-radius:10px;
  cursor:pointer;color:rgba(248,113,113,.65);background:transparent;
  white-space:nowrap;overflow:hidden;transition:all .2s var(--ease);
}
.sb-logout:hover{background:rgba(239,68,68,.1);color:#FCA5A5;}

/* ══ Main ══ */
.main{margin-right:var(--sb);flex:1;display:flex;flex-direction:column;min-height:100vh;}
.topbar{
  background:rgba(248,250,252,.96);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);
  padding:15px 28px;display:flex;align-items:center;justify-content:space-between;
  border-bottom:1px solid var(--border-s);position:sticky;top:0;z-index:50;
}
.tb-left{}
.tb-title{font-size:16px;font-weight:700;color:var(--t1);letter-spacing:-.01em;}
.tb-title span{color:var(--brand);}
.tb-meta{font-size:11px;color:var(--t4);margin-top:2px;font-weight:400;}
.tb-right{display:flex;align-items:center;gap:12px;}
.tb-avatar{
  width:34px;height:34px;border-radius:9px;
  background:linear-gradient(135deg,var(--brand),var(--brand-l));
  display:flex;align-items:center;justify-content:center;
  font-size:13px;font-weight:700;color:#fff;flex-shrink:0;
}
.tb-info{text-align:right;}
.tb-info-name{font-size:13px;font-weight:600;color:var(--t2);}
.tb-info-role{font-size:11px;color:var(--t4);margin-top:1px;}
.content{padding:28px;flex:1;}
.tab-section{display:none;}.tab-section.active{display:block;}

/* ══ KPI Cards ══ */
.kpi-row{display:grid;grid-template-columns:repeat(auto-fill,minmax(165px,1fr));gap:14px;margin-bottom:28px;}
.kpi-c{
  background:var(--surface);border-radius:var(--r);padding:20px;
  border:1px solid var(--border);box-shadow:var(--sh-sm);
  transition:all .25s var(--ease);cursor:default;
  display:flex;flex-direction:column;
}
.kpi-c:hover{box-shadow:var(--sh);transform:translateY(-2px);border-color:rgba(26,61,143,.12);}
.kpi-ico{
  width:42px;height:42px;border-radius:11px;
  display:flex;align-items:center;justify-content:center;
  margin-bottom:16px;transition:transform .25s var(--ease);flex-shrink:0;
}
.kpi-c:hover .kpi-ico{transform:scale(1.08);}
.kpi-num{font-size:28px;font-weight:700;line-height:1;letter-spacing:-.03em;color:var(--t1);}
.kpi-lbl{font-size:11px;color:var(--t4);font-weight:400;margin-top:6px;letter-spacing:.02em;}

/* ══ Charts ══ */
.charts-row{display:grid;grid-template-columns:1fr 200px 200px 200px;gap:14px;margin-bottom:28px;}
.chart-card{background:var(--surface);border-radius:var(--r);padding:24px;border:1px solid var(--border);box-shadow:var(--sh-sm);}
.chart-title{
  font-size:13px;font-weight:600;margin-bottom:20px;color:var(--t2);
  display:flex;align-items:center;gap:8px;
}
.chart-title::before{content:'';display:block;width:3px;height:14px;background:var(--brand);border-radius:2px;flex-shrink:0;}
.donut-wrap{position:relative;display:inline-flex;align-items:center;justify-content:center;}
.donut-center{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;pointer-events:none;}
.donut-pct{font-size:24px;font-weight:700;color:var(--t1);letter-spacing:-.03em;line-height:1;}
.donut-pct-sub{font-size:10px;color:var(--t4);margin-top:3px;letter-spacing:.04em;}

/* ══ Apt Grid ══ */
.apt-filters{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:18px;}
.af{padding:6px 14px;border-radius:8px;border:1px solid var(--border);background:var(--surface);font-family:inherit;font-size:12px;font-weight:500;cursor:pointer;color:var(--t3);transition:all .2s var(--ease);}
.af:hover{background:var(--s2);color:var(--t2);}
.af.active{background:var(--brand);border-color:var(--brand);color:#fff;box-shadow:0 2px 8px rgba(26,61,143,.25);}
.apt-bld{background:var(--surface);border-radius:var(--r);border:1px solid var(--border);box-shadow:var(--sh-sm);padding:22px;margin-bottom:14px;}
.apt-bld-hd{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;}
.apt-bld-name{font-size:14px;font-weight:700;color:var(--t1);letter-spacing:-.01em;}
.apt-floor-lbl{font-size:10px;font-weight:500;color:var(--t4);margin-bottom:10px;letter-spacing:.07em;text-transform:uppercase;}
.apt-grid{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:14px;}
.apt{width:100px;border-radius:10px;padding:10px 6px;text-align:center;cursor:pointer;transition:all .2s var(--ease);user-select:none;}
.apt-type{font-size:10px;margin-top:3px;opacity:.82;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;line-height:1.3;}
.apt:hover{opacity:.82;transform:translateY(-2px);box-shadow:0 6px 16px rgba(0,0,0,.18);}
.apt-n{font-size:14px;font-weight:700;line-height:1;letter-spacing:-.01em;}
.apt-s{font-size:9px;margin-top:2px;opacity:.85;}
.apt-g{font-size:9px;margin-top:1px;opacity:.78;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.apt.occ{background:#B91C1C;color:#fff;}
.apt.vac{background:#047857;color:#fff;}
.apt.cin{background:#1D4ED8;color:#fff;}
.apt.cout{background:#B45309;color:#fff;}
.apt.awt{background:#5B21B6;color:#fff;}
.apt.awp{background:#92400E;color:#fff;}
.apt.dirty{outline:2px solid #B45309;outline-offset:1px;}
.apt.maintenance{outline:2px solid #6B7280;outline-offset:1px;}

/* ══ Table ══ */
.tbl-wrap{overflow-x:auto;}
.stbl{width:100%;border-collapse:collapse;font-size:13px;}
.stbl th{background:var(--s2);color:var(--brand);padding:11px 14px;text-align:right;font-weight:600;font-size:11px;letter-spacing:.04em;text-transform:uppercase;border-bottom:1px solid var(--border);}
.stbl td{padding:12px 14px;border-bottom:1px solid var(--border-s);color:var(--t2);font-weight:400;}
.stbl tbody tr{transition:background .15s var(--ease);}
.stbl tr:hover td{background:var(--s2);}
.badge{display:inline-flex;padding:3px 10px;border-radius:6px;font-size:11px;font-weight:600;letter-spacing:.01em;}
.b-active{background:rgba(4,120,87,.09);color:#047857;}
.b-awaiting{background:rgba(91,33,182,.09);color:#5B21B6;}
.b-checkout{background:rgba(180,83,9,.09);color:#B45309;}
.b-pending{background:rgba(146,64,14,.09);color:#92400E;}
.b-cancelled{background:rgba(185,28,28,.08);color:#B91C1C;}
.b-awaiting_payment{background:rgba(29,78,216,.09);color:#1D4ED8;}

/* ══ Search ══ */
.search-bar{display:flex;gap:10px;margin-bottom:18px;flex-wrap:wrap;}
.sinp{padding:9px 14px;border:1.5px solid var(--border);border-radius:10px;font-family:inherit;font-size:13px;outline:none;flex:1;min-width:180px;background:var(--surface);color:var(--t1);transition:border-color .2s,box-shadow .2s;}
.sinp:focus{border-color:var(--brand);box-shadow:0 0 0 3px rgba(26,61,143,.08);}
.sbtn{padding:9px 20px;background:linear-gradient(135deg,var(--brand),var(--brand-l));border:none;border-radius:10px;font-family:inherit;font-size:13px;font-weight:600;cursor:pointer;color:#fff;box-shadow:0 2px 8px rgba(26,61,143,.22);transition:all .2s var(--ease);}
.sbtn:hover{transform:translateY(-1px);box-shadow:0 4px 16px rgba(26,61,143,.32);}

/* ══ HK Grid ══ */
.hk-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(110px,1fr));gap:10px;}
.hk-card{background:var(--surface);border-radius:12px;border:1.5px solid var(--border);padding:14px 10px;text-align:center;cursor:pointer;transition:all .2s var(--ease);}
.hk-card:hover{border-color:var(--brand);box-shadow:var(--sh-sm);transform:translateY(-1px);}
.hk-apt{font-size:15px;font-weight:700;color:var(--t1);letter-spacing:-.01em;}
.hk-st{font-size:11px;font-weight:500;margin-top:4px;}
.hk-clean{color:var(--green);}.hk-dirty{color:var(--red);}.hk-inspecting{color:var(--amber);}.hk-maintenance{color:var(--purple);}
.hk-card.hk-dirty-c{border-color:rgba(185,28,28,.28);background:rgba(185,28,28,.03);}
.hk-card.hk-maintenance-c{border-color:rgba(91,33,182,.28);background:rgba(91,33,182,.03);}

/* ══ Activity ══ */
.act-row{display:flex;align-items:center;gap:14px;padding:14px 0;border-bottom:1px solid var(--border-s);}
.act-ico{width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.act-in{background:var(--green-bg);color:var(--green);}
.act-out{background:var(--amber-bg);color:var(--amber);}
.act-hk{background:var(--blue-bg);color:var(--blue);}
.act-info{flex:1;}
.act-main{font-size:13px;font-weight:600;color:var(--t1);}
.act-sub{font-size:11px;color:var(--t4);margin-top:2px;}
.act-time{font-size:11px;color:var(--t4);text-align:left;}

/* ══ Modal ══ */
.overlay{position:fixed;inset:0;background:rgba(15,23,42,.5);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);display:flex;align-items:center;justify-content:center;z-index:1000;}
.modal{background:var(--surface);border-radius:var(--r-lg);width:90%;max-width:440px;overflow:hidden;box-shadow:var(--sh-lg);border:1px solid var(--border);}
.mhd{background:linear-gradient(135deg,#060E1F,var(--brand));color:#fff;padding:18px 22px;display:flex;align-items:center;justify-content:space-between;}
.mhd-title{font-size:14px;font-weight:600;letter-spacing:.01em;}
.mclose{background:none;border:none;color:rgba(255,255,255,.45);font-size:20px;cursor:pointer;line-height:1;transition:color .15s;}
.mclose:hover{color:#fff;}
.mbody{padding:22px;display:flex;flex-direction:column;gap:12px;font-size:13px;}
.mrow{display:flex;justify-content:space-between;padding:9px 0;border-bottom:1px solid var(--border-s);color:var(--t3);}
.mrow b{color:var(--t1);font-weight:600;}
.mbtn{padding:11px;border:none;border-radius:10px;font-family:inherit;font-size:13px;font-weight:600;cursor:pointer;flex:1;transition:all .2s var(--ease);}
.mbtn-in{background:var(--green);color:#fff;}.mbtn-in:hover{background:#036046;box-shadow:0 4px 14px rgba(4,120,87,.3);}
.mbtn-out{background:var(--amber);color:#fff;}.mbtn-out:hover{background:#92400E;box-shadow:0 4px 14px rgba(180,83,9,.3);}
.mbtn-cancel{background:var(--s2);color:var(--t3);}.mbtn-cancel:hover{background:var(--border);color:var(--t2);}
.occ-stat{display:flex;align-items:center;gap:6px;font-size:12px;font-weight:500;}

/* ══ Toast ══ */
#toast{position:fixed;bottom:28px;left:50%;transform:translateX(-50%);background:var(--t1);color:#fff;padding:11px 22px;border-radius:10px;font-size:13px;font-weight:500;opacity:0;transition:opacity .3s;z-index:9999;pointer-events:none;box-shadow:var(--sh);letter-spacing:.01em;}

/* ══ Vouchers ══ */
.vou-cards{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:28px;}
.vou-card{flex:1;min-width:150px;border-radius:var(--r);padding:28px 20px;text-align:center;cursor:pointer;transition:all .25s var(--ease);color:#fff;user-select:none;box-shadow:var(--sh-sm);}
.vou-card:hover{transform:translateY(-4px);box-shadow:var(--sh);}
.vou-ico{margin-bottom:12px;display:flex;align-items:center;justify-content:center;}
.vou-lbl{font-size:13px;font-weight:600;letter-spacing:.01em;}
.vou-section{display:none;}.vou-section.active{display:block;}

/* ══ Modal inputs ══ */
.modal input,.modal select,.modal textarea{background:var(--s2);border:1.5px solid var(--border);color:var(--t1);border-radius:8px;padding:9px 12px;font-family:inherit;font-size:13px;width:100%;transition:border-color .2s,box-shadow .2s;outline:none;}
.modal input:focus,.modal select:focus,.modal textarea:focus{border-color:var(--brand);box-shadow:0 0 0 3px rgba(26,61,143,.08);background:var(--surface);}
.modal input::placeholder,.modal textarea::placeholder{color:var(--t4);}
.modal label{color:var(--t3);font-size:12px;font-weight:600;}
.modal select option{background:#fff;color:var(--t1);}

@keyframes dot-pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.75)}}
.flatpickr-calendar{border-radius:14px!important;box-shadow:0 8px 28px rgba(15,23,42,.13)!important;border:1px solid #e2e8f0!important;font-family:'Cairo',sans-serif!important;direction:rtl!important;}
.flatpickr-months{background:var(--brand)!important;border-radius:13px 13px 0 0!important;padding:4px 0!important;}
.flatpickr-month,.flatpickr-current-month,.flatpickr-current-month .cur-month{color:#fff!important;}
.flatpickr-current-month .flatpickr-monthDropdown-months{color:#fff!important;font-weight:700!important;font-size:14px!important;font-family:'Cairo',sans-serif!important;border:none!important;background:transparent!important;cursor:pointer!important;}
.flatpickr-current-month .flatpickr-monthDropdown-months option{color:#0f172a!important;background:#fff!important;}
.flatpickr-current-month input.cur-year{color:#fff!important;font-weight:800!important;font-size:14px!important;}
.numInputWrapper:hover{background:rgba(255,255,255,.1)!important;}
.arrowUp:after{border-bottom-color:#fff!important;} .arrowDown:after{border-top-color:#fff!important;}
.flatpickr-prev-month svg,.flatpickr-next-month svg{fill:#fff!important;}
.flatpickr-prev-month:hover,.flatpickr-next-month:hover{background:rgba(255,255,255,.15)!important;}
.flatpickr-weekday{color:var(--brand)!important;font-weight:700!important;}
.flatpickr-day.selected{background:var(--brand)!important;border-color:var(--brand)!important;border-radius:8px!important;}
.flatpickr-day:hover{background:var(--brand-m)!important;border-radius:8px!important;}
.flatpickr-day.today{border-color:var(--brand)!important;font-weight:700!important;}
.cust-ff{display:flex;flex-direction:column;gap:3px;}
.cust-ff label{font-size:10px;font-weight:700;color:#1a3d8f;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.cff{padding:6px 10px;border-radius:7px;border:1px solid #dde4f0;background:#f7f9ff;color:#1a1a2e;font-family:inherit;font-size:12px;outline:none;width:100%;}
.cff:focus{border-color:#1a3d8f;background:#fff;}

/* ══ Print ══ */
@media print{.sb,.topbar,.apt-filters,.search-bar,button,.overlay{display:none!important;}.main{margin:0!important;}.content{padding:0!important;}#printArea{display:block!important;}}
#printArea{display:none;position:fixed;inset:0;background:#fff;z-index:9999;padding:32px;overflow:auto;}
.print-doc{max-width:700px;margin:0 auto;font-family:'Cairo',sans-serif;direction:rtl;}
.print-hd{display:flex;justify-content:space-between;align-items:flex-start;border-bottom:3px solid var(--brand);padding-bottom:16px;margin-bottom:20px;}
.print-logo{font-size:22px;font-weight:700;color:#0f172a;}.print-logo span{color:var(--brand);}
.print-type{font-size:18px;font-weight:700;color:#fff;padding:6px 18px;border-radius:8px;}
.print-meta{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:20px;font-size:13px;}
.print-meta-row{display:flex;gap:6px;padding:6px 0;border-bottom:1px solid #f1f5f9;}
.print-meta-row span{color:#64748b;min-width:110px;}.print-meta-row b{color:#0f172a;}
.print-total{background:#f8fafc;border:2px solid var(--brand);border-radius:12px;padding:14px 20px;display:flex;justify-content:space-between;align-items:center;margin-top:16px;}
.print-total-lbl{font-size:14px;font-weight:600;color:#475569;}.print-total-val{font-size:22px;font-weight:700;color:var(--brand);}
.print-footer{text-align:center;margin-top:24px;font-size:11px;color:#94a3b8;border-top:1px solid #e2e8f0;padding-top:12px;}
.print-btns{display:flex;gap:8px;margin-bottom:16px;}
@media(max-width:768px){.main{margin-right:var(--sb);}.charts-row{grid-template-columns:1fr;}.kpi-row{grid-template-columns:repeat(2,1fr);}.vou-cards{gap:10px;}}
</style>
<link rel="manifest" href="/manifest.json">
<meta name="theme-color" content="#1e3a5f">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="بارز موظفين">
<link rel="apple-touch-icon" href="/images/logo-dark.png">
</head>
<body>

<!-- Sidebar -->
<aside class="sb" id="sb">
  <div class="sb-logo"><img src="/images/logo-dark.png" alt="Barez" style="height:46px;width:auto;"></div>
  <div class="sb-bld"><%= staff.building %></div>
  <nav class="sb-nav">
    <div class="sn active" onclick="goTab('dashboard',this)" id="sn-dashboard"><span class="sn-ico"><svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg></span><span class="sn-lbl">لوحة المعلومات</span></div>
    <% const P = staff.permissions && staff.permissions.length ? staff.permissions : ['dashboard','apartments','bookings','customers','housekeeping','activity','new_booking','edit_booking','cancel_booking','vouchers']; %>
    <div class="sn" onclick="goTab('apartments',this)" id="sn-apartments" style="display:<%= P.includes('apartments')?'flex':'none' %>"><span class="sn-ico"><svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg></span><span class="sn-lbl">الشقق والتسكين</span></div>
    <div class="sn" onclick="goTab('bookings',this)" id="sn-bookings" style="display:<%= P.includes('bookings')?'flex':'none' %>"><span class="sn-ico"><svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></span><span class="sn-lbl">الحجوزات</span></div>
    <div class="sn" onclick="goTab('customers',this)" id="sn-customers" style="display:<%= P.includes('customers')?'flex':'none' %>"><span class="sn-ico"><svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></span><span class="sn-lbl">العملاء</span></div>
    <div class="sn" onclick="goTab('housekeeping',this)" id="sn-housekeeping" style="display:<%= P.includes('housekeeping')?'flex':'none' %>"><span class="sn-ico"><svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></span><span class="sn-lbl">خدمة الغرف</span></div>
    <div class="sn" onclick="goTab('activity',this)" id="sn-activity" style="display:<%= P.includes('activity')?'flex':'none' %>"><span class="sn-ico"><svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg></span><span class="sn-lbl">سجل الحركات</span></div>
    <div class="sn" onclick="goTab('vouchers',this)" id="sn-vouchers" style="display:<%= P.includes('vouchers')?'flex':'none' %>"><span class="sn-ico"><svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg></span><span class="sn-lbl">السندات والفواتير</span></div>
  </nav>
  <div class="sb-foot">
    <a href="/staff/logout" class="sb-logout" style="text-decoration:none;"><span class="sn-ico"><svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg></span><span class="sn-lbl">خروج</span></a>
  </div>
</aside>

<!-- Main -->
<div class="main">
  <div class="topbar">
    <div class="tb-left">
      <div class="tb-title" id="tbTitle"><%= staff.building %> — <span>لوحة المعلومات</span></div>
      <div class="tb-meta" id="tbDate"></div>
    </div>
    <div class="tb-right">
      <div class="tb-avatar"><%= staff.name.charAt(0) %></div>
      <div class="tb-info">
        <div class="tb-info-name"><%= staff.name %></div>
        <div class="tb-info-role"><%= staff.role==='manager'?'مدير':'موظف استقبال' %> · <%= staff.building %></div>
      </div>
    </div>
  </div>

  <div class="content">

    <!-- ── Dashboard ── -->
    <div class="tab-section active" id="tab-dashboard">
      <div class="kpi-row">
        <div class="kpi-c"><div class="kpi-ico" style="background:rgba(29,78,216,.1);color:#1D4ED8;"><svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div><div class="kpi-num" id="k-arrivals">—</div><div class="kpi-lbl">وصول اليوم</div></div>
        <div class="kpi-c"><div class="kpi-ico" style="background:rgba(4,120,87,.1);color:#047857;"><svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></div><div class="kpi-num" id="k-checkin">—</div><div class="kpi-lbl">تسجيل الدخول</div></div>
        <div class="kpi-c"><div class="kpi-ico" style="background:rgba(180,83,9,.1);color:#B45309;"><svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg></div><div class="kpi-num" id="k-departures">—</div><div class="kpi-lbl">مغادرة اليوم</div></div>
        <div class="kpi-c"><div class="kpi-ico" style="background:rgba(91,33,182,.1);color:#5B21B6;"><svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div><div class="kpi-num" id="k-guests">—</div><div class="kpi-lbl">النزلاء الباقين</div></div>
        <div class="kpi-c"><div class="kpi-ico" style="background:rgba(26,61,143,.1);color:#1a3d8f;"><svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div><div class="kpi-num" id="k-new">—</div><div class="kpi-lbl">حجوزات جديدة</div></div>
        <div class="kpi-c"><div class="kpi-ico" style="background:rgba(15,23,42,.07);color:#0F172A;"><svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg></div><div class="kpi-num" id="k-rate">—%</div><div class="kpi-lbl">نسبة الإشغال</div></div>
      </div>
      <!-- جدول اليوم -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px;" id="today-schedule-wrap">
        <div style="background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:14px;">
          <div style="font-size:11px;font-weight:700;color:#1A5276;margin-bottom:10px;display:flex;align-items:center;gap:6px;">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="7 10 12 15 17 10"/></svg>
            وصول اليوم
          </div>
          <div id="today-arrivals" style="display:flex;flex-direction:column;gap:6px;max-height:160px;overflow-y:auto;"></div>
        </div>
        <div style="background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:14px;">
          <div style="font-size:11px;font-weight:700;color:#A04000;margin-bottom:10px;display:flex;align-items:center;gap:6px;">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="17 14 12 9 7 14"/></svg>
            مغادرة اليوم
          </div>
          <div id="today-departures" style="display:flex;flex-direction:column;gap:6px;max-height:160px;overflow-y:auto;"></div>
        </div>
      </div>

      <!-- شريط التقدم الشهري -->
      <div style="background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:14px;margin-bottom:14px;" id="monthly-progress-wrap">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
          <div style="font-size:12px;font-weight:700;color:#1e3a5f;">إنجاز الشهر</div>
          <div style="font-size:10px;color:#64748b;" id="monthly-label">— / — حجز</div>
        </div>
        <div style="background:#f1f5f9;border-radius:20px;height:8px;overflow:hidden;margin-bottom:8px;">
          <div id="monthly-bar" style="height:100%;width:0%;background:linear-gradient(90deg,#1a3d8f,#2a5cc7);border-radius:20px;transition:width 1s;"></div>
        </div>
        <div style="display:flex;justify-content:space-between;font-size:10px;color:#94a3b8;">
          <span>0%</span>
          <span id="monthly-pct" style="font-weight:700;color:#1a3d8f;">0%</span>
          <span>الهدف: <span id="monthly-target">20</span> حجز</span>
        </div>
      </div>

      <div class="charts-row">
        <div class="chart-card">
          <div class="chart-title">حالة الشقق الأسبوعية</div>
          <canvas id="weeklyChart" height="180"></canvas>
        </div>
        <div class="chart-card" style="display:flex;flex-direction:column;align-items:center;justify-content:center;">
          <div class="chart-title" style="justify-content:center;">حالة الشقق</div>
          <div class="donut-wrap">
            <canvas id="donutChart" width="170" height="170"></canvas>
            <div class="donut-center">
              <div class="donut-pct" id="donutPct">—</div>
              <div class="donut-pct-sub">إشغال</div>
            </div>
          </div>
          <div id="donutLegend" style="margin-top:12px;font-size:11px;text-align:center;display:flex;gap:12px;justify-content:center;"></div>
        </div>
        <div class="chart-card" style="display:flex;flex-direction:column;align-items:center;justify-content:center;">
          <div class="chart-title" style="justify-content:center;">خدمة الغرف</div>
          <div class="donut-wrap">
            <canvas id="hkDonutChart" width="170" height="170"></canvas>
            <div class="donut-center">
              <div class="donut-pct" id="hkDonutNum">—</div>
              <div class="donut-pct-sub">نظيف</div>
            </div>
          </div>
          <div id="hkDonutLegend" style="margin-top:12px;font-size:11px;text-align:center;display:flex;gap:12px;justify-content:center;"></div>
        </div>
        <div class="chart-card">
          <div class="chart-title">اشغال أنواع الغرف</div>
          <div id="roomTypeChart" style="padding-top:4px;"></div>
        </div>
      </div>
    </div>

    <!-- ── Apartments ── -->
    <div class="tab-section" id="tab-apartments">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;flex-wrap:wrap;gap:8px;">
        <div class="apt-filters" style="margin-bottom:0;">
          <button class="af active" onclick="filterApts('all',this)">الكل</button>
        <button class="af" onclick="filterApts('occupied',this)">مؤجر <span id="fc-occupied">—</span></button>
        <button class="af" onclick="filterApts('vacant',this)">شاغر <span id="fc-vacant">—</span></button>
        <button class="af" onclick="filterApts('checkin_today',this)">وصول اليوم <span id="fc-checkin_today">—</span></button>
        <button class="af" onclick="filterApts('checkout_today',this)">خروج اليوم <span id="fc-checkout_today">—</span></button>
        <button class="af" onclick="filterApts('awaiting',this)">انتظار <span id="fc-awaiting">—</span></button>
        <span id="apts-occ-rate" style="font-size:13px;font-weight:700;align-self:center;"></span>
        <span style="display:flex;align-items:center;gap:5px;font-size:11px;color:var(--t3);padding:4px 10px;background:rgba(4,120,87,.06);border:1px solid rgba(4,120,87,.2);border-radius:20px;">
          <span id="apt-sync-dot" style="width:6px;height:6px;border-radius:50%;background:#047857;display:inline-block;animation:dot-pulse 2s infinite;"></span>
          <span>مباشر ·</span>
          <span id="apt-sync-time">—</span>
        </span>
        </div>
        <% if(P.includes('new_booking')){ %><button class="sbtn" onclick="openNewBkModal()">+ حجز جديد</button><% } %>
      </div>
      <div id="aptsContainer"></div>
    </div>

    <!-- ── Bookings ── -->
    <div class="tab-section" id="tab-bookings">

      <!-- البحث المتقدم -->
      <div style="background:#fff;border:1px solid #e2e8f0;border-radius:12px;margin-bottom:12px;overflow:hidden;">
        <div onclick="toggleBkSearch()" style="display:flex;justify-content:space-between;align-items:center;padding:10px 16px;cursor:pointer;background:#f8fafc;border-bottom:1px solid #e2e8f0;">
          <span style="font-size:12px;font-weight:700;color:#1a3d8f;">البحث المتقدم</span>
          <svg id="bk-chevron" width="14" height="14" fill="none" stroke="#64748b" stroke-width="2" viewBox="0 0 24 24" style="transition:transform .2s;"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
        <div id="bk-search-body" style="padding:12px 16px;">
          <!-- صف 1 -->
          <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:8px;margin-bottom:8px;">
            <div class="cust-ff"><label>من تاريخ</label><input type="date" id="bkDateFrom" class="cff" onchange="loadBookings()"></div>
            <div class="cust-ff"><label>إلى تاريخ</label><input type="date" id="bkDateTo" class="cff" onchange="loadBookings()"></div>
            <div class="cust-ff"><label>رقم العقد</label><input type="text" id="bkNum" class="cff" placeholder="آخر 5 أرقام"></div>
            <div class="cust-ff"><label>الشقة</label><input type="text" id="bkApt" class="cff" placeholder="رقم الشقة"></div>
            <div class="cust-ff"><label>-- نوع الغرفة --</label>
              <select id="bkRoomType" class="cff">
                <option value="">الكل</option>
                <option>غرفة وصالة</option><option>غرفتين وصالة</option><option>استوديو</option><option>جناح</option>
              </select>
            </div>
            <div class="cust-ff"><label>-- مصدر الحجز --</label>
              <select id="bkSource" class="cff">
                <option value="">الكل</option>
                <option>مباشر</option><option>واتساب</option><option>Booking.com</option><option>Airbnb</option><option>موقع</option><option>جاذر ان</option>
              </select>
            </div>
            <div class="cust-ff"><label>رقم مصدر الحجز</label><input type="text" id="bkSourceNum" class="cff" placeholder="رقم"></div>
          </div>
          <!-- صف 2 -->
          <div style="display:grid;grid-template-columns:2fr 1.5fr 1fr 1fr 2fr auto auto;gap:8px;align-items:flex-end;">
            <div class="cust-ff"><label>اسم العميل</label><input type="text" id="bkName" class="cff" placeholder="اسم العميل..."></div>
            <div class="cust-ff"><label>الجوال</label><input type="text" id="bkPhone" class="cff" placeholder="05xxxxxxxx"></div>
            <div class="cust-ff"><label>-- نوع الإيجار --</label>
              <select id="bkType" class="cff">
                <option value="">الكل</option><option value="daily">يومي</option><option value="annual">شهري</option>
              </select>
            </div>
            <div class="cust-ff"><label>-- نوع الحجز --</label>
              <select id="bkCat" class="cff">
                <option value="">الكل</option><option value="inquiry">استفسار</option><option value="daily">حجز</option>
              </select>
            </div>
            <div class="cust-ff"><label>حالة الحجز</label>
              <select id="bk-status-filter" class="cff">
                <option value="open">الحجوزات المفتوحة</option>
                <option value="active">النزلاء المقيمين</option>
                <option value="pending_checkin">الحجوزات (بدون دخول)</option>
                <option value="today_arrival_pending">وصول اليوم (بدون دخول)</option>
                <option value="today_arrival_done">وصول اليوم (دخول)</option>
                <option value="today_arrival_all">وصول اليوم (الجميع)</option>
                <option value="today_dep_pending">مغادرة اليوم (بدون خروج)</option>
                <option value="today_dep_done">مغادرة اليوم (خروج)</option>
                <option value="today_dep_all">مغادرة اليوم (الجميع)</option>
                <option value="closed">الحجوزات المغلقة</option>
                <option value="cancelled">الحجوزات الملغاة</option>
                <option value="all">جميع الحجوزات</option>
              </select>
            </div>
            <button onclick="loadBookings()" style="padding:7px 18px;border-radius:8px;background:linear-gradient(135deg,#1a3d8f,#2a5cc7);border:none;color:#fff;font-family:inherit;font-size:12px;font-weight:700;cursor:pointer;">بحث</button>
            <button onclick="clearBkFilters()" style="padding:7px 14px;border-radius:8px;border:1px solid #e2e8f0;background:#f8fafc;color:#64748b;font-family:inherit;font-size:12px;cursor:pointer;">مسح</button>
          </div>
        </div>
      </div>

      <!-- شريط الأزرار -->
      <div style="display:flex;justify-content:flex-end;gap:8px;margin-bottom:10px;">
        <span style="font-size:11px;color:#94a3b8;align-self:center;" id="bkCount"></span>
        <% if(P.includes('new_booking')){ %><button class="sbtn" onclick="openNewBkModal()" style="background:linear-gradient(135deg,#22c55e,#16a34a);">+ حجز جديد</button><% } %>
      </div>

      <div class="apt-bld">
        <div class="tbl-wrap">
          <table class="stbl">
            <thead><tr><th>رقم العقد</th><th>الشقة</th><th>النزيل</th><th>الجوال</th><th>نوع الإيجار</th><th>الدخول</th><th>الخروج</th><th>الإجمالي</th><th>الحالة</th><th>إجراء</th></tr></thead>
            <tbody id="bkTbody"><tr><td colspan="10" style="text-align:center;padding:30px;color:#94a3b8;">جاري التحميل...</td></tr></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ── Customers ── -->
    <div class="tab-section" id="tab-customers">

      <!-- رأس إدارة العملاء -->
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
        <div style="font-size:11px;color:#64748b;" id="custDateTime"></div>
        <div style="font-size:14px;font-weight:700;color:#0891b2;">إدارة العملاء</div>
      </div>

      <!-- شريط الفلترة -->
      <div style="background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:10px 14px;margin-bottom:10px;display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
        <input type="text" id="custIdNum" class="cff" placeholder="رقم الإثبات" style="width:130px;">
        <input type="text" id="custSearch" class="cff" placeholder="الاسم" style="width:140px;">
        <input type="text" id="custPhone" class="cff" placeholder="جوال" style="width:130px;">
        <select id="custSF" class="cff" style="width:170px;">
          <option value="open">الحجوزات المفتوحة</option>
          <option value="active">النزلاء المقيمين</option>
          <option value="pending_checkin">بدون دخول</option>
          <option value="today_arrival_all">وصول اليوم</option>
          <option value="today_dep_all">مغادرة اليوم</option>
          <option value="closed">مغلقة</option>
          <option value="cancelled">ملغاة</option>
          <option value="all">الجميع</option>
        </select>
        <button onclick="loadCustomers()" style="padding:7px 20px;border-radius:8px;background:#1a3d8f;border:none;color:#fff;font-family:inherit;font-size:12px;font-weight:700;cursor:pointer;">بحث</button>
        <button onclick="clearCustFilters()" style="padding:7px 14px;border-radius:8px;border:1px solid #e2e8f0;background:#f8fafc;color:#64748b;font-family:inherit;font-size:12px;cursor:pointer;">مسح</button>
        <span style="font-size:11px;color:#94a3b8;margin-right:auto;" id="custCount"></span>
      </div>

      <!-- زر إضافة -->
      <div style="margin-bottom:10px;">
        <% if(P.includes('new_booking')){ %>
        <button onclick="openNewBkModal()" style="display:inline-flex;align-items:center;gap:6px;padding:7px 16px;border-radius:8px;background:#0891b2;border:none;color:#fff;font-family:inherit;font-size:12px;font-weight:700;cursor:pointer;">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          إضافة عميل
        </button>
        <% } %>
      </div>

