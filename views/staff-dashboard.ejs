<script>
const BUILDING = '<%= staff.building %>';
const STAFF_ROLE = '<%= staff.role %>';
const isManager = STAFF_ROLE === 'manager';
const PERMS = <%- JSON.stringify(staff.permissions && staff.permissions.length ? staff.permissions : ['dashboard','apartments','bookings','customers','housekeeping','activity','new_booking','edit_booking','cancel_booking','vouchers']) %>;
const can = p => PERMS.includes(p);
const canMaintenance = () => isManager || PERMS.includes('maintenance');
let aptsFilter='all', aptsRawData=null, roomInfoMap={};
let weeklyChartInst=null, donutChartInst=null, hkDonutInst=null;
let hkCurrentApt=null;

// ── Utils ────────────────────────────────────────────────
function toast(msg, type='info'){
  const t=document.getElementById('toast');
  t.className='show';
  if(type==='success') t.classList.add('toast-success');
  if(type==='error')   t.classList.add('toast-error');
  t.innerHTML=msg;
  clearTimeout(t._tmr);
  t._tmr=setTimeout(()=>t.classList.remove('show','toast-success','toast-error'),2800);
}
function setFieldState(inputId,wrapId,hintId,state,msg=''){
  const inp=document.getElementById(inputId);
  const hint=document.getElementById(hintId);
  if(!inp) return;
  inp.classList.remove('f-idle','f-valid','f-error');
  inp.classList.add(state==='valid'?'f-valid':state==='error'?'f-error':'f-idle');
  if(hint){hint.textContent=msg;hint.className='field-hint '+(state==='error'?'err':state==='valid'?'ok':'');}
}
function shakeField(inputId,wrapId,hintId,errMsg){
  const inp=document.getElementById(inputId);
  if(inp){inp.classList.remove('f-error');void inp.offsetWidth;inp.classList.add('f-error');}
  setFieldState(inputId,wrapId,hintId,'error',errMsg);
}
function validateField(inputId,wrapId,hintId,errMsg){
  const el=document.getElementById(inputId); if(!el) return;
  const val=el.tagName==='SELECT'?el.value:el.value.trim();
  setFieldState(inputId,wrapId,hintId,val?'valid':'idle','');
}
function validatePhone(){
  const v=document.getElementById('nb-phone').value;
  if(v.length===10&&/^\d{10}$/.test(v)) setFieldState('nb-phone','fw-phone','fh-phone','valid','');
  else if(v.length===0) setFieldState('nb-phone','fw-phone','fh-phone','idle','');
  else setFieldState('nb-phone','fw-phone','fh-phone','idle','');
}

function animateNum(el, target, suffix=''){
  if(!el||isNaN(target)) return;
  const duration=700;
  const startTime=performance.now();
  const update=t=>{
    const progress=Math.min((t-startTime)/duration,1);
    const ease=1-Math.pow(1-progress,3);
    el.textContent=Math.round(target*ease)+suffix;
    if(progress<1) requestAnimationFrame(update);
  };
  requestAnimationFrame(update);
}
function esc(s){ return String(s||'').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
function fDate(d){ if(!d)return'—'; const dt=new Date(d); return dt.toLocaleDateString('en-GB',{day:'2-digit',month:'2-digit',year:'numeric',calendar:'gregory'}); }
function waPhone(p){ let n=(p||'').replace(/\D/g,''); if(n.startsWith('966'))return n; if(n.startsWith('0'))return'966'+n.slice(1); if(n.startsWith('5'))return'966'+n; return n; }
function statusBadge(s){
  const m={active:'b-active مفتوح',awaiting_checkin:'b-awaiting انتظار الدخول',awaiting_payment:'b-awaiting_payment انتظار الدفع',checkout:'b-checkout خروج',pending:'b-pending جديد',cancelled:'b-cancelled ملغي'};
  const [cls,lbl]=(m[s]||'b-pending '+s).split(' ');
  return `<span class="badge ${cls}">${lbl||s}</span>`;
}

// ── Mobile sidebar ───────────────────────────────────────
function toggleSidebar(){
  const sb=document.getElementById('sb');
  const ov=document.getElementById('sb-overlay');
  const isOpen=sb.classList.contains('open');
  if(isOpen){ closeSidebar(); } else {
    sb.classList.add('open');
    ov.classList.add('show');
    document.body.style.overflow='hidden';
  }
}
function closeSidebar(){
  const sb=document.getElementById('sb');
  const ov=document.getElementById('sb-overlay');
  sb.classList.remove('open');
  ov.classList.remove('show');
  document.body.style.overflow='';
}

