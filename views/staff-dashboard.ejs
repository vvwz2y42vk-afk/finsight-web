          <button class="sbtn" onclick="openVouModal('disbursement')" style="background:linear-gradient(135deg,#f59e0b,#d97706);">+ إضافة سند صرف</button>
          <button class="sbtn" onclick="loadVouList('disbursement')" style="background:#475569;">تحديث</button>
        </div>
        <div class="apt-bld">
          <div style="font-size:15px;font-weight:800;color:#1e293b;margin-bottom:14px;">سندات الصرف</div>
          <div class="tbl-wrap"><table class="stbl">
            <thead><tr><th>الرقم</th><th>التاريخ</th><th>المستلم</th><th>البيان</th><th>المبلغ</th><th>إجراء</th></tr></thead>
            <tbody id="vou-disbursement-tbody"><tr><td colspan="6" style="text-align:center;padding:20px;color:#94a3b8;">اضغط تحديث لتحميل البيانات</td></tr></tbody>
