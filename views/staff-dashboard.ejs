            <div>
              <label style="font-size:11px;font-weight:600;color:var(--t3);display:block;margin-bottom:4px;">الشهر</label>
              <select id="mr-month" style="padding:8px 10px;border:1.5px solid var(--border);border-radius:9px;font-family:inherit;font-size:12px;background:#fff;outline:none;">
                <% for(let i=1;i<=12;i++){ %><option value="<%=i%>"><%=i%></option><% } %>
              </select>
            </div>
            <div style="display:flex;gap:6px;">
              <button onclick="loadMonthlyReport()" style="padding:8px 20px;background:var(--brand);border:none;border-radius:9px;color:#fff;font-family:inherit;font-size:12px;font-weight:700;cursor:pointer;">عرض</button>
              <button onclick="printMonthlyReport()" style="padding:8px 14px;background:var(--surface);border:1.5px solid var(--border);border-radius:9px;font-family:inherit;font-size:12px;cursor:pointer;" title="طباعة">🖨️</button>
            </div>
          </div>
          <div style="display:flex;gap:20px;margin-top:14px;flex-wrap:wrap;">
            <label style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--t2);cursor:pointer;"><input type="radio" name="mr-type" value="detail" checked style="cursor:pointer;accent-color:var(--brand);"> تفصيلي للحجوزات</label>
            <label style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--t2);cursor:pointer;"><input type="radio" name="mr-type" value="summary" style="cursor:pointer;accent-color:var(--brand);"> تجميعي للحجوزات</label>
            <label style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--t2);cursor:pointer;"><input type="radio" name="mr-type" value="total" style="cursor:pointer;accent-color:var(--brand);"> تجميعي كلي</label>
          </div>
        </div>
        <div id="mr-body"></div>
      </div>

      <!-- ── تقرير نسب الإشغال ── -->
      <div style="margin-bottom:32px;border-bottom:2.5px solid var(--border);padding-bottom:28px;">
        <div style="font-size:11px;font-weight:700;color:var(--brand);text-transform:uppercase;letter-spacing:.08em;margin-bottom:16px;">تقرير نسب الإشغال</div>
        <div style="background:var(--surface);border:1.5px solid var(--border);border-radius:14px;padding:16px;margin-bottom:16px;">
          <div style="display:flex;gap:10px;align-items:flex-end;flex-wrap:wrap;">
            <div>
              <label style="font-size:11px;font-weight:600;color:var(--t3);display:block;margin-bottom:4px;">من</label>
              <input type="date" id="occ-from" style="padding:8px 10px;border:1.5px solid var(--border);border-radius:9px;font-family:inherit;font-size:12px;background:#fff;outline:none;">
            </div>
            <div>
              <label style="font-size:11px;font-weight:600;color:var(--t3);display:block;margin-bottom:4px;">إلى</label>
              <input type="date" id="occ-to" style="padding:8px 10px;border:1.5px solid var(--border);border-radius:9px;font-family:inherit;font-size:12px;background:#fff;outline:none;">
            </div>
            <div>
              <label style="font-size:11px;font-weight:600;color:var(--t3);display:block;margin-bottom:4px;">الشقة</label>
              <select id="occ-apt" style="padding:8px 10px;border:1.5px solid var(--border);border-radius:9px;font-family:inherit;font-size:12px;background:#fff;outline:none;min-width:120px;">
                <option value="">الجميع</option>
              </select>
            </div>
            <div style="display:flex;gap:6px;">
              <button onclick="loadOccupancyReport()" style="padding:8px 20px;background:var(--brand);border:none;border-radius:9px;color:#fff;font-family:inherit;font-size:12px;font-weight:700;cursor:pointer;">عرض</button>
              <button onclick="printOccupancyReport()" style="padding:8px 14px;background:var(--surface);border:1.5px solid var(--border);border-radius:9px;font-family:inherit;font-size:12px;cursor:pointer;" title="طباعة">🖨️</button>
            </div>
          </div>
          <div style="display:flex;gap:20px;margin-top:14px;flex-wrap:wrap;">
            <label style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--t2);cursor:pointer;"><input type="radio" name="occ-type" value="rooms" checked style="cursor:pointer;accent-color:var(--brand);"> نسبة الإشغال للغرف</label>
            <label style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--t2);cursor:pointer;"><input type="radio" name="occ-type" value="types" style="cursor:pointer;accent-color:var(--brand);"> نسبة الإشغال لأنواع الغرف</label>
          </div>
        </div>
        <div id="occ-body"></div>
      </div>

      <!-- اليوم -->
      <div style="font-size:11px;font-weight:700;color:var(--brand);text-transform:uppercase;letter-spacing:.08em;margin-bottom:10px;">اليوم</div>
      <div class="kpi-row" style="margin-bottom:24px;" id="rpt-today-kpis">
        <div class="kpi-c"><div class="kpi-ico" style="background:var(--green-bg);color:var(--green);"><svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="23" y2="8"/><line x1="21" y1="6" x2="21" y2="10"/></svg></div><div class="kpi-num" id="rpt-arrivals">—</div><div class="kpi-lbl">وصولات اليوم</div></div>
        <div class="kpi-c"><div class="kpi-ico" style="background:var(--amber-bg);color:var(--amber);"><svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="23" y1="11" x2="17" y2="11"/></svg></div><div class="kpi-num" id="rpt-departures">—</div><div class="kpi-lbl">مغادرات اليوم</div></div>
        <div class="kpi-c"><div class="kpi-ico" style="background:var(--brand-m);color:var(--brand);"><svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg></div><div class="kpi-num" id="rpt-occ">—%</div><div class="kpi-lbl">نسبة الإشغال</div></div>
        <div class="kpi-c"><div class="kpi-ico" style="background:rgba(4,120,87,.08);color:#047857;"><svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></div><div class="kpi-num" id="rpt-today-rev">—</div><div class="kpi-lbl">إيراد الحجوزات اليوم</div></div>
      </div>

      <!-- الشهر -->
      <div style="font-size:11px;font-weight:700;color:var(--brand);text-transform:uppercase;letter-spacing:.08em;margin-bottom:10px;">الشهر الحالي</div>
      <div class="kpi-row" style="margin-bottom:24px;">
        <div class="kpi-c"><div class="kpi-ico" style="background:var(--brand-m);color:var(--brand);"><svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div><div class="kpi-num" id="rpt-month-bk">—</div><div class="kpi-lbl">إجمالي الحجوزات</div></div>
        <div class="kpi-c"><div class="kpi-ico" style="background:var(--green-bg);color:var(--green);"><svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></div><div class="kpi-num" id="rpt-month-rev">—</div><div class="kpi-lbl">إجمالي الإيرادات</div></div>
        <div class="kpi-c"><div class="kpi-ico" style="background:rgba(4,120,87,.08);color:#047857;"><svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></div><div class="kpi-num" id="rpt-month-paid">—</div><div class="kpi-lbl">المحصّل</div></div>
        <div class="kpi-c"><div class="kpi-ico" style="background:var(--red-bg);color:var(--red);"><svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg></div><div class="kpi-num" id="rpt-month-rem">—</div><div class="kpi-lbl">المتبقي</div></div>
        <div class="kpi-c"><div class="kpi-ico" style="background:var(--blue-bg);color:var(--blue);"><svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div><div class="kpi-num" id="rpt-month-daily-rev">—</div><div class="kpi-lbl">إيراد يومي</div></div>
        <div class="kpi-c"><div class="kpi-ico" style="background:var(--purple-bg);color:var(--purple);"><svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg></div><div class="kpi-num" id="rpt-month-annual-rev">—</div><div class="kpi-lbl">إيراد شهري</div></div>
      </div>

      <!-- مخطط الإيرادات -->
      <div class="chart-card" style="margin-bottom:24px;">
        <div class="chart-title" id="rpt-chart-title">الإيرادات اليومية</div>
        <canvas id="revenueChart" style="width:100%;height:200px;"></canvas>
      </div>

      <!-- مخطط مقارنة الأشهر -->
      <div class="chart-card" style="margin-bottom:24px;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
          <div class="chart-title" style="margin-bottom:0;">مقارنة الإيرادات — آخر 12 شهر</div>
          <div id="yearly-total" style="font-size:13px;font-weight:700;color:var(--green);"></div>
        </div>
        <canvas id="yearlyChart" style="width:100%;height:220px;"></canvas>
        <div id="yearly-summary" style="display:flex;gap:16px;margin-top:14px;flex-wrap:wrap;"></div>
      </div>

      <!-- المديونيات -->
      <div style="font-size:11px;font-weight:700;color:var(--red);text-transform:uppercase;letter-spacing:.08em;margin-bottom:10px;">المديونيات — المبالغ المتبقية</div>
      <div id="rpt-debts-wrap"></div>

    </div>

    <!-- ── Calendar ── -->
    <div class="tab-section" id="tab-calendar">
      <!-- header -->
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;flex-wrap:wrap;gap:10px;">
        <div style="display:flex;align-items:center;gap:10px;">
          <div style="font-size:15px;font-weight:800;color:var(--t1);">التقويم الشهري</div>
          <!-- legend -->
          <div style="display:flex;gap:8px;flex-wrap:wrap;">
            <span style="display:inline-flex;align-items:center;gap:4px;font-size:10px;color:var(--t3);"><span style="width:10px;height:10px;border-radius:3px;background:#DBEAFE;border:1px solid #93C5FD;display:inline-block;"></span>دخول</span>
            <span style="display:inline-flex;align-items:center;gap:4px;font-size:10px;color:var(--t3);"><span style="width:10px;height:10px;border-radius:3px;background:#FFE4E6;border:1px solid #FCA5A5;display:inline-block;"></span>مشغول</span>
            <span style="display:inline-flex;align-items:center;gap:4px;font-size:10px;color:var(--t3);"><span style="width:10px;height:10px;border-radius:3px;background:#FEF3C7;border:1px solid #FCD34D;display:inline-block;"></span>خروج</span>
          </div>
        </div>
        <div style="display:flex;align-items:center;gap:6px;">
          <button onclick="calPrevMonth()" style="width:30px;height:30px;border-radius:8px;border:1px solid var(--border);background:var(--surface);cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;color:var(--brand);">&#8249;</button>
          <span id="cal-month-label" style="font-size:13px;font-weight:700;color:var(--brand);min-width:130px;text-align:center;"></span>
          <button onclick="calNextMonth()" style="width:30px;height:30px;border-radius:8px;border:1px solid var(--border);background:var(--surface);cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;color:var(--brand);">&#8250;</button>
        </div>
      </div>
      <!-- two-column layout -->
      <div class="cal-layout">
        <!-- main calendar -->
        <div class="cal-main">
          <div style="background:var(--surface);border-radius:var(--r);border:1px solid var(--border);box-shadow:var(--sh-sm);overflow-x:auto;padding:14px;">
            <div id="calContainer"><div style="text-align:center;padding:40px;color:var(--t4);">جاري التحميل...</div></div>
          </div>
        </div>
        <!-- quick summary panel -->
        <div class="cal-panel" id="calPanel">
          <div class="cal-panel-hd">
            <div class="cal-panel-ttl">وصول اليوم</div>
            <div class="cal-panel-sub" id="cal-panel-date">—</div>
          </div>
          <div class="cal-panel-body" id="cal-panel-body">
            <div style="text-align:center;padding:20px 10px;color:var(--t4);font-size:12px;">جاري التحميل...</div>
          </div>
        </div>
      </div>
    </div>

    <!-- ── Channel Manager ── -->
    <div class="tab-section" id="tab-channels">

      <!-- Header -->
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;flex-wrap:wrap;gap:12px;">
        <div>
          <div style="font-size:17px;font-weight:800;color:var(--t1);letter-spacing:-.02em;">إدارة قنوات الحجز</div>
          <div style="font-size:12px;color:var(--t4);margin-top:3px;">ربط جميع المنصات · منع الازدواجية · إشعارات تلقائية</div>
        </div>
        <button class="sbtn" onclick="syncAllChannels(this)" style="display:flex;align-items:center;gap:8px;">
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="1 4 1 10 7 10"/><polyline points="23 20 23 14 17 14"/><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15"/></svg>
          مزامنة الكل
        </button>
      </div>

      <!-- KPI Strip -->
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:12px;margin-bottom:24px;" id="ch-kpi-row">
        <div class="kpi-c" style="padding:16px 18px;">
          <div style="font-size:10px;font-weight:700;color:var(--t3);letter-spacing:.04em;margin-bottom:8px;">منصات مفعّلة</div>
          <div style="font-size:28px;font-weight:900;color:var(--brand);" id="ch-kpi-active">—</div>
        </div>
        <div class="kpi-c" style="padding:16px 18px;">
          <div style="font-size:10px;font-weight:700;color:var(--t3);letter-spacing:.04em;margin-bottom:8px;">حجوزات القنوات</div>
          <div style="font-size:28px;font-weight:900;color:var(--green);" id="ch-kpi-total">—</div>
        </div>
        <div class="kpi-c" style="padding:16px 18px;">
          <div style="font-size:10px;font-weight:700;color:var(--t3);letter-spacing:.04em;margin-bottom:8px;">آخر مزامنة</div>
          <div style="font-size:13px;font-weight:700;color:var(--t2);margin-top:6px;" id="ch-kpi-sync">—</div>
        </div>
        <div class="kpi-c" style="padding:16px 18px;">
          <div style="font-size:10px;font-weight:700;color:var(--t3);letter-spacing:.04em;margin-bottom:8px;">إيميل الإشعارات</div>
          <div style="font-size:11px;font-weight:600;color:var(--t2);margin-top:6px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" id="ch-kpi-email">—</div>
        </div>
      </div>

      <!-- Platform Cards -->
      <div class="ch-grid" id="ch-cards-container">
        <!-- Rendered by JS -->
        <div class="ch-empty">جاري تحميل إعدادات القنوات…</div>
      </div>

      <!-- How-to Guide (accordion) -->
      <div class="ch-how" id="ch-how">
        <div class="ch-how-hd" onclick="toggleChHow()">
          <svg width="16" height="16" fill="none" stroke="var(--brand)" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <div class="ch-how-hd-title">كيف تربط كل منصة؟ — دليل خطوة بخطوة</div>
          <svg id="ch-how-arrow" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="transition:transform .3s;flex-shrink:0;"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
        <div class="ch-how-body" id="ch-how-body">

          <!-- Airbnb -->
          <div style="margin-bottom:20px;">
            <div style="font-size:12px;font-weight:800;color:#FF5A5F;margin-bottom:10px;display:flex;align-items:center;gap:8px;">
              <span style="font-size:18px;">🏡</span> Airbnb — ربط عبر iCal
            </div>
            <div class="ch-how-step">
              <div class="ch-how-num">١</div>
              <div class="ch-how-text"><strong>احصل على رابط iCal من Airbnb</strong><p>ادخل على Airbnb Host → الوحدة → التقويم → استيراد/تصدير التقويم → انسخ "رابط تصدير iCal"</p></div>
            </div>
            <div class="ch-how-step">
              <div class="ch-how-num">٢</div>
              <div class="ch-how-text"><strong>الصق الرابط في حقل "رابط iCal للاستيراد" هنا</strong><p>سيقرأ النظام الحجوزات منه تلقائياً عند كل مزامنة</p></div>
            </div>
            <div class="ch-how-step">
              <div class="ch-how-num">٣</div>
              <div class="ch-how-text"><strong>أضف رابط iCal الخاص بنا إلى Airbnb</strong><p>انسخ "رابط iCal للتصدير" من هنا، ثم في Airbnb → التقويم → استيراد تقويم خارجي → الصق الرابط. هكذا تُغلق Airbnb الأيام المحجوزة عندنا تلقائياً.</p></div>
            </div>
          </div>

          <!-- Booking.com -->
          <div style="margin-bottom:20px;">
            <div style="font-size:12px;font-weight:800;color:#003580;margin-bottom:10px;display:flex;align-items:center;gap:8px;">
              <span style="font-size:18px;">🌐</span> Booking.com — ربط عبر iCal أو API
            </div>
            <div class="ch-how-step">
              <div class="ch-how-num">١</div>
              <div class="ch-how-text"><strong>رابط iCal من Booking.com Extranet</strong><p>ادخل على Extranet → Calendar → Sync Calendar → "Export to iCal" → انسخ الرابط والصقه هنا</p></div>
            </div>
            <div class="ch-how-step">
              <div class="ch-how-num">٢</div>
              <div class="ch-how-text"><strong>أضف رابطنا إلى Booking.com</strong><p>في نفس صفحة Sync Calendar → "Import iCal" → الصق رابط iCal الخاص بنا</p></div>
            </div>
            <div class="ch-how-step">
              <div class="ch-how-num">٣</div>
              <div class="ch-how-text"><strong>للربط المباشر عبر API (للشركاء)</strong><p>أدخل <code>hotel_id</code> من لوحة Booking.com. يتطلب الانضمام لبرنامج Connectivity Partners. راسل Booking.com للحصول على مفاتيح API.</p></div>
            </div>
          </div>

          <!-- Gathering -->
          <div style="margin-bottom:20px;">
            <div style="font-size:12px;font-weight:800;color:#1a6b3c;margin-bottom:10px;display:flex;align-items:center;gap:8px;">
              <span style="font-size:18px;">🏘️</span> Gathering — ربط عبر iCal أو Webhook
            </div>
            <div class="ch-how-step">
              <div class="ch-how-num">١</div>
              <div class="ch-how-text"><strong>من لوحة Gathering → إعدادات العقار → مزامنة التقويم</strong><p>انسخ رابط iCal والصقه في الحقل أعلاه</p></div>
            </div>
            <div class="ch-how-step">
              <div class="ch-how-num">٢</div>
              <div class="ch-how-text"><strong>إعداد Webhook (اختياري للإشعار الفوري)</strong><p>في Gathering → إعدادات → Webhook URL، أدخل:<br><code id="ch-webhook-url-g">https://yoursite.com/staff/api/channels/webhook/gathering?secret=SECRET</code></p></div>
            </div>
          </div>

          <!-- Website -->
          <div>
            <div style="font-size:12px;font-weight:800;color:var(--brand);margin-bottom:10px;display:flex;align-items:center;gap:8px;">
              <span style="font-size:18px;">✅</span> موقعنا — متصل تلقائياً
            </div>
            <div class="ch-how-step">
              <div class="ch-how-num">١</div>
              <div class="ch-how-text"><strong>الموقع مربوط مباشرة بقاعدة البيانات</strong><p>حجوزات الموقع تظهر فوراً في الحجوزات. لا تحتاج إعداداً إضافياً.</p></div>
            </div>
            <div class="ch-how-step">
              <div class="ch-how-num">٢</div>
