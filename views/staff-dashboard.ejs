function toggleCustSearch(){
  const body=document.getElementById('cust-search-body');
  const chev=document.getElementById('cust-chevron');
  const open=body.style.display!=='none';
  body.style.display=open?'none':'block';
  if(chev) chev.style.transform=open?'rotate(-90deg)':'rotate(0deg)';
}

function clearCustFilters(){
  ['custSearch','custIdSearch','custPhoneSearch'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
  const cat=document.getElementById('custCatFilter');if(cat)cat.value='';
  const cb=document.getElementById('custShowCompanies');if(cb)cb.checked=false;
  _custFilter='all';
  loadCustomers();
}
let _custTimer;
function custSearchDebounce(){ clearTimeout(_custTimer); _custTimer=setTimeout(loadCustomers,300); }

const BTYPE_LBL={daily:'يومي',annual:'شهري',inquiry:'استفسار'};

// تحديث الوقت في رأس العملاء
function updateCustDateTime(){
  const el=document.getElementById('custDateTime');
  if(!el)return;
  const now=new Date();
  const d=now.toLocaleDateString('ar-SA',{weekday:'long',year:'numeric',month:'long',day:'numeric'});
  const t=now.toLocaleTimeString('ar-SA',{hour:'2-digit',minute:'2-digit',second:'2-digit'});
  el.textContent=`${d}  ${t}`;
}
setInterval(updateCustDateTime,1000);

const CUST_CAT={regular:{lbl:'عادي',bg:'#f1f5f9',c:'#64748b'},vip:{lbl:'VIP',bg:'rgba(234,179,8,.15)',c:'#b45309'},blocked:{lbl:'محظور',bg:'rgba(220,38,38,.1)',c:'#dc2626'}};
let _custData=[], _custTotal=0, _custPage=1, _custApiPage=1, _custLimit=100, _custFilter='all';

function setCustFilter(f){
  _custFilter=f; _custApiPage=1;
  ['All','Blocked','Vip'].forEach(x=>{
    const btn=document.getElementById('custFilter'+x);
    if(!btn) return;
    const active=f===(x==='All'?'all':x.toLowerCase());
    const colors={All:'#1a3d8f',Blocked:'#dc2626',Vip:'#b45309'};
    const col=colors[x];
    btn.style.background=active?col:'#fff';
    btn.style.color=active?'#fff':col;
    btn.style.borderColor=active?col:'#e2e8f0';
  });
  loadCustomers();
}
function setCustPage(p){_custPage=p;renderCustRows();}

function renderCustRows(){
  const tb=document.getElementById('custTbody');
  const cnt=document.getElementById('custCount');
  const slice=_custData.slice((_custPage-1)*PER_PAGE,_custPage*PER_PAGE);
  if(cnt) cnt.textContent=_custTotal?`${_custTotal.toLocaleString('ar')} عميل`:'';
  if(!slice.length){tb.innerHTML='<tr><td colspan="10" style="text-align:center;padding:30px;color:#94a3b8;">لا توجد نتائج</td></tr>';return;}
  const offset=(_custPage-1)*PER_PAGE;
  const ID_TYPES={national_id:'هوية وطنية',passport:'جواز سفر',iqama:'إقامة',family_card:'بطاقة عائلة'};
  tb.innerHTML=slice.map((c,i)=>{
    const cat=CUST_CAT[c.category]||CUST_CAT.regular;
    const phone=c.phone&&!c.phone.startsWith('nzl-')&&!c.phone.startsWith('nophone-')&&!c.phone.startsWith('dup-')?c.phone:'—';
    const starIcon=c.category==='vip'?'<span style="color:#f59e0b;font-size:14px;" title="VIP">⭐</span>':c.category==='blocked'?'<span style="color:#dc2626;font-size:14px;" title="محظور">🚫</span>':'';
    return`<tr>
      <td data-label="الاسم">
        <div style="display:flex;align-items:center;gap:6px;">
          ${starIcon}
          <span onclick="openGuestCard('${esc(c.phone||'')}')" style="cursor:pointer;color:var(--brand);font-weight:700;">${esc(c.name||'—')}</span>
        </div>
      </td>
      <td data-label="نوع الإثبات" style="font-size:11px;color:var(--t3);">${ID_TYPES[c.idType]||c.idType||'—'}</td>
      <td data-label="رقم الإثبات" style="font-family:monospace;font-size:12px;color:var(--t2);">${esc(c.idNumber||'—')}</td>
      <td data-label="مكان الإصدار" style="font-size:11px;color:var(--t4);">${esc(c.nationality||'—')}</td>
      <td data-label="جوال">${phone!=='—'?`<a href="https://wa.me/${waPhone(c.phone)}" target="_blank" style="color:var(--brand);text-decoration:none;font-family:monospace;font-size:12px;">${esc(phone)}</a>`:'<span style="color:var(--t4);">—</span>'}</td>
      <td data-label="البريد" style="font-size:11px;color:var(--t4);">${esc(c.email||'—')}</td>
      <td data-label="الحجوزات" style="text-align:center;font-weight:700;color:var(--brand);">${c.totalBookings||0}</td>
      <td data-label="آخر زيارة" style="font-size:11px;color:var(--t4);">${c.lastSeen?fDate(c.lastSeen):'—'}</td>
      <td data-label="التصنيف"><span style="padding:3px 9px;border-radius:20px;font-size:10px;font-weight:700;background:${cat.bg};color:${cat.c};">${cat.lbl}</span></td>
      <td data-label="العمليات">
        <div class="tbl-act">
          <button class="ia ia-view" data-tip="عرض الملف" onclick="openGuestCard('${esc(c.phone||'')}')"><svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></button>
          <button class="ia" data-tip="VIP" onclick="setCustCategory('${c._id}','vip')" style="background:rgba(234,179,8,.1);color:#b45309;">⭐</button>
          <button class="ia ia-cancel" data-tip="محظور" onclick="setCustCategory('${c._id}','blocked')">🚫</button>
        </div>
      </td>
    </tr>`;}).join('');
  // pagination داخل الصفحة الحالية
  renderPager(_custPage,_custData.length,'setCustPage','custPager');
  // أزرار التنقل بين صفحات API
  const totalApiPages = Math.ceil(_custTotal/_custLimit);
  const apiPager = document.getElementById('custApiPager');
  if(apiPager){
    if(totalApiPages<=1){apiPager.innerHTML='';return;}
    let html=`<div style="display:flex;gap:6px;align-items:center;justify-content:center;margin-top:10px;flex-wrap:wrap;">`;
    if(_custApiPage>1) html+=`<button onclick="loadCustomersPage(${_custApiPage-1})" style="padding:5px 14px;border-radius:8px;border:1px solid #e2e8f0;background:#f8fafc;cursor:pointer;font-family:inherit;">‹ السابق</button>`;
    html+=`<span style="font-size:12px;color:#64748b;">صفحة ${_custApiPage} من ${totalApiPages}</span>`;
    if(_custApiPage<totalApiPages) html+=`<button onclick="loadCustomersPage(${_custApiPage+1})" style="padding:5px 14px;border-radius:8px;border:1px solid #e2e8f0;background:#f8fafc;cursor:pointer;font-family:inherit;">التالي ›</button>`;
    html+=`</div>`;
    apiPager.innerHTML=html;
  }
}

async function loadCustomersPage(apiPage=1){
  _custApiPage=apiPage;
  loadCustomers();
}

async function setCustCategory(id, category){
  const c=_custData.find(x=>x._id===id);
  const prev=c?c.category:null;
  if(c){ c.category=category; renderCustRows(); }
  try{
    const r=await fetch('/staff/api/guests/'+id+'/category',{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({category})});
    if(!r.ok){ if(c){ c.category=prev; renderCustRows(); } toast('❌ فشل تحديث التصنيف'); return; }
    toast('✅ تم تحديث التصنيف');
  }catch(e){ if(c){ c.category=prev; renderCustRows(); } toast('❌ حدث خطأ'); }
}

async function loadCustomers(){
  updateCustDateTime();
  const nameQ=(document.getElementById('custSearch')?.value||'').trim();
  const idQ=(document.getElementById('custIdSearch')?.value||'').trim();
  const phoneQ=(document.getElementById('custPhoneSearch')?.value||'').trim();
  const catSel=document.getElementById('custCatFilter')?.value||'';
  const q=nameQ||idQ||phoneQ;
  if(q||catSel) _custApiPage=1;
  const catParam=catSel||(_custFilter==='all'?'':_custFilter);
  const params=new URLSearchParams({q, page:_custApiPage, limit:_custLimit, category:catParam});
  if(idQ) params.set('idNumber',idQ);
  if(phoneQ) params.set('phone',phoneQ);
  const tb=document.getElementById('custTbody');
  if(tb) tb.innerHTML='<tr><td colspan="10" style="text-align:center;padding:20px;color:#94a3b8;">⏳ جاري التحميل…</td></tr>';
  try{
    const r=await fetch('/staff/api/customers?'+params);
    const json=await r.json();
    _custData=Array.isArray(json)?json:(json.data||[]);
    _custTotal=json.total||_custData.length;
    _custPage=1;
    renderCustRows();
  }catch(e){
    if(tb) tb.innerHTML='<tr><td colspan="10" style="text-align:center;padding:30px;color:#dc2626;">❌ تعذر تحميل البيانات — تحقق من الاتصال</td></tr>';
  }
}

// ── Housekeeping ─────────────────────────────────────────
async function loadHousekeeping(){
  try{
    const r=await fetch('/staff/api/housekeeping');
    const list=await r.json();
    _hkData=list; // حفظ للجدول
    const grid=document.getElementById('hkGrid');
    const ST={
      clean:{lbl:'نظيف',cls:'hk-clean-c',dot:'#047857'},
      dirty:{lbl:'غير نظيف',cls:'hk-dirty-c',dot:'#B91C1C'},
      inspecting:{lbl:'قيد الفحص',cls:'hk-inspect-c',dot:'#B45309'},
      maintenance:{lbl:'صيانة',cls:'hk-maint-c',dot:'#5B21B6'}
    };
    let cntClean=0,cntDirty=0,cntInsp=0,cntMaint=0;
    list.forEach(t=>{if(t.status==='clean')cntClean++;else if(t.status==='dirty')cntDirty++;else if(t.status==='inspecting')cntInsp++;else if(t.status==='maintenance')cntMaint++;});
    const sumEl=document.getElementById('hk-summary-txt');
    if(sumEl) sumEl.textContent=`نظيف: ${cntClean} · غير نظيف: ${cntDirty} · صيانة: ${cntMaint}`;
    // تحديث عدادات الحالة (نزيل)
    const cClean=document.getElementById('hk-cnt-clean'); if(cClean) cClean.textContent=cntClean;
    const cDirty=document.getElementById('hk-cnt-dirty'); if(cDirty) cDirty.textContent=cntDirty;
    const cInsp=document.getElementById('hk-cnt-inspect'); if(cInsp) cInsp.textContent=cntInsp;
    const cMaint=document.getElementById('hk-cnt-maint'); if(cMaint) cMaint.textContent=cntMaint;
    // تحديث قائمة الشقق في فلتر نزيل
    const aptSel=document.getElementById('hk-filter-apt');
    if(aptSel&&aptSel.options.length<=1){
      const apts=[...new Set(list.map(t=>t.apt))].sort();
      apts.forEach(a=>{const opt=document.createElement('option');opt.value=a;opt.textContent=a;aptSel.appendChild(opt);});
    }
    // تطبيق فلتر الحالة
    const statusFilter=document.getElementById('hk-filter-status')?.value||'';
    const aptFilter=document.getElementById('hk-filter-apt')?.value||'';
    const filtered=list.filter(t=>{
      if(statusFilter&&t.status!==statusFilter) return false;
      if(aptFilter&&t.apt!==aptFilter) return false;
      return true;
    });
    if(grid) grid.innerHTML=filtered.map(t=>{
      const s=ST[t.status]||ST.clean;
      return `<div class="hk-card ${s.cls}" onclick="openHkModal('${t.apt}','${t.status}','${esc(t.notes||'')}')">
        <div class="hk-apt">${esc(t.apt)}</div>
        <div class="hk-badge"><span style="width:6px;height:6px;border-radius:50%;background:${s.dot};display:inline-block;flex-shrink:0;"></span>${s.lbl}</div>
        ${t.notes?`<div class="hk-notes">${esc(t.notes)}</div>`:''}
      </div>`;
    }).join('');
    if(_hkView==='table') renderHkTable();
  }catch(e){ toast('❌ تعذر تحميل بيانات النظافة'); }
}

function openHkModal(apt,status,notes){
  hkCurrentApt=apt;
  document.getElementById('hkModalTitle').textContent='شقة '+apt+' — خدمة الغرف';
  document.getElementById('hkNotes').value=notes||'';
  const ST=[{v:'clean',lbl:'✅ نظيف',bg:'#22c55e'},{v:'dirty',lbl:'🔴 غير نظيف',bg:'#ef4444'},{v:'inspecting',lbl:'🔍 قيد الفحص',bg:'#eab308'},{v:'maintenance',lbl:'🔧 صيانة',bg:'#a855f7'}];
  document.getElementById('hkBtns').innerHTML=ST.map(s=>`<button onclick="saveHk('${apt}','${s.v}')" style="padding:10px;background:${s.v===status?s.bg:'#f1f5f9'};color:${s.v===status?'#fff':'#475569'};border:none;border-radius:10px;font-family:inherit;font-size:13px;font-weight:700;cursor:pointer;">${s.lbl}</button>`).join('');
  document.getElementById('hkModal').style.display='flex';
}
function closeHkModal(){ document.getElementById('hkModal').style.display='none'; }

async function saveHk(apt,status){
  const notes=document.getElementById('hkNotes').value;
  try{
    await fetch('/staff/api/housekeeping/'+apt,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({status,notes})});
    toast('✅ تم تحديث حالة الشقة '+apt);
    closeHkModal();
    loadHousekeeping();
  }catch(e){ toast('❌ حدث خطأ'); }
}

