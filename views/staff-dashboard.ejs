      },
      options: {
        responsive: false,
        plugins: {
          legend: { display: false },
          tooltip: { rtl: true, bodyFont: { family: 'Cairo' }, callbacks: { label: ctx => fmt(ctx.parsed.y) + ' ﷼' } }
        },
        scales: {
          x: { ticks: { font: { family: 'Cairo', size: 10 }, maxRotation: 45 }, grid: { display: false } },
          y: { beginAtZero: true, ticks: { font: { family: 'Cairo', size: 10 }, callback: v => fmt(v) }, grid: { color: 'rgba(0,0,0,.04)' } }
        }
      }
    });
  }

  // Debts
  const dw = document.getElementById('rpt-debts-wrap');
  if (dw) {
    if (!debts?.length) {
      dw.innerHTML = '<div style="background:var(--green-bg);border:1px solid var(--green-b);border-radius:12px;padding:16px;text-align:center;font-size:13px;font-weight:600;color:var(--green);">✅ لا توجد مديونيات</div>';
    } else {
      const totalDebt = debts.reduce((s,d) => s + d.remaining, 0);
      dw.innerHTML = `<div style="background:var(--surface);border:1px solid var(--red-b);border-radius:12px;overflow:hidden;margin-bottom:8px;">
        <div style="padding:12px 16px;background:var(--red-bg);display:flex;justify-content:space-between;align-items:center;">
          <span style="font-size:12px;font-weight:700;color:var(--red);">${debts.length} عميل لديهم مبالغ متبقية</span>
          <span style="font-size:14px;font-weight:800;color:var(--red);">إجمالي: ${fmt(totalDebt)} ﷼</span>
        </div>
        <div class="tbl-wrap"><table class="stbl">
          <thead><tr><th>رقم العقد</th><th>العميل</th><th>الجوال</th><th>الشقة</th><th>الإجمالي</th><th>المدفوع</th><th>المتبقي</th><th>الحالة</th></tr></thead>
          <tbody>${debts.map(d=>`<tr>
            <td style="font-family:monospace;font-weight:700;color:var(--brand);">#${esc(d.bookingNum)}</td>
            <td>${esc(d.name||'—')}</td>
            <td><a href="https://wa.me/${waPhone(d.phone)}" target="_blank" style="color:var(--brand);">${esc(d.phone||'—')}</a></td>
            <td><b>${esc(d.apt||'—')}</b></td>
            <td>${fmt(d.totalPrice)} ﷼</td>
            <td style="color:var(--green);">${fmt(d.paidAmount)} ﷼</td>
            <td style="color:var(--red);font-weight:700;">${fmt(d.remaining)} ﷼</td>
            <td>${statusBadge(d.status)}</td>
          </tr>`).join('')}</tbody>
        </table></div>
      </div>`;
    }
  }
}

