// Load saved vouchers from DB
async function loadVouList(type){
  const tbId='vou-'+type+'-tbody';
  const tb=document.getElementById(tbId); if(!tb)return;
  tb.innerHTML=`<tr><td colspan="${VOU_COLS[type]||7}" style="text-align:center;padding:20px;color:#94a3b8;">جاري التحميل...</td></tr>`;
  try{
    const r=await fetch('/staff/api/vouchers?type='+type);
    const list=await r.json();
    if(!list.length){tb.innerHTML=`<tr><td colspan="${VOU_COLS[type]||7}" style="text-align:center;padding:20px;color:#94a3b8;">لا توجد وثائق بعد — اضغط إضافة</td></tr>`;return;}
    tb.innerHTML=list.map((v,i)=>{
      const cols=renderVouRow(v,type,i);
      return `<tr>${cols}</tr>`;
    }).join('');
  }catch(e){tb.innerHTML=`<tr><td colspan="${VOU_COLS[type]||7}" style="text-align:center;padding:20px;color:#ef4444;">خطأ في التحميل</td></tr>`;}
}

function renderVouRow(v,type,i){
  const date=v.date?new Date(v.date).toLocaleDateString('ar-SA'):'—';
  const amt=(v.amount||0).toLocaleString();
  const actions=`<div style="display:flex;gap:4px;">
    <button onclick="printVoucher('${v._id}')" style="padding:3px 8px;background:#1a3d8f;color:#111;border:none;border-radius:6px;font-size:10px;font-weight:700;cursor:pointer;">🖨️ طباعة</button>
    <button onclick="deleteVou('${v._id}','${type}')" style="padding:3px 8px;background:#fef2f2;color:#dc2626;border:1px solid #fecaca;border-radius:6px;font-size:10px;font-weight:700;cursor:pointer;">🗑️</button>
  </div>`;
  if(type==='receipt'||type==='invoice')
    return `<td style="font-size:10px;color:#94a3b8;">${esc(v.number||'—')}</td><td>${date}</td><td><b>${esc(v.name||'—')}</b></td><td>${esc(v.apt||'—')}</td><td style="font-size:11px;color:#64748b;">${esc(v.description||'—')}</td><td style="font-weight:700;">${amt} ر</td><td>${actions}</td>`;
  if(type==='disbursement')
    return `<td style="font-size:10px;color:#94a3b8;">${esc(v.number||'—')}</td><td>${date}</td><td><b>${esc(v.name||'—')}</b></td><td style="font-size:11px;color:#64748b;">${esc(v.description||'—')}</td><td style="font-weight:700;">${amt} ر</td><td>${actions}</td>`;
  if(type==='check')
    return `<td style="font-size:10px;color:#94a3b8;">${esc(v.number||'—')}</td><td>${date}</td><td><b>${esc(v.name||'—')}</b></td><td>${esc(v.checkNumber||'—')}</td><td>${esc(v.bankName||'—')}</td><td>${v.dueDate?new Date(v.dueDate).toLocaleDateString('ar-SA'):'—'}</td><td style="font-weight:700;">${amt} ر</td><td>${actions}</td>`;
  if(type==='tax'){
    const rate=(propSettings.vatRate??15)/100;
    const tax=Math.round((v.amount||0)*rate); const total=(v.amount||0)+tax;
    return `<td style="font-size:10px;color:#94a3b8;">${esc(v.number||'—')}</td><td>${date}</td><td><b>${esc(v.name||'—')}</b></td><td>${esc(v.apt||'—')}</td><td>${amt} ر</td><td style="color:#dc2626;">${tax.toLocaleString()} ر</td><td style="font-weight:700;">${total.toLocaleString()} ر</td><td>${actions}</td>`;
  }
  return '';
}

async function deleteVou(id,type){
  if(!confirm('حذف هذه الوثيقة؟'))return;
  try{
