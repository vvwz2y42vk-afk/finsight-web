    ${type==='invoice'&&propSettings.contractTerms?`<div style="margin-top:14px;padding:10px;background:#FFFBEB;border:1px solid #FDE68A;border-radius:8px;font-size:11px;color:#92400E;white-space:pre-line;"><b>شروط العقد:</b><br>${esc(propSettings.contractTerms)}</div>`:''}

    <div class="print-footer">
      <div>BAREZ — نظام إدارة الشقق الفندقية</div>
