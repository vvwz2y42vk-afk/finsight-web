<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title><%= staff.building %> — بوابة الموظفين</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/ar.js"></script>
<style>
/* ═══ BAREZ — LUXURY DASHBOARD SYSTEM ═══ */
:root{
  --bg:#F8FAFC;--surface:#FFFFFF;--s2:#F1F5F9;--s3:#E8EEF8;
  --border:#E2E8F0;--border-s:#EEF2F8;
  --t1:#0F172A;--t2:#334155;--t3:#64748B;--t4:#94A3B8;
  --brand:#1a3d8f;--brand-l:#2563eb;--brand-m:rgba(26,61,143,.08);
  --green:#047857;--green-bg:rgba(4,120,87,.08);--green-b:rgba(4,120,87,.2);
  --amber:#B45309;--amber-bg:rgba(180,83,9,.08);--amber-b:rgba(180,83,9,.2);
  --red:#B91C1C;--red-bg:rgba(185,28,28,.08);--red-b:rgba(185,28,28,.2);
  --blue:#1D4ED8;--blue-bg:rgba(29,78,216,.08);
  --purple:#5B21B6;--purple-bg:rgba(91,33,182,.08);
  --r:14px;--r-lg:18px;
  --sh-xs:0 1px 2px rgba(15,23,42,.04);
  --sh-sm:0 2px 8px rgba(15,23,42,.05),0 1px 2px rgba(15,23,42,.03);
  --sh:0 4px 20px rgba(15,23,42,.08),0 2px 4px rgba(15,23,42,.04);
  --sh-lg:0 20px 50px rgba(15,23,42,.12),0 6px 12px rgba(15,23,42,.05);
  --ease:cubic-bezier(.4,0,.2,1);
  --sb:64px;--sb-exp:204px;
  --glass-border:1px solid rgba(255,255,255,.8);
  --glass-sh:0 2px 16px rgba(15,23,42,.06),inset 0 1px 0 rgba(255,255,255,.95);
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Cairo',sans-serif;background:var(--bg);direction:rtl;display:flex;min-height:100vh;color:var(--t1);-webkit-font-smoothing:antialiased;font-weight:400;}

/* ══ Sidebar ══ */
.sb{
  width:var(--sb);
  background:linear-gradient(180deg,#0A1628 0%,#071530 55%,#050D1A 100%);
  border-left:1px solid rgba(255,255,255,.05);
  display:flex;flex-direction:column;align-items:center;
  padding:20px 0;position:fixed;top:0;right:0;bottom:0;z-index:100;
  transition:width .28s var(--ease);
  box-shadow:-4px 0 28px rgba(0,0,0,.18);
}
.sb:hover{width:var(--sb-exp);}
.sb-logo{display:flex;align-items:center;justify-content:center;margin-bottom:4px;padding:8px 0;width:100%;}
.sb-logo img{filter:brightness(0) invert(1);opacity:.9;}
.sb-bld{font-size:10px;color:rgba(255,255,255,.3);text-align:center;padding:0 10px;white-space:nowrap;overflow:hidden;margin-bottom:22px;max-width:0;opacity:0;transition:all .28s var(--ease);letter-spacing:.1em;text-transform:uppercase;}
.sb:hover .sb-bld{max-width:200px;opacity:1;}
.sb-nav{flex:1;width:100%;display:flex;flex-direction:column;gap:2px;padding:0 10px;}
.sn{
  display:flex;align-items:center;gap:11px;padding:10px 10px;border-radius:10px;
  cursor:pointer;color:rgba(255,255,255,.4);
  transition:all .2s var(--ease);white-space:nowrap;overflow:hidden;position:relative;
}
.sn:hover{background:rgba(255,255,255,.06);color:rgba(255,255,255,.82);}
.sn.active{
  background:linear-gradient(135deg,rgba(37,99,235,.28),rgba(26,61,143,.18));
  color:#BFDBFE;
  box-shadow:inset 0 0 0 1px rgba(59,130,246,.3), 0 0 20px rgba(59,130,246,.12);
}
.sn.active::after{
  content:'';position:absolute;right:0;top:12%;bottom:12%;
  width:3px;border-radius:2px 0 0 2px;
  background:linear-gradient(180deg,#60A5FA,#3B82F6,#60A5FA);
  box-shadow:0 0 16px rgba(96,165,250,.9), 0 0 4px #60A5FA;
}
.sb-occ{
  width:calc(100% - 20px);margin:0 10px 14px;
  background:rgba(255,255,255,.04);border-radius:10px;
  padding:10px;overflow:hidden;max-height:0;opacity:0;
  transition:all .28s var(--ease);
}
.sb:hover .sb-occ{max-height:80px;opacity:1;}
.sb-occ-bar{height:4px;background:rgba(255,255,255,.1);border-radius:4px;margin-top:6px;overflow:hidden;}
.sb-occ-fill{height:100%;border-radius:4px;background:linear-gradient(90deg,#3B82F6,#60A5FA);transition:width .8s var(--ease);}
.sn-ico{flex-shrink:0;width:22px;display:flex;align-items:center;justify-content:center;}
.sn-lbl{font-size:13px;font-weight:500;opacity:0;transition:opacity .2s var(--ease);}
.sb:hover .sn-lbl{opacity:1;}
.sb-foot{width:100%;padding:0 10px 10px;}
.sb-logout{
  display:flex;align-items:center;gap:11px;padding:10px;border-radius:10px;
  cursor:pointer;color:rgba(248,113,113,.65);background:transparent;
  white-space:nowrap;overflow:hidden;transition:all .2s var(--ease);
}
.sb-logout:hover{background:rgba(239,68,68,.1);color:#FCA5A5;}

/* ══ Main ══ */
.main{margin-right:var(--sb);flex:1;display:flex;flex-direction:column;min-height:100vh;}
.topbar{
  background:rgba(255,255,255,.97);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);
  padding:14px 28px;display:flex;align-items:center;justify-content:space-between;
  border-bottom:1px solid var(--border-s);position:sticky;top:0;z-index:50;
  box-shadow:0 1px 12px rgba(15,23,42,.05);
}
.tb-left{}
.tb-title{font-size:16px;font-weight:700;color:var(--t1);letter-spacing:-.01em;}
.tb-title span{color:var(--brand);}
.tb-meta{font-size:11px;color:var(--t4);margin-top:2px;font-weight:400;}
.tb-right{display:flex;align-items:center;gap:12px;}
.tb-avatar{
  width:34px;height:34px;border-radius:9px;
  background:linear-gradient(135deg,var(--brand),var(--brand-l));
  display:flex;align-items:center;justify-content:center;
  font-size:13px;font-weight:700;color:#fff;flex-shrink:0;
}
.tb-info{text-align:right;}
.tb-info-name{font-size:13px;font-weight:600;color:var(--t2);}
.tb-info-role{font-size:11px;color:var(--t4);margin-top:1px;}
.content{padding:28px;flex:1;}
/* ══ KPI Cards ══ */
.kpi-row{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:14px;margin-bottom:28px;}
.kpi-c{
  background:linear-gradient(145deg,rgba(255,255,255,.98),rgba(248,250,255,.95));
  border-radius:16px;padding:22px 20px;
  border:var(--glass-border);
  box-shadow:var(--glass-sh);
  backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);
  transition:all .25s var(--ease);cursor:default;
  display:flex;flex-direction:column;
  position:relative;overflow:hidden;
}
.kpi-c::before{content:'';position:absolute;top:0;right:0;left:0;height:2px;background:linear-gradient(90deg,transparent,rgba(26,61,143,.12),transparent);pointer-events:none;}
.kpi-c::after{content:'';position:absolute;bottom:-30px;left:-30px;width:100px;height:100px;border-radius:50%;background:radial-gradient(circle,rgba(26,61,143,.04) 0%,transparent 70%);pointer-events:none;}
.kpi-c:hover{box-shadow:0 8px 32px rgba(15,23,42,.1),inset 0 1px 0 rgba(255,255,255,1);transform:translateY(-4px);border-color:rgba(26,61,143,.18);}
.kpi-ico{
  width:48px;height:48px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  margin-bottom:16px;transition:transform .3s var(--ease);flex-shrink:0;
  box-shadow:0 2px 8px rgba(0,0,0,.08);
}
.kpi-c:hover .kpi-ico{transform:scale(1.12) rotate(-6deg);}
.kpi-num{font-size:36px;font-weight:900;line-height:1;letter-spacing:-.05em;color:var(--t1);}
.kpi-lbl{font-size:11px;color:var(--t3);font-weight:600;margin-top:8px;letter-spacing:.03em;}

/* ══ Charts ══ */
.charts-row{display:grid;grid-template-columns:1fr 200px 200px 200px;gap:14px;margin-bottom:28px;}
.chart-card{
  background:linear-gradient(145deg,rgba(255,255,255,.98),rgba(248,250,255,.94));
  border-radius:16px;padding:22px;
  border:var(--glass-border);
  box-shadow:var(--glass-sh);
  backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);
}
.chart-title{
  font-size:13px;font-weight:700;margin-bottom:18px;color:var(--t1);
  display:flex;align-items:center;gap:8px;
}
.chart-title::before{content:'';display:block;width:4px;height:16px;background:linear-gradient(180deg,var(--brand-l),var(--brand));border-radius:3px;flex-shrink:0;box-shadow:0 0 8px rgba(26,61,143,.3);}
.donut-wrap{position:relative;display:inline-flex;align-items:center;justify-content:center;}
.donut-center{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;pointer-events:none;}
.donut-pct{font-size:24px;font-weight:700;color:var(--t1);letter-spacing:-.03em;line-height:1;}
.donut-pct-sub{font-size:10px;color:var(--t4);margin-top:3px;letter-spacing:.04em;}

/* ══ Apt Grid ══ */
.apt-filters{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px;align-items:center;}
.af{padding:5px 12px;border-radius:20px;border:1px solid var(--border);background:var(--surface);font-family:inherit;font-size:11px;font-weight:600;cursor:pointer;color:var(--t3);transition:all .18s var(--ease);white-space:nowrap;display:inline-flex;align-items:center;gap:4px;}
.af:hover{background:var(--s2);color:var(--t2);border-color:rgba(26,61,143,.2);}
.af.active{background:var(--brand);border-color:transparent;color:#fff;box-shadow:0 2px 10px rgba(26,61,143,.28);}
.af .af-cnt{font-size:10px;background:rgba(255,255,255,.25);border-radius:10px;padding:0 5px;min-width:18px;text-align:center;display:inline-block;}
.af:not(.active) .af-cnt{background:var(--s3);color:var(--brand);}
.apt-bld{background:var(--surface);border-radius:var(--r);border:1px solid var(--border);box-shadow:var(--sh-sm);padding:20px;margin-bottom:14px;}
.apt-bld-hd{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;}
.apt-bld-name{font-size:15px;font-weight:800;color:var(--t1);letter-spacing:-.01em;}
.apt-floor-row{display:flex;align-items:center;gap:10px;margin-bottom:8px;margin-top:6px;}
.apt-floor-lbl{font-size:11px;font-weight:700;color:var(--brand);letter-spacing:.05em;text-transform:uppercase;white-space:nowrap;}
.apt-floor-stats{font-size:10px;font-weight:700;padding:2px 9px;background:rgba(26,61,143,.08);color:var(--brand);border-radius:20px;white-space:nowrap;flex-shrink:0;}
.apt-floor-line{flex:1;height:1px;background:rgba(26,61,143,.1);}
.apt-grid{display:flex;flex-wrap:wrap;gap:9px;margin-bottom:16px;}
.apt{width:116px;border-radius:13px;padding:12px 8px 10px;text-align:center;cursor:pointer;transition:all .22s var(--ease);user-select:none;position:relative;border:1.5px solid var(--border);background:var(--surface);}
.apt:hover{transform:translateY(-3px);box-shadow:0 8px 20px rgba(0,0,0,.1);}
.apt-type{font-size:9px;margin-top:3px;opacity:.75;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;line-height:1.3;}
.apt-n{font-size:20px;font-weight:900;line-height:1;letter-spacing:-.03em;}
.apt-s{font-size:10px;margin-top:4px;font-weight:700;letter-spacing:.01em;opacity:.9;}
.apt-g{font-size:10px;margin-top:2px;opacity:.8;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-weight:500;}
.apt-nights{display:inline-block;margin-top:5px;font-size:9px;background:rgba(0,0,0,.1);padding:1px 7px;border-radius:20px;font-weight:800;letter-spacing:.02em;}

/* Soft muted apartment colors */
.apt.vac{background:linear-gradient(145deg,#F0FDF4,#DCFCE7);color:#14532D;border-color:rgba(34,197,94,.25);}
.apt.occ{background:linear-gradient(145deg,#FFF1F2,#FFE4E6);color:#9F1239;border-color:rgba(244,63,94,.25);}
.apt.cin{background:linear-gradient(145deg,#EFF6FF,#DBEAFE);color:#1E3A8A;border-color:rgba(59,130,246,.28);}
.apt.cout{background:linear-gradient(145deg,#FFFBEB,#FEF3C7);color:#78350F;border-color:rgba(245,158,11,.28);}
.apt.awt{background:linear-gradient(145deg,#F5F3FF,#EDE9FE);color:#3B0764;border-color:rgba(139,92,246,.25);}
.apt.awp{background:linear-gradient(145deg,#FEFCE8,#FEF9C3);color:#713F12;border-color:rgba(202,138,4,.25);}
.apt.dirty{outline:2px solid rgba(234,179,8,.6);outline-offset:2px;}
.apt.maintenance{outline:2px solid rgba(107,114,128,.5);outline-offset:2px;}

@keyframes urgentPulse{0%,100%{box-shadow:0 0 0 0 rgba(59,130,246,.2);}50%{box-shadow:0 0 0 5px rgba(59,130,246,.08);}}
.apt.cin,.apt.cout{animation:urgentPulse 2s ease-in-out infinite;}
@keyframes kpiIn{from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:translateY(0);}}
.kpi-c{animation:kpiIn .45s ease both;}

/* ══ Table ══ */
.tbl-wrap{overflow-x:auto;border-radius:12px;border:1px solid var(--border);box-shadow:var(--sh-sm);}
.pager{display:flex;align-items:center;justify-content:center;gap:4px;padding:10px 0;flex-wrap:wrap;}
.pager button{min-width:32px;height:32px;padding:0 8px;border-radius:8px;border:1px solid #e2e8f0;background:#fff;color:#475569;font-family:inherit;font-size:12px;font-weight:600;cursor:pointer;transition:all .15s;}
.pager button:hover{background:#f1f5f9;}
.pager button.active{background:#1a3d8f;color:#fff;border-color:#1a3d8f;}
.pager button:disabled{opacity:.4;cursor:default;}
.pager-info{font-size:11px;color:var(--t4);margin:0 6px;}
.stbl{width:100%;border-collapse:collapse;font-size:13px;}
.stbl th{background:linear-gradient(135deg,#F8FAFC,#F1F5F9);color:var(--t2);padding:10px 12px;text-align:right;font-weight:700;font-size:11px;letter-spacing:.05em;text-transform:uppercase;border-bottom:2px solid var(--border);}
.stbl td{padding:10px 12px;border-bottom:1px solid var(--border-s);color:var(--t2);}
.stbl tbody tr:nth-child(even) td{background:rgba(248,250,252,.7);}
.stbl tbody tr:hover td{background:rgba(237,242,252,.9)!important;}
.stbl tbody tr.co-row td{background:rgba(26,61,143,.07)!important;}
.stbl tbody tr.co-row:hover td{background:rgba(26,61,143,.12)!important;}
.stbl tbody tr{transition:background .12s;}

/* Tbl action icon buttons */
.tbl-act{display:inline-flex;gap:3px;align-items:center;flex-wrap:wrap;}
.ia{width:27px;height:27px;border-radius:7px;border:none;cursor:pointer;display:inline-flex;align-items:center;justify-content:center;font-size:13px;transition:all .15s;position:relative;flex-shrink:0;}
.ia:hover{transform:scale(1.15);}
.ia::after{content:attr(data-tip);position:absolute;bottom:calc(100%+5px);left:50%;transform:translateX(-50%);background:rgba(15,23,42,.88);color:#fff;font-size:10px;font-weight:600;padding:3px 8px;border-radius:6px;white-space:nowrap;pointer-events:none;opacity:0;transition:opacity .15s;font-family:'Cairo',sans-serif;z-index:10;}
.ia:hover::after{opacity:1;}
.ia-in{background:#DCFCE7;color:#16A34A;}.ia-out{background:#FFEDD5;color:#EA580C;}
.ia-edit{background:#EFF6FF;color:#2563EB;}.ia-cancel{background:#FEF2F2;color:#DC2626;}
.ia-print{background:#F0FDF4;color:#16A34A;}.ia-contract{background:#FEFCE8;color:#854D0E;}
.ia-wa{background:#DCFCE7;color:#15803D;}.ia-view{background:#F0F4FF;color:#1a3d8f;}

/* Status badges */
.badge{display:inline-flex;padding:3px 9px;border-radius:20px;font-size:10px;font-weight:700;letter-spacing:.02em;white-space:nowrap;}
.b-active{background:rgba(4,120,87,.1);color:#047857;}
.b-awaiting{background:rgba(91,33,182,.09);color:#5B21B6;}
.b-checkout{background:rgba(180,83,9,.09);color:#B45309;}
.b-pending{background:rgba(146,64,14,.09);color:#92400E;}
.b-cancelled{background:rgba(185,28,28,.08);color:#B91C1C;}
.b-awaiting_payment{background:rgba(29,78,216,.09);color:#1D4ED8;}

/* Skeleton loader */
@keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}
.skel{background:linear-gradient(90deg,#f1f5f9 25%,#e8eef5 50%,#f1f5f9 75%);background-size:200% 100%;animation:shimmer 1.6s infinite;border-radius:6px;display:inline-block;}

/* Calendar layout */
.cal-layout{display:flex;gap:16px;align-items:flex-start;}
.cal-main{flex:1;min-width:0;}
.cal-panel{width:232px;flex-shrink:0;background:var(--surface);border-radius:var(--r);border:1px solid var(--border);box-shadow:var(--sh-sm);overflow:hidden;position:sticky;top:70px;}
.cal-panel-hd{padding:12px 14px;background:linear-gradient(135deg,var(--brand),var(--brand-l));color:#fff;}
.cal-panel-ttl{font-size:12px;font-weight:700;}
.cal-panel-sub{font-size:10px;opacity:.75;margin-top:1px;}
.cal-panel-body{padding:10px;max-height:460px;overflow-y:auto;}
.cal-pi{display:flex;align-items:center;gap:8px;padding:7px 6px;border-radius:8px;transition:background .12s;cursor:default;}
.cal-pi:hover{background:var(--s2);}
.cal-pi-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.cal-pi-info{flex:1;min-width:0;}
.cal-pi-apt{font-size:11px;font-weight:700;color:var(--t1);}
.cal-pi-name{font-size:10px;color:var(--t4);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.cal-pi-type{font-size:9px;font-weight:700;padding:1px 5px;border-radius:8px;}

/* Calendar table */
.cal-table-wrap{overflow-x:auto;border-radius:12px;border:1px solid var(--border);}
.cal-table{border-collapse:collapse;min-width:900px;font-size:12px;}
.cal-table th,.cal-table td{border:1px solid var(--border-s);text-align:center;padding:0;}
.cal-apt-col{min-width:80px;padding:6px 10px;background:var(--s2);color:var(--brand);font-weight:700;position:sticky;right:0;z-index:2;}
.cal-day-col{min-width:28px;max-width:28px;padding:5px 2px;background:var(--s2);color:var(--t3);font-size:10px;font-weight:600;}
.cal-apt-label{padding:6px 10px;background:var(--surface);font-weight:600;color:var(--t1);position:sticky;right:0;z-index:1;white-space:nowrap;font-size:12px;}
.cal-floor-row td{padding:5px 12px;background:var(--s3);color:var(--brand);font-weight:700;font-size:10px;letter-spacing:.05em;text-transform:uppercase;}
.cal-v{background:var(--surface);}
.cal-o{background:#FFE4E6;}
.cal-i{background:#DBEAFE;}
.cal-x{background:#FEF3C7;}
.cal-v,.cal-o,.cal-i,.cal-x{width:28px;height:28px;cursor:default;transition:opacity .15s;}
.cal-o{border-radius:0;}
.cal-i:first-of-type,.cal-i+.cal-x{border-radius:8px 0 0 8px;}
.cal-v,.cal-o,.cal-i,.cal-x{position:relative;}
.cal-o::after,.cal-i::after,.cal-x::after{content:'';position:absolute;inset:2px 0;border-radius:0;}

/* ══ Search ══ */
.search-bar{display:flex;gap:10px;margin-bottom:18px;flex-wrap:wrap;}
.sinp{padding:9px 14px;border:1.5px solid var(--border);border-radius:10px;font-family:inherit;font-size:13px;outline:none;flex:1;min-width:180px;background:var(--surface);color:var(--t1);transition:border-color .2s,box-shadow .2s;}
.sinp:focus{border-color:var(--brand);box-shadow:0 0 0 3px rgba(26,61,143,.08);}
.sbtn{padding:9px 20px;background:linear-gradient(135deg,var(--brand),var(--brand-l));border:none;border-radius:10px;font-family:inherit;font-size:13px;font-weight:600;cursor:pointer;color:#fff;box-shadow:0 2px 8px rgba(26,61,143,.22);transition:all .2s var(--ease);}
.sbtn:hover{transform:translateY(-1px);box-shadow:0 4px 16px rgba(26,61,143,.32);}

/* ══ HK Grid ══ */
.hk-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(82px,1fr));gap:7px;}
.hk-card{background:var(--surface);border-radius:11px;border:1.5px solid var(--border);padding:12px 6px 10px;text-align:center;cursor:pointer;transition:all .18s var(--ease);position:relative;}
.hk-card:hover{transform:translateY(-3px);box-shadow:var(--sh-sm);}
.hk-apt{font-size:18px;font-weight:900;color:var(--t1);letter-spacing:-.04em;line-height:1;}
.hk-badge{display:inline-flex;align-items:center;gap:3px;padding:2px 7px;border-radius:20px;font-size:9px;font-weight:700;margin-top:5px;white-space:nowrap;}
/* HK status colors applied to badge */
.hk-card.hk-clean-c  .hk-badge{background:rgba(4,120,87,.1);color:#047857;}
.hk-card.hk-dirty-c  .hk-badge{background:rgba(185,28,28,.1);color:#B91C1C;}
.hk-card.hk-inspect-c .hk-badge{background:rgba(202,138,4,.1);color:#B45309;}
.hk-card.hk-maint-c  .hk-badge{background:rgba(91,33,182,.1);color:#5B21B6;}
.hk-card.hk-dirty-c{border-color:rgba(185,28,28,.3);background:rgba(254,242,242,.6);}
.hk-card.hk-maint-c{border-color:rgba(91,33,182,.25);background:rgba(245,243,255,.6);}
.hk-card.hk-inspect-c{border-color:rgba(202,138,4,.25);background:rgba(255,251,235,.6);}
.hk-card.hk-clean-c{border-color:rgba(4,120,87,.2);}
.hk-notes{font-size:9px;color:var(--t4);margin-top:3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;padding:0 4px;}

/* ══ Activity ══ */
.act-row{display:flex;align-items:center;gap:14px;padding:14px 0;border-bottom:1px solid var(--border-s);}
.act-ico{width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.act-in{background:var(--green-bg);color:var(--green);}
.act-out{background:var(--amber-bg);color:var(--amber);}
.act-hk{background:var(--blue-bg);color:var(--blue);}
.act-info{flex:1;}
.act-main{font-size:13px;font-weight:600;color:var(--t1);}
.act-sub{font-size:11px;color:var(--t4);margin-top:2px;}
.act-time{font-size:11px;color:var(--t4);text-align:left;}

/* ══ Modal ══ */
.overlay{position:fixed;inset:0;background:rgba(15,23,42,.5);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);display:flex;align-items:center;justify-content:center;z-index:1000;}
.modal{background:var(--surface);border-radius:var(--r-lg);width:90%;max-width:440px;overflow:hidden;box-shadow:var(--sh-lg);border:1px solid var(--border);}
.mhd{background:linear-gradient(135deg,#060E1F,var(--brand));color:#fff;padding:18px 22px;display:flex;align-items:center;justify-content:space-between;}
.mhd-title{font-size:14px;font-weight:600;letter-spacing:.01em;}
.mclose{background:none;border:none;color:rgba(255,255,255,.45);font-size:20px;cursor:pointer;line-height:1;transition:color .15s;}
.mclose:hover{color:#fff;}
.mbody{padding:22px;display:flex;flex-direction:column;gap:12px;font-size:13px;}
.mrow{display:flex;justify-content:space-between;padding:9px 0;border-bottom:1px solid var(--border-s);color:var(--t3);}
.mrow b{color:var(--t1);font-weight:600;}
.mbtn{padding:11px;border:none;border-radius:10px;font-family:inherit;font-size:13px;font-weight:600;cursor:pointer;flex:1;transition:all .2s var(--ease);}
.mbtn-in{background:var(--green);color:#fff;}.mbtn-in:hover{background:#036046;box-shadow:0 4px 14px rgba(4,120,87,.3);}
.mbtn-out{background:var(--amber);color:#fff;}.mbtn-out:hover{background:#92400E;box-shadow:0 4px 14px rgba(180,83,9,.3);}
.mbtn-cancel{background:var(--s2);color:var(--t3);}.mbtn-cancel:hover{background:var(--border);color:var(--t2);}
.occ-stat{display:flex;align-items:center;gap:6px;font-size:12px;font-weight:500;}

/* ══ Toast ══ */
#toast{position:fixed;bottom:28px;left:50%;transform:translateX(-50%) translateY(8px);background:rgba(15,23,42,.93);backdrop-filter:blur(16px);color:#fff;padding:13px 26px;border-radius:14px;font-size:13px;font-weight:600;opacity:0;transition:opacity .28s,transform .28s cubic-bezier(.34,1.56,.64,1);z-index:9999;pointer-events:none;box-shadow:0 12px 32px rgba(0,0,0,.28);letter-spacing:.01em;border:1px solid rgba(255,255,255,.1);display:flex;align-items:center;gap:8px;}
#toast.show{opacity:1;transform:translateX(-50%) translateY(0);}
#toast.toast-success{background:linear-gradient(135deg,rgba(4,120,87,.95),rgba(5,150,105,.95));border-color:rgba(52,211,153,.3);}
#toast.toast-error{background:linear-gradient(135deg,rgba(185,28,28,.95),rgba(220,38,38,.95));border-color:rgba(252,165,165,.3);}

/* ══ Success Overlay ══ */
#successOverlay{position:fixed;inset:0;z-index:10000;display:flex;align-items:center;justify-content:center;pointer-events:none;}
.success-burst{
  display:flex;flex-direction:column;align-items:center;gap:10px;
  background:rgba(255,255,255,.96);backdrop-filter:blur(20px);
  border-radius:24px;padding:28px 40px;
  box-shadow:0 24px 60px rgba(4,120,87,.2), 0 0 0 1px rgba(4,120,87,.15);
  transform:scale(.7);opacity:0;
  transition:all .3s cubic-bezier(.34,1.56,.64,1);
}
.success-burst.show{transform:scale(1);opacity:1;}
.success-burst svg{filter:drop-shadow(0 4px 12px rgba(4,120,87,.4));}
.success-burst span{font-size:14px;font-weight:700;color:#047857;}

/* ══ Smart Form Validation ══ */
@keyframes shake{
  0%,100%{transform:translateX(0);}
  15%{transform:translateX(-7px);}
  30%{transform:translateX(6px);}
  45%{transform:translateX(-5px);}
  60%{transform:translateX(4px);}
  75%{transform:translateX(-3px);}
  90%{transform:translateX(2px);}
}
@keyframes fieldGlow{
  0%,100%{box-shadow:0 0 0 3px rgba(220,38,38,.08);}
  50%{box-shadow:0 0 0 5px rgba(220,38,38,.14);}
}
.f-req-star{color:#EF4444;font-size:14px;margin-right:2px;line-height:1;}
.field-wrap{position:relative;}
.field-hint{font-size:11px;font-weight:600;padding:4px 0 0 2px;min-height:18px;transition:all .2s;}
.field-hint.err{color:#EF4444;}
.field-hint.ok {color:#059669;}

/* Valid state */
.f-valid{border-color:#10B981 !important;background:rgba(16,185,129,.03) !important;box-shadow:0 0 0 3px rgba(16,185,129,.1) !important;}
/* Error state */
.f-error{border-color:#EF4444 !important;background:rgba(239,68,68,.03) !important;animation:shake .45s ease, fieldGlow 1.2s ease 2 !important;}
/* Idle required */
.f-idle{border-color:#E2E8F0 !important;}

/* ══ Tab Transition ══ */
.tab-section{display:none;}
.tab-section.active{display:block;animation:tabFadeIn .22s ease both;}
@keyframes tabFadeIn{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}

/* ══ Modal Animate ══ */
@keyframes modalIn{from{opacity:0;transform:scale(.94) translateY(12px);}to{opacity:1;transform:scale(1) translateY(0);}}
.overlay .modal,.overlay>div{animation:modalIn .25s cubic-bezier(.34,1.2,.64,1) both;}

/* ══ Vouchers ══ */
.vou-cards{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:24px;}
.vou-card{
  flex:1;min-width:130px;max-width:190px;border-radius:16px;padding:20px 16px 18px;text-align:center;
  cursor:pointer;transition:all .24s var(--ease);user-select:none;
  background:rgba(255,255,255,.97);border:1px solid var(--border);
  box-shadow:var(--sh-sm);position:relative;overflow:hidden;
}
.vou-card::before{content:'';position:absolute;top:-24px;right:-24px;width:80px;height:80px;border-radius:50%;opacity:.06;pointer-events:none;}
.vou-card:hover{transform:translateY(-5px);box-shadow:var(--sh);border-color:rgba(26,61,143,.18);}
.vou-ico-w{width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;margin:0 auto 12px;box-shadow:0 4px 14px rgba(0,0,0,.1);}
.vou-lbl{font-size:12px;font-weight:700;color:var(--t1);letter-spacing:.01em;}
.vou-sublbl{font-size:10px;color:var(--t4);margin-top:3px;}
.vou-section{display:none;}.vou-section.active{display:block;}

/* ══ Modal inputs ══ */
.modal input,.modal select,.modal textarea{background:var(--s2);border:1.5px solid var(--border);color:var(--t1);border-radius:8px;padding:9px 12px;font-family:inherit;font-size:13px;width:100%;transition:border-color .2s,box-shadow .2s;outline:none;}
.modal input:focus,.modal select:focus,.modal textarea:focus{border-color:var(--brand);box-shadow:0 0 0 3px rgba(26,61,143,.08);background:var(--surface);}
.modal input::placeholder,.modal textarea::placeholder{color:var(--t4);}
.modal label{color:var(--t3);font-size:12px;font-weight:600;}
.modal select option{background:#fff;color:var(--t1);}

@keyframes dot-pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.75)}}
.flatpickr-calendar{border-radius:14px!important;box-shadow:0 8px 28px rgba(15,23,42,.13)!important;border:1px solid #e2e8f0!important;font-family:'Cairo',sans-serif!important;direction:rtl!important;}
.flatpickr-months{background:var(--brand)!important;border-radius:13px 13px 0 0!important;padding:4px 0!important;}
.flatpickr-month,.flatpickr-current-month,.flatpickr-current-month .cur-month{color:#fff!important;}
.flatpickr-current-month .flatpickr-monthDropdown-months{color:#fff!important;font-weight:700!important;font-size:14px!important;font-family:'Cairo',sans-serif!important;border:none!important;background:transparent!important;cursor:pointer!important;}
.flatpickr-current-month .flatpickr-monthDropdown-months option{color:#0f172a!important;background:#fff!important;}
.flatpickr-current-month input.cur-year{color:#fff!important;font-weight:800!important;font-size:14px!important;}
.numInputWrapper:hover{background:rgba(255,255,255,.1)!important;}
.arrowUp:after{border-bottom-color:#fff!important;} .arrowDown:after{border-top-color:#fff!important;}
.flatpickr-prev-month svg,.flatpickr-next-month svg{fill:#fff!important;}
.flatpickr-prev-month:hover,.flatpickr-next-month:hover{background:rgba(255,255,255,.15)!important;}
.flatpickr-weekday{color:var(--brand)!important;font-weight:700!important;}
.flatpickr-day.selected{background:var(--brand)!important;border-color:var(--brand)!important;border-radius:8px!important;}
.flatpickr-day:hover{background:var(--brand-m)!important;border-radius:8px!important;}
.flatpickr-day.today{border-color:var(--brand)!important;font-weight:700!important;}
.cust-ff{display:flex;flex-direction:column;gap:3px;}
.cust-ff label{font-size:10px;font-weight:700;color:#1a3d8f;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.cff{padding:6px 10px;border-radius:7px;border:1px solid #dde4f0;background:#f7f9ff;color:#1a1a2e;font-family:inherit;font-size:12px;outline:none;width:100%;}
.cff:focus{border-color:#1a3d8f;background:#fff;}

/* ══ Print ══ */
@media print{.sb,.topbar,.apt-filters,.search-bar,button,.overlay{display:none!important;}.main{margin:0!important;}.content{padding:0!important;}#printArea{display:block!important;}}
#printArea{display:none;position:fixed;inset:0;background:#fff;z-index:9999;padding:32px;overflow:auto;}
.print-doc{max-width:700px;margin:0 auto;font-family:'Cairo',sans-serif;direction:rtl;}
.print-hd{display:flex;justify-content:space-between;align-items:flex-start;border-bottom:3px solid var(--brand);padding-bottom:16px;margin-bottom:20px;}
.print-logo{font-size:22px;font-weight:700;color:#0f172a;}.print-logo span{color:var(--brand);}
.print-type{font-size:18px;font-weight:700;color:#fff;padding:6px 18px;border-radius:8px;}
.print-meta{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:20px;font-size:13px;}
.print-meta-row{display:flex;gap:6px;padding:6px 0;border-bottom:1px solid #f1f5f9;}
.print-meta-row span{color:#64748b;min-width:110px;}.print-meta-row b{color:#0f172a;}
.print-total{background:#f8fafc;border:2px solid var(--brand);border-radius:12px;padding:14px 20px;display:flex;justify-content:space-between;align-items:center;margin-top:16px;}
.print-total-lbl{font-size:14px;font-weight:600;color:#475569;}.print-total-val{font-size:22px;font-weight:700;color:var(--brand);}
.print-footer{text-align:center;margin-top:24px;font-size:11px;color:#94a3b8;border-top:1px solid #e2e8f0;padding-top:12px;}
.print-btns{display:flex;gap:8px;margin-bottom:16px;}
@media(max-width:768px){
  .main{margin-right:var(--sb);}
  .charts-row{grid-template-columns:1fr;}
  .kpi-row{grid-template-columns:repeat(2,1fr);}
  .vou-cards{gap:10px;}
  /* فلتر الحجوزات والعملاء على الجوال */
  .cust-ff{min-width:140px;}
  [style*="grid-template-columns:repeat(7"]{grid-template-columns:repeat(2,1fr)!important;}
  [style*="grid-template-columns:2fr 1.5fr"]{grid-template-columns:1fr 1fr!important;flex-wrap:wrap!important;}
  /* الجداول تصير كروت */
  .stbl thead{display:none!important;}
  .stbl tr{display:block!important;background:#fff;border-radius:12px;margin-bottom:10px;padding:12px;box-shadow:var(--sh-sm);border:1px solid var(--border);}
  .stbl td{display:flex!important;justify-content:space-between;align-items:center;padding:5px 0!important;border:none!important;font-size:12px;}
  .stbl td::before{content:attr(data-label);color:var(--t3);font-size:11px;font-weight:600;margin-left:8px;white-space:nowrap;}
  /* KPI row */
  .kpi-row{gap:8px;}
  .kpi{padding:12px 10px;}
  /* content padding */
  .content{padding:12px;}
}
</style>
<link rel="manifest" href="/manifest.json">
<meta name="theme-color" content="#1e3a5f">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="بارز موظفين">
<link rel="apple-touch-icon" href="/images/logo-dark.png">
</head>
<body>

<!-- Sidebar -->
<aside class="sb" id="sb">
  <div class="sb-logo"><img src="/images/logo-dark.png" alt="Barez" style="height:46px;width:auto;"></div>
  <div class="sb-bld"><%= staff.building %></div>
  <div class="sb-occ">
    <div style="font-size:9px;color:rgba(255,255,255,.4);letter-spacing:.08em;text-transform:uppercase;">الإشغال الحالي</div>
    <div style="display:flex;justify-content:space-between;align-items:baseline;margin-top:3px;">
      <div style="font-size:18px;font-weight:800;color:#fff;" id="sb-occ-num">—</div>
      <div style="font-size:9px;color:rgba(255,255,255,.35);" id="sb-occ-total"></div>
    </div>
    <div class="sb-occ-bar"><div class="sb-occ-fill" id="sb-occ-fill" style="width:0%"></div></div>
  </div>
  <nav class="sb-nav">
    <div class="sn active" onclick="goTab('dashboard',this)" id="sn-dashboard"><span class="sn-ico"><svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg></span><span class="sn-lbl">لوحة المعلومات</span></div>
    <% const P = staff.permissions && staff.permissions.length ? staff.permissions : ['dashboard','apartments','bookings','customers','housekeeping','activity','new_booking','edit_booking','cancel_booking','vouchers']; %>
    <div class="sn" onclick="goTab('apartments',this)" id="sn-apartments" style="display:<%= P.includes('apartments')?'flex':'none' %>"><span class="sn-ico"><svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg></span><span class="sn-lbl">الشقق والتسكين</span></div>
    <div class="sn" onclick="goTab('bookings',this)" id="sn-bookings" style="display:<%= P.includes('bookings')?'flex':'none' %>"><span class="sn-ico"><svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></span><span class="sn-lbl">الحجوزات</span></div>
    <div class="sn" onclick="goTab('customers',this)" id="sn-customers" style="display:<%= P.includes('customers')?'flex':'none' %>"><span class="sn-ico"><svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></span><span class="sn-lbl">العملاء</span></div>
    <div class="sn" onclick="goTab('housekeeping',this)" id="sn-housekeeping" style="display:<%= P.includes('housekeeping')?'flex':'none' %>"><span class="sn-ico"><svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></span><span class="sn-lbl">خدمة الغرف</span></div>
    <div class="sn" onclick="goTab('activity',this)" id="sn-activity" style="display:<%= P.includes('activity')?'flex':'none' %>"><span class="sn-ico"><svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg></span><span class="sn-lbl">سجل الحركات</span></div>
    <div class="sn" onclick="goTab('vouchers',this)" id="sn-vouchers" style="display:<%= P.includes('vouchers')?'flex':'none' %>"><span class="sn-ico"><svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg></span><span class="sn-lbl">السندات والفواتير</span></div>
    <div class="sn" onclick="goTab('reports',this)" id="sn-reports"><span class="sn-ico"><svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg></span><span class="sn-lbl">التقارير</span></div>
    <div class="sn" onclick="goTab('calendar',this)" id="sn-calendar" style="display:<%= P.includes('reports')?'flex':'none' %>"><span class="sn-ico"><svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="8" y1="14" x2="8" y2="14"/><line x1="12" y1="14" x2="12" y2="14"/><line x1="16" y1="14" x2="16" y2="14"/></svg></span><span class="sn-lbl">التقويم</span></div>
    <div class="sn" onclick="goTab('guests',this)" id="sn-guests" style="display:<%= P.includes('guests') || staff.role==='manager' ? 'flex' : 'none' %>"><span class="sn-ico"><svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></span><span class="sn-lbl">الضيوف</span></div>
    <% if(staff.role==='manager'){ %>
    <div class="sn" onclick="goTab('settings',this)" id="sn-settings"><span class="sn-ico"><svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg></span><span class="sn-lbl">إعدادات المبنى</span></div>
    <% } %>
  </nav>
  <div class="sb-foot">
    <a href="/staff/logout" class="sb-logout" style="text-decoration:none;"><span class="sn-ico"><svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg></span><span class="sn-lbl">خروج</span></a>
  </div>
</aside>

<!-- Main -->
<div class="main">
  <div class="topbar">
    <div class="tb-left">
      <div class="tb-title" id="tbTitle"><%= staff.building %> — <span>لوحة المعلومات</span></div>
      <div class="tb-meta" id="tbDate"></div>
    </div>
    <div class="tb-right">
      <div class="tb-avatar"><%= staff.name.charAt(0) %></div>
      <div class="tb-info">
        <div class="tb-info-name"><%= staff.name %></div>
        <div class="tb-info-role"><%= staff.role==='manager'?'مدير':'موظف استقبال' %> · <%= staff.building %></div>
      </div>
    </div>
  </div>

  <div class="content">

    <!-- ── Dashboard ── -->
    <div class="tab-section active" id="tab-dashboard">
      <div class="kpi-row">
        <div class="kpi-c"><div class="kpi-ico" style="background:rgba(29,78,216,.1);color:#1D4ED8;"><svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div><div class="kpi-num" id="k-arrivals">—</div><div class="kpi-lbl">وصول اليوم</div></div>
        <div class="kpi-c"><div class="kpi-ico" style="background:rgba(4,120,87,.1);color:#047857;"><svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></div><div class="kpi-num" id="k-checkin">—</div><div class="kpi-lbl">تسجيل الدخول</div></div>
        <div class="kpi-c"><div class="kpi-ico" style="background:rgba(180,83,9,.1);color:#B45309;"><svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg></div><div class="kpi-num" id="k-departures">—</div><div class="kpi-lbl">مغادرة اليوم</div></div>
        <div class="kpi-c"><div class="kpi-ico" style="background:rgba(91,33,182,.1);color:#5B21B6;"><svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div><div class="kpi-num" id="k-guests">—</div><div class="kpi-lbl">النزلاء الباقين</div></div>
        <div class="kpi-c"><div class="kpi-ico" style="background:rgba(26,61,143,.1);color:#1a3d8f;"><svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div><div class="kpi-num" id="k-new">—</div><div class="kpi-lbl">حجوزات جديدة</div></div>
        <div class="kpi-c"><div class="kpi-ico" style="background:rgba(15,23,42,.07);color:#0F172A;"><svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg></div><div class="kpi-num" id="k-rate">—%</div><div class="kpi-lbl">نسبة الإشغال</div></div>
      </div>
      <!-- جدول اليوم -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px;" id="today-schedule-wrap">
        <div style="background:linear-gradient(145deg,rgba(255,255,255,.98),rgba(240,246,255,.9));border:1px solid rgba(29,78,216,.12);border-radius:16px;padding:16px;box-shadow:0 2px 12px rgba(29,78,216,.06),inset 0 1px 0 rgba(255,255,255,.9);">
          <div style="font-size:11px;font-weight:700;color:#1D4ED8;margin-bottom:12px;display:flex;align-items:center;justify-content:space-between;">
            <div style="display:flex;align-items:center;gap:7px;">
              <div style="width:28px;height:28px;border-radius:50%;background:rgba(29,78,216,.1);display:flex;align-items:center;justify-content:center;">
                <svg width="14" height="14" fill="none" stroke="#1D4ED8" stroke-width="2.2" viewBox="0 0 24 24"><path d="M3 12h18M12 5l7 7-7 7"/></svg>
              </div>
              وصول اليوم
            </div>
            <span id="arr-count" style="background:rgba(29,78,216,.1);color:#1D4ED8;border-radius:20px;padding:2px 9px;font-size:11px;font-weight:800;">0</span>
          </div>
          <div id="today-arrivals" style="display:flex;flex-direction:column;gap:6px;max-height:160px;overflow-y:auto;scrollbar-width:thin;"></div>
        </div>
        <div style="background:linear-gradient(145deg,rgba(255,255,255,.98),rgba(255,247,237,.9));border:1px solid rgba(180,83,9,.12);border-radius:16px;padding:16px;box-shadow:0 2px 12px rgba(180,83,9,.06),inset 0 1px 0 rgba(255,255,255,.9);">
          <div style="font-size:11px;font-weight:700;color:#B45309;margin-bottom:12px;display:flex;align-items:center;justify-content:space-between;">
            <div style="display:flex;align-items:center;gap:7px;">
              <div style="width:28px;height:28px;border-radius:50%;background:rgba(180,83,9,.1);display:flex;align-items:center;justify-content:center;">
                <svg width="14" height="14" fill="none" stroke="#B45309" stroke-width="2.2" viewBox="0 0 24 24"><path d="M21 12H3M12 19l-7-7 7-7"/></svg>
              </div>
              مغادرة اليوم
            </div>
            <span id="dep-count" style="background:rgba(180,83,9,.1);color:#B45309;border-radius:20px;padding:2px 9px;font-size:11px;font-weight:800;">0</span>
          </div>
          <div id="today-departures" style="display:flex;flex-direction:column;gap:6px;max-height:160px;overflow-y:auto;scrollbar-width:thin;"></div>
        </div>
      </div>

      <!-- شريط التقدم الشهري -->
      <div style="background:linear-gradient(145deg,rgba(255,255,255,.98),rgba(248,250,255,.94));border:1px solid rgba(255,255,255,.8);border-radius:16px;padding:16px;margin-bottom:14px;box-shadow:0 2px 12px rgba(15,23,42,.05),inset 0 1px 0 rgba(255,255,255,.95);" id="monthly-progress-wrap">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
          <div style="display:flex;align-items:center;gap:8px;">
            <div style="width:8px;height:8px;border-radius:50%;background:linear-gradient(135deg,#1a3d8f,#3B82F6);box-shadow:0 0 8px rgba(26,61,143,.4);"></div>
            <span style="font-size:12px;font-weight:700;color:#0F172A;">إنجاز الشهر</span>
          </div>
          <div style="font-size:11px;color:#64748b;font-weight:600;" id="monthly-label">— / —</div>
        </div>
        <div style="background:rgba(226,232,240,.5);border-radius:20px;height:7px;overflow:hidden;margin-bottom:8px;">
          <div id="monthly-bar" style="height:100%;width:0%;background:linear-gradient(90deg,#1a3d8f,#3B82F6);border-radius:20px;transition:width 1.2s cubic-bezier(.4,0,.2,1);box-shadow:0 1px 6px rgba(26,61,143,.3);"></div>
        </div>
        <div style="display:flex;justify-content:space-between;align-items:center;font-size:10px;color:#94a3b8;">
          <span>0%</span>
          <span id="monthly-pct" style="font-weight:800;color:#1a3d8f;font-size:12px;">0%</span>
          <span>الهدف: <span id="monthly-target">20</span> وحدة</span>
        </div>
      </div>

      <div class="charts-row">
        <div class="chart-card">
          <div class="chart-title">حالة الشقق الأسبوعية</div>
          <canvas id="weeklyChart" height="180"></canvas>
        </div>
        <div class="chart-card" style="display:flex;flex-direction:column;align-items:center;justify-content:center;">
          <div class="chart-title" style="justify-content:center;">حالة الشقق</div>
          <div class="donut-wrap">
            <canvas id="donutChart" width="170" height="170"></canvas>
            <div class="donut-center">
              <div class="donut-pct" id="donutPct">—</div>
              <div class="donut-pct-sub">إشغال</div>
            </div>
          </div>
          <div id="donutLegend" style="margin-top:12px;font-size:11px;text-align:center;display:flex;gap:12px;justify-content:center;"></div>
        </div>
        <div class="chart-card" style="display:flex;flex-direction:column;align-items:center;justify-content:center;">
          <div class="chart-title" style="justify-content:center;">خدمة الغرف</div>
          <div class="donut-wrap">
            <canvas id="hkDonutChart" width="170" height="170"></canvas>
            <div class="donut-center">
              <div class="donut-pct" id="hkDonutNum">—</div>
              <div class="donut-pct-sub">نظيف</div>
            </div>
          </div>
          <div id="hkDonutLegend" style="margin-top:12px;font-size:11px;text-align:center;display:flex;gap:12px;justify-content:center;"></div>
        </div>
        <div class="chart-card">
          <div class="chart-title">اشغال أنواع الغرف</div>
          <div id="roomTypeChart" style="padding-top:4px;"></div>
        </div>
      </div>
    </div>

    <!-- ── Apartments ── -->
    <div class="tab-section" id="tab-apartments">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;flex-wrap:wrap;gap:8px;">
        <div class="apt-filters" style="margin-bottom:0;">
          <button class="af active" onclick="filterApts('all',this)">الكل</button>
        <button class="af" onclick="filterApts('occupied',this)">مؤجر <span class="af-cnt" id="fc-occupied">—</span></button>
        <button class="af" onclick="filterApts('vacant',this)">شاغر <span class="af-cnt" id="fc-vacant">—</span></button>
        <button class="af" onclick="filterApts('checkin_today',this)">وصول <span class="af-cnt" id="fc-checkin_today">—</span></button>
        <button class="af" onclick="filterApts('checkout_today',this)">خروج <span class="af-cnt" id="fc-checkout_today">—</span></button>
        <button class="af" onclick="filterApts('awaiting',this)">انتظار <span class="af-cnt" id="fc-awaiting">—</span></button>
        <span id="apts-occ-rate" style="font-size:13px;font-weight:700;align-self:center;"></span>
        <span style="display:flex;align-items:center;gap:5px;font-size:11px;color:var(--t3);padding:4px 10px;background:rgba(4,120,87,.06);border:1px solid rgba(4,120,87,.2);border-radius:20px;">
          <span id="apt-sync-dot" style="width:6px;height:6px;border-radius:50%;background:#047857;display:inline-block;animation:dot-pulse 2s infinite;"></span>
          <span>مباشر ·</span>
          <span id="apt-sync-time">—</span>
        </span>
        </div>
        <% if(P.includes('new_booking')){ %><button class="sbtn" onclick="openNewBkModal()">+ حجز جديد</button><% } %>
      </div>
      <div id="apt-alert-strip" style="display:none;margin-bottom:14px;"></div>
      <div id="aptsContainer"></div>
      <div id="apt-maintenance-strip" style="display:none;margin-top:16px;"></div>
    </div>

    <!-- ── Bookings ── -->
    <div class="tab-section" id="tab-bookings">

      <!-- البحث المتقدم -->
      <div style="background:#fff;border:1px solid #e2e8f0;border-radius:12px;margin-bottom:12px;overflow:hidden;">
        <div onclick="toggleBkSearch()" style="display:flex;justify-content:space-between;align-items:center;padding:10px 16px;cursor:pointer;background:#f8fafc;border-bottom:1px solid #e2e8f0;">
          <span style="font-size:12px;font-weight:700;color:#1a3d8f;">البحث المتقدم</span>
          <svg id="bk-chevron" width="14" height="14" fill="none" stroke="#64748b" stroke-width="2" viewBox="0 0 24 24" style="transition:transform .2s;"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
        <div id="bk-search-body" style="padding:12px 16px;">
          <!-- صف 1 -->
          <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:8px;margin-bottom:8px;">
            <div class="cust-ff"><label>من تاريخ</label><input type="date" id="bkDateFrom" class="cff" onchange="loadBookings()"></div>
            <div class="cust-ff"><label>إلى تاريخ</label><input type="date" id="bkDateTo" class="cff" onchange="loadBookings()"></div>
            <div class="cust-ff"><label>رقم العقد</label><input type="text" id="bkNum" class="cff" placeholder="آخر 5 أرقام"></div>
            <div class="cust-ff"><label>الشقة</label><input type="text" id="bkApt" class="cff" placeholder="رقم الشقة"></div>
            <div class="cust-ff"><label>-- نوع الغرفة --</label>
              <select id="bkRoomType" class="cff">
                <option value="">الكل</option>
                <option>غرفة وصالة</option><option>غرفتين وصالة</option><option>استوديو</option><option>جناح</option>
              </select>
            </div>
            <div class="cust-ff"><label>-- مصدر الحجز --</label>
              <select id="bkSource" class="cff">
                <option value="">الكل</option>
                <option>مباشر</option><option>واتساب</option><option>Booking.com</option><option>Airbnb</option><option>موقع</option><option>جاذر ان</option>
              </select>
            </div>
            <div class="cust-ff"><label>رقم مصدر الحجز</label><input type="text" id="bkSourceNum" class="cff" placeholder="رقم"></div>
          </div>
          <!-- صف 2 -->
          <div style="display:grid;grid-template-columns:2fr 1.5fr 1fr 1fr 2fr auto auto;gap:8px;align-items:flex-end;">
            <div class="cust-ff"><label>اسم العميل</label><input type="text" id="bkName" class="cff" placeholder="اسم العميل..."></div>
            <div class="cust-ff"><label>الجوال</label><input type="text" id="bkPhone" class="cff" placeholder="05xxxxxxxx"></div>
            <div class="cust-ff"><label>-- نوع الإيجار --</label>
              <select id="bkType" class="cff">
                <option value="">الكل</option><option value="daily">يومي</option><option value="annual">شهري</option>
              </select>
            </div>
            <div class="cust-ff"><label>-- نوع الحجز --</label>
              <select id="bkCat" class="cff">
                <option value="">الكل</option><option value="inquiry">استفسار</option><option value="daily">حجز</option>
              </select>
            </div>
            <div class="cust-ff"><label>حالة الحجز</label>
              <select id="bk-status-filter" class="cff">
                <option value="open">الحجوزات المفتوحة</option>
                <option value="active">النزلاء المقيمين</option>
                <option value="pending_checkin">الحجوزات (بدون دخول)</option>
                <option value="today_arrival_pending">وصول اليوم (بدون دخول)</option>
                <option value="today_arrival_done">وصول اليوم (دخول)</option>
                <option value="today_arrival_all">وصول اليوم (الجميع)</option>
                <option value="today_dep_pending">مغادرة اليوم (بدون خروج)</option>
                <option value="today_dep_done">مغادرة اليوم (خروج)</option>
                <option value="today_dep_all">مغادرة اليوم (الجميع)</option>
                <option value="closed">الحجوزات المغلقة</option>
                <option value="cancelled">الحجوزات الملغاة</option>
                <option value="all">جميع الحجوزات</option>
              </select>
            </div>
            <button onclick="loadBookings()" style="padding:7px 18px;border-radius:8px;background:linear-gradient(135deg,#1a3d8f,#2a5cc7);border:none;color:#fff;font-family:inherit;font-size:12px;font-weight:700;cursor:pointer;">بحث</button>
            <button onclick="clearBkFilters()" style="padding:7px 14px;border-radius:8px;border:1px solid #e2e8f0;background:#f8fafc;color:#64748b;font-family:inherit;font-size:12px;cursor:pointer;">مسح</button>
          </div>
        </div>
      </div>

      <!-- شريط الأزرار -->
      <div style="display:flex;justify-content:flex-end;gap:8px;margin-bottom:10px;">
        <span style="font-size:11px;color:#94a3b8;align-self:center;" id="bkCount"></span>
        <% if(P.includes('new_booking')){ %><button class="sbtn" onclick="openNewBkModal()" style="background:linear-gradient(135deg,#22c55e,#16a34a);">+ حجز جديد</button><% } %>
      </div>

      <div class="apt-bld">
        <div class="tbl-wrap">
          <table class="stbl">
            <thead><tr><th>#</th><th>الشقة</th><th>النزيل</th><th>الجوال</th><th>نوع الإيجار</th><th>الدخول</th><th>الخروج</th><th>الإجمالي</th><th>المدفوع</th><th>المتبقي</th><th>الحالة</th><th>إجراء</th></tr></thead>
            <tbody id="bkTbody"><tr><td colspan="12" style="padding:16px;"><div class="skel" style="height:13px;width:100%;margin-bottom:10px;"></div><div class="skel" style="height:13px;width:88%;margin-bottom:10px;"></div><div class="skel" style="height:13px;width:94%;margin-bottom:10px;"></div><div class="skel" style="height:13px;width:80%;"></div></td></tr></tbody>
          </table>
        </div>
        <div id="bkPager" style="display:none;"></div>
      </div>
    </div>

    <!-- ── Customers ── -->
    <div class="tab-section" id="tab-customers">

      <!-- رأس إدارة العملاء -->
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
        <div style="font-size:11px;color:var(--t4);" id="custDateTime"></div>
        <div style="font-size:14px;font-weight:700;color:var(--brand);">إدارة العملاء</div>
      </div>

      <!-- شريط البحث -->
      <div style="background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:10px 14px;margin-bottom:10px;display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
        <input type="text" id="custSearch" class="cff" placeholder="بحث بالاسم أو الجوال أو رقم الهوية..." style="width:280px;" oninput="custSearchDebounce()">
        <button onclick="loadCustomers()" style="padding:7px 20px;border-radius:8px;background:#1a3d8f;border:none;color:#fff;font-family:inherit;font-size:12px;font-weight:700;cursor:pointer;">بحث</button>
        <button onclick="clearCustFilters()" style="padding:7px 14px;border-radius:8px;border:1px solid #e2e8f0;background:#f8fafc;color:#64748b;font-family:inherit;font-size:12px;cursor:pointer;">مسح</button>
        <span style="font-size:11px;color:#94a3b8;margin-right:auto;" id="custCount"></span>
      </div>

      <!-- زر إضافة -->
      <div style="margin-bottom:10px;">
        <% if(P.includes('new_booking')){ %>
        <button onclick="openNewBkModal()" style="display:inline-flex;align-items:center;gap:6px;padding:7px 16px;border-radius:8px;background:#0891b2;border:none;color:#fff;font-family:inherit;font-size:12px;font-weight:700;cursor:pointer;">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          إضافة عميل
        </button>
        <% } %>
      </div>

      <!-- الجدول -->
      <div class="tbl-wrap">
        <table class="stbl">
          <thead><tr>
            <th>#</th><th>الاسم</th><th>الجوال</th><th>نوع الإثبات</th><th>رقم الإثبات</th>
            <th>الجنسية</th><th>البريد</th><th>الحجوزات</th><th>آخر زيارة</th><th>التصنيف</th><th>إجراء</th>
          </tr></thead>
          <tbody id="custTbody"><tr><td colspan="10" style="padding:16px;"><div class="skel" style="height:13px;width:100%;margin-bottom:10px;"></div><div class="skel" style="height:13px;width:85%;margin-bottom:10px;"></div><div class="skel" style="height:13px;width:92%;"></div></td></tr></tbody>
        </table>
      </div>
      <div id="custPager" style="display:none;"></div>
    </div>

    <!-- ── Housekeeping ── -->
    <div class="tab-section" id="tab-housekeeping">
      <div style="display:flex;gap:6px;margin-bottom:14px;flex-wrap:wrap;align-items:center;">
        <span style="font-size:11px;font-weight:700;color:var(--t3);margin-left:4px;">الحالة:</span>
        <span style="font-size:10px;font-weight:700;background:rgba(4,120,87,.1);color:#047857;padding:3px 10px;border-radius:20px;display:inline-flex;align-items:center;gap:4px;"><span style="width:6px;height:6px;border-radius:50%;background:#047857;display:inline-block;"></span>نظيف</span>
        <span style="font-size:10px;font-weight:700;background:rgba(185,28,28,.1);color:#B91C1C;padding:3px 10px;border-radius:20px;display:inline-flex;align-items:center;gap:4px;"><span style="width:6px;height:6px;border-radius:50%;background:#B91C1C;display:inline-block;"></span>غير نظيف</span>
        <span style="font-size:10px;font-weight:700;background:rgba(202,138,4,.1);color:#B45309;padding:3px 10px;border-radius:20px;display:inline-flex;align-items:center;gap:4px;"><span style="width:6px;height:6px;border-radius:50%;background:#B45309;display:inline-block;"></span>قيد الفحص</span>
        <span style="font-size:10px;font-weight:700;background:rgba(91,33,182,.1);color:#5B21B6;padding:3px 10px;border-radius:20px;display:inline-flex;align-items:center;gap:4px;"><span style="width:6px;height:6px;border-radius:50%;background:#5B21B6;display:inline-block;"></span>صيانة</span>
        <span style="margin-right:auto;" id="hk-summary-txt" style="font-size:11px;color:var(--t4);"></span>
      </div>
      <div class="hk-grid" id="hkGrid"></div>
    </div>

