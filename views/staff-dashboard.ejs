          <button class="sbtn" onclick="showVouCards()" style="background:#64748b;">← رجوع</button>
          <button class="sbtn" onclick="openVouModal('tax')" style="background:linear-gradient(135deg,#ef4444,#b91c1c);">+ إضافة إشعار ضريبي</button>
