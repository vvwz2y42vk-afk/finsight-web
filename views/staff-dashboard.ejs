  loadCalendar();
}
function updateCalMonthLabel() {
  const el = document.getElementById('cal-month-label');
  if (el) el.textContent = MONTHS_AR[calMonth] + ' ' + calYear;
}

function renderCalPanel() {
  const dateEl = document.getElementById('cal-panel-date');
  const bodyEl = document.getElementById('cal-panel-body');
  if (!dateEl || !bodyEl) return;

  const today = new Date();
  dateEl.textContent = today.toLocaleDateString('ar-SA', { weekday:'long', day:'numeric', month:'long' });

  if (!calData) { bodyEl.innerHTML = '<div style="text-align:center;padding:20px;color:var(--t4);font-size:12px;">لا توجد بيانات</div>'; return; }

  const todayStr = today.toISOString().split('T')[0];
  const todayDay = today.getDate();
  const isCurrentMonth = (calMonth === today.getMonth() && calYear === today.getFullYear());

  const arrivals = [], occupied = [], departures = [];
  (calData.aptCalendar || []).forEach(a => {
    const day = (a.days || [])[todayDay - 1];
    if (!day) return;
    if (day.s === 'i') arrivals.push({ apt: a.apt, name: day.n || '' });
    else if (day.s === 'o') occupied.push({ apt: a.apt, name: day.n || '' });
    else if (day.s === 'x') departures.push({ apt: a.apt, name: day.n || '' });
  });

  if (!isCurrentMonth) {
    bodyEl.innerHTML = '<div style="text-align:center;padding:16px;color:var(--t4);font-size:11px;">عرض شهر آخر</div>'; return;
  }

  const mkItem = (items, color, dot, title) => items.length ? `
    <div style="font-size:10px;font-weight:700;color:${color};text-transform:uppercase;letter-spacing:.05em;margin:8px 0 4px;padding:0 4px;">${title} (${items.length})</div>
    ${items.map(it=>`<div class="cal-pi">
      <span class="cal-pi-dot" style="background:${dot};"></span>
      <div class="cal-pi-info">
        <div class="cal-pi-apt">شقة ${esc(it.apt)}</div>
        ${it.name?`<div class="cal-pi-name">${esc(it.name)}</div>`:''}
      </div>
    </div>`).join('')}` : '';

  const content = mkItem(arrivals,'#1D4ED8','#3B82F6','وصول') +
                  mkItem(occupied,'#B91C1C','#EF4444','مشغول') +
                  mkItem(departures,'#B45309','#F59E0B','مغادرة');

  bodyEl.innerHTML = content || '<div style="text-align:center;padding:20px;color:var(--t4);font-size:12px;">لا توجد حركات اليوم</div>';
}

async function loadCalendar() {
  updateCalMonthLabel();
  const wrap = document.getElementById('calContainer');
  if (wrap) wrap.innerHTML = '<div style="text-align:center;padding:40px;opacity:.5;">جاري التحميل...</div>';
  try {
    const r = await fetch(`/staff/api/calendar?month=${calMonth}&year=${calYear}`);
    calData = await r.json();
    renderCalendar();
    renderCalPanel();
  } catch(e) { toast('❌ تعذر تحميل التقويم'); }
}

function renderCalendar() {
  if (!calData) return;
  const { floors, aptCalendar, daysInMonth } = calData;
  updateCalMonthLabel();

  const nums = Array.from({ length: daysInMonth }, (_, i) => i + 1);
  const sc = { v:'cal-v', o:'cal-o', i:'cal-i', x:'cal-x' };
  const st = { v:'شاغرة', o:'مشغولة', i:'وصول', x:'مغادرة' };

  // index aptCalendar by apt name for fast lookup
  const aptMap = {};
  (aptCalendar || []).forEach(a => { aptMap[a.apt] = a.days || []; });

  let html = '<div class="cal-table-wrap"><table class="cal-table"><thead><tr><th class="cal-apt-col">الشقة</th>';
  nums.forEach(d => { html += `<th class="cal-day-col">${d}</th>`; });
  html += '</tr></thead><tbody>';

  (floors || []).forEach(f => {
    html += `<tr class="cal-floor-row"><td colspan="${daysInMonth + 1}">${esc(f.label || '')}</td></tr>`;
    (f.apts || []).forEach(apt => {
      const days = aptMap[apt] || [];
      html += `<tr><td class="cal-apt-label">${esc(apt)}</td>`;
      nums.forEach((_, idx) => {
        const day = days[idx] || { s:'v' };
        const s = day.s || 'v';
        const tip = (st[s] || '') + (day.n ? ' — ' + day.n : '');
        html += `<td class="${sc[s] || 'cal-v'}" title="${tip}"></td>`;
      });
      html += '</tr>';
    });
  });

  html += '</tbody></table></div>';
  const wrap = document.getElementById('calContainer');
  if (wrap) wrap.innerHTML = html;
}

async function exportReportCSV() {
  if (!rptData) { toast('❌ افتح التقارير أولاً'); return; }
  toast('جاري تحضير الملف...');
  try {
    const now = new Date();
    const monthStart = new Date(now.getFullYear(), now.getMonth(), 1).toISOString().split('T')[0];
    const monthEnd   = new Date(now.getFullYear(), now.getMonth()+1, 0).toISOString().split('T')[0];
    const r = await fetch(`/staff/api/bookings?sf=all&date_from=${monthStart}&date_to=${monthEnd}`);
    const bookings = await r.json();

    const { today, month } = rptData;
    const dateStr = now.toLocaleDateString('ar-SA', { year:'numeric', month:'long', day:'numeric' });
    const statusMap = { active:'مفتوح', awaiting_checkin:'انتظار الدخول', awaiting_payment:'انتظار الدفع', checkout:'خروج', cancelled:'ملغي', pending:'جديد' };
    const typeMap   = { daily:'يومي', annual:'شهري', inquiry:'استفسار' };

    const sep = ',';
    const cell = v => `"${String(v||'').replace(/"/g,'""')}"`;

    const lines = [];

    // ملخص
    lines.push([cell('ملخص التقرير'), cell(dateStr)].join(sep));
    lines.push([cell('المبنى'), cell(BUILDING)].join(sep));
    lines.push(['', ''].join(sep));
    lines.push([cell('--- اليوم ---'), ''].join(sep));
    lines.push([cell('وصولات اليوم'),    cell(today.arrivals)].join(sep));
    lines.push([cell('مغادرات اليوم'),   cell(today.departures)].join(sep));
    lines.push([cell('نسبة الإشغال'),    cell(today.occupancyRate + '%')].join(sep));
    lines.push([cell('إيراد اليوم'),     cell(today.revenue + ' ريال')].join(sep));
    lines.push(['', ''].join(sep));
    lines.push([cell('--- الشهر الحالي ---'), ''].join(sep));
    lines.push([cell('إجمالي الحجوزات'), cell(month.bookings)].join(sep));
    lines.push([cell('إجمالي الإيرادات'),cell(month.revenue + ' ريال')].join(sep));
    lines.push([cell('المحصّل'),         cell(month.paid + ' ريال')].join(sep));
    lines.push([cell('المتبقي'),         cell(month.remaining + ' ريال')].join(sep));
    lines.push([cell('إيراد يومي'),      cell(month.dailyRevenue + ' ريال')].join(sep));
    lines.push([cell('إيراد شهري'),      cell(month.annualRevenue + ' ريال')].join(sep));
    lines.push(['', ''].join(sep));

    // تفاصيل الحجوزات
    lines.push([cell('--- تفاصيل حجوزات الشهر ---'), '', '', '', '', '', '', '', '', '', ''].join(sep));
    lines.push([
      cell('رقم العقد'), cell('الاسم'), cell('الجوال'),
      cell('الشقة'), cell('نوع الإيجار'), cell('تاريخ الدخول'), cell('تاريخ الخروج'),
      cell('الإجمالي'), cell('المدفوع'), cell('المتبقي'), cell('الحالة'),
    ].join(sep));

    bookings.forEach(b => {
      const remaining = (b.totalPrice||0) - (b.paidAmount||0);
      lines.push([
        cell('#' + b.bookingNum),
        cell(b.name),
        cell(b.phone),
        cell(b.apt),
        cell(typeMap[b.bookingType] || b.bookingType),
        cell(b.checkIn ? new Date(b.checkIn).toLocaleDateString('en-GB') : ''),
        cell(b.checkOut ? new Date(b.checkOut).toLocaleDateString('en-GB') : ''),
        cell(b.totalPrice || 0),
        cell(b.paidAmount || 0),
        cell(Math.max(0, remaining)),
        cell(statusMap[b.status] || b.status),
      ].join(sep));
    });

    const csv = '﻿' + lines.join('\n');
    const a = document.createElement('a');
    a.href = 'data:text/csv;charset=utf-8,' + encodeURIComponent(csv);
    a.download = `تقرير-${BUILDING}-${monthStart}.csv`;
    a.click();
    toast('✅ تم تصدير ' + bookings.length + ' حجز');
  } catch(e) { toast('❌ فشل التصدير'); }
}

