    if(!outToday.length){
      el.innerHTML='<div style="grid-column:1/-1;text-align:center;padding:40px 20px;color:var(--t4);">لا يوجد خروجات اليوم</div>';
      return;
    }
    el.innerHTML=outToday.map(r=>`
      <div onclick="openBkModal('${r.bookingId||''}','${r.apt}','${r.status}')" style="background:linear-gradient(145deg,#FFF1F2,#FFE4E6);border:1.5px solid rgba(244,63,94,.3);border-radius:12px;padding:12px 10px;cursor:pointer;transition:all .2s;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform=''">
        <div style="font-size:9px;font-weight:700;color:#9F1239;margin-bottom:4px;text-align:center;background:rgba(185,28,28,.08);border-radius:6px;padding:2px 6px;">${r.apt} — ${r.bookingType==='daily'?'يومي':'شهري'}</div>
        <div style="font-size:12px;font-weight:800;color:#9F1239;text-align:center;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${r.name||'—'}</div>
        <div style="font-size:10px;color:#DC2626;text-align:center;margin-top:3px;">الرصيد: ${(Math.max(0,(r.totalPrice||0)-(r.paidAmount||0))).toLocaleString()} ر</div>
        <div style="margin-top:8px;display:flex;gap:4px;justify-content:center;">
          ${r.bookingId?`<button onclick="event.stopPropagation();changeStatus('${r.bookingId}','checkout')" style="padding:4px 10px;border-radius:6px;background:#dc2626;border:none;color:#fff;font-family:inherit;font-size:10px;font-weight:700;cursor:pointer;">🚪 تسجيل الخروج</button>`:''}
        </div>
      </div>`).join('');
  }
}

// شريط نسبة الإشغال (نزيل style)
function updateAptOccBar(){
  if(!aptsRawData) return;
  let totOcc=0,totAll=0;
  aptsRawData.floors.forEach(f=>f.rooms.forEach(r=>{
    totAll++;
    if(['occupied','checkout_today','awaiting','checkin_today','awaiting_checkin'].includes(r.status)) totOcc++;
  }));
  const pct=totAll?Math.round(totOcc/totAll*100):0;
  const bar=document.getElementById('apt-occ-bar');
  const pctEl=document.getElementById('apt-occ-pct');
  if(bar) bar.style.width=pct+'%';
  if(pctEl) pctEl.textContent=pct+'%';
}

