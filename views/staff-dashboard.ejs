      type: 'bar',
      data: {
        labels: chart.map(d => d.label),
        datasets: [{
          label: 'الإيراد',
          data: chart.map(d => d.revenue),
          backgroundColor: 'rgba(26,61,143,.18)',
          borderColor: 'rgba(26,61,143,.7)',
          borderWidth: 1.5,
          borderRadius: 6,
          hoverBackgroundColor: 'rgba(26,61,143,.35)',
