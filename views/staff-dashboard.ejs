const ID_TYPE_L={national_id:'هوية وطنية',passport:'جواز سفر',iqama:'إقامة',family_card:'كرت عائلة'};
const BK_TYPE_L={daily:'يومي',annual:'شهري'};
const VOU_NAMES={receipt:'سند قبض',invoice:'فاتورة',disbursement:'سند صرف',check:'كمبيالة',tax:'إشعار ضريبي'};
const VOU_COLS={receipt:7,invoice:7,disbursement:6,check:8,tax:8};

function showVouCards(){
  document.querySelectorAll('.vou-section').forEach(s=>s.classList.remove('active'));
  document.getElementById('vouCards').style.display='flex';
}
function showVouSection(name){
  document.getElementById('vouCards').style.display='none';
  document.querySelectorAll('.vou-section').forEach(s=>s.classList.remove('active'));
  document.getElementById('vou-'+name).classList.add('active');
