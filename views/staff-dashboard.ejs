const MAINT_TYPE_AR  = {electrical:'⚡ كهرباء',plumbing:'🚿 سباكة',furniture:'🪑 أثاث',ac:'❄️ تكييف',internet:'📶 إنترنت',other:'🔧 أخرى'};
