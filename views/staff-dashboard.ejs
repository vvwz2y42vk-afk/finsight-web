(function initMrSelects(){
  const now=new Date();
  const yEl=document.getElementById('mr-year');
  const mEl=document.getElementById('mr-month');
  if(yEl){ for(let y=now.getFullYear();y>=now.getFullYear()-5;y--){ const o=document.createElement('option'); o.value=y; o.textContent=y; yEl.appendChild(o); } }
  if(mEl) mEl.value=now.getMonth()+1;
})();

async function loadMonthlyReport(){
  const year=document.getElementById('mr-year')?.value;
  const month=document.getElementById('mr-month')?.value;
  const type=document.querySelector('input[name="mr-type"]:checked')?.value||'detail';
  const body=document.getElementById('mr-body');
  body.innerHTML='<div style="padding:20px;color:var(--t4);">⏳ جاري التحميل...</div>';
  try{
    const r=await fetch(`/staff/api/reports/monthly?year=${year}&month=${month}&type=${type}`);
    const d=await r.json();
    if(!r.ok){ body.innerHTML=`<div style="color:#dc2626;padding:20px;">${d.error||'حدث خطأ'}</div>`; return; }
    renderMonthlyReport(d,type,year,month);
  }catch(e){ body.innerHTML='<div style="color:#dc2626;padding:20px;">❌ حدث خطأ</div>'; }
}

function renderMonthlyReport(d,type,year,month){
  const body=document.getElementById('mr-body');
  const mName=MONTHS_AR[parseInt(month)-1]||month;

  if(type==='total'){
    body.innerHTML=`
      <div style="background:#fff;border:1px solid var(--border);border-radius:12px;overflow:hidden;" id="mr-printable">
        <div style="background:var(--brand);color:#fff;padding:12px 18px;font-weight:700;font-size:14px;">التقرير الشهري الكلي — ${mName} ${year}</div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:0;">
          ${[
            {lbl:'إجمالي الحجوزات',val:d.totalBookings,c:'#1a3d8f'},
            {lbl:'إجمالي الإيرادات',val:fmt(d.totalRevenue)+' ﷼',c:'#047857'},
            {lbl:'المحصّل',val:fmt(d.totalPaid)+' ﷼',c:'#0369a1'},
            {lbl:'المتبقي',val:fmt(d.totalRemaining)+' ﷼',c:'#dc2626'},
            {lbl:'نسبة الإشغال',val:(d.occupancyRate||0)+'%',c:'#7c3aed'},
          ].map(x=>`<div style="padding:16px 18px;border-left:1px solid var(--border);border-bottom:1px solid var(--border);">
            <div style="font-size:11px;color:var(--t3);margin-bottom:4px;">${x.lbl}</div>
            <div style="font-size:20px;font-weight:900;color:${x.c};">${x.val}</div>
          </div>`).join('')}
        </div>
      </div>`;
    return;
  }

  if(type==='summary'){
    const rows=(d.byApt||[]);
    body.innerHTML=`
      <div style="background:#fff;border:1px solid var(--border);border-radius:12px;overflow:hidden;" id="mr-printable">
        <div style="background:var(--brand);color:#fff;padding:12px 18px;font-weight:700;font-size:14px;">التقرير التجميعي — ${mName} ${year}</div>
        <div class="tbl-wrap"><table class="stbl">
          <thead><tr><th>الشقة</th><th>عدد الحجوزات</th><th>عدد الليالي</th><th>الإجمالي</th><th>المحصّل</th><th>المتبقي</th></tr></thead>
          <tbody>${rows.length?rows.map(r=>`<tr>
            <td style="font-weight:700;">${esc(r.apt)}</td>
            <td style="text-align:center;">${r.count}</td>
            <td style="text-align:center;">${r.nights||0}</td>
            <td style="font-weight:700;">${fmt(r.revenue)} ﷼</td>
            <td style="color:#047857;">${fmt(r.paid)} ﷼</td>
            <td style="color:#dc2626;">${fmt(r.remaining)} ﷼</td>
          </tr>`).join(''):'<tr><td colspan="6" style="text-align:center;padding:20px;color:var(--t4);">لا توجد بيانات</td></tr>'}</tbody>
          <tfoot><tr style="background:var(--brand-m);font-weight:700;">
            <td>الإجمالي</td><td style="text-align:center;">${d.totalBookings||0}</td><td style="text-align:center;">${d.totalNights||0}</td>
            <td>${fmt(d.totalRevenue)} ﷼</td><td style="color:#047857;">${fmt(d.totalPaid)} ﷼</td><td style="color:#dc2626;">${fmt(d.totalRemaining)} ﷼</td>
          </tr></tfoot>
        </table></div>
      </div>`;
    return;
  }

  // detail
  const rows=(d.bookings||[]);
  const ST_L={awaiting_checkin:'انتظار دخول',active:'مسكّن',checkout:'خروج',cancelled:'ملغي',pending:'قيد الانتظار',awaiting_payment:'انتظار دفع'};
  body.innerHTML=`
    <div style="background:#fff;border:1px solid var(--border);border-radius:12px;overflow:hidden;" id="mr-printable">
      <div style="background:var(--brand);color:#fff;padding:12px 18px;font-weight:700;font-size:14px;display:flex;justify-content:space-between;align-items:center;">
        <span>التقرير التفصيلي — ${mName} ${year}</span>
        <span style="font-size:12px;opacity:.8;">${rows.length} حجز</span>
      </div>
      <div class="tbl-wrap"><table class="stbl">
        <thead><tr><th>رقم العقد</th><th>الشقة</th><th>العميل</th><th>الدخول</th><th>الخروج</th><th>الليالي</th><th>الإجمالي</th><th>المحصّل</th><th>المتبقي</th><th>الحالة</th></tr></thead>
        <tbody>${rows.length?rows.map(b=>{
          const remain=Math.max(0,(b.totalPrice||0)-(b.paidAmount||0));
          return`<tr>
            <td style="font-family:monospace;font-size:11px;color:var(--t4);">#${b._id.toString().slice(-5).toUpperCase()}</td>
            <td style="font-weight:700;">${esc(b.apt||'—')}</td>
            <td>${esc(b.name||'—')}</td>
            <td style="font-size:11px;">${b.checkIn?new Date(b.checkIn).toLocaleDateString('ar-SA'):'—'}</td>
            <td style="font-size:11px;">${b.checkOut?new Date(b.checkOut).toLocaleDateString('ar-SA'):'—'}</td>
            <td style="text-align:center;">${b.nights||0}</td>
            <td style="font-weight:700;">${fmt(b.totalPrice)} ﷼</td>
            <td style="color:#047857;">${fmt(b.paidAmount)} ﷼</td>
            <td style="color:#dc2626;">${fmt(remain)} ﷼</td>
            <td><span style="padding:2px 8px;border-radius:10px;font-size:10px;font-weight:700;background:var(--brand-m);color:var(--brand);">${ST_L[b.status]||b.status}</span></td>
          </tr>`;
        }).join(''):'<tr><td colspan="10" style="text-align:center;padding:20px;color:var(--t4);">لا توجد حجوزات لهذا الشهر</td></tr>'}
        </tbody>
        <tfoot><tr style="background:var(--brand-m);font-weight:700;">
          <td colspan="6">الإجمالي (${rows.length} حجز)</td>
          <td>${fmt(d.totalRevenue)} ﷼</td><td style="color:#047857;">${fmt(d.totalPaid)} ﷼</td><td style="color:#dc2626;">${fmt(d.totalRemaining)} ﷼</td><td></td>
        </tr></tfoot>
      </table></div>
    </div>`;
}

