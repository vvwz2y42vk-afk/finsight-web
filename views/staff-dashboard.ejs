        <div style="font-size:12px;color:#64748b;margin-top:3px;">${esc(g.phone)} · آخر زيارة: ${g.lastSeen?new Date(g.lastSeen).toLocaleDateString('ar-SA',{year:'numeric',month:'short',day:'numeric'}):'—'}</div>
      </div>
      <span style="background:${cat.bg};color:${cat.c};padding:4px 12px;border-radius:20px;font-size:12px;font-weight:700;">${cat.lbl}</span>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:20px;">
      <div style="background:#f0f9ff;border-radius:12px;padding:14px;text-align:center;">
        <div style="font-size:22px;font-weight:800;color:#0369a1;">${g.totalBookings||bookings.length}</div>
        <div style="font-size:11px;color:#64748b;margin-top:4px;">إجمالي الحجوزات</div>
      </div>
      <div style="background:#f0fdf4;border-radius:12px;padding:14px;text-align:center;">
        <div style="font-size:18px;font-weight:800;color:#16a34a;">${totalPaid.toLocaleString()}</div>
        <div style="font-size:11px;color:#64748b;margin-top:4px;">إجمالي المدفوع (ر)</div>
      </div>
      <div style="background:${(totalPrice-totalPaid)>0?'#fef2f2':'#f0fdf4'};border-radius:12px;padding:14px;text-align:center;">
        <div style="font-size:18px;font-weight:800;color:${(totalPrice-totalPaid)>0?'#dc2626':'#16a34a'};">${(totalPrice-totalPaid).toLocaleString()}</div>
        <div style="font-size:11px;color:#64748b;margin-top:4px;">المتبقي (ر)</div>
      </div>
    </div>

    <div style="font-size:11px;font-weight:700;color:#64748b;letter-spacing:.5px;margin-bottom:10px;padding-bottom:6px;border-bottom:1px solid #e2e8f0;">بيانات الهوية</div>
    <div style="margin-bottom:18px;">
      ${row('نوع الإثبات', idL[g.idType]||g.idType||'')}
      ${row('رقم الإثبات', g.idNumber)}
      ${row('الجنسية', g.nationality)}
      ${row('جهة العمل', g.employer)}
      ${g.email?row('البريد', `<a href="mailto:${esc(g.email)}" style="color:#2563eb;">${esc(g.email)}</a>`):''}
    </div>

    <div style="font-size:11px;font-weight:700;color:#64748b;letter-spacing:.5px;margin-bottom:10px;padding-bottom:6px;border-bottom:1px solid #e2e8f0;">سجل الحجوزات (${bookings.length})</div>
    ${bookings.length ? `
    <div style="overflow-x:auto;">
    <table style="width:100%;border-collapse:collapse;font-size:12px;">
      <thead><tr style="background:#f8fafc;">
        <th style="padding:8px 10px;text-align:right;font-weight:700;color:#475569;">الشقة</th>
        <th style="padding:8px 10px;text-align:right;font-weight:700;color:#475569;">الدخول</th>
        <th style="padding:8px 10px;text-align:right;font-weight:700;color:#475569;">الخروج</th>
        <th style="padding:8px 10px;text-align:right;font-weight:700;color:#475569;">الإجمالي</th>
        <th style="padding:8px 10px;text-align:right;font-weight:700;color:#475569;">المدفوع</th>
        <th style="padding:8px 10px;text-align:right;font-weight:700;color:#475569;">الحالة</th>
      </tr></thead>
      <tbody>
        ${bookings.map(b=>`<tr style="border-bottom:1px solid #f1f5f9;">
          <td style="padding:8px 10px;font-weight:600;">${esc(b.apt||'—')}</td>
          <td style="padding:8px 10px;">${fDate(b.checkIn)}</td>
          <td style="padding:8px 10px;">${fDate(b.checkOut)}</td>
          <td style="padding:8px 10px;">${(b.totalPrice||0).toLocaleString()}</td>
          <td style="padding:8px 10px;color:#16a34a;">${(b.paidAmount||0).toLocaleString()}</td>
          <td style="padding:8px 10px;"><span style="color:${ST_C[b.status]||'#64748b'};font-weight:600;font-size:11px;">${ST[b.status]||b.status}</span></td>
        </tr>`).join('')}
      </tbody>
    </table>
    </div>` : '<div style="text-align:center;padding:20px;color:#94a3b8;font-size:13px;">لا توجد حجوزات مسجّلة</div>'}

    <div style="display:flex;gap:10px;justify-content:flex-end;margin-top:16px;">
      <a href="https://wa.me/${(g.phone||'').replace(/^0/,'966')}" target="_blank" style="padding:10px 18px;background:#dcfce7;color:#16a34a;border-radius:10px;font-size:13px;font-weight:700;text-decoration:none;">واتساب ↗</a>
      <button onclick="closeCustomerProfile();openGuestCard('${esc(g.phone||'')}')" style="padding:10px 18px;background:#eff6ff;color:#2563eb;border:none;border-radius:10px;font-family:inherit;font-size:13px;font-weight:700;cursor:pointer;">✏️ تعديل البيانات</button>
      <button onclick="closeCustomerProfile()" style="padding:10px 18px;background:#f1f5f9;color:#64748b;border:none;border-radius:10px;font-family:inherit;font-size:13px;font-weight:700;cursor:pointer;">إغلاق</button>
    </div>`;

    document.getElementById('cpBody').innerHTML = html;
  } catch(e) {
    document.getElementById('cpBody').innerHTML = `<div style="color:#dc2626;padding:20px;text-align:center;">❌ ${e.message}</div>`;
  }
}
function closeCustomerProfile() { document.getElementById('customerProfileOverlay').style.display='none'; }

// ── Print Contract ───────────────────────────────────────
async function printContract(bookingId) {
  try {
    const r = await fetch('/staff/api/bookings/' + bookingId);
    if (!r.ok) { toast('❌ تعذر تحميل بيانات الحجز'); return; }
    const b = await r.json();

    let g = null;
    if (b.phone) {
      try { const gr=await fetch('/staff/api/guests/by-phone/'+encodeURIComponent(b.phone)); if(gr.ok) g=await gr.json(); } catch(e){}
    }

    const ID_L = { national_id:'هوية وطنية', passport:'جواز سفر', residence:'إقامة', gcc:'هوية خليجي', other:'أخرى' };
    const BT_L = { daily:'يومي', annual:'شهري', inquiry:'استفسار' };
    const vatRate = propSettings.vatRate ?? 15;
    const net = b.totalPrice || 0;
    const tax = b.bookingType === 'daily' ? Math.round(net * vatRate / 100) : 0;
    const total = net + tax;
    const paid = b.paidAmount || 0;
    const remain = Math.max(0, total - paid);
    const contractNum = 'C-' + b._id.toString().slice(-6).toUpperCase();
    const now = new Date().toLocaleDateString('ar-SA', { year:'numeric', month:'long', day:'numeric' });

    const terms = (propSettings.contractTerms || '').split('\n').filter(Boolean);

    const w = window.open('', '_blank');
    w.document.write(`<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
<meta charset="UTF-8">
<title>عقد إيجار — ${contractNum}</title>
<style>
