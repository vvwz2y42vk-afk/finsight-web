// ── Fuzzy Search Utility ──────────────────────────────────
function _arNorm(s){
  return (s||'').trim()
    .replace(/[أإآ]/g,'ا').replace(/ة/g,'ه').replace(/ى/g,'ي');
}
function _fuzzyScore(text,q){
  if(!text||!q) return 0;
  const t=_arNorm(String(text)), n=_arNorm(q);
  if(!n) return 100;
  if(t===n) return 100;
  if(t.startsWith(n)) return 90;
  if(t.includes(n)) return 80;
  let qi=0; for(let i=0;i<t.length&&qi<n.length;i++) if(t[i]===n[qi]) qi++;
  if(qi===n.length) return 60;
  if(n.length>=3){ for(let s=0;s<n.length;s++){ if(t.includes(n.slice(0,s)+n.slice(s+1))) return 45; } }
  return 0;
}
function fuzzySearch(items,q,fields){
  if(!q||!q.trim()) return items;
  const scored=items.map(item=>({item,score:Math.max(...fields(item).map(f=>_fuzzyScore(f,q)))})).filter(x=>x.score>0);
  scored.sort((a,b)=>b.score-a.score);
  return scored.map(x=>x.item);
}

