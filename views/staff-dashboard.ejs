          <td style="padding:8px 10px;color:#16a34a;">${(b.paidAmount||0).toLocaleString()}</td>
          <td style="padding:8px 10px;"><span style="color:${ST_C[b.status]||'#64748b'};font-weight:600;font-size:11px;">${ST[b.status]||b.status}</span></td>
        </tr>`).join('')}
      </tbody>
    </table>
    </div>` : '<div style="text-align:center;padding:20px;color:#94a3b8;font-size:13px;">لا توجد حجوزات مسجّلة</div>'}

    <div style="display:flex;gap:10px;justify-content:flex-end;margin-top:16px;">
