          <input id="nb-name" type="text" placeholder="اسم النزيل" class="f-idle" oninput="validateField('nb-name','fw-name','fh-name','أدخل اسم النزيل')" style="width:100%;padding:9px;border:1.5px solid #e2e8f0;border-radius:10px;font-family:inherit;font-size:13px;outline:none;">
          <div class="field-hint" id="fh-name"></div>
        </div>
        <div class="field-wrap" id="fw-phone">
          <label style="font-size:12px;font-weight:700;color:#475569;display:block;margin-bottom:5px;"><span class="f-req-star">*</span> رقم الجوال</label>
          <div style="position:relative;">
            <input id="nb-phone" type="tel" inputmode="numeric" maxlength="10" placeholder="05xxxxxxxx" class="f-idle" oninput="this.value=this.value.replace(/[^0-9]/g,'').slice(0,10);onPhoneInput(this.value);validatePhone()" style="width:100%;padding:9px;border:1.5px solid #e2e8f0;border-radius:10px;font-family:inherit;font-size:13px;outline:none;">
            <span id="nb-guest-badge" style="display:none;position:absolute;left:8px;top:50%;transform:translateY(-50%);background:#047857;color:#fff;font-size:10px;font-weight:700;padding:2px 8px;border-radius:20px;">ضيف سابق ✓</span>
          </div>
          <div class="field-hint" id="fh-phone"></div>
        </div>
        <div>
          <label style="font-size:12px;font-weight:700;color:#475569;display:block;margin-bottom:5px;">نوع الحجز *</label>
          <select id="nb-type" onchange="toggleNbType()" style="width:100%;padding:9px;border:1.5px solid #e2e8f0;border-radius:10px;font-family:inherit;font-size:13px;outline:none;">
