      ${b.idNumber?`<div class="info-row"><span>رقم الإثبات:</span><b style="font-family:monospace;">${esc(b.idNumber)}</b></div>`:''}
      ${g?.nationality?`<div class="info-row"><span>الجنسية:</span><b>${esc(g.nationality)}</b></div>`:''}
