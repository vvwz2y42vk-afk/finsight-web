    const grid=document.getElementById('hkGrid');
    const ST={
      clean:{lbl:'نظيف',cls:'hk-clean-c',dot:'#047857'},
      dirty:{lbl:'غير نظيف',cls:'hk-dirty-c',dot:'#B91C1C'},
      inspecting:{lbl:'قيد الفحص',cls:'hk-inspect-c',dot:'#B45309'},
      maintenance:{lbl:'صيانة',cls:'hk-maint-c',dot:'#5B21B6'}
    };
    let cntClean=0,cntDirty=0,cntInsp=0,cntMaint=0;
    list.forEach(t=>{if(t.status==='clean')cntClean++;else if(t.status==='dirty')cntDirty++;else if(t.status==='inspecting')cntInsp++;else if(t.status==='maintenance')cntMaint++;});
    const sumEl=document.getElementById('hk-summary-txt');
    if(sumEl) sumEl.textContent=`نظيف: ${cntClean} · غير نظيف: ${cntDirty} · صيانة: ${cntMaint}`;
    grid.innerHTML=list.map(t=>{
      const s=ST[t.status]||ST.clean;
      return `<div class="hk-card ${s.cls}" onclick="openHkModal('${t.apt}','${t.status}','${esc(t.notes||'')}')">
        <div class="hk-apt">${esc(t.apt)}</div>
        <div class="hk-badge"><span style="width:6px;height:6px;border-radius:50%;background:${s.dot};display:inline-block;flex-shrink:0;"></span>${s.lbl}</div>
        ${t.notes?`<div class="hk-notes">${esc(t.notes)}</div>`:''}
      </div>`;
    }).join('');
  }catch(e){ toast('❌ تعذر تحميل بيانات النظافة'); }
}

