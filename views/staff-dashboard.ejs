        <div class="vou-card" style="background:linear-gradient(135deg,#ef4444,#b91c1c);" onclick="showVouSection('tax')">
          <div class="vou-ico"><svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="12" y1="17" x2="8" y2="17"/></svg></div><div class="vou-lbl">الإشعارات الضريبية</div>
        </div>
