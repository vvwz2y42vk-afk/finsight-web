function toggleNbType(){
  const t=document.getElementById('nb-type').value;
  document.getElementById('nb-checkout-grp').style.display=t==='daily'?'':'none';
  document.getElementById('nb-months-grp').style.display=t==='annual'?'':'none';
  calcNbTotal();
}

function calcNbTotal(){
  const type=document.getElementById('nb-type').value;
  const price=parseFloat(document.getElementById('nb-price').value)||0;
  if(type==='daily'){
    const cin=document.getElementById('nb-checkin').value;
    const cout=document.getElementById('nb-checkout').value;
    if(cin&&cout){ const nights=Math.round((new Date(cout)-new Date(cin))/(86400000)); document.getElementById('nb-total').value=nights>0?nights*price:price; }
  } else {
    const months=parseInt(document.getElementById('nb-months').value)||1;
    document.getElementById('nb-total').value=months*price;
  }
  calcNbRemain();
}
function calcNbRemain(){
  const total=parseFloat(document.getElementById('nb-total').value)||0;
  const paid=parseFloat(document.getElementById('nb-paid').value)||0;
  const remain=Math.max(0,total-paid);
  document.getElementById('nb-remain').value=remain||'';
  document.getElementById('nb-remain').style.color=remain>0?'#dc2626':'#16a34a';
}

function updateNbPrice(){
  const apt=document.getElementById('nb-apt').value;
  const type=document.getElementById('nb-type').value;
  const listing=nbListings.find(r=>r.apt===apt);
  if(listing){
    const p=type==='daily'?(listing.priceDaily||0):(listing.priceAnnual||0);
    if(p) document.getElementById('nb-price').value=p;
    calcNbTotal();
  }
}

async function submitNewBk(){
  const apt=document.getElementById('nb-apt').value;
  const name=document.getElementById('nb-name').value.trim();
  const phone=document.getElementById('nb-phone').value.trim();
  const type=document.getElementById('nb-type').value;
  const checkin=document.getElementById('nb-checkin').value;
  const checkout=type==='daily'?document.getElementById('nb-checkout').value:'';
  const months=type==='annual'?parseInt(document.getElementById('nb-months').value)||1:0;
  const price=parseFloat(document.getElementById('nb-price').value)||0;
  const total=parseFloat(document.getElementById('nb-total').value)||price;
  const paid=parseFloat(document.getElementById('nb-paid').value)||0;
  const idType=document.getElementById('nb-idtype').value;
  const idNumber=document.getElementById('nb-idnum').value.trim();
  const status=document.getElementById('nb-status').value;
  const notes=document.getElementById('nb-notes').value.trim();
  const errEl=document.getElementById('nb-err');
  errEl.style.display='none';
  let valid=true;
  if(!apt)  { shakeField('nb-apt','fw-apt','fh-apt','اختر الشقة'); valid=false; }
  if(!name) { shakeField('nb-name','fw-name','fh-name','أدخل اسم النزيل الكامل'); valid=false; }
  if(!phone||!/^\d{10}$/.test(phone)){ shakeField('nb-phone','fw-phone','fh-phone','رقم جوال صحيح مطلوب (10 أرقام)'); valid=false; }
  if(!checkin){ shakeField('nb-checkin','fw-checkin','fh-checkin','اختر تاريخ الدخول'); valid=false; }
  if(type==='daily'&&!checkout){ shakeField('nb-checkout','nb-checkout-grp','fh-checkout','اختر تاريخ الخروج'); valid=false; }
  if(!price){ shakeField('nb-price','fw-price','fh-price','أدخل سعر الإيجار'); valid=false; }
  if(!valid) return;
  try{
    const body={apt,name,phone,bookingType:type,checkIn:checkin,checkOut:checkout,months,pricePerUnit:price,totalPrice:total,paidAmount:paid,idType,idNumber,status,notes};
    const url=editBkId?`/staff/api/bookings/${editBkId}/edit`:'/staff/api/bookings/new';
    const method=editBkId?'PUT':'POST';
    const r=await fetch(url,{method,headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
    const d=await r.json();
    if(!r.ok){errEl.textContent=d.error||'حدث خطأ';errEl.style.display='block';return;}
    closeNewBkModal();
    toast(editBkId?'✏️ تم تعديل الحجز':'✅ تم إضافة الحجز بنجاح','success');
    loadApartments(); loadStats(); loadBookings();
  }catch(e){errEl.textContent='حدث خطأ';errEl.style.display='block';}
}

