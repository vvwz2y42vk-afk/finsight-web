function renderAptGrid(){
  if(!aptsRawData){return;}
  const container=document.getElementById('aptsContainer');
  let html='<div class="apt-bld"><div class="apt-bld-hd"><div class="apt-bld-name">'+esc(aptsRawData.building)+'</div></div>';
  aptsRawData.floors.forEach(floor=>{
    const rooms=floor.rooms.filter(r=>aptsFilter==='all'||r.status===aptsFilter);
    if(!rooms.length) return;
    html+=`<div class="apt-floor-lbl">${esc(floor.label)}</div><div class="apt-grid">`;
    rooms.forEach(r=>{
      const s=APT_MAP[r.status]||{cls:'',lbl:r.status};
      const hkClass=r.housekeeping==='dirty'?'dirty':r.housekeeping==='maintenance'?'maintenance':'';
      const dbInfo=roomInfoMap[r.apt]||null;
      const fbInfo=(APT_TYPES[BUILDING]||{})[r.apt]||null;
      const rt=dbInfo?.roomType||fbInfo?.t||'';
      const bd=dbInfo?.beds||fbInfo?.b||'';
      const editBtn=can('edit_room_info')?`<div onclick="event.stopPropagation();openRoomInfoModal('${r.apt}','${esc(rt)}','${esc(bd)}')" style="position:absolute;top:4px;left:4px;width:16px;height:16px;background:rgba(255,255,255,.25);border-radius:4px;display:flex;align-items:center;justify-content:center;cursor:pointer;" title="تعديل">✏️</div>`:'';
      html+=`<div class="apt ${s.cls} ${hkClass}" style="position:relative;" onclick="openBkModal('${r.bookingId||''}','${r.apt}','${r.status}')">
        ${editBtn}
        <div class="apt-n">${esc(r.apt)}</div>
        ${rt?'<div class="apt-type">'+esc(rt)+'</div>':''}
        ${bd?'<div class="apt-type" style="opacity:.65;">('+esc(bd)+')</div>':''}
        <div class="apt-s">${s.lbl}</div>
        ${r.name?'<div class="apt-g">'+esc(r.name)+'</div>':''}
      </div>`;
    });
    html+='</div>';
  });
  html+='</div>';
  container.innerHTML=html;
}

function filterApts(f,btn){
  aptsFilter=f;
