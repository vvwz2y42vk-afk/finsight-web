async function confirmRefund(bookingId, amount, guestName, apt){
  const method=document.getElementById('refund-method')?.value||'cash';
  document.getElementById('refund-overlay')?.remove();
  try{
    const r=await fetch('/staff/api/vouchers',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({
        type:'disbursement',
        name: guestName,
        apt,
        amount,
        description: `استرداد إلغاء حجز — شقة ${apt} — ${guestName}`,
        paymentMethod: method,
        bookingId,
      })
    });
    const d=await r.json();
    if(d.success) toast('✅ سند الاسترداد: '+d.number,'success');
    else toast('❌ فشل إنشاء سند الاسترداد: '+(d.error||''),'error');
  }catch(e){ toast('❌ حدث خطأ في إنشاء سند الاسترداد'); }
}

async function changeStatus(id,status){
  if(status==='checkout' && !confirm('تأكيد تسجيل خروج النزيل من الشقة؟')) return;
  try{
    const r=await fetch('/staff/api/bookings/'+id+'/status',{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({status})});
    const d=await r.json();
    if(d.success){ toast(status==='active'?'✅ تم تسجيل الدخول':'🚪 تم تسجيل الخروج','success'); closeBkModal(); loadApartments(); loadStats(); _pollKick(); }
    else toast('❌ '+d.error,'error');
  }catch(e){ toast('❌ حدث خطأ'); }
}

