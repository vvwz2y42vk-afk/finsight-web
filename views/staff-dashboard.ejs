  const bld=document.getElementById('rec-bld-filter')?.value||'';
  const r=await fetch(`/staff/api/receipts${bld?'?building='+encodeURIComponent(bld):''}`).catch(()=>null);
  if(!r||!r.ok){ el.innerHTML='<div style="padding:40px;text-align:center;color:#dc2626;">خطأ في تحميل الإيصالات</div>'; return; }
  const recs=await r.json();
  // Stats
  const total=recs.length;
  const matched=recs.filter(r=>r.analysis?.matchesBuilding===true).length;
  const warned=recs.filter(r=>r.analysis?.matchesBuilding===false).length;
  const sumAmt=recs.reduce((s,r)=>s+(r.analysis?.amount||r.analysis?.cashTotal||0),0);
  if(statsEl) statsEl.innerHTML=`
    <div style="background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:10px 16px;flex:1;min-width:100px;text-align:center;">
      <div style="font-size:20px;font-weight:800;color:#0f172a;">${total}</div><div style="font-size:11px;color:#64748b;">إجمالي الإيصالات</div>
    </div>
    <div style="background:#d1fae5;border:1px solid #6ee7b7;border-radius:10px;padding:10px 16px;flex:1;min-width:100px;text-align:center;">
      <div style="font-size:20px;font-weight:800;color:#065f46;">${matched}</div><div style="font-size:11px;color:#065f46;">مطابق للجهة</div>
    </div>
    <div style="background:#fef3c7;border:1px solid #fcd34d;border-radius:10px;padding:10px 16px;flex:1;min-width:100px;text-align:center;">
      <div style="font-size:20px;font-weight:800;color:#92400e;">${warned}</div><div style="font-size:11px;color:#92400e;">تحذير جهة</div>
    </div>
    <div style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:10px;padding:10px 16px;flex:1;min-width:100px;text-align:center;">
      <div style="font-size:20px;font-weight:800;color:#1a3d8f;">${sumAmt.toLocaleString('ar-SA')}</div><div style="font-size:11px;color:#1a3d8f;">إجمالي المبالغ (ريال)</div>
    </div>`;
  if(!recs.length){ el.innerHTML='<div style="padding:60px;text-align:center;color:#94a3b8;font-size:13px;">لا توجد إيصالات مسجلة</div>'; return; }
  const typeMap={network:'شبكة',transfer:'تحويل',cash:'نقداً',other:'أخرى'};
  el.innerHTML=`<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(270px,1fr));gap:14px;">${
    recs.map(rec=>{
      const a=rec.analysis||{};
      const date=new Date(rec.createdAt).toLocaleDateString('ar-SA',{year:'numeric',month:'short',day:'numeric'});
      const isMismatch=a.matchesBuilding===false;
      const isMatch=a.matchesBuilding===true;
      const borderColor=isMismatch?'#fcd34d':isMatch?'#6ee7b7':'#e2e8f0';
      const amtVal=a.cashTotal!=null?a.cashTotal:a.amount;
      const imgSrc=rec.imageData?`data:${rec.imageMimeType||'image/jpeg'};base64,${rec.imageData}`:null;
      return `<div style="background:#fff;border:1.5px solid ${borderColor};border-radius:14px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,.06);">
        ${imgSrc?`<img src="${imgSrc}" style="width:100%;height:150px;object-fit:cover;cursor:pointer;display:block;" onclick="document.getElementById('receipt-fullscreen-img').src=this.src;document.getElementById('receipt-fullscreen').style.display='flex'" onerror="this.parentNode.removeChild(this)">`:
        '<div style="height:70px;background:#f1f5f9;display:flex;align-items:center;justify-content:center;font-size:28px;">🧾</div>'}
        <div style="padding:12px;">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;">
            <span style="font-size:14px;font-weight:700;color:#0f172a;">${esc(rec.apt||'—')}</span>
            <span style="font-size:10px;color:#64748b;">${date}</span>
          </div>
          <div style="font-size:11px;color:#475569;margin-bottom:2px;">${esc(rec.guestName||'—')}</div>
          <div style="font-size:11px;color:#64748b;margin-bottom:8px;">${esc(rec.building||'')}</div>
          <div style="background:#f8fafc;border-radius:8px;padding:8px;font-size:11px;display:grid;grid-template-columns:auto 1fr;gap:3px 8px;">
            <span style="color:#64748b;">النوع:</span><span style="font-weight:700;">${typeMap[a.paymentType]||a.paymentType||'—'}</span>
            <span style="color:#64748b;">المبلغ:</span><span style="font-weight:700;color:#059669;">${amtVal!=null?Number(amtVal).toLocaleString('ar-SA')+' ريال':'—'}</span>
            ${a.transactionNumber?`<span style="color:#64748b;">العملية:</span><span style="font-weight:700;word-break:break-all;">${esc(a.transactionNumber)}</span>`:''}
            ${a.entityName?`<span style="color:#64748b;">الجهة:</span><span style="font-weight:700;">${esc(a.entityName)} ${isMismatch?'⚠️':isMatch?'✓':''}</span>`:''}
          </div>
          ${isMismatch?`<div style="margin-top:6px;font-size:10px;color:#92400e;font-weight:600;">⚠️ الجهة لا تطابق المبنى</div>`:''}
          ${rec.bookingId?`<div style="margin-top:6px;font-size:10px;color:#64748b;">الحجز: ${String(rec.bookingId).slice(-8)}</div>`:''}
        </div>
      </div>`;
    }).join('')
  }</div>`;
}

