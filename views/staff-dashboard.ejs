      <button onclick="closePrint()" style="padding:8px 20px;background:#f1f5f9;color:#475569;border:none;border-radius:8px;font-family:Cairo,sans-serif;font-size:13px;font-weight:700;cursor:pointer;">✕ إغلاق</button>
    </div>
    <div class="print-doc">
      <div class="print-hd">
        <div>
