          <input id="nb-checkout" type="date" class="f-idle" onchange="calcNbTotal();validateField('nb-checkout','nb-checkout-grp','fh-checkout','اختر تاريخ الخروج')" style="width:100%;padding:9px;border:1.5px solid #e2e8f0;border-radius:10px;font-family:inherit;font-size:13px;outline:none;">
          <div class="field-hint" id="fh-checkout"></div>
        </div>
