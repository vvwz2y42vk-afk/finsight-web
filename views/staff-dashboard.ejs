      <div id="refund-method-row" style="margin-bottom:16px;">
        <label style="font-size:11px;font-weight:700;color:#475569;display:block;margin-bottom:5px;">طريقة الاسترداد</label>
        <select id="refund-method" style="width:100%;padding:8px;border:1.5px solid #e2e8f0;border-radius:9px;font-family:inherit;font-size:12px;outline:none;">
