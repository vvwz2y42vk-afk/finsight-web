function cfInitDates(){
  const now=new Date();
  const pad=n=>String(n).padStart(2,'0');
  const y=now.getFullYear(), m=pad(now.getMonth()+1), d=pad(now.getDate());
  document.getElementById('cf-from').value=`${y}-${m}-${d}T00:00`;
  document.getElementById('cf-to').value=`${y}-${m}-${d}T23:59`;
}

async function loadCashFlow(){
  const from=document.getElementById('cf-from').value;
  const to=document.getElementById('cf-to').value;
  const user=document.getElementById('cf-user').value;
  const includeClosed=document.getElementById('cf-closed').checked;
  const includeServices=document.getElementById('cf-services').checked;
  const includeDeposits=document.getElementById('cf-deposits').checked;

  const body=document.getElementById('cf-body');
  body.innerHTML='<div style="text-align:center;padding:30px;color:var(--t4);">⏳ جاري التحميل...</div>';

  try{
    const p=new URLSearchParams({dateFrom:from,dateTo:to,user,includeClosed,includeServices,includeDeposits});
    const r=await fetch('/staff/api/reports/cash-flow?'+p);
    const d=await r.json();
    if(!r.ok){body.innerHTML=`<div style="color:#dc2626;padding:20px;">❌ ${d.error||'حدث خطأ'}</div>`;return;}

    // تحديث قائمة المستخدمين
    const sel=document.getElementById('cf-user');
    const cur=sel.value;
    sel.innerHTML='<option value="">الجميع</option>'+(d.users||[]).map(u=>`<option value="${esc(u)}"${u===cur?' selected':''}>${esc(u)}</option>`).join('');

    const fmt2=n=>(n||0).toLocaleString('ar',{minimumFractionDigits:2,maximumFractionDigits:2});
    const fmtDt=dt=>{
      if(!dt) return '—';
      const x=new Date(dt);
      if(isNaN(x.getTime())) return '—';
      return x.toLocaleDateString('ar-SA',{day:'2-digit',month:'2-digit',year:'numeric'})+' '+x.toLocaleTimeString('ar-SA',{hour:'2-digit',minute:'2-digit'});
    };
    const pmL={cash:'نقداً',transfer:'تحويل بنكي',network:'شبكة',check:'كمبيالة',digital:'دفع رقمي',travel_agent:'وكيل سفر','':'نقداً'};
    const pmBg={cash:'#f0fdf4',transfer:'#eff6ff',network:'#fef3c7',check:'#f5f3ff',digital:'#ecfeff',travel_agent:'#fff7ed','':'#f0fdf4'};
    const pmC={cash:'#166534',transfer:'#1a3d8f',network:'#92400e',check:'#7c3aed',digital:'#0891b2',travel_agent:'#b45309','':'#166534'};

