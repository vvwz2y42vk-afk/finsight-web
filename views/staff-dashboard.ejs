    closeRoomInfoModal();
    renderAptGrid();
    toast('تم حفظ بيانات الشقة '+riCurrentApt);
  }catch(e){errEl.textContent='حدث خطأ';errEl.style.display='block';}
}


// ── Date Pickers ─────────────────────────────────────────
function initFP(){
  ['bkDateFrom','bkDateTo','custDateFrom','custDateTo','nb-checkin','nb-checkout'].forEach(id=>{
    const el=document.getElementById(id);
    if(!el||el._flatpickr)return;
    flatpickr(el,{locale:'ar',dateFormat:'Y-m-d',disableMobile:true,
      onChange(){el.dispatchEvent(new Event('change'));}
    });
  });
}

// ── Init ─────────────────────────────────────────────────
window.addEventListener('load',()=>{
  loadStats();
  loadApartments();
  updateClock();
  setTimeout(initFP,300);

  setInterval(updateClock,1000);
  setInterval(loadStats,60000);
  setInterval(loadApartments,30000);
  if('serviceWorker' in navigator)navigator.serviceWorker.register('/sw.js').catch(()=>{});
});
// re-init after tab switch in case new date inputs appeared
