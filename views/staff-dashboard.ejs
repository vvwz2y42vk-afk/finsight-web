        const pDate=new Date(p.date).toLocaleDateString('ar-SA',{day:'2-digit',month:'2-digit',year:'numeric'})+' '+new Date(p.date).toLocaleTimeString('ar-SA',{hour:'2-digit',minute:'2-digit'});
        html+=`<div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;padding:9px 12px;margin-bottom:6px;display:flex;justify-content:space-between;align-items:center;gap:8px;">
          <div style="display:flex;align-items:center;gap:8px;flex:1;flex-wrap:wrap;">
