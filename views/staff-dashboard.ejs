  if(id==='reports'){
    if(!can('reports')){
      document.getElementById('tab-reports').innerHTML=`
        <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;padding:60px 20px;text-align:center;">
          <div style="font-size:48px;margin-bottom:16px;">🔒</div>
          <div style="font-size:17px;font-weight:700;color:var(--t1);margin-bottom:8px;">ليس لديك صلاحية</div>
          <div style="font-size:13px;color:var(--t3);">تواصل مع المدير لتفعيل صلاحية التقارير</div>
        </div>`;
    } else { loadReports(); loadYearlyChart(); cfInitDates(); initOccAptDropdown(); }
  }
  if(id==='analytics')  loadAnalytics();
  if(id==='receipts')     loadReceipts();
  if(id==='maintenance')  loadMaintenance();
  if(id==='calendar')     loadCalendar();
  if(id==='settings')   loadSettings();
  if(id==='channels')   loadChannels();
}

// ── Smart Sync (SWR-style change detection) ──────────────
function _djb2(s){let h=5381;for(let i=0;i<s.length;i++)h=((h<<5)+h)^s.charCodeAt(i);return h>>>0;}
let _statsHash=null, _aptsHash=null;

function _syncPulse(dotId){
  const el=document.getElementById(dotId);
  if(!el) return;
  el.style.background='#10b981';el.style.animation='none';
  setTimeout(()=>{el.style.background='#047857';el.style.animation='dot-pulse 2s infinite';},700);
}

// ── Dashboard ────────────────────────────────────────────
let _acStats=null;
async function loadStats(){
  if(_acStats)_acStats.abort();
  _acStats=new AbortController();
  try{
    const r=await fetch('/staff/api/stats',{signal:_acStats.signal}); const d=await r.json();
    const h=_djb2(JSON.stringify(d));
    if(h===_statsHash) return; // بيانات لم تتغيّر — تجنّب إعادة الرسم
    _statsHash=h;
    animateNum(document.getElementById('k-arrivals'), d.arrivals);
    animateNum(document.getElementById('k-checkin'), d.arrivals);
    animateNum(document.getElementById('k-departures'), d.departures);
    animateNum(document.getElementById('k-guests'), d.currentGuests);
    animateNum(document.getElementById('k-new'), d.newBookings);
    animateNum(document.getElementById('k-rate'), d.occupancyRate, '%');
    renderWeeklyChart(d.weekly, d.total);
    renderDonut(d.occupied, d.total);
  }catch(e){ if(e.name!=='AbortError') toast('❌ تعذر تحميل الإحصاءات — تحقق من الاتصال'); }
}

function renderWeeklyChart(weekly, total){
  const ctx=document.getElementById('weeklyChart').getContext('2d');
  if(weeklyChartInst) weeklyChartInst.destroy();

  // Gradient fills
  const gradOcc=ctx.createLinearGradient(0,0,0,180);
  gradOcc.addColorStop(0,'rgba(185,28,28,.35)');
  gradOcc.addColorStop(1,'rgba(185,28,28,.02)');
  const gradVac=ctx.createLinearGradient(0,0,0,180);
  gradVac.addColorStop(0,'rgba(4,120,87,.22)');
  gradVac.addColorStop(1,'rgba(4,120,87,.01)');

  weeklyChartInst=new Chart(ctx,{
    type:'line',
    data:{
      labels:weekly.map(w=>w.label),
      datasets:[
        {
          label:'محجوز',
          data:weekly.map(w=>w.occupied),
          borderColor:'#DC2626',
          backgroundColor:gradOcc,
          borderWidth:2.5,
          pointRadius:4,pointHoverRadius:6,
          pointBackgroundColor:'#fff',pointBorderColor:'#DC2626',pointBorderWidth:2,
          tension:.42,fill:true,
        },
        {
          label:'شاغر',
          data:weekly.map(w=>Math.max(0,total-w.occupied)),
          borderColor:'#059669',
          backgroundColor:gradVac,
          borderWidth:2,
          pointRadius:3,pointHoverRadius:5,
          pointBackgroundColor:'#fff',pointBorderColor:'#059669',pointBorderWidth:2,
          tension:.42,fill:true,
        },
      ]
    },
    options:{
      responsive:true,
      interaction:{mode:'index',intersect:false},
      plugins:{
        legend:{position:'top',labels:{font:{family:'Cairo',size:11},color:'#64748B',boxWidth:10,boxHeight:10,borderRadius:4,useBorderRadius:true,padding:16}},
        tooltip:{backgroundColor:'#0F172A',titleFont:{family:'Cairo',size:12},bodyFont:{family:'Cairo',size:11},padding:12,cornerRadius:10,displayColors:true,callbacks:{label:ctx=>`${ctx.dataset.label}: ${ctx.parsed.y}`}}
      },
      scales:{
        x:{grid:{display:false},border:{display:false},ticks:{font:{family:'Cairo',size:10},color:'#94A3B8'}},
        y:{max:total+1,min:0,grid:{color:'rgba(226,232,240,.5)',drawBorder:false},border:{display:false},ticks:{font:{family:'Cairo',size:10},color:'#94A3B8',maxTicksLimit:5}}
      }
    }
  });
}

function renderDonut(occupied, total){
  const ctx=document.getElementById('donutChart').getContext('2d');
  if(donutChartInst) donutChartInst.destroy();
  const vacant=Math.max(0,total-occupied);
  const rate=total?Math.round(occupied/total*100):0;
  donutChartInst=new Chart(ctx,{
    type:'doughnut',
    data:{labels:['محجوز','شاغر'],datasets:[{
      data:[occupied||0,vacant||1],
      backgroundColor:['#B91C1C','#047857'],
      hoverBackgroundColor:['#991B1B','#036046'],
      borderWidth:0,
      borderRadius:4,
      spacing:2
    }]},
    options:{cutout:'76%',plugins:{legend:{display:false},tooltip:{backgroundColor:'#0F172A',titleFont:{family:'Cairo',size:11},bodyFont:{family:'Cairo',size:11},padding:10,cornerRadius:8}}}
  });
  document.getElementById('donutPct').textContent=rate+'%';
  document.getElementById('donutLegend').innerHTML=
    `<span style="display:flex;align-items:center;gap:5px;color:#64748B;font-size:11px;"><span style="width:8px;height:8px;border-radius:2px;background:#B91C1C;display:inline-block;"></span>محجوز ${occupied}</span>`+
    `<span style="display:flex;align-items:center;gap:5px;color:#64748B;font-size:11px;"><span style="width:8px;height:8px;border-radius:2px;background:#047857;display:inline-block;"></span>شاغر ${Math.max(0,total-occupied)}</span>`;
}

function renderRoomTypeChart(){
  if(!aptsRawData) return;
  const el=document.getElementById('roomTypeChart');
  if(!el) return;
  const bTypes=APT_TYPES[BUILDING]||{};
  const stats={};
  aptsRawData.floors.forEach(f=>f.rooms.forEach(r=>{
    const dbInfo=roomInfoMap[r.apt]||null;
    const fbInfo=bTypes[r.apt]||null;
    const type=dbInfo?.roomType||fbInfo?.t||'';
    if(!type) return;
    if(!stats[type]) stats[type]={total:0,occupied:0};
    stats[type].total++;
    if(['occupied','checkin_today','checkout_today','awaiting','awaiting_payment'].includes(r.status))
      stats[type].occupied++;
  }));
  const sorted=Object.entries(stats).sort((a,b)=>b[1].total-a[1].total);
  if(!sorted.length){el.innerHTML='<div style="font-size:11px;color:#94a3b8;text-align:center;padding:20px 0;">لا توجد بيانات</div>';return;}
  el.innerHTML=sorted.map(([type,{total,occupied}])=>{
    const pct=total?Math.round(occupied/total*100):0;
    const barColor = pct>=85
      ? 'linear-gradient(90deg,#DC2626,#EF4444)'
      : pct>=60
        ? 'linear-gradient(90deg,#D97706,#F59E0B)'
        : 'linear-gradient(90deg,#1a3d8f,#3B82F6)';
    const pctColor = pct>=85?'#DC2626':pct>=60?'#D97706':'#1a3d8f';
    return `<div style="margin-bottom:14px;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
        <span style="font-size:11px;font-weight:700;color:var(--t2);">${esc(type)}</span>
        <span style="font-size:11px;font-weight:800;color:${pctColor};">${pct}%</span>
      </div>
      <div style="background:rgba(226,232,240,.6);border-radius:20px;height:6px;overflow:hidden;">
        <div style="background:${barColor};height:100%;width:${pct}%;border-radius:20px;transition:width .7s cubic-bezier(.4,0,.2,1);box-shadow:0 1px 4px rgba(0,0,0,.12);"></div>
      </div>
      <div style="font-size:9px;color:var(--t4);margin-top:3px;text-align:left;">${occupied} من ${total}</div>
    </div>`;
  }).join('');
}

function renderHkDonut(){
  if(!aptsRawData) return;
  let clean=0, dirty=0;
  aptsRawData.floors.forEach(f=>f.rooms.forEach(r=>{
    if(r.housekeeping==='dirty'||r.housekeeping==='maintenance'||r.housekeeping==='inspection') dirty++;
    else clean++;
  }));
  const canvas=document.getElementById('hkDonutChart');
  if(!canvas) return;
  const ctx=canvas.getContext('2d');
  if(hkDonutInst) hkDonutInst.destroy();
  hkDonutInst=new Chart(ctx,{
    type:'doughnut',
    data:{labels:['نظيف','غير نظيف'],datasets:[{
      data:[clean||0, dirty||0],
      backgroundColor:['rgba(4,120,87,.55)','rgba(234,179,8,.6)'],
      hoverBackgroundColor:['rgba(4,120,87,.8)','rgba(234,179,8,.85)'],
      borderWidth:0,borderRadius:4
    }]},
    options:{cutout:'76%',plugins:{legend:{display:false},tooltip:{backgroundColor:'#0F172A',titleFont:{family:'Cairo',size:11},bodyFont:{family:'Cairo',size:11},padding:10,cornerRadius:8}}}
  });
  const numEl=document.getElementById('hkDonutNum'); if(numEl) numEl.textContent=clean;
  document.getElementById('hkDonutLegend').innerHTML=
    `<span style="display:flex;align-items:center;gap:5px;color:#64748B;font-size:11px;"><span style="width:8px;height:8px;border-radius:2px;background:rgba(4,120,87,.7);display:inline-block;"></span>نظيف ${clean}</span>`+
    `<span style="display:flex;align-items:center;gap:5px;color:#64748B;font-size:11px;"><span style="width:8px;height:8px;border-radius:2px;background:rgba(234,179,8,.8);display:inline-block;"></span>غير نظيف ${dirty}</span>`;
}

// ── Apartments ───────────────────────────────────────────
let _acApts=null;
async function loadApartments(){
  if(_acApts)_acApts.abort();
  _acApts=new AbortController();
  try{
    const [r, ri]=await Promise.all([fetch('/staff/api/apartments',{signal:_acApts.signal}),fetch('/staff/api/room-info',{signal:_acApts.signal})]);
    const freshApts=await r.json();
    const freshRoom=ri.ok?await ri.json():null;
    const h=_djb2(JSON.stringify(freshApts)+(freshRoom?JSON.stringify(freshRoom):''));
    const changed=h!==_aptsHash;
    _aptsHash=h;
    aptsRawData=freshApts;
    if(freshRoom) roomInfoMap=freshRoom;
    if(changed){
      renderAptGrid();
      updateAptCounts();
      renderTodaySchedule();
      renderMonthlyProgress();
      renderHkDonut();
      renderRoomTypeChart();
      _syncPulse('apt-sync-dot');
    }
    const el=document.getElementById('apt-sync-time');
    if(el) el.textContent=new Date().toLocaleTimeString('ar-SA',{hour:'2-digit',minute:'2-digit'});
  }catch(e){
    if(e.name==='AbortError') return;
    const el=document.getElementById('apt-sync-dot');
    if(el){el.style.background='#B91C1C';}
  }
}

function renderTodaySchedule(){
  if(!aptsRawData) return;
  const arrivals=[], departures=[];
  aptsRawData.floors.forEach(f=>f.rooms.forEach(r=>{
    if(r.status==='checkin_today') arrivals.push(r);
    else if(r.status==='checkout_today') departures.push(r);
  }));

  const card = (r,color) => `<div style="display:flex;align-items:center;gap:8px;padding:6px 8px;background:#f8fafc;border-radius:8px;border-right:3px solid ${color};">
    <div style="flex:1;min-width:0;">
      <div style="font-size:11px;font-weight:700;color:#1e3a5f;">${esc(r.apt)}</div>
      <div style="font-size:10px;color:#64748b;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${r.name?esc(r.name):'—'}</div>
    </div>
  </div>`;

  const arrEl=document.getElementById('today-arrivals');
  const depEl=document.getElementById('today-departures');
  const emptyState=(msg,color)=>`<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;padding:20px 8px;gap:6px;"><div style="width:36px;height:36px;border-radius:50%;background:rgba(148,163,184,.08);display:flex;align-items:center;justify-content:center;"><svg width="16" height="16" fill="none" stroke="#CBD5E1" stroke-width="1.8" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div><span style="font-size:11px;color:#CBD5E1;font-weight:500;">${msg}</span></div>`;
  if(arrEl) arrEl.innerHTML=arrivals.length?arrivals.map(r=>card(r,'#1D4ED8')).join(''):emptyState('لا يوجد وصول اليوم','#1D4ED8');
  if(depEl) depEl.innerHTML=departures.length?departures.map(r=>card(r,'#B45309')).join(''):emptyState('لا يوجد مغادرة اليوم','#B45309');
  const ac=document.getElementById('arr-count'); if(ac) ac.textContent=arrivals.length;
  const dc=document.getElementById('dep-count'); if(dc) dc.textContent=departures.length;
}

function renderMonthlyProgress(){
  if(!aptsRawData) return;
  const target=20;
  let booked=0;
  aptsRawData.floors.forEach(f=>f.rooms.forEach(r=>{
    if(['occupied','checkout_today','checkin_today','awaiting','awaiting_payment'].includes(r.status)) booked++;
  }));
  const pct=Math.min(Math.round(booked/target*100),100);
  const bar=document.getElementById('monthly-bar');
  const pctEl=document.getElementById('monthly-pct');
  const lbl=document.getElementById('monthly-label');
  if(bar) bar.style.width=pct+'%';
  if(bar) bar.style.background=pct>=100?'linear-gradient(90deg,#047857,#10b981)':'linear-gradient(90deg,#1a3d8f,#2a5cc7)';
  if(pctEl) pctEl.textContent=pct+'%';
  if(lbl) lbl.textContent=booked+' / '+target+' وحدة مشغولة';
}

function updateAptCounts(){
  if(!aptsRawData) return;
  const c={occupied:0,vacant:0,checkin_today:0,checkout_today:0,awaiting:0,awaiting_payment:0};
  let totOcc=0, totAll=0;
  aptsRawData.floors.forEach(f=>f.rooms.forEach(r=>{
    totAll++; c[r.status]=(c[r.status]||0)+1;
    if(['occupied','checkout_today','awaiting','checkin_today'].includes(r.status)) totOcc++;
  }));
  Object.keys(c).forEach(k=>{const el=document.getElementById('fc-'+k);if(el)el.textContent=c[k]||0;});
  const rate=totAll?Math.round(totOcc/totAll*100):0;
  const el=document.getElementById('apts-occ-rate');
  if(el) el.innerHTML=`نسبة الإشغال: <span style="color:#1a3d8f;">${rate}%</span> (${totOcc}/${totAll})`;
  const sbNum=document.getElementById('sb-occ-num');
  const sbTot=document.getElementById('sb-occ-total');
  const sbFill=document.getElementById('sb-occ-fill');
  if(sbNum) sbNum.textContent=rate+'%';
  if(sbTot) sbTot.textContent=totOcc+'/'+totAll+' وحدة';
  if(sbFill) sbFill.style.width=rate+'%';
  // تحديث بادج الإشغال في التوبار
  const topOcc=document.getElementById('topbar-occ-badge');
  const topOccTxt=document.getElementById('topbar-occ-txt');
  if(topOcc&&topOccTxt){topOcc.style.display='flex';topOccTxt.textContent=totOcc+' / '+totAll+' وحدة';}
  // شريط الإشغال (نزيل style)
  updateAptOccBar();
  // عداد الصيانة
  const mcnt=document.getElementById('fc-maintenance');
  if(mcnt) mcnt.textContent=c['maintenance']||0;
  // عرض محتوى تبويب الشقق الحالي
  renderAptTabContent();

  // شريط التنبيهات العاجلة
  const strip=document.getElementById('apt-alert-strip');
  if(!strip) return;
  const alerts=[];
  if(c.checkin_today>0) alerts.push(`<div style="display:flex;align-items:center;gap:8px;padding:10px 16px;background:linear-gradient(135deg,rgba(29,78,216,.08),rgba(29,78,216,.04));border:1px solid rgba(29,78,216,.2);border-radius:10px;"><span style="width:8px;height:8px;border-radius:50%;background:#2563eb;display:inline-block;animation:dot-pulse 1.5s infinite;flex-shrink:0;"></span><span style="font-size:13px;font-weight:700;color:#1D4ED8;">${c.checkin_today} حجز بانتظار الدخول اليوم</span></div>`);
  if(c.checkout_today>0) alerts.push(`<div style="display:flex;align-items:center;gap:8px;padding:10px 16px;background:linear-gradient(135deg,rgba(180,83,9,.08),rgba(180,83,9,.04));border:1px solid rgba(180,83,9,.2);border-radius:10px;"><span style="width:8px;height:8px;border-radius:50%;background:#B45309;display:inline-block;animation:dot-pulse 1.5s infinite;flex-shrink:0;"></span><span style="font-size:13px;font-weight:700;color:#B45309;">${c.checkout_today} شقة موعد خروجها اليوم</span></div>`);
  if(alerts.length){
    strip.style.display='flex';
    strip.style.gap='10px';
    strip.style.flexWrap='wrap';
    strip.innerHTML=alerts.join('');
  } else { strip.style.display='none'; }
}

// ── Apartment Sub-tabs (نزيل style) ──────────────────────
let _aptTab='checkin';
function switchAptTab(tab){
  _aptTab=tab;
  ['checkin','checkout','status'].forEach(t=>{
    const btn=document.getElementById('apt-tab-'+t);
    const pane=document.getElementById('apt-pane-'+t);
    const isActive=(t===tab);
    if(btn){
      btn.style.color=isActive?'var(--brand)':'var(--t3)';
      btn.style.borderBottom=isActive?'2px solid var(--brand)':'2px solid transparent';
    }
    if(pane) pane.style.display=isActive?'block':'none';
  });
  // شريط العدادات + فلاتر — يظهر فقط في وضع حالة الشقق
  const sc=document.getElementById('apt-status-counters');
  const sf=document.getElementById('apt-status-filters');
  if(sc) sc.style.display=tab==='status'?'flex':'none';
  if(sf) sf.style.display=tab==='status'?'flex':'none';
  renderAptTabContent();
}

function renderAptTabContent(){
  if(!aptsRawData) return;
  const allRooms=[];
  aptsRawData.floors.forEach(f=>f.rooms.forEach(r=>allRooms.push(r)));

  if(_aptTab==='checkin'){
    const checkins=allRooms.filter(r=>r.status==='awaiting_checkin'||r.status==='checkin_today');
    const el=document.getElementById('apt-checkin-cards');
    if(!el) return;
    if(!checkins.length){
      el.innerHTML='<div style="grid-column:1/-1;text-align:center;padding:40px 20px;color:var(--t4);">✅ لا يوجد حجوزات بانتظار تسجيل الدخول</div>';
      return;
    }
    el.innerHTML=checkins.map(r=>`
      <div onclick="openBkModal('${r.bookingId||''}','${r.apt}','${r.status}')" style="background:linear-gradient(145deg,#EFF6FF,#DBEAFE);border:1.5px solid rgba(59,130,246,.3);border-radius:12px;padding:12px 10px;cursor:pointer;transition:all .2s;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform=''">
        <div style="font-size:9px;font-weight:700;color:#1D4ED8;margin-bottom:4px;text-align:center;background:rgba(29,78,216,.08);border-radius:6px;padding:2px 6px;">${r.apt} — ${r.bookingType==='daily'?'يومي':'شهري'}</div>
        <div style="font-size:12px;font-weight:800;color:#1E3A8A;text-align:center;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${r.name||'—'}</div>
        <div style="font-size:10px;color:#3B82F6;text-align:center;margin-top:3px;">الرصيد: ${(Math.max(0,(r.totalPrice||0)-(r.paidAmount||0))).toLocaleString()} ر</div>
