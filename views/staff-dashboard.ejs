async function loadOccupancyReport(){
  const from=document.getElementById('occ-from')?.value;
  const to=document.getElementById('occ-to')?.value;
  const apt=document.getElementById('occ-apt')?.value||'';
  const type=document.querySelector('input[name="occ-type"]:checked')?.value||'rooms';
  const body=document.getElementById('occ-body');
  if(!from||!to){ toast('اختر نطاق التاريخ'); return; }
  body.innerHTML='<div style="padding:20px;color:var(--t4);">⏳ جاري التحميل...</div>';
  try{
    const params=new URLSearchParams({from,to,apt,type});
    const r=await fetch('/staff/api/reports/occupancy?'+params);
    const d=await r.json();
    if(!r.ok){ body.innerHTML=`<div style="color:#dc2626;padding:20px;">${d.error||'حدث خطأ'}</div>`; return; }
    renderOccupancyReport(d,type,from,to);
  }catch(e){ body.innerHTML='<div style="color:#dc2626;padding:20px;">❌ حدث خطأ</div>'; }
}

function renderOccupancyReport(d,type,from,to){
  const body=document.getElementById('occ-body');
  const rows=d.rows||[];
  const totalDays=d.totalDays||1;
  body.innerHTML=`
    <div style="background:#fff;border:1px solid var(--border);border-radius:12px;overflow:hidden;" id="occ-printable">
      <div style="background:var(--brand);color:#fff;padding:12px 18px;font-weight:700;font-size:14px;display:flex;justify-content:space-between;align-items:center;">
        <span>تقرير نسب الإشغال${type==='types'?' (أنواع الغرف)':' (الغرف)'}</span>
        <span style="font-size:12px;opacity:.8;">${from} — ${to} (${totalDays} يوم)</span>
      </div>
      <div class="tbl-wrap"><table class="stbl">
        <thead><tr>
          <th>${type==='types'?'نوع الغرفة':'الشقة'}</th>
          <th style="text-align:center;">أيام مشغولة</th>
          <th style="text-align:center;">أيام شاغرة</th>
          <th style="text-align:center;">نسبة الإشغال</th>
          <th>شريط الإشغال</th>
        </tr></thead>
        <tbody>${rows.length?rows.map(r=>{
          const pct=Math.round((r.occupiedDays/totalDays)*100);
          const barColor=pct>=80?'#047857':pct>=50?'#1a3d8f':'#dc2626';
          return`<tr>
            <td style="font-weight:700;">${esc(r.label)}</td>
            <td style="text-align:center;color:#047857;font-weight:700;">${r.occupiedDays}</td>
            <td style="text-align:center;color:var(--t3);">${totalDays-r.occupiedDays}</td>
            <td style="text-align:center;font-weight:900;color:${barColor};font-size:14px;">${pct}%</td>
            <td style="min-width:120px;">
              <div style="background:#f1f5f9;border-radius:20px;height:8px;overflow:hidden;">
                <div style="background:${barColor};height:100%;width:${pct}%;border-radius:20px;transition:width .6s;"></div>
              </div>
            </td>
          </tr>`;
        }).join(''):'<tr><td colspan="5" style="text-align:center;padding:20px;color:var(--t4);">لا توجد بيانات</td></tr>'}
        </tbody>
        ${rows.length?`<tfoot><tr style="background:var(--brand-m);font-weight:700;">
          <td>الإجمالي (${rows.length} ${type==='types'?'نوع':'شقة'})</td>
          <td style="text-align:center;color:#047857;">${Math.round(rows.reduce((s,r)=>s+r.occupiedDays,0)/rows.length)}</td>
          <td style="text-align:center;"></td>
          <td style="text-align:center;font-size:14px;">${Math.round(rows.reduce((s,r)=>s+(r.occupiedDays/totalDays)*100,0)/rows.length)}%</td>
          <td></td>
        </tr></tfoot>`:''}
      </table></div>
    </div>`;
}

async function initOccAptDropdown(){
  const sel=document.getElementById('occ-apt');
  if(!sel||sel.options.length>1) return;
  try{
    const r=await fetch('/staff/api/apartments');
    const d=await r.json();
    const apts=[];
    (d.floors||[]).forEach(f=>(f.rooms||[]).forEach(r=>apts.push(r.apt)));
    apts.sort((a,b)=>a.localeCompare(b,'ar')).forEach(a=>{
      const o=document.createElement('option'); o.value=a; o.textContent=a; sel.appendChild(o);
    });
  }catch(e){}
}

