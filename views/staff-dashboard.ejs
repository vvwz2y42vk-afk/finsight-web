async function compressImg(file, maxPx, q){
  return new Promise(resolve=>{
    const rd=new FileReader();
    rd.onload=e=>{
      const img=new Image();
      img.onload=()=>{
        let w=img.width, h=img.height;
        if(w>maxPx||h>maxPx){
          if(w>h){h=Math.round(h*maxPx/w);w=maxPx;}
          else{w=Math.round(w*maxPx/h);h=maxPx;}
        }
        const cv=document.createElement('canvas');
        cv.width=w; cv.height=h;
        cv.getContext('2d').drawImage(img,0,0,w,h);
        resolve(cv.toDataURL('image/jpeg',q));
      };
      img.src=e.target.result;
    };
    rd.readAsDataURL(file);
  });
}

async function onReceiptFile(input){
  const file=input.files[0];
  if(!file) return;
  const dataUrl=await compressImg(file,1400,0.82);
  _receiptBase64=dataUrl.split(',')[1];
  _receiptMime='image/jpeg';
  document.getElementById('receipt-preview-img').src=dataUrl;
  document.getElementById('receipt-fullscreen-img').src=dataUrl;
  document.getElementById('receipt-upload-area').style.display='none';
  document.getElementById('receipt-preview-wrap').style.display='block';
  document.getElementById('receipt-analyzing').style.display='block';
  document.getElementById('receipt-result').style.display='none';
  document.getElementById('receipt-error').style.display='none';
  document.getElementById('receipt-status-badge').style.display='none';
  document.getElementById('receipt-box').style.border='1.5px solid #bae6fd';
  _receiptAccepted=false;
  await analyzeReceipt();
}

async function analyzeReceipt(){
  try{
    const payMethod=document.getElementById('nb-paymethod').value;
    const expectedPaid=parseFloat(document.getElementById('nb-paid').value)||0;
    const r=await fetch('/staff/api/receipts/analyze',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({imageBase64:_receiptBase64,mimeType:_receiptMime||'image/jpeg',building:BUILDING||'',payMethod,expectedPaid}),
    });
    const d=await r.json();
    document.getElementById('receipt-analyzing').style.display='none';
    if(!r.ok||!d.success){
      document.getElementById('receipt-error').textContent=d.error||'فشل التحليل';
      document.getElementById('receipt-error').style.display='block';
      return;
    }
    _receiptAnalysis=d.analysis;
    showReceiptResult(d.analysis, payMethod, expectedPaid);
  }catch(e){
    document.getElementById('receipt-analyzing').style.display='none';
    document.getElementById('receipt-error').textContent='خطأ في الاتصال بالذكاء الاصطناعي';
    document.getElementById('receipt-error').style.display='block';
  }
}

function showReceiptResult(a, payMethod, expectedPaid){
  const isCash = payMethod==='cash' || a.paymentType==='cash';
  const typeMap={network:'شبكة (POS)',transfer:'تحويل بنكي',cash:'نقداً',other:'أخرى'};

  if(isCash){
    const cashEl=document.getElementById('receipt-cash-result');
    const cashTotal=a.cashTotal;
    const bills=a.bills||[];
    const billsHtml=bills.length
      ? '<div style="margin-top:6px;font-size:12px;display:flex;flex-wrap:wrap;gap:6px;">'
        + bills.map(b=>`<span style="background:rgba(0,0,0,.08);padding:2px 8px;border-radius:12px;">${b.denomination} × ${b.count} = ${(b.denomination*b.count).toLocaleString('ar-SA')}</span>`).join('')
        + '</div>'
      : '';
    if(cashTotal===null||cashTotal===undefined){
      cashEl.style.background='#fef3c7'; cashEl.style.border='1px solid #fcd34d'; cashEl.style.color='#92400e';
      cashEl.innerHTML='⚠️ لم يتم التعرف على العملات في الصورة. تأكد من وضوح الصورة وأن الأوراق النقدية واضحة.';
    } else if(a.cashMatchesPaid===true){
      cashEl.style.background='#d1fae5'; cashEl.style.border='1px solid #6ee7b7'; cashEl.style.color='#065f46';
      cashEl.innerHTML=`✓ المبلغ النقدي <strong>${cashTotal.toLocaleString('ar-SA')} ريال</strong> يطابق المبلغ المدفوع`+billsHtml;
    } else if(a.cashMatchesPaid===false){
      cashEl.style.background='#fee2e2'; cashEl.style.border='1px solid #fca5a5'; cashEl.style.color='#991b1b';
      cashEl.innerHTML=`⚠️ المبلغ النقدي المتعرف عليه <strong>${cashTotal.toLocaleString('ar-SA')} ريال</strong> لا يطابق المدفوع <strong>${expectedPaid.toLocaleString('ar-SA')} ريال</strong>`+billsHtml;
    } else {
      cashEl.style.background='#f0f9ff'; cashEl.style.border='1px solid #bae6fd'; cashEl.style.color='#0369a1';
      cashEl.innerHTML=`تم التعرف على مبلغ نقدي: <strong>${cashTotal.toLocaleString('ar-SA')} ريال</strong>`+billsHtml;
    }
    cashEl.style.display='block';
    document.getElementById('ra-type').textContent='نقداً';
    document.getElementById('ra-amount').textContent=cashTotal!=null?`${cashTotal.toLocaleString('ar-SA')} ريال`:'—';
    document.getElementById('ra-date-row').style.display='none';
    document.getElementById('ra-txn-row').style.display='none';
    document.getElementById('ra-entity-row').style.display='none';
  } else {
    document.getElementById('receipt-cash-result').style.display='none';
    document.getElementById('ra-date-row').style.display='';
    document.getElementById('ra-txn-row').style.display='';
    document.getElementById('ra-entity-row').style.display='';
    // Entity check
    const warnEl=document.getElementById('receipt-entity-warn');
    const okEl=document.getElementById('receipt-entity-ok');
    const expectedMap={'المنارا':'شركة بارز برايم أو مؤسسة جهد وأمان','جوان ان':'شركة بارز برايم أو مؤسسة جهد وأمان','الماسة':'إبراهيم الزاحم','الواحة':'أحمد الزاحم'};
    if(a.matchesBuilding===false&&a.entityName){
      warnEl.innerHTML=`⚠️ تحذير: الجهة في الإيصال "<strong>${esc(a.entityName)}</strong>" لا تطابق الجهة المتوقعة لـ ${esc(BUILDING||'')}: <strong>${esc(expectedMap[BUILDING||'']||'الجهة المحددة')}</strong>`;
      warnEl.style.display='block'; okEl.style.display='none';
    } else if(a.matchesBuilding===true){
      okEl.textContent=`✓ الجهة "${a.entityName}" مطابقة للمبنى`;
      okEl.style.display='block'; warnEl.style.display='none';
    } else { warnEl.style.display='none'; okEl.style.display='none'; }
    document.getElementById('ra-type').textContent=typeMap[a.paymentType]||a.paymentType||'—';
    document.getElementById('ra-amount').textContent=a.amount!=null?`${Number(a.amount).toLocaleString('ar-SA')} ريال`:'—';
    document.getElementById('ra-date').textContent=a.date||'—';
    document.getElementById('ra-txn').textContent=a.transactionNumber||'—';
    document.getElementById('ra-entity').textContent=a.entityName||'—';
  }
  document.getElementById('receipt-result').style.display='block';
}

function acceptReceiptData(){
  if(!_receiptAnalysis) return;
  const a=_receiptAnalysis;
  // Auto-fill
  if(a.paymentType==='network') document.getElementById('nb-paymethod').value='network';
  else if(a.paymentType==='transfer') document.getElementById('nb-paymethod').value='transfer';
  const amt=a.paymentType==='cash'?a.cashTotal:a.amount;
  if(amt&&parseFloat(amt)>0){ document.getElementById('nb-paid').value=amt; calcNbRemain(); }
  if(a.date&&!document.getElementById('nb-checkin').value){
    const d=new Date(a.date);
    if(!isNaN(d)){ document.getElementById('nb-checkin').value=d.toISOString().split('T')[0]; calcNbTotal(); }
  }
  _receiptAccepted=true;
  const btn=document.getElementById('receipt-accept-btn');
  btn.textContent='✓ تم القبول'; btn.style.background='#047857'; btn.disabled=true;
  const badge=document.getElementById('receipt-status-badge');
  badge.textContent='✓ مقبول'; badge.style.background='#d1fae5'; badge.style.color='#065f46'; badge.style.display='inline-block';
  document.getElementById('receipt-box').style.border='1.5px solid #6ee7b7';
}

