<!-- Main -->
<div class="main">
  <div class="topbar">
    <div class="tb-left">
      <div class="tb-title" id="tbTitle"><%= staff.building %> — <span>لوحة المعلومات</span></div>
      <div class="tb-meta" id="tbDate"></div>
    </div>
    <div class="tb-right">
      <div class="tb-avatar"><%= staff.name.charAt(0) %></div>
      <div class="tb-info">
        <div class="tb-info-name"><%= staff.name %></div>
        <div class="tb-info-role"><%= staff.role==='manager'?'مدير':'موظف استقبال' %> · <%= staff.building %></div>
      </div>
    </div>
  </div>

  <div class="content">

    <!-- ── Dashboard ── -->
    <div class="tab-section active" id="tab-dashboard">
      <div class="kpi-row">
        <div class="kpi-c"><div class="kpi-ico" style="background:rgba(29,78,216,.1);color:#1D4ED8;"><svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div><div class="kpi-num" id="k-arrivals">—</div><div class="kpi-lbl">وصول اليوم</div></div>
        <div class="kpi-c"><div class="kpi-ico" style="background:rgba(4,120,87,.1);color:#047857;"><svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></div><div class="kpi-num" id="k-checkin">—</div><div class="kpi-lbl">تسجيل الدخول</div></div>
        <div class="kpi-c"><div class="kpi-ico" style="background:rgba(180,83,9,.1);color:#B45309;"><svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg></div><div class="kpi-num" id="k-departures">—</div><div class="kpi-lbl">مغادرة اليوم</div></div>
        <div class="kpi-c"><div class="kpi-ico" style="background:rgba(91,33,182,.1);color:#5B21B6;"><svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div><div class="kpi-num" id="k-guests">—</div><div class="kpi-lbl">النزلاء الباقين</div></div>
        <div class="kpi-c"><div class="kpi-ico" style="background:rgba(26,61,143,.1);color:#1a3d8f;"><svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div><div class="kpi-num" id="k-new">—</div><div class="kpi-lbl">حجوزات جديدة</div></div>
        <div class="kpi-c"><div class="kpi-ico" style="background:rgba(15,23,42,.07);color:#0F172A;"><svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg></div><div class="kpi-num" id="k-rate">—%</div><div class="kpi-lbl">نسبة الإشغال</div></div>
      </div>
      <!-- جدول اليوم -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px;" id="today-schedule-wrap">
        <div style="background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:14px;">
          <div style="font-size:11px;font-weight:700;color:#1A5276;margin-bottom:10px;display:flex;align-items:center;gap:6px;">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="7 10 12 15 17 10"/></svg>
            وصول اليوم
          </div>
          <div id="today-arrivals" style="display:flex;flex-direction:column;gap:6px;max-height:160px;overflow-y:auto;"></div>
        </div>
        <div style="background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:14px;">
          <div style="font-size:11px;font-weight:700;color:#A04000;margin-bottom:10px;display:flex;align-items:center;gap:6px;">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="17 14 12 9 7 14"/></svg>
            مغادرة اليوم
          </div>
          <div id="today-departures" style="display:flex;flex-direction:column;gap:6px;max-height:160px;overflow-y:auto;"></div>
        </div>
      </div>

      <!-- شريط التقدم الشهري -->
      <div style="background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:14px;margin-bottom:14px;" id="monthly-progress-wrap">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
          <div style="font-size:12px;font-weight:700;color:#1e3a5f;">إنجاز الشهر</div>
          <div style="font-size:10px;color:#64748b;" id="monthly-label">— / — حجز</div>
        </div>
        <div style="background:#f1f5f9;border-radius:20px;height:8px;overflow:hidden;margin-bottom:8px;">
          <div id="monthly-bar" style="height:100%;width:0%;background:linear-gradient(90deg,#1a3d8f,#2a5cc7);border-radius:20px;transition:width 1s;"></div>
        </div>
        <div style="display:flex;justify-content:space-between;font-size:10px;color:#94a3b8;">
          <span>0%</span>
          <span id="monthly-pct" style="font-weight:700;color:#1a3d8f;">0%</span>
          <span>الهدف: <span id="monthly-target">20</span> حجز</span>
        </div>
      </div>

      <div class="charts-row">
        <div class="chart-card">
          <div class="chart-title">حالة الشقق الأسبوعية</div>
          <canvas id="weeklyChart" height="180"></canvas>
        </div>
        <div class="chart-card" style="display:flex;flex-direction:column;align-items:center;justify-content:center;">
          <div class="chart-title" style="justify-content:center;">حالة الشقق</div>
          <div class="donut-wrap">
            <canvas id="donutChart" width="170" height="170"></canvas>
            <div class="donut-center">
              <div class="donut-pct" id="donutPct">—</div>
              <div class="donut-pct-sub">إشغال</div>
            </div>
          </div>
          <div id="donutLegend" style="margin-top:12px;font-size:11px;text-align:center;display:flex;gap:12px;justify-content:center;"></div>
        </div>
        <div class="chart-card" style="display:flex;flex-direction:column;align-items:center;justify-content:center;">
          <div class="chart-title" style="justify-content:center;">خدمة الغرف</div>
          <div class="donut-wrap">
            <canvas id="hkDonutChart" width="170" height="170"></canvas>
            <div class="donut-center">
              <div class="donut-pct" id="hkDonutNum">—</div>
              <div class="donut-pct-sub">نظيف</div>
            </div>
          </div>
          <div id="hkDonutLegend" style="margin-top:12px;font-size:11px;text-align:center;display:flex;gap:12px;justify-content:center;"></div>
        </div>
        <div class="chart-card">
          <div class="chart-title">اشغال أنواع الغرف</div>
          <div id="roomTypeChart" style="padding-top:4px;"></div>
        </div>
      </div>
    </div>

    <!-- ── Apartments ── -->
    <div class="tab-section" id="tab-apartments">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;flex-wrap:wrap;gap:8px;">
        <div class="apt-filters" style="margin-bottom:0;">
          <button class="af active" onclick="filterApts('all',this)">الكل</button>
        <button class="af" onclick="filterApts('occupied',this)">مؤجر <span id="fc-occupied">—</span></button>
        <button class="af" onclick="filterApts('vacant',this)">شاغر <span id="fc-vacant">—</span></button>
        <button class="af" onclick="filterApts('checkin_today',this)">وصول اليوم <span id="fc-checkin_today">—</span></button>
        <button class="af" onclick="filterApts('checkout_today',this)">خروج اليوم <span id="fc-checkout_today">—</span></button>
        <button class="af" onclick="filterApts('awaiting',this)">انتظار <span id="fc-awaiting">—</span></button>
        <span id="apts-occ-rate" style="font-size:13px;font-weight:700;align-self:center;"></span>
        <span style="display:flex;align-items:center;gap:5px;font-size:11px;color:var(--t3);padding:4px 10px;background:rgba(4,120,87,.06);border:1px solid rgba(4,120,87,.2);border-radius:20px;">
          <span id="apt-sync-dot" style="width:6px;height:6px;border-radius:50%;background:#047857;display:inline-block;animation:dot-pulse 2s infinite;"></span>
          <span>مباشر ·</span>
          <span id="apt-sync-time">—</span>
        </span>
        </div>
        <% if(P.includes('new_booking')){ %><button class="sbtn" onclick="openNewBkModal()">+ حجز جديد</button><% } %>
      </div>
      <div id="apt-alert-strip" style="display:none;margin-bottom:14px;"></div>
      <div id="aptsContainer"></div>
    </div>

    <!-- ── Bookings ── -->
    <div class="tab-section" id="tab-bookings">

      <!-- البحث المتقدم -->
      <div style="background:#fff;border:1px solid #e2e8f0;border-radius:12px;margin-bottom:12px;overflow:hidden;">
