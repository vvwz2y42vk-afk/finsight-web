    const { guest: g, bookings, totalPaid, totalPrice } = await r.json();

    const catMap = { regular:{lbl:'عادي',bg:'#e0f2fe',c:'#0369a1'}, vip:{lbl:'⭐ VIP',bg:'#fef9c3',c:'#854d0e'}, blocked:{lbl:'🚫 محظور',bg:'#fee2e2',c:'#b91c1c'} };
