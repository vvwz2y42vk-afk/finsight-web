// ── Daily Closing ─────────────────────────────────────────
function dcToday(){
  const now=new Date(Date.now()+3*60*60*1000);
  return now.toISOString().split('T')[0];
}
function dcPrevDay(){
  const d=new Date(document.getElementById('dcDatePicker').value||dcToday());
  d.setDate(d.getDate()-1);
  loadDailyClosing(d.toISOString().split('T')[0]);
}
function dcNextDay(){
  const cur=document.getElementById('dcDatePicker').value||dcToday();
  const today=dcToday();
  if(cur>=today) return;
  const d=new Date(cur); d.setDate(d.getDate()+1);
  loadDailyClosing(d.toISOString().split('T')[0]);
}
function openDailyClosing(){
  document.getElementById('dailyClosingModal').style.display='flex';
  const today=dcToday();
  document.getElementById('dcDatePicker').value=today;
  document.getElementById('dcDatePicker').max=today;
  loadDailyClosing(today);
}
async function loadDailyClosing(date){
  const today=dcToday();
  if(!date||date>today) date=today;
  document.getElementById('dcDatePicker').value=date;
  document.getElementById('dcDatePicker').max=today;
  // إخفاء زر التالي إذا وصلنا لليوم
  document.getElementById('dcNextBtn').style.opacity=date>=today?'0.3':'1';
  document.getElementById('dcNextBtn').style.pointerEvents=date>=today?'none':'auto';
  const el=document.getElementById('dcBody');
  el.innerHTML='<div style="text-align:center;padding:30px;color:var(--t4);">⏳ جاري التحميل...</div>';
  try{
    const r=await fetch('/staff/api/daily-closing?date='+encodeURIComponent(date));
    const d=await r.json();
    if(!r.ok){el.innerHTML=`<div style="color:#dc2626;padding:20px;">❌ ${d.error||'حدث خطأ'}</div>`;return;}

    const dateAr=new Date(d.date+'T12:00:00').toLocaleDateString('ar-SA',{weekday:'long',year:'numeric',month:'long',day:'numeric'});
    const fmt=n=>(n||0).toLocaleString();
    const pmIcon={cash:'💵',transfer:'🏦',network:'💳',other:'🔖','':'❓'};
    const pmL={cash:'كاش',transfer:'تحويل',network:'شبكة',other:'أخرى','':'غير محدد'};
    const stL={active:'مقيم',awaiting_checkin:'انتظار دخول',awaiting_payment:'انتظار دفع',checkout:'خرج',cancelled:'ملغي'};

    let h=`<div style="text-align:center;margin-bottom:20px;">
      <div style="font-size:12px;color:var(--t4);">${dateAr}</div>
      <div style="font-size:28px;font-weight:900;color:#047857;margin-top:4px;">${fmt(d.totalCollected)} <span style="font-size:14px;">ريال</span></div>
      <div style="font-size:11px;color:var(--t4);margin-top:2px;">إجمالي المحصّل اليوم</div>
    </div>`;

    // تفصيل طرق الدفع
    if(d.byMethod.length){
      h+=`<div style="margin-bottom:18px;"><div style="font-size:12px;font-weight:700;color:#0f172a;margin-bottom:10px;display:flex;align-items:center;gap:6px;"><span style="width:4px;height:14px;background:#047857;border-radius:3px;display:inline-block;"></span>تفصيل طرق الدفع</div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:8px;">
        ${d.byMethod.map(m=>`<div style="background:#f0fdf4;border:1.5px solid #bbf7d0;border-radius:12px;padding:12px;text-align:center;">
          <div style="font-size:20px;">${pmIcon[m.label==='كاش'?'cash':m.label==='تحويل'?'transfer':m.label==='شبكة'?'network':'other']||'💰'}</div>
          <div style="font-size:11px;color:#047857;font-weight:700;margin:4px 0;">${m.label}</div>
          <div style="font-size:16px;font-weight:900;color:#0f172a;">${fmt(m.total)}</div>
          <div style="font-size:10px;color:var(--t4);">${m.bookings.length} دفعة</div>
        </div>`).join('')}
        </div></div>`;
    }

    // الحجوزات الجديدة اليوم
    if(d.newBookings.length){
      h+=`<div style="margin-bottom:18px;"><div style="font-size:12px;font-weight:700;color:#0f172a;margin-bottom:10px;display:flex;align-items:center;gap:6px;"><span style="width:4px;height:14px;background:#1a3d8f;border-radius:3px;display:inline-block;"></span>الحجوزات الجديدة (${d.newBookings.length})</div>
        <div style="display:flex;flex-direction:column;gap:6px;">
        ${d.newBookings.map(b=>`<div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;padding:10px 12px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:6px;">
          <div>
            <span style="font-weight:700;font-size:13px;">${esc(b.apt)}</span>
            <span style="color:var(--t3);font-size:12px;margin-right:8px;">${esc(b.name)}</span>
          </div>
          <div style="display:flex;gap:8px;align-items:center;">
            ${b.paymentMethod?`<span style="font-size:10px;background:#eff6ff;color:#1a3d8f;padding:2px 8px;border-radius:20px;font-weight:700;">${pmL[b.paymentMethod]||b.paymentMethod}</span>`:''}
            <span style="font-size:12px;color:#16a34a;font-weight:700;">${fmt(b.paidAmount)} ر</span>
            ${b.totalPrice>b.paidAmount?`<span style="font-size:10px;color:#dc2626;">متبقي ${fmt(b.totalPrice-b.paidAmount)}</span>`:'<span style="font-size:10px;color:#16a34a;">✓ مكتمل</span>'}
          </div>
        </div>`).join('')}
        </div></div>`;
    }

    // الوصولات
    if(d.arrivals.length){
      h+=`<div style="margin-bottom:18px;"><div style="font-size:12px;font-weight:700;color:#0f172a;margin-bottom:10px;display:flex;align-items:center;gap:6px;"><span style="width:4px;height:14px;background:#22c55e;border-radius:3px;display:inline-block;"></span>وصولات اليوم (${d.arrivals.length})</div>
        <div style="display:flex;flex-direction:column;gap:6px;">
        ${d.arrivals.map(b=>`<div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:10px;padding:9px 12px;display:flex;justify-content:space-between;align-items:center;">
          <div><span style="font-weight:700;">${esc(b.apt)}</span> <span style="color:var(--t3);font-size:12px;">${esc(b.name)}</span></div>
          <span style="font-size:10px;background:#dcfce7;color:#166534;padding:2px 8px;border-radius:20px;font-weight:700;">${stL[b.status]||b.status}</span>
        </div>`).join('')}
        </div></div>`;
    }

    // المغادرات
    if(d.departures.length){
      h+=`<div style="margin-bottom:8px;"><div style="font-size:12px;font-weight:700;color:#0f172a;margin-bottom:10px;display:flex;align-items:center;gap:6px;"><span style="width:4px;height:14px;background:#f59e0b;border-radius:3px;display:inline-block;"></span>مغادرات اليوم (${d.departures.length})</div>
        <div style="display:flex;flex-direction:column;gap:6px;">
        ${d.departures.map(b=>`<div style="background:#fffbeb;border:1px solid #fde68a;border-radius:10px;padding:9px 12px;display:flex;justify-content:space-between;align-items:center;">
          <div><span style="font-weight:700;">${esc(b.apt)}</span> <span style="color:var(--t3);font-size:12px;">${esc(b.name)}</span></div>
          <span style="font-size:10px;background:#fef3c7;color:#92400e;padding:2px 8px;border-radius:20px;font-weight:700;">${stL[b.status]||b.status}</span>
        </div>`).join('')}
        </div></div>`;
    }

    if(!d.newBookings.length&&!d.arrivals.length&&!d.departures.length)
      h+='<div style="text-align:center;padding:30px;color:var(--t4);font-size:13px;">لا توجد حركات اليوم</div>';

    el.innerHTML=h;
  }catch(e){el.innerHTML='<div style="color:#dc2626;padding:20px;">❌ حدث خطأ</div>';}
}
