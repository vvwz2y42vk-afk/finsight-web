<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= q ? 'نتائج: ' + q : 'بحث متقدم' %> — Barez</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/client.css">
<style>
.sf-hero{background:linear-gradient(135deg,#1a3d8f 0%,#1e4fa8 100%);padding:60px 0 0;position:relative;overflow:hidden;}
.sf-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at 30% 50%,rgba(255,255,255,.06) 0%,transparent 60%);}
.sf-hero__inner{position:relative;z-index:1;text-align:center;padding:0 16px 40px;}
.sf-hero__tag{display:inline-block;font-size:11px;font-weight:700;letter-spacing:2px;color:rgba(255,255,255,.65);text-transform:uppercase;margin-bottom:14px;}
.sf-hero__title{font-size:clamp(1.6rem,4vw,2.4rem);font-weight:900;color:#fff;margin-bottom:8px;}
.sf-hero__title span{color:#fff;text-decoration:underline;text-decoration-color:rgba(255,255,255,.4);text-underline-offset:6px;}
.sf-hero__sub{font-size:14px;color:rgba(255,255,255,.65);margin-bottom:32px;}

/* ── Search box ── */
.sf-box{background:#fff;border:none;border-radius:20px;padding:20px 24px;max-width:860px;margin:0 auto;box-shadow:0 20px 60px rgba(0,0,0,.18);}
.sf-row{display:flex;gap:10px;flex-wrap:wrap;}
.sf-main{display:flex;gap:10px;width:100%;margin-bottom:14px;}
.sf-inp{flex:1;padding:13px 18px;border-radius:12px;border:1.5px solid #dde4f0;background:#f7f9ff;color:#1a1a2e;font-family:'Cairo',sans-serif;font-size:15px;outline:none;min-width:0;}
.sf-inp::placeholder{color:#9aaabb;}
.sf-inp:focus{border-color:#1a3d8f;background:#fff;}
.sf-inp option{background:#fff;color:#1a1a2e;}
.sf-btn{padding:13px 28px;border-radius:12px;background:linear-gradient(135deg,#1a3d8f,#2a5cc7);border:none;color:#fff;font-family:'Cairo',sans-serif;font-size:15px;font-weight:800;cursor:pointer;white-space:nowrap;flex-shrink:0;box-shadow:0 4px 16px rgba(26,61,143,.35);}
.sf-btn:hover{opacity:.9;}

.sf-filters{display:flex;gap:8px;flex-wrap:wrap;align-items:center;}
.sf-filter{display:flex;flex-direction:column;gap:4px;flex:1;min-width:110px;}
.sf-filter label{font-size:10px;font-weight:700;color:#1a3d8f;letter-spacing:.5px;text-transform:uppercase;}
.sf-select,.sf-num{width:100%;padding:8px 12px;border-radius:8px;border:1.5px solid #dde4f0;background:#f7f9ff;color:#1a1a2e;font-family:'Cairo',sans-serif;font-size:12px;outline:none;}
.sf-select:focus,.sf-num:focus{border-color:#1a3d8f;}
.sf-select option{background:#fff;color:#1a1a2e;}
.sf-num{-moz-appearance:textfield;}
.sf-num::-webkit-outer-spin-button,.sf-num::-webkit-inner-spin-button{-webkit-appearance:none;}
.sf-divider{width:1px;background:#dde4f0;align-self:stretch;margin:0 4px;}
.sf-clear{color:#9aaabb;font-size:12px;text-decoration:none;white-space:nowrap;padding:4px 0;align-self:center;}
.sf-clear:hover{color:#1a3d8f;}

/* ── Cat tabs ── */
.sf-cats{display:flex;gap:6px;justify-content:center;padding:18px 16px 0;flex-wrap:wrap;}
.sf-cat{padding:7px 18px;border-radius:20px;border:1px solid rgba(255,255,255,.12);color:rgba(255,255,255,.5);font-family:'Cairo',sans-serif;font-size:12px;font-weight:600;cursor:pointer;text-decoration:none;transition:all .15s;}
.sf-cat:hover{border-color:rgba(218,165,32,.4);color:rgba(218,165,32,.8);}
.sf-cat.active{background:rgba(218,165,32,.15);border-color:rgba(218,165,32,.5);color:#DAA520;}

/* ── Results ── */
.sr-bar{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;flex-wrap:wrap;gap:8px;}
.sr-count{font-size:14px;color:var(--text3);}
.sr-count strong{color:var(--dark);}
.sr-count .c-gold{font-weight:700;}
.sr-sort{display:flex;align-items:center;gap:8px;font-size:13px;color:var(--text3);}
.sr-sort select{border:1px solid var(--border);border-radius:8px;padding:5px 10px;font-family:'Cairo',sans-serif;font-size:12px;color:var(--dark);background:#fff;outline:none;}

.price-tag{font-size:11px;font-weight:700;color:var(--gold);margin-top:4px;}

@media(max-width:600px){
  .sf-filters{gap:6px;}
  .sf-filter{min-width:calc(50% - 6px);}
  .sf-main{flex-wrap:wrap;}
}
</style>
</head>
<body class="home-page csb-layout">

<aside class="client-sidebar" id="clientSidebar">
  <div class="csb-logo">
    <img src="/images/logo-dark.png" alt="Barez" style="height:52px;width:auto;">
  </div>
  <nav class="csb-nav">
    <a href="/" class="csb-lnk"><span class="csb-ico">⬡</span><span>الرئيسية</span></a>
    <div class="csb-divider"></div>
    <a href="/listings" class="csb-lnk"><span class="csb-ico">🏢</span><span>عقاراتنا</span></a>
    <div class="csb-sub">
      <a href="/listings?cat=rental_apartment" class="csb-sublnk">شقق للإيجار</a>
      <a href="/listings?cat=rental_commercial" class="csb-sublnk">معارض للإيجار</a>
      <a href="/listings?cat=sale_land" class="csb-sublnk">أراضي للبيع</a>
      <a href="/listings?cat=sale_apartment" class="csb-sublnk">شقق للبيع</a>
    </div>
    <div class="csb-divider"></div>
    <a href="/search" class="csb-lnk active"><span class="csb-ico">🔍</span><span>بحث</span></a>
    <% if (typeof customer !== 'undefined' && customer) { %>
    <a href="/account" class="csb-lnk"><span class="csb-ico">👤</span><span><%= customer.name %></span></a>
    <% } else { %>
    <a href="/account/login" class="csb-lnk"><span class="csb-ico">👤</span><span>حسابي</span></a>
    <% } %>
    <a href="/about" class="csb-lnk"><span class="csb-ico">ℹ️</span><span>من نحن</span></a>
    <a href="/inquiry" class="csb-lnk"><span class="csb-ico">💬</span><span>تواصل معنا</span></a>
  </nav>
  <div class="csb-foot">
    <a href="https://wa.me/966590561057" target="_blank" class="csb-wa">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
      <span>0590561057</span>
    </a>
  </div>
</aside>
<div class="csb-overlay" id="csbOverlay" onclick="closeSidebar()"></div>
<button class="csb-ham" id="csbHam" onclick="toggleSidebar()"><span></span><span></span><span></span></button>

<div class="csb-content">

<!-- ═══════════ HERO + SEARCH BOX ═══════════ -->
<section class="sf-hero">
  <div class="sf-hero__inner">
    <div class="sf-hero__tag">Barez</div>
    <h1 class="sf-hero__title">ابحث عن <span>عقارك المثالي</span></h1>
    <p class="sf-hero__sub">شقق إيجار يومي وشهري • معارض تجارية • أراضي وشقق للبيع</p>

    <form method="GET" action="/search" id="searchForm">
      <div class="sf-box">
        <!-- Main search + submit -->
        <div class="sf-main">
          <input class="sf-inp" type="text" name="q" value="<%= q %>" placeholder="🔍  ابحث بالاسم أو الموقع أو المجمع...">
          <button type="submit" class="sf-btn">بحث</button>
        </div>

        <!-- Filters row -->
        <div class="sf-filters">
          <!-- Type -->
          <div class="sf-filter">
            <label>نوع العقار</label>
            <select class="sf-select" name="cat" onchange="toggleTypeFilter()">
              <option value="" <%=!cat?'selected':''%>>الكل</option>
              <option value="rental_apartment" <%=cat==='rental_apartment'?'selected':''%>>شقق إيجار</option>
              <option value="rental_commercial" <%=cat==='rental_commercial'?'selected':''%>>معارض إيجار</option>
              <option value="sale_apartment" <%=cat==='sale_apartment'?'selected':''%>>شقق للبيع</option>
              <option value="sale_land" <%=cat==='sale_land'?'selected':''%>>أراضي للبيع</option>
            </select>
          </div>

          <!-- Rental type (daily/monthly) — shown only for rental_apartment -->
          <div class="sf-filter" id="sf-type-filter" style="<%= cat==='rental_apartment'||!cat?'':'display:none' %>">
            <label>طريقة الإيجار</label>
            <select class="sf-select" name="type">
              <option value=""    <%=!type||type==='all'?'selected':''%>>الكل</option>
              <option value="daily"  <%=type==='daily'?'selected':''%>>🌙 يومي</option>
              <option value="annual" <%=type==='annual'?'selected':''%>>📋 شهري</option>
            </select>
          </div>

          <!-- Bedrooms — shown for apartment categories -->
          <div class="sf-filter" id="sf-beds-filter" style="<%= cat==='rental_apartment'||cat==='sale_apartment'||!cat?'':'display:none' %>">
            <label>الغرف</label>
            <select class="sf-select" name="beds">
              <option value="" <%=!beds?'selected':''%>>أي عدد</option>
              <option value="1" <%=beds===1?'selected':''%>>1+</option>
              <option value="2" <%=beds===2?'selected':''%>>2+</option>
              <option value="3" <%=beds===3?'selected':''%>>3+</option>
              <option value="4" <%=beds===4?'selected':''%>>4+</option>
            </select>
          </div>

          <div class="sf-divider"></div>

          <!-- Price from -->
          <div class="sf-filter" style="min-width:90px;">
            <label>السعر من</label>
            <input class="sf-num sf-inp" type="number" name="min_price" value="<%= minPrice||'' %>" placeholder="0" min="0">
          </div>

          <!-- Price to -->
          <div class="sf-filter" style="min-width:90px;">
            <label>السعر إلى</label>
            <input class="sf-num sf-inp" type="number" name="max_price" value="<%= maxPrice||'' %>" placeholder="∞" min="0">
          </div>

          <!-- Sort -->
          <div class="sf-filter">
            <label>الترتيب</label>
            <select class="sf-select" name="sort">
              <option value="newest"     <%=sort==='newest'?'selected':''%>>الأحدث</option>
              <option value="price_asc"  <%=sort==='price_asc'?'selected':''%>>السعر: الأقل</option>
              <option value="price_desc" <%=sort==='price_desc'?'selected':''%>>السعر: الأعلى</option>
            </select>
          </div>

          <% if (hasFilters) { %>
          <a href="/search" class="sf-clear">× مسح</a>
          <% } %>
        </div>
      </div>
    </form>
  </div>

</section>

<!-- ═══════════ RESULTS ═══════════ -->
<section style="padding:40px 0 80px;background:var(--light);">
  <div class="page-container">

    <% if (!hasFilters) { %>
    <!-- Idle state -->
    <div style="text-align:center;padding:70px 0;">
      <h3 style="font-size:1.3rem;font-weight:700;margin-bottom:8px;">ابدأ بالبحث أو اختر فئة</h3>
      <p style="color:var(--text3);margin-bottom:28px;">ابحث بالاسم، الموقع، أو استخدم الفلاتر لتضييق النتائج</p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
        <a href="/search?cat=rental_apartment" class="btn btn-gold" style="display:inline-flex;">شقق إيجار</a>
        <a href="/search?cat=sale_land"        class="btn"          style="display:inline-flex;">أراضي للبيع</a>
        <a href="/search?cat=rental_commercial" class="btn"         style="display:inline-flex;">معارض</a>
      </div>
    </div>

    <% } else if (listings.length === 0) { %>
    <!-- No results -->
    <div style="text-align:center;padding:70px 0;">
      <div style="font-size:3.5rem;margin-bottom:16px;">😔</div>
      <h3 style="font-size:1.3rem;font-weight:700;margin-bottom:8px;">لا توجد نتائج</h3>
      <p style="color:var(--text3);margin-bottom:24px;">جرّب تغيير الفلاتر أو توسيع نطاق السعر</p>
      <a href="/search" class="btn btn-gold" style="display:inline-flex;">مسح الفلاتر</a>
    </div>

    <% } else { %>
    <!-- Results bar -->
    <div class="sr-bar">
      <div class="sr-count">
        <% if (q) { %>نتائج "<strong><%= q %></strong>":<% } else { %>النتائج:<% } %>
        <span class="c-gold"> <%= listings.length %> عقار</span>
      </div>
      <div class="sr-sort">
        <span>الترتيب:</span>
        <select onchange="changeSortURL(this.value)">
          <option value="newest"     <%=sort==='newest'?'selected':''%>>الأحدث</option>
          <option value="price_asc"  <%=sort==='price_asc'?'selected':''%>>السعر: الأقل</option>
          <option value="price_desc" <%=sort==='price_desc'?'selected':''%>>السعر: الأعلى</option>
        </select>
      </div>
    </div>

    <!-- Cards -->
    <div class="listing-grid">
      <% listings.forEach(l => {
        const lcat = l.category || 'rental_apartment';
        const catEmoji = lcat==='rental_apartment'?'🏢':lcat==='rental_commercial'?'🏪':lcat==='sale_apartment'?'🏠':'🌍';
        const catLabel = lcat==='rental_apartment'?(l.type==='daily'?'يومي':l.type==='annual'?'شهري':'يومي + شهري'):lcat==='rental_commercial'?'للإيجار':lcat==='sale_apartment'?'شقة للبيع':'أرض للبيع';
        const priceNum  = (lcat==='sale_land'||lcat==='sale_apartment')?l.price_sale:lcat==='rental_commercial'?l.price_annual:l.price_daily;
        const priceUnit = (lcat==='sale_land'||lcat==='sale_apartment')?'﷼':lcat==='rental_commercial'?'﷼/شهر':'﷼/ليلة';
      %>
      <a href="/listings/<%= l._id %>" class="listing-card">
        <div class="listing-card__photo">
          <% if (l.photos && l.photos.length) { %>
          <img src="<%= l.photos[0] %>" alt="<%= l.title %>" loading="lazy">
          <% } else { %>
          <div class="listing-card__photo-ph"><%= catEmoji %></div>
          <% } %>
          <div class="listing-card__badges">
            <% if (l.featured) { %><span class="lc-badge lc-badge--featured">⭐ مميز</span><% } %>
            <span class="lc-badge lc-badge--type"><%= catLabel %></span>
          </div>
        </div>
        <div class="listing-card__body">
          <% if (l.building) { %>
          <div class="listing-card__building"><%= l.building %></div>
          <% } else if (l.location) { %>
          <div class="listing-card__building">📍 <%= l.location %></div>
          <% } %>
          <div class="listing-card__title"><%= l.title %></div>
          <div class="listing-card__meta">
            <% if ((lcat==='rental_apartment'||lcat==='sale_apartment') && l.bedrooms) { %>
            <span>🛏 <%= l.bedrooms %> غرف</span>
            <% } %>
            <% if (l.area) { %><span>📐 <%= l.area %> م²</span><% } %>
          </div>
          <% if (priceNum) { %>
          <div class="price-tag"><%= priceNum.toLocaleString('ar-SA') %> <%= priceUnit %></div>
          <% } %>
          <div class="listing-card__footer">
            <span class="listing-card__cta">تفاصيل ←</span>
          </div>
        </div>
      </a>
      <% }); %>
    </div>
    <% } %>

  </div>
</section>

<!-- FOOTER -->
<footer class="site-footer-new">
  <div class="page-container">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="footer-brand__logo">
          <img src="/images/logo-dark.png" alt="Barez" style="height:52px;width:auto;">
        </div>
        <p class="footer-brand__desc">شركة رائدة في إدارة الأملاك والوساطة العقارية بالمدينة المنورة.</p>
      </div>
      <div class="footer-col">
        <div class="footer-col__title">الأقسام</div>
        <a href="/listings?cat=rental_apartment">🏠 شقق للإيجار</a>
        <a href="/listings?cat=rental_commercial">🏪 معارض للإيجار</a>
        <a href="/listings?cat=sale_land">🌍 أراضي للبيع</a>
      </div>
      <div class="footer-col">
        <div class="footer-col__title">روابط سريعة</div>
        <a href="/">الرئيسية</a>
        <a href="/about">من نحن</a>
        <a href="/inquiry">تواصل معنا</a>
      </div>
      <div class="footer-col">
        <div class="footer-col__title">تواصل معنا</div>
        <a href="https://wa.me/966590561057">0590561057</a>
        <a href="mailto:realstate@barezz.com">realstate@barezz.com</a>
      </div>
    </div>
    <div class="footer-bottom">
      <p>© 2026 Barez — جميع الحقوق محفوظة &nbsp;·&nbsp; <a href="/terms" style="color:inherit;opacity:.6;">الشروط والأحكام</a></p>
    </div>
  </div>
</footer>

</div><!-- /csb-content -->
<script>
function toggleSidebar(){document.getElementById('clientSidebar').classList.toggle('open');document.getElementById('csbOverlay').classList.toggle('open');document.getElementById('csbHam').classList.toggle('active');}
function closeSidebar(){document.getElementById('clientSidebar').classList.remove('open');document.getElementById('csbOverlay').classList.remove('open');document.getElementById('csbHam').classList.remove('active');}

function toggleTypeFilter(){
  const cat = document.querySelector('[name="cat"]').value;
  const isApt  = cat==='rental_apartment'||cat==='';
  const hasBeds = cat==='rental_apartment'||cat==='sale_apartment'||cat==='';
  const tf = document.getElementById('sf-type-filter');
  const bf = document.getElementById('sf-beds-filter');
  if(tf) tf.style.display = isApt ? '' : 'none';
  if(bf) bf.style.display = hasBeds ? '' : 'none';
}

function changeSortURL(val){
  const url = new URL(window.location.href);
  url.searchParams.set('sort', val);
  window.location.href = url.toString();
}
</script>
</body>
</html>
