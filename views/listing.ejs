<script>
function toggleNav() {
  document.getElementById('navLinks').classList.toggle('open');
  document.getElementById('hamburger').classList.toggle('active');
}
const allPhotos = <%- JSON.stringify(listing.photos||[]) %>;
let currentPhotoIndex = 0;

function setPhoto(src, el) {
  currentPhotoIndex = allPhotos.indexOf(src);
  document.getElementById('mainImg').src = src;
  document.querySelectorAll('.listing-gallery__thumb').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
}

function openLightbox(index) {
  currentPhotoIndex = index;
  document.getElementById('lb-img').src = allPhotos[index];
  document.getElementById('lb-counter').textContent = (index+1) + ' / ' + allPhotos.length;
  document.getElementById('lightbox').style.display = 'flex';
  document.body.style.overflow = 'hidden';
}
function closeLightbox() {
  document.getElementById('lightbox').style.display = 'none';
  document.body.style.overflow = '';
}
function lbNav(dir) {
  currentPhotoIndex = (currentPhotoIndex + dir + allPhotos.length) % allPhotos.length;
  document.getElementById('lb-img').src = allPhotos[currentPhotoIndex];
  document.getElementById('lb-counter').textContent = (currentPhotoIndex+1) + ' / ' + allPhotos.length;
}
document.addEventListener('keydown', e => {
  if (document.getElementById('lightbox').style.display==='flex') {
    if (e.key==='ArrowRight') lbNav(-1);
    else if (e.key==='ArrowLeft') lbNav(1);
    else if (e.key==='Escape') closeLightbox();
  }
});

function copyListingLink() {
  navigator.clipboard.writeText(window.location.href).then(() => {
    const btn = document.getElementById('copyBtn');
    btn.textContent = '✅ تم النسخ';
    setTimeout(() => { btn.innerHTML = '🔗 نسخ الرابط'; }, 2000);
  });
}

const priceDaily = <%= listing.price_daily || 0 %>;
const priceAnnual = <%= listing.price_annual || 0 %>;
let currentType = '<%= listing.type==="annual"?"annual":"daily" %>';

function setType(type, btn) {
  currentType = type;
  document.querySelectorAll('.lbb-toggle__btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('dailyFields').style.display = type === 'daily' ? 'block' : 'none';
  document.getElementById('bookBtn').href = '/book/<%= listing._id %>?type=' + type;
  calcNights();
}

function calcNights() {
  if (currentType !== 'daily') return;
  const ci = document.getElementById('checkIn').value;
  const co = document.getElementById('checkOut').value;
  if (!ci || !co) { document.getElementById('totalBox').style.display = 'none'; return; }
  const d1 = new Date(ci), d2 = new Date(co);
  const nights = Math.max(1, Math.round((d2 - d1) / 86400000));
  if (nights <= 0) { document.getElementById('totalBox').style.display = 'none'; return; }
  const total = nights * priceDaily;
  document.getElementById('nightsLbl').textContent = nights + ' ليلة × ' + priceDaily.toLocaleString('ar-SA') + ' ريال';
  document.getElementById('nightsPrice').textContent = (nights * priceDaily).toLocaleString('ar-SA') + ' ريال';
  document.getElementById('totalPrice').textContent = total.toLocaleString('ar-SA') + ' ريال';
  document.getElementById('totalBox').style.display = 'block';

  const btn = document.getElementById('bookBtn');
  btn.href = '/book/<%= listing._id %>?type=daily&checkin=' + ci + '&checkout=' + co + '&guests=' + document.getElementById('guests').value;
}

// Init Flatpickr if apartment booking box is present
if (document.getElementById('checkIn')) {
  const today = new Date().toISOString().split('T')[0];
  const blockedRanges = <%- JSON.stringify((listing.blockedRanges||[]).map(r=>({from:new Date(r.checkIn).toISOString().split('T')[0],to:new Date(r.checkOut).toISOString().split('T')[0]}))) %>;
  const fpOpts = { locale: 'ar', minDate: today, dateFormat: 'Y-m-d', disable: blockedRanges, onChange: calcNights };
  const fpOut = flatpickr('#checkOut', { ...fpOpts, minDate: new Date(Date.now()+86400000) });
  flatpickr('#checkIn', { ...fpOpts, onClose: d => { if (d[0]) fpOut.set('minDate', d[0]); } });
}
</script>
