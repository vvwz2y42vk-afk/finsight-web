<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= listing.title %> — Barez</title>
<meta name="description" content="<%= (listing.description||listing.title).substring(0,160) %>">
<meta property="og:title" content="<%= listing.title %> — Barez">
<meta property="og:description" content="<%= (listing.description||listing.title).substring(0,160) %>">
<% if(listing.photos && listing.photos.length){ %><meta property="og:image" content="<%= listing.photos[0] %>"><% } %>
<meta property="og:type" content="website">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/client.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
</head>
<body class="home-page csb-layout">

<aside class="client-sidebar" id="clientSidebar">
  <div class="csb-logo">
    <img src="/images/logo-dark.png" alt="Barez" style="height:52px;width:auto;">
  </div>
  <nav class="csb-nav">
    <a href="/" class="csb-lnk"><span class="csb-ico"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></span><span>الرئيسية</span></a>
    <div class="csb-divider"></div>
    <a href="/listings" class="csb-lnk active"><span class="csb-ico"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="16" height="20" x="4" y="2" rx="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h4"/><path d="M8 10h4"/><path d="M8 14h4"/></svg></span><span>عقاراتنا</span></a>
    <div class="csb-sub">
      <a href="/listings?cat=rental_apartment" class="csb-sublnk">🛏 شقق للإيجار</a>
      <a href="/listings?cat=rental_commercial" class="csb-sublnk">🏪 معارض للإيجار</a>
      <a href="/listings?cat=sale_land" class="csb-sublnk">🌍 أراضي للبيع</a>
      <a href="/listings?cat=sale_apartment" class="csb-sublnk">🏠 شقق للبيع</a>
    </div>
    <div class="csb-divider"></div>
    <a href="/search" class="csb-lnk"><span class="csb-ico"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg></span><span>بحث</span></a>
    <% if (typeof customer !== 'undefined' && customer) { %>
    <a href="/account" class="csb-lnk"><span class="csb-ico"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></span><span><%= customer.name %></span></a>
    <% } else { %>
    <a href="/account/login" class="csb-lnk"><span class="csb-ico"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></span><span>حسابي</span></a>
    <% } %>
    <a href="/about" class="csb-lnk"><span class="csb-ico"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg></span><span>من نحن</span></a>
    <a href="/inquiry" class="csb-lnk"><span class="csb-ico"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></span><span>تواصل معنا</span></a>
  </nav>
  <div class="csb-foot">
    <a href="https://wa.me/966590561057" target="_blank" class="csb-wa">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
      <span>0590561057</span>
    </a>
    
  </div>
</aside>
<div class="csb-overlay" id="csbOverlay" onclick="closeSidebar()"></div>
<button class="csb-ham" id="csbHam" onclick="toggleSidebar()"><span></span><span></span><span></span></button>

<div class="csb-content">

<!-- BREADCRUMB -->
<div style="background:#fff;border-bottom:1px solid var(--border);padding:12px 0;">
  <div class="page-container">
    <div style="font-size:13px;color:var(--text3);display:flex;align-items:center;gap:8px;">
      <a href="/listings" style="color:var(--gold);text-decoration:none;">عقاراتنا</a>
      <span>/</span>
      <a href="/listings?building=<%= listing.building %>" style="color:var(--gold);text-decoration:none;"><%= listing.building %></a>
      <span>/</span>
      <span><%= listing.title %></span>
    </div>
  </div>
</div>

<!-- GALLERY -->
<div class="listing-gallery-section">
  <div class="page-container">
    <% if (listing.photos && listing.photos.length > 0) { %>
    <div class="listing-gallery">
      <div class="listing-gallery__main" id="mainPhoto" onclick="openLightbox(currentPhotoIndex)" style="cursor:zoom-in;">
        <img src="<%= listing.photos[0] %>" alt="<%= listing.title %>" id="mainImg" loading="lazy">
      </div>
      <% if (listing.photos.length > 1) { %>
      <div class="listing-gallery__thumbs">
        <% listing.photos.forEach((ph, i) => { %>
        <div class="listing-gallery__thumb <%= i===0?'active':'' %>" onclick="setPhoto('<%= ph %>',this)">
          <img src="<%= ph %>" alt="صورة <%= i+1 %>" loading="lazy">
        </div>
        <% }); %>
      </div>
      <% } %>
    </div>
    <% } else { %>
    <div class="listing-gallery__placeholder">
      <span>🏢</span>
      <p>لا توجد صور مضافة</p>
    </div>
    <% } %>
  </div>
</div>

<!-- DETAIL LAYOUT -->
<section style="padding:48px 0 80px;background:#fff;">
  <div class="page-container">
    <div class="listing-layout">

      <!-- LEFT: INFO -->
      <div class="listing-info">
        <% const isApt = listing.category==='rental_apartment'; const isComm = listing.category==='rental_commercial'; const isLand = listing.category==='sale_land'; const isSaleApt = listing.category==='sale_apartment'; %>
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">
          <% if (isApt) { %>
          <span class="lc-badge lc-badge--type" style="font-size:12px;"><%= listing.type==='daily'?'يومي':listing.type==='annual'?'شهري':'يومي + شهري' %></span>
          <% } else if (isComm) { %>
          <span class="lc-badge lc-badge--type" style="font-size:12px;">معرض للإيجار</span>
          <% } else if (isSaleApt) { %>
          <span class="lc-badge lc-badge--type" style="font-size:12px;background:rgba(212,175,55,.9);">شقة للبيع</span>
          <% } else { %>
          <span class="lc-badge lc-badge--type" style="font-size:12px;background:rgba(212,175,55,.9);">أرض للبيع</span>
          <% } %>
          <% if (listing.featured) { %><span class="lc-badge lc-badge--featured" style="font-size:12px;">⭐ مميز</span><% } %>
        </div>
        <h1 style="font-size:clamp(1.5rem,3vw,2rem);font-weight:800;line-height:1.3;margin-bottom:6px;"><%= listing.title %></h1>
        <% if (listing.reviewCount > 0) { %>
        <div style="display:flex;align-items:center;gap:6px;margin-bottom:8px;">
          <% for(let i=1;i<=5;i++) { %><span style="font-size:15px;color:<%= i<=Math.round(listing.avgRating)?'#f59e0b':'#d1d5db' %>;">★</span><% } %>
          <span style="font-size:13px;font-weight:700;color:var(--dark);margin-right:2px;"><%= listing.avgRating.toFixed(1) %></span>
          <a href="#reviews" style="font-size:12px;color:var(--text3);text-decoration:underline;">(<%= listing.reviewCount %> تقييم)</a>
        </div>
        <% } %>
        <p style="color:var(--text3);font-size:14px;margin-bottom:24px;">
          <% if ((isApt || isSaleApt) && listing.building) { %>📍 <%= listing.building %><% if(listing.apt){ %> — شقة <%= listing.apt %><% } %><% if(listing.floor){ %> | الدور <%= listing.floor %><% } %>
          <% } else if (listing.location) { %>📍 <%= listing.location %>
          <% } %>
        </p>

        <!-- STATS -->
        <div class="listing-stats">
          <% if (isApt) { %>
          <div class="listing-stat"><div class="listing-stat__val"><%= listing.maxGuests %></div><div class="listing-stat__lbl">ضيوف</div></div>
          <div class="listing-stat"><div class="listing-stat__val"><%= listing.bedrooms %></div><div class="listing-stat__lbl"><%= listing.bedrooms===1?'غرفة':'غرف' %></div></div>
          <div class="listing-stat"><div class="listing-stat__val"><%= listing.bathrooms %></div><div class="listing-stat__lbl">حمام</div></div>
          <% } else if (isSaleApt) { %>
          <div class="listing-stat"><div class="listing-stat__val"><%= listing.bedrooms %></div><div class="listing-stat__lbl"><%= listing.bedrooms===1?'غرفة':'غرف' %></div></div>
          <div class="listing-stat"><div class="listing-stat__val"><%= listing.bathrooms %></div><div class="listing-stat__lbl">حمام</div></div>
          <% } %>
          <% if (listing.area) { %><div class="listing-stat"><div class="listing-stat__val"><%= listing.area %></div><div class="listing-stat__lbl">م²</div></div><% } %>
          <% if (isLand && listing.frontage) { %><div class="listing-stat"><div class="listing-stat__val"><%= listing.frontage %></div><div class="listing-stat__lbl">م واجهة</div></div><% } %>
          <% if (!isApt) { %>
          <div class="listing-stat">
            <div class="listing-stat__val" style="font-size:1rem;">
              <%= (isLand||isSaleApt)?(listing.price_sale||0).toLocaleString():(listing.price_annual||0).toLocaleString() %>
            </div>
            <div class="listing-stat__lbl">ريال <%= (isLand||isSaleApt)?'سعر البيع':'/شهر' %></div>
          </div>
          <% } %>
        </div>

        <div class="listing-divider"></div>

        <!-- DESCRIPTION -->
        <% if (listing.description) { %>
        <div style="margin-bottom:32px;">
          <h3 style="font-size:1.1rem;font-weight:700;margin-bottom:12px;"><%= isLand?'عن الأرض':isComm?'عن المعرض':'عن الوحدة' %></h3>
          <p style="color:var(--text2);line-height:2;font-size:15px;"><%= listing.description %></p>
        </div>
        <% } %>

        <!-- AMENITIES -->
        <% if (listing.amenities && listing.amenities.length > 0) { %>
        <div>
          <h3 style="font-size:1.1rem;font-weight:700;margin-bottom:16px;">المرافق والمميزات</h3>
          <div class="listing-amenities">
            <% const amenityIcons = {'واي فاي':'📶','مكيف':'❄️','مطبخ مجهز':'🍳','تلفزيون':'📺','غسالة':'🌀','موقف سيارة':'🚗','مصعد':'🛗','حراسة 24 ساعة':'🔒','مطل على الشارع':'🪟','أثاث كامل':'🛋️','ثلاجة':'🧊','تدفئة مركزية':'🌡️'}; %>
            <% listing.amenities.forEach(am => { %>
            <div class="listing-amenity">
              <span><%= amenityIcons[am] || '✓' %></span>
              <span><%= am %></span>
            </div>
            <% }); %>
          </div>
        </div>
        <% } %>

        <!-- LOCATION MAP LINK -->
        <% const mapQuery = encodeURIComponent((listing.location || listing.building || '') + ' المدينة المنورة'); %>
        <% if (listing.location || listing.building) { %>
        <div style="margin-top:24px;">
          <h3 style="font-size:1.1rem;font-weight:700;margin-bottom:12px;">الموقع</h3>
          <a href="https://www.google.com/maps/search/?api=1&query=<%= mapQuery %>" target="_blank" rel="noopener" style="display:flex;align-items:center;gap:10px;padding:14px 16px;background:var(--light);border:1px solid var(--border);border-radius:12px;text-decoration:none;color:var(--text2);font-size:14px;font-weight:600;transition:background .2s;" onmouseover="this.style.background='#e9e9e9'" onmouseout="this.style.background='var(--light)'">
            <span style="font-size:1.5rem;">📍</span>
            <span><%= listing.location || listing.building %> — المدينة المنورة</span>
            <span style="margin-right:auto;font-size:12px;color:var(--text3);">فتح في الخريطة ←</span>
          </a>
        </div>
        <% } %>
      </div>

      <!-- RIGHT: BOOKING BOX -->
      <div class="listing-book-box" id="bookBox">

        <% if (listing.category === 'rental_apartment') { %>
        <!-- APARTMENT BOOKING BOX -->
        <div class="lbb-price">
          <% if (listing.type==='daily'||listing.type==='both') { %>
          <span class="lbb-price__num"><%= listing.price_daily.toLocaleString() %></span>
          <span class="lbb-price__unit"> ريال / ليلة</span>
          <% } %>
          <% if (listing.type==='annual'||listing.type==='both') { %>
          <% if(listing.type==='both') { %><div style="font-size:12px;color:var(--text3);margin-top:4px;">أو</div><% } %>
          <span class="lbb-price__num" style="<%= listing.type==='both'?'font-size:1.2rem;':'' %>"><%= listing.price_annual.toLocaleString() %></span>
          <span class="lbb-price__unit"> ريال / شهر</span>
          <% } %>
        </div>
        <% if (listing.type==='both') { %>
        <div class="lbb-toggle" id="typeToggle">
          <button class="lbb-toggle__btn active" onclick="setType('daily',this)">يومي</button>
          <button class="lbb-toggle__btn" onclick="setType('annual',this)">شهري</button>
        </div>
        <% } %>
        <div id="dailyFields" style="<%= listing.type==='annual'?'display:none':'display:block' %>">
          <div class="lbb-row"><label class="lbb-lbl">تاريخ الوصول</label><input type="text" class="lbb-inp" id="checkIn" placeholder="اختر التاريخ" readonly></div>
          <div class="lbb-row"><label class="lbb-lbl">تاريخ المغادرة</label><input type="text" class="lbb-inp" id="checkOut" placeholder="اختر التاريخ" readonly></div>
          <div class="lbb-row"><label class="lbb-lbl">عدد الضيوف</label>
            <select class="lbb-inp" id="guests"><% for(let i=1;i<=listing.maxGuests;i++) { %><option value="<%= i %>"><%= i %> ضيف</option><% } %></select>
          </div>
          <div class="lbb-total" id="totalBox" style="display:none">
            <div class="lbb-total__row"><span id="nightsLbl">—</span><span id="nightsPrice">—</span></div>
            <div class="lbb-total__sum"><span>الإجمالي</span><span class="c-gold" id="totalPrice">—</span></div>
          </div>
        </div>
        <a id="bookBtn" href="/book/<%= listing._id %>?type=<%= listing.type==='annual'?'annual':'daily' %>" class="btn btn-gold" style="width:100%;justify-content:center;padding:14px;font-size:1rem;font-weight:700;margin-top:16px;border-radius:12px;">احجز الآن</a>

        <% } else if (listing.category === 'rental_commercial') { %>
        <!-- COMMERCIAL INQUIRY BOX -->
        <div class="lbb-price">
          <span class="lbb-price__num"><%= (listing.price_annual||0).toLocaleString() %></span>
          <span class="lbb-price__unit"> ريال / شهر</span>
        </div>
        <div style="background:var(--light);border-radius:10px;padding:12px 14px;margin-bottom:16px;font-size:13px;color:var(--text3);line-height:1.8;">
          <% if (listing.area) { %><div>📐 المساحة: <strong style="color:var(--dark);"><%= listing.area %> م²</strong></div><% } %>
          <% if (listing.floor) { %><div>🏢 الدور: <strong style="color:var(--dark);"><%= listing.floor %></strong></div><% } %>
        </div>
        <a href="/book/<%= listing._id %>" class="btn btn-gold" style="width:100%;justify-content:center;padding:14px;font-size:1rem;font-weight:700;border-radius:12px;">أرسل استفساراً</a>

        <% } else if (isSaleApt) { %>
        <!-- SALE APARTMENT INQUIRY BOX -->
        <div class="lbb-price">
          <span class="lbb-price__num"><%= (listing.price_sale||0).toLocaleString() %></span>
          <span class="lbb-price__unit"> ريال</span>
        </div>
        <div style="background:var(--light);border-radius:10px;padding:12px 14px;margin-bottom:16px;font-size:13px;color:var(--text3);line-height:1.8;">
          <% if (listing.bedrooms) { %><div>🛏 الغرف: <strong style="color:var(--dark);"><%= listing.bedrooms %> <%= listing.bedrooms===1?'غرفة':'غرف' %></strong></div><% } %>
          <% if (listing.bathrooms) { %><div>🚿 الحمامات: <strong style="color:var(--dark);"><%= listing.bathrooms %></strong></div><% } %>
          <% if (listing.area) { %><div>📐 المساحة: <strong style="color:var(--dark);"><%= listing.area %> م²</strong></div><% } %>
          <% if (listing.area && listing.price_sale) { %><div>💰 السعر/م²: <strong style="color:var(--gold);"><%= Math.round(listing.price_sale/listing.area).toLocaleString() %> ريال</strong></div><% } %>
        </div>
        <a href="/book/<%= listing._id %>" class="btn btn-gold" style="width:100%;justify-content:center;padding:14px;font-size:1rem;font-weight:700;border-radius:12px;">أرسل استفساراً</a>

        <% } else { %>
        <!-- LAND INQUIRY BOX -->
        <div class="lbb-price">
          <span class="lbb-price__num"><%= (listing.price_sale||0).toLocaleString() %></span>
          <span class="lbb-price__unit"> ريال</span>
        </div>
        <div style="background:var(--light);border-radius:10px;padding:12px 14px;margin-bottom:16px;font-size:13px;color:var(--text3);line-height:1.8;">
          <% if (listing.area) { %><div>📐 المساحة: <strong style="color:var(--dark);"><%= listing.area %> م²</strong></div><% } %>
          <% if (listing.frontage) { %><div>↔️ الواجهة: <strong style="color:var(--dark);"><%= listing.frontage %> م</strong></div><% } %>
          <% if (listing.area && listing.price_sale) { %><div>💰 السعر/م²: <strong style="color:var(--gold);"><%= Math.round(listing.price_sale/listing.area).toLocaleString() %> ريال</strong></div><% } %>
        </div>
        <a href="/book/<%= listing._id %>" class="btn btn-gold" style="width:100%;justify-content:center;padding:14px;font-size:1rem;font-weight:700;border-radius:12px;">أرسل استفساراً</a>
        <% } %>

        <a href="https://wa.me/966590561057?text=أهلاً، أريد الاستفسار عن: <%= encodeURIComponent(listing.title) %>" target="_blank" class="lbb-wa">
