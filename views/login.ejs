<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>تسجيل الدخول — BAREZ</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@400;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/client.css">
</head>
<body>
<div class="login-wrap">
  <svg class="login-bg-logo" width="700" height="260" viewBox="0 0 420 120" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <linearGradient id="lg" x1="0" y1="0" x2="0.5" y2="1">
        <stop offset="0%" stop-color="#F5D060"/>
        <stop offset="100%" stop-color="#8B6010"/>
      </linearGradient>
    </defs>
    <path d="M4,4 L54,4 L54,24 L26,24 L18,32 L4,32 Z" fill="url(#lg)"/>
    <rect x="4" y="4" width="14" height="60" fill="url(#lg)"/>
    <path d="M4,40 L42,40 L42,52 L18,52 L4,62 Z" fill="url(#lg)"/>
    <text x="72" y="52" font-family="Arial,sans-serif" font-size="52" font-weight="900" fill="#DAA520" letter-spacing="6">INSIGHT</text>
  </svg>
  <div class="login-card">
    <div class="login-logo">
      <div class="ico">FS</div>
      <h2>BAREZ</h2>
      <p>لوحة تحكم الموظفين</p>
    </div>
    <% if (error) { %>
      <div class="login-error"><%= error %></div>
    <% } %>
    <form method="POST" action="/login">
      <div class="login-group">
        <label>اسم المستخدم</label>
        <input type="text" name="username" placeholder="اسم المستخدم" autofocus>
      </div>
      <div class="login-group">
        <label>كلمة المرور</label>
        <input type="password" name="password" placeholder="••••••••">
      </div>
      <button type="submit" class="login-btn">دخول ←</button>
    </form>
    <div style="margin-top:20px;text-align:center;">
      <a href="/" style="color:#555;font-size:12px;">← العودة للموقع</a>
    </div>
  </div>
</div>
</body>
</html>
