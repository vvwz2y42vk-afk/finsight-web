<script>
// Scroll animations
const observer = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
}, { threshold: 0.12 });
document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));

// Animate property count
fetch('/superadmin/api/public-stats').then(r => r.json()).then(d => {
  const el = document.getElementById('cnt-props');
  if (!el || !d.total) return;
  let n = 0; const target = d.total;
  const step = () => { n = Math.min(n + 1, target); el.textContent = n; if (n < target) requestAnimationFrame(step); };
  requestAnimationFrame(step);
}).catch(() => { document.getElementById('cnt-props').textContent = '50+'; });

// Nav scroll effect
window.addEventListener('scroll', () => {
  document.querySelector('nav').style.background =
    window.scrollY > 40 ? 'rgba(6,11,24,.97)' : 'rgba(6,11,24,.85)';
});
</script>
