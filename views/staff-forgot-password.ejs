<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>نسيت كلمة المرور — BAREZ</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Cairo',sans-serif;background:#04091a;min-height:100vh;display:flex;align-items:center;justify-content:center;overflow:hidden;position:relative;}
.bg-glow{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);width:900px;height:900px;background:radial-gradient(ellipse at center,rgba(26,61,143,.35) 0%,rgba(26,61,143,.08) 45%,transparent 70%);pointer-events:none;z-index:0;}
.bg-glow2{position:fixed;bottom:-200px;right:-200px;width:600px;height:600px;background:radial-gradient(ellipse at center,rgba(201,168,68,.12) 0%,transparent 65%);pointer-events:none;z-index:0;}
.bg-text{position:fixed;bottom:40px;left:50%;transform:translateX(-50%);font-size:clamp(60px,12vw,130px);font-weight:900;letter-spacing:.25em;color:transparent;-webkit-text-stroke:1px rgba(255,255,255,.04);white-space:nowrap;z-index:0;pointer-events:none;user-select:none;}
.box{position:relative;z-index:10;background:rgba(255,255,255,.06);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);border:1px solid rgba(255,255,255,.1);border-radius:24px;padding:44px 40px;width:100%;max-width:400px;box-shadow:0 32px 80px rgba(0,0,0,.6),inset 0 1px 0 rgba(255,255,255,.1);}
.logo-wrap{display:flex;justify-content:center;margin-bottom:28px;}
.logo-wrap img{height:68px;width:auto;filter:brightness(0) invert(1);}
.brand{text-align:center;font-size:22px;font-weight:900;color:#fff;letter-spacing:.15em;margin-bottom:2px;}
.brand-sub{text-align:center;font-size:11px;color:rgba(255,255,255,.45);letter-spacing:.1em;margin-bottom:28px;}
.title{font-size:18px;font-weight:700;color:#fff;margin-bottom:6px;}
.sub{font-size:13px;color:rgba(255,255,255,.45);margin-bottom:24px;line-height:1.6;}
label{display:block;font-size:11px;font-weight:700;color:rgba(255,255,255,.55);margin-bottom:6px;letter-spacing:.06em;}
input{width:100%;padding:12px 14px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);border-radius:10px;font-family:inherit;font-size:14px;color:#fff;outline:none;transition:border .2s,background .2s;margin-bottom:16px;}
input::placeholder{color:rgba(255,255,255,.3);}
input:focus{border-color:rgba(42,92,199,.8);background:rgba(255,255,255,.12);}
button{width:100%;padding:14px;background:linear-gradient(135deg,#1a3d8f,#2a5cc7);border:none;border-radius:12px;color:#fff;font-family:inherit;font-size:15px;font-weight:800;cursor:pointer;transition:all .2s;box-shadow:0 4px 20px rgba(26,61,143,.5);letter-spacing:.05em;}
button:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(26,61,143,.65);}
.err{background:rgba(220,38,38,.15);border:1px solid rgba(220,38,38,.3);color:#fca5a5;border-radius:10px;padding:10px 14px;font-size:13px;font-weight:600;margin-bottom:16px;text-align:center;}
.ok{background:rgba(16,185,129,.12);border:1px solid rgba(16,185,129,.3);color:#6ee7b7;border-radius:10px;padding:10px 14px;font-size:13px;font-weight:600;margin-bottom:16px;text-align:center;}
.back{text-align:center;margin-top:20px;font-size:12px;color:rgba(255,255,255,.3);}
.back a{color:rgba(255,255,255,.55);text-decoration:none;font-weight:700;}
.back a:hover{color:#fff;}
</style>
</head>
<body>
<div class="bg-glow"></div>
<div class="bg-glow2"></div>
<div class="bg-text">BAREZ</div>
<div class="box">
  <div class="logo-wrap"><img src="/images/logo-dark.png" alt="Barez"></div>
  <div class="brand">BAREZ</div>
  <div class="brand-sub">بوابة الموظفين</div>
  <div class="title">نسيت كلمة المرور؟</div>
  <div class="sub">أدخل اسم المستخدم وسنرسل لك رابط إعادة التعيين على البريد الإلكتروني المسجل</div>
  <% if (error) { %><div class="err">⚠️ <%= error %></div><% } %>
  <% if (success) { %><div class="ok">✓ <%= success %></div><% } %>
  <% if (!success) { %>
  <form method="POST" action="/staff/forgot-password">
    <label>اسم المستخدم</label>
    <input type="text" name="username" placeholder="username" required autofocus>
    <button type="submit">إرسال رابط إعادة التعيين ←</button>
  </form>
  <% } %>
  <div class="back"><a href="/staff/login">← العودة لتسجيل الدخول</a></div>
</div>
</body>
</html>
