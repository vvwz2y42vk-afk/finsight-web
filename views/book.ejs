<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>حجز — <%= listing.title %> — BAREZ</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/client.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
</head>
<body class="home-page csb-layout">

<aside class="client-sidebar" id="clientSidebar">
  <div class="csb-logo">
    <img src="/images/logo-dark.png" alt="Barez" style="height:52px;width:auto;">
  </div>
  <nav class="csb-nav">
    <a href="/" class="csb-lnk"><span class="csb-ico">⬡</span><span>الرئيسية</span></a>
    <div class="csb-divider"></div>
    <a href="/listings" class="csb-lnk active"><span class="csb-ico">🏢</span><span>عقاراتنا</span></a>
    <div class="csb-sub">
      <a href="/listings?cat=rental_apartment" class="csb-sublnk">🛏 شقق للإيجار</a>
      <a href="/listings?cat=rental_commercial" class="csb-sublnk">🏪 معارض للإيجار</a>
      <a href="/listings?cat=sale_land" class="csb-sublnk">🌍 أراضي للبيع</a>
      <a href="/listings?cat=sale_apartment" class="csb-sublnk">🏠 شقق للبيع</a>
    </div>
    <div class="csb-divider"></div>
    <a href="/search" class="csb-lnk"><span class="csb-ico">🔍</span><span>بحث</span></a>
    <% if (typeof customer !== 'undefined' && customer) { %>
    <a href="/account" class="csb-lnk"><span class="csb-ico">👤</span><span><%= customer.name %></span></a>
    <% } else { %>
    <a href="/account/login" class="csb-lnk"><span class="csb-ico">👤</span><span>حسابي</span></a>
    <% } %>
    <a href="/about" class="csb-lnk"><span class="csb-ico">ℹ️</span><span>من نحن</span></a>
    <a href="/inquiry" class="csb-lnk"><span class="csb-ico">💬</span><span>تواصل معنا</span></a>
  </nav>
  <div class="csb-foot">
    <a href="https://wa.me/966590561057" target="_blank" class="csb-wa">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
      <span>0590561057</span>
    </a>
    
  </div>
</aside>
<div class="csb-overlay" id="csbOverlay" onclick="closeSidebar()"></div>
<button class="csb-ham" id="csbHam" onclick="toggleSidebar()"><span></span><span></span><span></span></button>

<div class="csb-content">

<section style="padding:80px 0;background:var(--light);min-height:80vh;">
  <div class="page-container" style="max-width:760px;">

    <!-- LISTING SUMMARY -->
    <a href="/listings/<%= listing._id %>" class="book-listing-preview">
      <div class="book-listing-preview__photo">
        <% if (listing.photos && listing.photos.length) { %>
        <img src="<%= listing.photos[0] %>" alt="<%= listing.title %>">
        <% } else { %>
        <div class="listing-card__photo-ph" style="height:100%;">🏢</div>
        <% } %>
      </div>
      <div class="book-listing-preview__info">
        <div style="font-size:12px;color:var(--gold);font-weight:700;"><%= listing.building %></div>
        <div style="font-size:1rem;font-weight:700;margin:4px 0;"><%= listing.title %></div>
        <% if (listing.category==='rental_apartment') { %>
        <div style="font-size:13px;color:var(--text3);">🛏 <%= listing.bedrooms %> غرف | 🚿 <%= listing.bathrooms %> حمام<% if(listing.area) { %> | 📐 <%= listing.area %> م²<% } %></div>
        <% } else { %>
        <div style="font-size:13px;color:var(--text3);"><% if(listing.area) { %>📐 <%= listing.area %> م²<% } %><% if(listing.category==='sale_land'&&listing.price_sale) { %> | 💰 <%= listing.price_sale.toLocaleString() %> ريال<% } else if(listing.price_annual) { %> | 💰 <%= listing.price_annual.toLocaleString() %> ريال/شهر<% } %></div>
        <% } %>
      </div>
      <span style="color:var(--text3);font-size:12px;margin-right:auto;white-space:nowrap;">← تفاصيل</span>
    </a>

    <!-- FORM CARD -->
    <div class="book-form-card">
      <% if (listing.category !== 'rental_apartment') { %>
      <h2 style="font-size:1.4rem;font-weight:800;margin-bottom:4px;">إرسال استفسار</h2>
      <p style="color:var(--text3);font-size:13px;margin-bottom:28px;">أدخل بياناتك وسيتواصل معك فريقنا في أقرب وقت</p>
      <% } else { %>
      <h2 style="font-size:1.4rem;font-weight:800;margin-bottom:4px;">تأكيد الحجز</h2>
      <p style="color:var(--text3);font-size:13px;margin-bottom:28px;">أدخل بياناتك وسيتواصل معك فريقنا لتأكيد الحجز</p>
      <% } %>

      <% if (error === 'overlap') { %>
      <div style="background:rgba(192,57,43,.08);border:1px solid rgba(192,57,43,.3);border-radius:12px;padding:14px 16px;margin-bottom:20px;font-size:14px;color:#c0392b;font-weight:600;">
        ⚠️ التواريخ المختارة محجوزة. اختر تواريخ أخرى.
      </div>
      <% } %>

      <form method="POST" action="/book/<%= listing._id %>">

        <% if (listing.category !== 'rental_apartment') { %>
        <!-- INQUIRY FORM (non-apartment) -->
        <input type="hidden" name="bookingType" value="inquiry">
        <% } else { %>
        <!-- RENTAL TYPE -->
        <div style="margin-bottom:20px;">
          <div class="form-lbl">نوع الإيجار</div>
          <div class="book-type-toggle">
            <% const showDaily = listing.type==='daily'||listing.type==='both'; %>
            <% const showAnnual = listing.type==='annual'||listing.type==='both'; %>
            <% if (showDaily) { %>
            <label class="book-type-opt">
              <input type="radio" name="bookingType" value="daily" <%= prefill.type==='daily'?'checked':'' %> onchange="toggleType(this.value)">
              <span class="book-type-opt__label">
                <span class="book-type-opt__ico">🌙</span>
                <span>
                  <strong>يومي</strong>
                  <small><%= listing.price_daily.toLocaleString() %> ريال/ليلة</small>
                </span>
              </span>
            </label>
            <% } %>
            <% if (showAnnual) { %>
            <label class="book-type-opt">
              <input type="radio" name="bookingType" value="annual" <%= prefill.type==='annual'?'checked':'' %> onchange="toggleType(this.value)">
              <span class="book-type-opt__label">
                <span class="book-type-opt__ico">📋</span>
                <span>
                  <strong>شهري</strong>
                  <small><%= listing.price_annual.toLocaleString() %> ريال/شهر</small>
                </span>
              </span>
            </label>
            <% } %>
          </div>
        </div>

        <!-- DAILY DATES -->
        <div id="dailySection" style="display:<%= prefill.type==='daily'?'block':'none' %>">
          <div class="book-form-grid">
            <div>
              <label class="form-lbl">تاريخ الوصول</label>
              <input type="text" name="checkIn" id="fp-checkin" class="form-inp" placeholder="اختر تاريخ الوصول" readonly>
            </div>
            <div>
              <label class="form-lbl">تاريخ المغادرة</label>
              <input type="text" name="checkOut" id="fp-checkout" class="form-inp" placeholder="اختر تاريخ المغادرة" readonly>
            </div>
          </div>
          <div style="margin-bottom:20px;">
            <label class="form-lbl">عدد الضيوف</label>
            <select name="guests" class="form-inp" style="max-width:200px;">
              <% for(let i=1;i<=listing.maxGuests;i++) { %><option value="<%= i %>"><%= i %> <%= i===1?'ضيف':'ضيوف' %></option><% } %>
            </select>
          </div>
          <div class="book-total-box" id="totalBox" style="display:none">
            <div style="display:flex;justify-content:space-between;font-size:13px;color:var(--text3);"><span id="totalNights">—</span><span id="totalCalc">—</span></div>
            <div style="display:flex;justify-content:space-between;font-size:1rem;font-weight:700;margin-top:8px;padding-top:8px;border-top:1px solid var(--border);"><span>الإجمالي</span><span class="c-gold" id="totalFinal">—</span></div>
          </div>
        </div>

        <!-- ANNUAL START -->
        <div id="annualSection" style="display:<%= prefill.type==='annual'?'block':'none' %>">
          <div style="margin-bottom:20px;">
            <label class="form-lbl">تاريخ البدء المقترح</label>
            <input type="date" name="checkIn" class="form-inp" style="max-width:260px;" min="<%= new Date().toISOString().split('T')[0] %>">
            <input type="hidden" name="checkOut">
          </div>
        </div>
        <% } %>

        <div class="book-divider"></div>

        <!-- PERSONAL INFO -->
        <% if (!customer) { %>
        <div style="background:var(--light);border:1px solid var(--border);border-radius:12px;padding:12px 16px;margin-bottom:16px;font-size:13px;display:flex;align-items:center;justify-content:space-between;gap:12px;">
          <span style="color:var(--text3);">لديك حساب؟ سجّل دخولك لملء بياناتك تلقائياً</span>
          <a href="/account/login?next=<%= encodeURIComponent('/book/' + listing._id) %>" class="btn btn-gold" style="font-size:12px;padding:6px 14px;white-space:nowrap;">دخول ←</a>
        </div>
        <% } else { %>
        <div style="background:rgba(212,175,55,.08);border:1px solid rgba(212,175,55,.3);border-radius:12px;padding:12px 16px;margin-bottom:16px;font-size:13px;color:var(--text2);display:flex;align-items:center;gap:10px;">
          <span style="font-size:20px;">👤</span>
          <span>مرحباً <strong><%= customer.name %></strong> — بياناتك ستُرسل مع الحجز</span>
        </div>
        <% } %>
        <div class="book-form-grid">
          <div>
            <label class="form-lbl">الاسم الكامل <span style="color:var(--red)">*</span></label>
            <input type="text" name="name" class="form-inp" placeholder="اسمك الكامل" required value="<%= customer ? customer.name : '' %>">
          </div>
          <div>
            <label class="form-lbl">رقم الهاتف <span style="color:var(--red)">*</span></label>
            <input type="tel" name="phone" class="form-inp" placeholder="05xxxxxxxx" required value="<%= customer ? customer.phone : '' %>">
          </div>
          <div class="book-full">
            <label class="form-lbl">البريد الإلكتروني <span style="color:var(--text3);font-size:11px;">(اختياري)</span></label>
            <input type="email" name="email" class="form-inp" placeholder="email@example.com" value="<%= customer ? (customer.email || '') : '' %>">
          </div>
          <div class="book-full">
            <label class="form-lbl">ملاحظات <span style="color:var(--text3);font-size:11px;">(اختياري)</span></label>
            <textarea name="notes" class="form-inp" rows="3" placeholder="أي متطلبات أو استفسارات..." style="resize:vertical;"></textarea>
          </div>
        </div>

        <button type="submit" class="btn btn-gold" style="width:100%;padding:14px;font-size:1rem;font-weight:700;border-radius:12px;margin-top:8px;">
          إرسال طلب الحجز ←
        </button>
        <p style="text-align:center;font-size:12px;color:var(--text3);margin-top:10px;">لن يُطلب منك الدفع الآن — سنتواصل معك للتأكيد</p>
      </form>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer class="site-footer-new">
  <div class="page-container">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="footer-brand__logo">
          <img src="/images/logo-dark.png" alt="Barez" style="height:52px;width:auto;">
        </div>
        <p class="footer-brand__desc">شركة رائدة في إدارة الأملاك والوساطة العقارية بالمدينة المنورة.</p>
      </div>
      <div class="footer-col">
        <div class="footer-col__title">روابط سريعة</div>
        <a href="/">الرئيسية</a><a href="/about">من نحن</a>
        <a href="/listings">عقاراتنا</a><a href="/inquiry">تواصل معنا</a>
      </div>
      <div class="footer-col">
        <div class="footer-col__title">تواصل معنا</div>
        <a href="https://wa.me/966590561057">0590561057</a>
        <a href="mailto:realstate@barezz.com">realstate@barezz.com</a>
      </div>
    </div>
    <div class="footer-bottom">
      <p>© 2026 Barez — جميع الحقوق محفوظة &nbsp;·&nbsp; <a href="/terms" style="color:inherit;opacity:.6;">الشروط والأحكام</a></p>
    </div>
  </div>
</footer>

</div><!-- /csb-content -->
<script>
function toggleSidebar(){document.getElementById('clientSidebar').classList.toggle('open');document.getElementById('csbOverlay').classList.toggle('open');document.getElementById('csbHam').classList.toggle('active');}
function closeSidebar(){document.getElementById('clientSidebar').classList.remove('open');document.getElementById('csbOverlay').classList.remove('open');document.getElementById('csbHam').classList.remove('active');}
</script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/ar.js"></script>
<script>
const priceDaily = <%= listing.price_daily || 0 %>;
const blockedRanges = <%- JSON.stringify((listing.blockedRanges||[]).map(r=>({from:new Date(r.checkIn).toISOString().split('T')[0],to:new Date(r.checkOut).toISOString().split('T')[0]}))) %>;
const today = new Date().toISOString().split('T')[0];

let fpIn, fpOut;

function calcTotal() {
  const ci = document.getElementById('fp-checkin')?.value;
  const co = document.getElementById('fp-checkout')?.value;
  if (!ci || !co) return;
  const n = Math.max(1, Math.round((new Date(co) - new Date(ci)) / 86400000));
  document.getElementById('totalNights').textContent = n + ' ليلة × ' + priceDaily.toLocaleString('ar-SA') + ' ريال';
  document.getElementById('totalCalc').textContent = (n * priceDaily).toLocaleString('ar-SA') + ' ريال';
  document.getElementById('totalFinal').textContent = (n * priceDaily).toLocaleString('ar-SA') + ' ريال';
  document.getElementById('totalBox').style.display = 'block';
}

function toggleType(type) {
  document.getElementById('dailySection').style.display = type === 'daily' ? 'block' : 'none';
  document.getElementById('annualSection').style.display = type === 'annual' ? 'block' : 'none';
}

// Init Flatpickr date pickers with blocked ranges
const fpOpts = {
  locale: 'ar',
  minDate: today,
  dateFormat: 'Y-m-d',
  disable: blockedRanges,
  onChange: calcTotal,
};
fpIn  = flatpickr('#fp-checkin',  { ...fpOpts, onClose: d => { if(fpOut) fpOut.set('minDate', d[0] || today); } });
fpOut = flatpickr('#fp-checkout', { ...fpOpts, minDate: new Date(Date.now()+86400000) });
</script>
</body>
</html>
