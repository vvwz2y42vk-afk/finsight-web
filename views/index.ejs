</div>

<!-- ═══════════════════════════════════
     ABOUT INTRO
════════════════════════════════════ -->
<section class="about-intro">
  <div class="page-container">
    <div class="about-intro__grid" data-aos="fade-up" data-aos-duration="900">
      <div class="about-intro__text">
