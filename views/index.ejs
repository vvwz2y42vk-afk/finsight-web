<div class="csb-content">

<!-- ═══════════════════════════════════
     HERO
════════════════════════════════════ -->
<section class="hero-section">
  <canvas id="heroCanvas"></canvas>
  <div class="hero-orb hero-orb--1"></div>
  <div class="hero-orb hero-orb--2"></div>
  <div class="hero-orb hero-orb--3"></div>
  <div class="hero-section__overlay"></div>
  <div class="hero-section__content">
    <div class="hero-section__badge">
      <span class="badge-dot"></span>
      <span><%= stats.freeUnits %>+ عقار متاح الآن</span>
    </div>
    <h1 class="hero-section__title">
      عقارك المثالي
      <span class="hero-section__title--gold">في المدينة المنورة</span>
    </h1>
    <p class="hero-section__desc">شقق · معارض · أراضي · للإيجار والبيع — بإدارة احترافية وخدمة متكاملة على أعلى المستويات</p>

    <!-- Property Type Tabs -->
    <div style="display:flex;gap:8px;justify-content:center;flex-wrap:wrap;margin-bottom:18px;">
      <a href="/listings?cat=rental_apartment" class="hero-type-pill">شقق إيجار</a>
      <a href="/listings?cat=sale_apartment" class="hero-type-pill">شقق للبيع</a>
      <a href="/listings?cat=rental_commercial" class="hero-type-pill">معارض إيجار</a>
      <a href="/listings?cat=sale_land" class="hero-type-pill">أراضي للبيع</a>
    </div>

    <!-- Quick Search -->
    <form method="GET" action="/search" class="hero-search-glass">
      <select name="type" style="padding:13px 12px;border-radius:10px;font-family:'Cairo',sans-serif;font-size:13px;flex-shrink:0;cursor:pointer;">
        <option value="" style="background:#0d1f42;color:#fff;">كل الأنواع</option>
        <option value="rental_apartment" style="background:#0d1f42;color:#fff;">شقق إيجار</option>
        <option value="sale_apartment" style="background:#0d1f42;color:#fff;">شقق بيع</option>
        <option value="rental_commercial" style="background:#0d1f42;color:#fff;">معارض إيجار</option>
        <option value="sale_land" style="background:#0d1f42;color:#fff;">أراضي بيع</option>
      </select>
      <input type="text" name="q" placeholder="ابحث بالاسم أو الموقع..."
        style="flex:1;padding:13px 16px;border-radius:10px;font-family:'Cairo',sans-serif;font-size:14px;min-width:0;">
      <button type="submit"
        style="padding:13px 22px;border-radius:10px;border:none;color:#fff;font-family:'Cairo',sans-serif;font-size:14px;font-weight:800;cursor:pointer;white-space:nowrap;flex-shrink:0;">
        بحث
      </button>
    </form>

    <div class="hero-section__cta">
      <a href="/listings" class="btn btn-gold btn-lg">
        <svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        استكشف كل العقارات
      </a>
      <a href="/inquiry" class="btn btn-ghost btn-lg">
        <svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        تواصل معنا
      </a>
    </div>

    <div class="hero-stats-bar">
      <div class="hero-stat-item">
        <div class="hero-stat-item__num">+3000</div>
        <div class="hero-stat-item__lbl">عميل راضٍ</div>
      </div>
      <div class="hero-stat-divider"></div>
      <div class="hero-stat-item">
        <div class="hero-stat-item__num"><%= stats.totalUnits %>+</div>
        <div class="hero-stat-item__lbl">وحدة عقارية</div>
      </div>
      <div class="hero-stat-divider"></div>
      <div class="hero-stat-item">
        <div class="hero-stat-item__num">4</div>
        <div class="hero-stat-item__lbl">أنواع عقارات</div>
      </div>
      <div class="hero-stat-divider"></div>
      <div class="hero-stat-item">
        <div class="hero-stat-item__num">✓</div>
        <div class="hero-stat-item__lbl">رخصة فال</div>
      </div>
    </div>
  </div>
  <div class="hero-section__scroll">
    <span>اكتشف المزيد</span>
    <div class="scroll-icon"></div>
  </div>
</section>

<!-- ═══════════════════════════════════
