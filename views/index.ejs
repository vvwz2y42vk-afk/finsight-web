      <a href="/listings?cat=rental_commercial" class="csb-sublnk">معارض للإيجار</a>
      <a href="/listings?cat=sale_land" class="csb-sublnk">أراضي للبيع</a>
      <a href="/listings?cat=sale_apartment" class="csb-sublnk">شقق للبيع</a>
    </div>
    <div class="csb-divider"></div>
    <a href="/search" class="csb-lnk"><span class="csb-ico"><svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg></span><span>بحث</span></a>
    <% if (typeof customer !== 'undefined' && customer) { %>
