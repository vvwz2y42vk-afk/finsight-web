<div class="csb-overlay" id="csbOverlay" onclick="closeSidebar()"></div>
<button class="csb-ham" id="csbHam" onclick="toggleSidebar()"><span></span><span></span><span></span></button>

<div class="csb-content">

<!-- ═══════════════════════════════════
     HERO
════════════════════════════════════ -->
<section class="hero-section">
  <canvas id="heroCanvas"></canvas>
  <div class="hero-orb hero-orb--1"></div>
  <div class="hero-orb hero-orb--2"></div>
  <div class="hero-orb hero-orb--3"></div>
  <div class="hero-section__overlay"></div>
  <div class="hero-section__content">
    <div class="hero-section__badge">
      <span class="badge-dot"></span>
      <span><%= stats.freeUnits %> وحدة متاحة الآن</span>
    </div>
    <h1 class="hero-section__title">
      سكنك المثالي
      <span class="hero-section__title--gold">في قلب المدينة المنورة</span>
    </h1>
    <p class="hero-section__desc">٤ مجمعات سكنية راقية — وحدات فاخرة بمواقع استراتيجية متكاملة الخدمات، بإدارة احترافية على أعلى المستويات</p>
    <!-- Quick Search Widget -->
    <form method="GET" action="/search" style="display:flex;gap:10px;max-width:560px;margin:0 auto 28px;width:100%;">
      <input type="text" name="q" placeholder="🔍  ابحث بالاسم أو الموقع أو المجمع..."
        style="flex:1;padding:14px 18px;border-radius:12px;border:2px solid rgba(74,144,226,.35);background:rgba(255,255,255,.08);color:#fff;font-family:'Cairo',sans-serif;font-size:14px;outline:none;min-width:0;backdrop-filter:blur(8px);"
        onfocus="this.style.borderColor='rgba(126,200,248,.8)';this.style.background='rgba(255,255,255,.12)'" onblur="this.style.borderColor='rgba(74,144,226,.35)';this.style.background='rgba(255,255,255,.08)'">
      <button type="submit"
        style="padding:14px 24px;border-radius:12px;background:linear-gradient(135deg,#1a3d8f,#2a5cc7);border:none;color:#fff;font-family:'Cairo',sans-serif;font-size:14px;font-weight:800;cursor:pointer;white-space:nowrap;flex-shrink:0;box-shadow:0 8px 24px rgba(26,61,143,.4);">
        بحث
      </button>
    </form>
    <div class="hero-section__cta">
      <a href="/listings" class="btn btn-gold btn-lg">
        <svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        استكشف عقاراتنا
      </a>
      <a href="/search" class="btn btn-ghost btn-lg">
        <svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        بحث متقدم
      </a>
    </div>
    <div class="hero-stats-bar">
      <div class="hero-stat-item">
        <div class="hero-stat-item__num"><%= stats.totalContracts %>+</div>
        <div class="hero-stat-item__lbl">عقد إيجاري</div>
      </div>
      <div class="hero-stat-divider"></div>
      <div class="hero-stat-item">
        <div class="hero-stat-item__num"><%= stats.buildings %></div>
        <div class="hero-stat-item__lbl">مجمعات سكنية</div>
      </div>
      <div class="hero-stat-divider"></div>
      <div class="hero-stat-item">
        <div class="hero-stat-item__num"><%= stats.totalUnits %>+</div>
        <div class="hero-stat-item__lbl">وحدة سكنية</div>
      </div>
      <div class="hero-stat-divider"></div>
      <div class="hero-stat-item">
        <div class="hero-stat-item__num">✓</div>
        <div class="hero-stat-item__lbl">رخصة فال</div>
      </div>
    </div>
  </div>
  <div class="hero-section__scroll">
    <span>اكتشف المزيد</span>
    <div class="scroll-icon"></div>
  </div>
</section>

<!-- ═══════════════════════════════════
     MARQUEE STRIP
════════════════════════════════════ -->
<div class="marquee-strip">
  <div class="marquee-track">
    <span>⬦ مجمع المنارا</span>
    <span>⬦ مجمع جوان إن</span>
