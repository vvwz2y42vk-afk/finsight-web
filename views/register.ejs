<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>إنشاء حساب — Barez</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/client.css">
<style>
.auth-wrap{min-height:100vh;display:flex;align-items:center;justify-content:center;background:var(--light);padding:40px 16px;}
.auth-card{background:#fff;border-radius:20px;padding:40px 36px;width:100%;max-width:480px;box-shadow:0 4px 40px rgba(0,0,0,.07);}
.auth-logo{text-align:center;margin-bottom:28px;}
.auth-logo__icon{width:52px;height:52px;border-radius:14px;background:var(--gold);color:#fff;font-size:20px;font-weight:900;display:flex;align-items:center;justify-content:center;margin:0 auto 10px;}
.auth-logo__name{font-size:1.3rem;font-weight:900;letter-spacing:1px;}
.auth-logo__sub{font-size:11px;color:var(--text3);letter-spacing:3px;}
.auth-title{font-size:1.4rem;font-weight:800;margin-bottom:6px;}
.auth-sub{font-size:13px;color:var(--text3);margin-bottom:28px;}
.auth-err{background:rgba(192,57,43,.08);border:1px solid rgba(192,57,43,.3);border-radius:10px;padding:12px 16px;margin-bottom:20px;font-size:13px;color:#c0392b;font-weight:600;}
.auth-group{margin-bottom:18px;}
.auth-lbl{display:block;font-size:13px;font-weight:600;margin-bottom:6px;color:var(--text2);}
.auth-inp{width:100%;padding:11px 14px;border-radius:10px;border:1px solid var(--border);font-family:inherit;font-size:14px;outline:none;transition:border .2s;background:#fff;}
.auth-inp:focus{border-color:var(--gold);}
.auth-row{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.auth-hint{font-size:11px;color:var(--text3);margin-top:4px;}
.auth-btn{width:100%;padding:13px;background:var(--gold);border:none;border-radius:12px;color:#fff;font-family:inherit;font-size:1rem;font-weight:700;cursor:pointer;transition:opacity .2s;margin-top:8px;}
.auth-btn:hover{opacity:.9;}
.auth-foot{text-align:center;margin-top:20px;font-size:13px;color:var(--text3);}
.auth-foot a{color:var(--gold);font-weight:600;text-decoration:none;}
@media(max-width:520px){.auth-row{grid-template-columns:1fr;}.auth-card{padding:28px 20px;}}
</style>
</head>
<body style="background:var(--light);">

<div class="auth-wrap">
  <div class="auth-card">
    <div class="auth-logo">
      <div class="auth-logo__icon">FS</div>
      <img src="/images/logo-dark.png" alt="Barez" style="height:64px;width:auto;margin:0 auto;">
    </div>

    <h2 class="auth-title">إنشاء حساب جديد</h2>
    <p class="auth-sub">سجّل بياناتك لتتابع حجوزاتك بسهولة</p>

    <% if (error) { %>
    <div class="auth-err">⚠️ <%= error %></div>
    <% } %>

    <form method="POST" action="/account/register">
      <div class="auth-row">
        <div class="auth-group">
          <label class="auth-lbl">الاسم الكامل <span style="color:var(--red)">*</span></label>
          <input type="text" name="name" class="auth-inp" placeholder="اسمك الكامل" required autocomplete="name">
        </div>
        <div class="auth-group">
          <label class="auth-lbl">رقم الجوال <span style="color:var(--red)">*</span></label>
          <input type="tel" name="phone" class="auth-inp" placeholder="05xxxxxxxx" required autocomplete="tel">
        </div>
      </div>

      <div class="auth-group">
        <label class="auth-lbl">البريد الإلكتروني <span style="color:var(--text3);font-weight:400;">(اختياري)</span></label>
        <input type="email" name="email" class="auth-inp" placeholder="example@email.com" autocomplete="email">
      </div>

      <div class="auth-row">
        <div class="auth-group">
          <label class="auth-lbl">رقم الهوية / الإقامة</label>
          <input type="text" name="nationalId" class="auth-inp" placeholder="10XXXXXXXX">
          <p class="auth-hint">اختياري — يُستخدم لتسهيل التعاملات</p>
        </div>
        <div class="auth-group">
          <label class="auth-lbl">الجنسية</label>
          <select name="nationality" class="auth-inp">
            <option value="سعودي">سعودي</option>
            <option value="غير سعودي">غير سعودي</option>
          </select>
        </div>
      </div>

      <div class="auth-row">
        <div class="auth-group">
          <label class="auth-lbl">كلمة المرور <span style="color:var(--red)">*</span></label>
          <input type="password" name="password" id="pwd" class="auth-inp" placeholder="6 أحرف على الأقل" required autocomplete="new-password" minlength="6">
        </div>
        <div class="auth-group">
          <label class="auth-lbl">تأكيد كلمة المرور <span style="color:var(--red)">*</span></label>
          <input type="password" name="confirmPassword" id="pwd2" class="auth-inp" placeholder="أعد كتابة كلمة المرور" required autocomplete="new-password">
        </div>
      </div>

      <button type="submit" class="auth-btn">إنشاء الحساب ←</button>
    </form>

    <div class="auth-foot">
      لديك حساب بالفعل؟ <a href="/account/login">تسجيل الدخول</a>
    </div>
    <div class="auth-foot" style="margin-top:8px;">
      <a href="/" style="color:var(--text3);">← العودة للموقع</a>
    </div>
  </div>
</div>

<script>
document.querySelector('form').addEventListener('submit', function(e) {
  const p1 = document.getElementById('pwd').value;
  const p2 = document.getElementById('pwd2').value;
  if (p1 !== p2) {
    e.preventDefault();
    alert('كلمتا المرور غير متطابقتين');
  }
});
</script>
</body>
</html>
