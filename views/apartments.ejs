        <div class="footer-col__title">روابط سريعة</div>
        <a href="/">الرئيسية</a>
        <a href="/about">من نحن</a>
        <a href="/listings">عقاراتنا</a>
        <a href="/inquiry">تواصل معنا</a>
      </div>
      <div class="footer-col">
        <div class="footer-col__title">المجمعات</div>
        <a href="/apartments?building=%D8%A7%D9%84%D9%85%D9%86%D8%A7%D8%B1%D8%A7">مجمع المنارا</a>
        <a href="/apartments?building=%D8%AC%D9%88%D8%A7%D9%86+%D8%A7%D9%86">مجمع جوان إن</a>
        <a href="/apartments?building=%D8%A7%D9%84%D9%85%D8%A7%D8%B3%D8%A9">مجمع الماسة</a>
        <a href="/apartments?building=%D8%A7%D9%84%D9%88%D8%A7%D8%AD%D8%A9">مجمع الواحة</a>
      </div>
      <div class="footer-col">
        <div class="footer-col__title">تواصل معنا</div>
        <a href="tel:+966590561057">0590561057</a>
        <a href="mailto:realstate@barezz.com">realstate@barezz.com</a>
        <a href="/inquiry">أرسل استفساراً</a>
      </div>
    </div>
    <div class="footer-bottom">
      <p>© 2026 Barez — جميع الحقوق محفوظة &nbsp;·&nbsp; <a href="/terms" style="color:inherit;opacity:.6;">الشروط والأحكام</a></p>
    </div>
  </div>
</footer>

</div><!-- /csb-content -->
<script>
function toggleSidebar(){document.getElementById('clientSidebar').classList.toggle('open');document.getElementById('csbOverlay').classList.toggle('open');document.getElementById('csbHam').classList.toggle('active');}
function closeSidebar(){document.getElementById('clientSidebar').classList.remove('open');document.getElementById('csbOverlay').classList.remove('open');document.getElementById('csbHam').classList.remove('active');}

/* ── Status filter ── */
document.querySelectorAll('.apm-sf').forEach(function(btn) {
  btn.addEventListener('click', function() {
    document.querySelectorAll('.apm-sf').forEach(function(b){ b.classList.remove('active'); });
    btn.classList.add('active');

    var filter = btn.dataset.filter;
    document.querySelectorAll('.apm-unit').forEach(function(unit) {
      if (filter === 'all') {
        unit.style.opacity = '1';
        unit.style.transform = '';
      } else if (unit.classList.contains(filter)) {
        unit.style.opacity = '1';
        unit.style.transform = '';
      } else {
        unit.style.opacity = '0.18';
        unit.style.transform = 'scale(0.92)';
      }
    });

    /* Hide buildings that have zero matching units */
    document.querySelectorAll('.apm-bld').forEach(function(bld) {
      if (filter === 'all') { bld.style.display = ''; return; }
      var hasMatch = bld.querySelector('.apm-unit.' + filter);
      bld.style.display = hasMatch ? '' : 'none';
    });
  });
});

/* ── Stagger entrance animation ── */
var units = document.querySelectorAll('.apm-unit');
units.forEach(function(u, i) {
  u.style.opacity = '0';
  u.style.transform = 'scale(0.85)';
  setTimeout(function() {
    u.style.transition = 'opacity .25s, transform .25s';
    u.style.opacity = '1';
    u.style.transform = '';
  }, 30 + i * 8);
});
</script>
</body>
</html>
