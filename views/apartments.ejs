<div class="csb-overlay" id="csbOverlay" onclick="closeSidebar()"></div>
<button class="csb-ham" id="csbHam" onclick="toggleSidebar()"><span></span><span></span><span></span></button>

<div class="csb-content">

<!-- HERO -->
<section class="about-hero" style="min-height:220px;">
  <div class="about-hero__overlay"></div>
  <div class="about-hero__content">
    <div class="sec-tag">مجمعاتنا الأربعة · <%= stats.total %> وحدة</div>
    <h1 class="about-hero__title">خريطة <span class="c-gold">الشقق</span></h1>
    <p class="about-hero__sub">حالة كل وحدة محدّثة لحظياً · الوحدات الخضراء متاحة للحجز الآن</p>
  </div>
</section>

<section class="apm-page">
<div class="page-container">

  <!-- KPIs -->
  <div class="apm-kpis">
    <div class="apm-kpi k-free">
      <div class="apm-kpi__num"><%= stats.free %></div>
      <div class="apm-kpi__lbl">متاحة للحجز</div>
    </div>
    <div class="apm-kpi k-occ">
      <div class="apm-kpi__num"><%= stats.occupied %></div>
      <div class="apm-kpi__lbl">مؤجرة</div>
    </div>
    <% if (stats.soon > 0) { %>
    <div class="apm-kpi k-soon">
      <div class="apm-kpi__num"><%= stats.soon %></div>
      <div class="apm-kpi__lbl">تتوفر قريباً</div>
    </div>
    <% } %>
    <% if (stats.incoming > 0) { %>
    <div class="apm-kpi k-inc">
      <div class="apm-kpi__num"><%= stats.incoming %></div>
      <div class="apm-kpi__lbl">وصول قريب</div>
    </div>
    <% } %>
    <div class="apm-kpi k-total">
      <div class="apm-kpi__num"><%= stats.total %></div>
      <div class="apm-kpi__lbl">إجمالي الوحدات</div>
    </div>
  </div>

  <!-- Legend -->
  <div class="apm-legend">
    <span style="font-size:12px;font-weight:700;color:#111;margin-left:4px;">الحالات:</span>
    <div class="apm-legend__item"><div class="apm-legend__dot ld-free"></div>متاحة للحجز</div>
    <div class="apm-legend__item"><div class="apm-legend__dot ld-occ"></div>مؤجرة</div>
    <div class="apm-legend__item"><div class="apm-legend__dot ld-soon"></div>تتوفر خلال 5 أيام</div>
    <div class="apm-legend__item"><div class="apm-legend__dot ld-inc"></div>محجوزة · وصول قريب</div>
    <span style="font-size:11px;color:#9ca3af;margin-right:auto;">انقر على الوحدة الخضراء للحجز</span>
  </div>

  <!-- Status Filter -->
  <div class="apm-sfilt">
    <button class="apm-sf active" data-filter="all">الكل</button>
    <button class="apm-sf" data-filter="available">متاحة فقط</button>
    <button class="apm-sf" data-filter="soon">تتوفر قريباً</button>
    <button class="apm-sf" data-filter="occupied">مؤجرة</button>
  </div>

  <!-- Building Tabs -->
  <div class="apm-btabs">
    <a href="/apartments" class="apm-btab <%= selectedBuilding === '' ? 'active' : '' %>">كل المجمعات</a>
    <% buildingNames.forEach(b => { %>
    <a href="/apartments?building=<%= encodeURIComponent(b) %>" class="apm-btab <%= selectedBuilding === b ? 'active' : '' %>"><%= b %></a>
    <% }) %>
  </div>

  <%
    const bldIcon = { 'المنارا':'🏢', 'جوان ان':'🏨', 'الماسة':'💎', 'الواحة':'🌴' };
    const bldNames = Object.keys(buildings);
  %>

  <% if (bldNames.length === 0) { %>
    <div class="apm-empty">
      <div style="font-size:3rem;margin-bottom:12px;">🏢</div>
      <p>تعذّر تحميل بيانات الشقق، حاول مجدداً</p>
    </div>
  <% } %>

  <% bldNames.forEach(function(bName) { %>
  <% const bld = buildings[bName]; %>
  <div class="apm-bld" data-building="<%= bName %>">
    <!-- Building Header -->
    <div class="apm-bld-hd">
      <span class="apm-bld-hd__icon"><%= bldIcon[bName] || '🏢' %></span>
      <span class="apm-bld-hd__name">مجمع <%= bName %></span>
      <div class="apm-bld-hd__stats">
        <span class="apm-bld-badge ab-free"><%= bld.free %> متاحة</span>
        <span class="apm-bld-badge ab-occ"><%= bld.occupied %> مؤجرة</span>
        <span style="color:rgba(255,255,255,.4);font-size:11px;"><%= bld.total %> وحدة</span>
      </div>
    </div>

    <!-- Floors -->
    <div class="apm-floors">
      <% bld.floors.forEach(function(floor) { %>
      <div class="apm-floor">
        <div class="apm-floor-lbl"><%= floor.label %></div>
        <div class="apm-units">
          <% floor.apts.forEach(function(unit) { %>
          <%
            const daysStr = unit.daysLeft !== null
              ? (unit.daysLeft <= 0 ? 'اليوم' : 'خلال ' + unit.daysLeft + ' يوم')
              : '';
            const label = {
              available: 'متاحة',
              occupied:  'مؤجرة',
              soon:      'قريباً',
              incoming:  'محجوزة',
            }[unit.status] || 'متاحة';
            const href = unit.status === 'available'
              ? `/inquiry?building=${encodeURIComponent(bName)}&apartment=${unit.apt}`
              : null;
          %>
          <% if (href) { %>
          <a href="<%= href %>" class="apm-unit <%= unit.status %>" title="الوحدة <%= unit.apt %> — <%= label %> · انقر للحجز">
          <% } else { %>
          <div class="apm-unit <%= unit.status %>"<%= unit.status === 'soon' && daysStr ? ` data-days="${daysStr}"` : '' %> title="الوحدة <%= unit.apt %> — <%= label %><%= daysStr ? ' · ' + daysStr : '' %>">
          <% } %>
            <span class="apm-unit__num"><%= unit.apt %></span>
            <span class="apm-unit__lbl"><%= label %></span>
          <% if (href) { %></a><% } else { %></div><% } %>
          <% }) %>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
  <% }) %>

  <!-- CTA for available -->
  <% if (stats.free > 0) { %>
  <div style="text-align:center;margin-top:48px;">
    <p style="font-size:14px;color:#6b7280;margin-bottom:16px;">هناك <strong style="color:#16a34a;"><%= stats.free %> وحدة</strong> متاحة الآن — انقر على أي وحدة خضراء أو تواصل معنا مباشرة</p>
    <a href="/inquiry" class="btn btn-gold btn-lg">تواصل معنا</a>
  </div>
  <% } else { %>
  <div style="text-align:center;margin-top:48px;padding:40px 20px;background:#fff;border-radius:16px;border:1px solid #e5e7eb;">
    <div style="font-size:2.5rem;margin-bottom:12px;">📋</div>
    <h3 style="font-weight:700;margin-bottom:8px;">جميع الوحدات مشغولة حالياً</h3>
    <p style="color:#6b7280;margin-bottom:20px;">أرسل طلبك وسنتواصل معك بمجرد توفر وحدة مناسبة</p>
    <a href="/inquiry" class="btn btn-gold btn-lg">أرسل طلب انتظار</a>
  </div>
  <% } %>

</div>
</section>

<!-- FOOTER -->
<footer class="site-footer-new">
  <div class="page-container">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="footer-brand__logo">
