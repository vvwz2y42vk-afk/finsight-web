<style>
/* ── Apartment Map Styles ── */
.apm-page { padding:40px 0 72px; background:#f5f7fa; }

/* KPI Strip */
.apm-kpis { display:flex; gap:12px; flex-wrap:wrap; margin-bottom:32px; }
.apm-kpi  { flex:1; min-width:110px; background:#fff; border:1px solid #e5e7eb; border-radius:14px; padding:16px 18px; text-align:center; }
.apm-kpi__num  { font-size:1.9rem; font-weight:800; line-height:1; margin-bottom:4px; }
.apm-kpi__lbl  { font-size:11px; font-weight:600; color:#6b7280; }
.apm-kpi.k-free  .apm-kpi__num { color:#16a34a; }
.apm-kpi.k-occ   .apm-kpi__num { color:#dc2626; }
.apm-kpi.k-soon  .apm-kpi__num { color:#d97706; }
.apm-kpi.k-inc   .apm-kpi__num { color:#2563eb; }
.apm-kpi.k-total .apm-kpi__num { color:#111; }

/* Legend */
.apm-legend { display:flex; gap:20px; flex-wrap:wrap; align-items:center; margin-bottom:24px; padding:12px 18px; background:#fff; border:1px solid #e5e7eb; border-radius:12px; }
.apm-legend__item { display:flex; align-items:center; gap:7px; font-size:12px; font-weight:600; color:#374151; }
.apm-legend__dot  { width:13px; height:13px; border-radius:4px; flex-shrink:0; }
.ld-free { background:#16a34a; }
.ld-occ  { background:#dc2626; }
.ld-soon { background:#f59e0b; }
.ld-inc  { background:#3b82f6; }

/* Status filter */
.apm-sfilt { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:24px; }
.apm-sf { padding:7px 18px; border-radius:20px; border:1.5px solid #e5e7eb; background:#fff; font-size:12px; font-weight:700; cursor:pointer; font-family:inherit; color:#374151; transition:background .18s,color .18s,border-color .18s; }
.apm-sf.active, .apm-sf:hover { background:#1a3d8f; color:#fff; border-color:#1a3d8f; }

/* Building tabs */
.apm-btabs { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:28px; }
.apm-btab  { padding:9px 22px; border-radius:24px; border:1.5px solid #e5e7eb; background:#fff; font-size:13px; font-weight:600; text-decoration:none; color:#374151; transition:background .18s,color .18s,border-color .18s; }
.apm-btab.active, .apm-btab:hover { background:#1a3d8f; color:#fff; border-color:#1a3d8f; }

/* Building section */
.apm-bld  { margin-bottom:36px; background:#fff; border:1px solid #e5e7eb; border-radius:16px; overflow:hidden; }
.apm-bld-hd { display:flex; align-items:center; gap:14px; padding:16px 22px; background:linear-gradient(135deg,#0d1b2d,#1a3a5c); }
.apm-bld-hd__icon { font-size:1.4rem; }
.apm-bld-hd__name { font-size:1rem; font-weight:700; color:#fff; }
.apm-bld-hd__stats { margin-right:auto; display:flex; gap:8px; align-items:center; }
.apm-bld-badge { border-radius:16px; padding:3px 12px; font-size:11px; font-weight:700; }
.ab-free { background:rgba(22,163,74,.22); color:#86efac; }
.ab-occ  { background:rgba(220,38,38,.22); color:#fca5a5; }

/* Floors */
.apm-floors { padding:16px 20px 18px; }
.apm-floor  { display:flex; align-items:flex-start; gap:12px; margin-bottom:12px; }
.apm-floor:last-child { margin-bottom:0; }
.apm-floor-lbl { width:76px; flex-shrink:0; text-align:center; font-size:11px; font-weight:700; color:#6b7280; background:#f3f4f6; border-radius:8px; padding:6px 4px; margin-top:2px; }
.apm-units { display:flex; flex-wrap:wrap; gap:7px; }

/* Unit card */
.apm-unit {
  width:68px; height:68px; border-radius:10px; border:2px solid;
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  gap:3px; text-decoration:none; transition:transform .18s; position:relative;
  cursor:default;
}
.apm-unit:not(.occupied):not(.incoming) { cursor:pointer; }
.apm-unit:hover { transform:translateY(-3px); }
.apm-unit__num  { font-size:15px; font-weight:800; line-height:1; }
.apm-unit__lbl  { font-size:9px; font-weight:700; padding:2px 6px; border-radius:8px; white-space:nowrap; }

/* Status colours */
.apm-unit.available { background:#f0fdf4; border-color:#86efac; color:#16a34a; }
.apm-unit.available .apm-unit__lbl { background:#dcfce7; color:#16a34a; }
.apm-unit.occupied  { background:#fef2f2; border-color:#fca5a5; color:#dc2626; }
.apm-unit.occupied .apm-unit__lbl  { background:#fee2e2; color:#dc2626; }
.apm-unit.soon      { background:#fffbeb; border-color:#fcd34d; color:#d97706; }
.apm-unit.soon .apm-unit__lbl      { background:#fef3c7; color:#d97706; }
.apm-unit.incoming  { background:#eff6ff; border-color:#93c5fd; color:#2563eb; }
.apm-unit.incoming .apm-unit__lbl  { background:#dbeafe; color:#2563eb; }

/* Tooltip on hover for "soon" units */
.apm-unit.soon::after {
  content: attr(data-days);
  position:absolute; bottom:calc(100% + 6px); left:50%; transform:translateX(-50%);
  background:#1a1a1a; color:#fff; border-radius:6px; padding:4px 8px; font-size:10px;
  font-weight:600; white-space:nowrap; pointer-events:none; opacity:0; transition:opacity .15s;
  font-family:'Cairo',sans-serif;
}
.apm-unit.soon:hover::after { opacity:1; }

/* Empty state */
.apm-empty { text-align:center; padding:60px 20px; color:#6b7280; }

/* Mobile */
@media(max-width:640px){
  .apm-kpi { min-width:80px; padding:12px 10px; }
  .apm-kpi__num { font-size:1.5rem; }
  .apm-floor { flex-direction:column; gap:6px; }
  .apm-floor-lbl { width:auto; text-align:right; padding:4px 10px; }
  .apm-unit { width:60px; height:60px; }
  .apm-unit__num { font-size:13px; }
}
</style>
</head>
