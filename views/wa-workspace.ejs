<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>Barez Workspace — WhatsApp</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════════════════
   BAREZ OMNICHANNEL WORKSPACE — DESIGN SYSTEM
   ═══════════════════════════════════════════════════════ */
:root {
  --bg:       #0B141A;
  --s1:       #111B21;
  --s2:       #1A2533;
  --s3:       #202C33;
  --s4:       #2A3942;
  --border:   rgba(255,255,255,.06);
  --border2:  rgba(255,255,255,.04);
  --t1:       #E9EDEF;
  --t2:       #AEBAC1;
  --t3:       #8696A0;
  --t4:       #4A5568;
  --green:    #00A884;
  --green-d:  #017561;
  --green-l:  #d9fdd3;
  --red:      #EF4444;
  --amber:    #F59E0B;
  --blue:     #3B82F6;
  --bubble-in: #202C33;
  --bubble-out:#005C4B;
  --r:         10px;
  --ease:      cubic-bezier(.4,0,.2,1);
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-font-smoothing:antialiased}
html,body{height:100%;overflow:hidden}
body{font-family:'Cairo',sans-serif;background:var(--bg);color:var(--t1);direction:rtl;display:flex;flex-direction:column}

/* ── TOP BAR ── */
.topbar{
  height:52px;background:var(--s1);border-bottom:1px solid var(--border);
  display:flex;align-items:center;gap:14px;padding:0 20px;flex-shrink:0;
  z-index:10;
}
.topbar-brand{display:flex;align-items:center;gap:10px;}
.topbar-brand .ico{
  width:34px;height:34px;border-radius:10px;
  background:linear-gradient(135deg,var(--green),var(--green-d));
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
}
.topbar-brand .ico svg{width:18px;height:18px;fill:#fff}
.topbar-brand span{font-size:15px;font-weight:700;color:var(--t1)}
.topbar-brand small{font-size:11px;color:var(--t3);margin-right:2px}
.topbar-spacer{flex:1}
.agent-chip{
  display:flex;align-items:center;gap:8px;padding:6px 12px;
  background:rgba(255,255,255,.04);border-radius:20px;border:1px solid var(--border);
}
.agent-dot{width:8px;height:8px;border-radius:50%;background:var(--green);box-shadow:0 0 6px var(--green)}
.agent-chip span{font-size:12px;color:var(--t2);font-weight:600}
.topbar-btn{
  width:34px;height:34px;border-radius:8px;border:none;cursor:pointer;
  background:rgba(255,255,255,.05);color:var(--t3);
  display:flex;align-items:center;justify-content:center;transition:all .15s;text-decoration:none;
}
.topbar-btn:hover{background:rgba(255,255,255,.09);color:var(--t1)}

/* ── WORKSPACE LAYOUT ── */
.workspace{display:flex;flex:1;overflow:hidden}

/* ══ LEFT PANEL ══ */
.left-panel{
  width:340px;min-width:280px;display:flex;flex-direction:column;
  background:var(--s1);border-left:1px solid var(--border);flex-shrink:0;
}
.lp-head{padding:14px 16px 10px;border-bottom:1px solid var(--border2)}
.lp-head h3{font-size:14px;font-weight:700;color:var(--t1);margin-bottom:10px}

/* Tabs */
.tabs{display:flex;gap:4px;background:rgba(255,255,255,.04);border-radius:8px;padding:3px}
.tab{
  flex:1;padding:6px 4px;border-radius:6px;border:none;cursor:pointer;
  font-family:'Cairo',sans-serif;font-size:12px;font-weight:600;color:var(--t3);
  background:transparent;transition:all .15s;position:relative;
}
.tab.active{background:var(--s3);color:var(--t1)}
.tab .badge{
  position:absolute;top:-4px;left:-4px;background:var(--green);color:#fff;
  border-radius:10px;font-size:10px;font-weight:700;padding:1px 5px;min-width:16px;
}

/* Search */
.search-wrap{padding:10px 14px;border-bottom:1px solid var(--border2)}
.search-wrap input{
  width:100%;background:rgba(255,255,255,.05);border:1.5px solid transparent;
  border-radius:8px;padding:8px 12px;color:var(--t1);font-family:'Cairo',sans-serif;
  font-size:13px;outline:none;transition:border .2s;
}
.search-wrap input:focus{border-color:var(--green)}
.search-wrap input::placeholder{color:var(--t4)}

/* Conversation list */
.conv-list{flex:1;overflow-y:auto;scrollbar-width:thin;scrollbar-color:rgba(255,255,255,.08) transparent}
.conv-list::-webkit-scrollbar{width:4px}
.conv-list::-webkit-scrollbar-thumb{background:rgba(255,255,255,.08);border-radius:4px}

.conv-item{
  display:flex;align-items:center;gap:11px;padding:11px 16px;cursor:pointer;
  border-bottom:1px solid var(--border2);transition:background .12s;position:relative;
}
.conv-item:hover{background:rgba(255,255,255,.03)}
.conv-item.active{background:rgba(0,168,132,.08);border-right:3px solid var(--green)}
.conv-item.locked::after{
  content:'🔒';position:absolute;left:14px;top:10px;font-size:11px;opacity:.6;
}

.conv-avatar{
  width:44px;height:44px;border-radius:50%;flex-shrink:0;
  background:linear-gradient(135deg,#2D3748,#374151);
  display:flex;align-items:center;justify-content:center;
  font-size:16px;font-weight:700;color:rgba(255,255,255,.7);position:relative;
}
.conv-avatar .unread-dot{
  position:absolute;bottom:1px;left:1px;width:12px;height:12px;
  background:var(--green);border-radius:50%;border:2px solid var(--s1);
}

.conv-body{flex:1;min-width:0}
.conv-name{font-size:13.5px;font-weight:600;color:var(--t1);margin-bottom:2px}
.conv-preview{font-size:12px;color:var(--t3);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.conv-preview.typing{color:var(--green);font-style:italic}

.conv-side{display:flex;flex-direction:column;align-items:flex-end;gap:5px;flex-shrink:0}
.conv-time{font-size:11px;color:var(--t4)}
.conv-unread{
  background:var(--green);color:#fff;border-radius:10px;
  padding:1px 6px;font-size:11px;font-weight:700;min-width:20px;text-align:center;
}
.sla-warn{
  font-size:10px;color:var(--amber);background:rgba(245,158,11,.1);
  padding:2px 6px;border-radius:6px;font-weight:600;white-space:nowrap;
}
.sla-breach{color:var(--red)!important;background:rgba(239,68,68,.1)!important}

.conv-empty{padding:40px 20px;text-align:center;color:var(--t4);font-size:13px}

/* ══ MIDDLE PANEL ══ */
.mid-panel{flex:1;display:flex;flex-direction:column;min-width:0;background:var(--bg)}

/* Chat Header */
.chat-head{
  padding:10px 16px;background:var(--s3);border-bottom:1px solid var(--border);
  display:flex;align-items:center;gap:12px;flex-shrink:0;
}
.chat-head-avatar{
  width:40px;height:40px;border-radius:50%;flex-shrink:0;
  background:linear-gradient(135deg,#2D3748,#374151);
  display:flex;align-items:center;justify-content:center;
  font-size:15px;font-weight:700;color:rgba(255,255,255,.7);
}
.chat-head-info{flex:1}
.chat-head-info h3{font-size:14px;font-weight:700;color:var(--t1)}
.chat-head-info p{font-size:12px;color:var(--t3);margin-top:1px}
.lock-badge{
  display:flex;align-items:center;gap:5px;padding:4px 10px;border-radius:20px;
  background:rgba(0,168,132,.12);border:1px solid rgba(0,168,132,.2);
  font-size:11px;color:var(--green);font-weight:600;
}
.lock-badge.locked-other{background:rgba(239,68,68,.1);border-color:rgba(239,68,68,.2);color:var(--red)}
.chat-head-actions{display:flex;gap:6px}
.icon-btn{
  width:34px;height:34px;border-radius:8px;border:none;cursor:pointer;
  background:rgba(255,255,255,.05);color:var(--t3);
  display:flex;align-items:center;justify-content:center;transition:all .15s;
}
.icon-btn:hover{background:rgba(255,255,255,.09);color:var(--t1)}

/* No chat */
.no-chat{
  flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:14px;
}
.no-chat svg{opacity:.08;width:80px;height:80px}
.no-chat p{color:var(--t4);font-size:14px}

/* Messages */
.msgs-area{
  flex:1;overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:3px;
  background-image:url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.015'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  scrollbar-width:thin;scrollbar-color:rgba(255,255,255,.06) transparent;
}
.msgs-area::-webkit-scrollbar{width:5px}
.msgs-area::-webkit-scrollbar-thumb{background:rgba(255,255,255,.06);border-radius:4px}

.load-more{text-align:center;padding:8px 0 16px}
.load-more button{
  background:rgba(255,255,255,.05);border:1px solid var(--border);color:var(--t3);
  padding:6px 16px;border-radius:20px;font-family:'Cairo',sans-serif;font-size:12px;cursor:pointer;
  transition:all .15s;
}
.load-more button:hover{background:rgba(255,255,255,.09)}

.date-sep{text-align:center;margin:14px 0 8px}
.date-sep span{
  display:inline-block;background:rgba(11,20,26,.9);backdrop-filter:blur(8px);
  border:1px solid var(--border);color:var(--t3);font-size:11px;padding:4px 14px;border-radius:8px;
}

.bubble-row{display:flex;margin-bottom:2px;gap:8px}
.bubble-row.in{justify-content:flex-end}
.bubble-row.out{justify-content:flex-start}

.bubble{
  max-width:62%;padding:8px 12px 18px;border-radius:var(--r);position:relative;
  font-size:14px;line-height:1.5;word-break:break-word;
}
.bubble-row.in  .bubble{background:var(--bubble-in);border-radius:var(--r) 0 var(--r) var(--r)}
.bubble-row.out .bubble{background:var(--bubble-out);border-radius:0 var(--r) var(--r) var(--r)}
.bubble-row.optimistic .bubble{opacity:.7}
.bubble-row.failed .bubble{border:1px solid rgba(239,68,68,.3)}

.bubble-media{max-width:260px;border-radius:6px;margin-bottom:4px;cursor:pointer;display:block}
.bubble-audio{width:220px;margin-bottom:4px}

.bubble-footer{
  position:absolute;bottom:4px;left:10px;
  display:flex;align-items:center;gap:4px;
}
.bubble-row.in .bubble-footer{left:auto;right:10px}
.bubble-time{font-size:10px;color:rgba(255,255,255,.4)}
.bubble-status{font-size:10px;color:rgba(255,255,255,.4)}
.bubble-status.sent{color:var(--t4)}
.bubble-status.delivered{color:var(--t3)}
.bubble-status.read{color:#53BDEB}
.bubble-status.failed{color:var(--red)}
.retry-btn{
  font-size:10px;color:var(--amber);cursor:pointer;text-decoration:underline;
  background:none;border:none;font-family:'Cairo',sans-serif;padding:0;
}

.typing-indicator{
  display:flex;gap:4px;align-items:center;padding:10px 14px;
  background:var(--bubble-in);border-radius:var(--r) 0 var(--r) var(--r);
  max-width:60px;
}
.typing-dot{
  width:7px;height:7px;border-radius:50%;background:var(--t3);
  animation:td .9s infinite ease-in-out both;
}
.typing-dot:nth-child(2){animation-delay:.2s}
.typing-dot:nth-child(3){animation-delay:.4s}
@keyframes td{0%,80%,100%{transform:scale(0.8);opacity:.5}40%{transform:scale(1);opacity:1}}

.agent-label{
  font-size:10px;color:var(--t4);text-align:left;padding:0 4px;
  margin-bottom:2px;
}
.bubble-row.out + .agent-label{display:block}

/* Input area */
.input-zone{
  padding:10px 14px;background:var(--s3);border-top:1px solid var(--border);flex-shrink:0;
}
.template-bar{
  display:flex;gap:6px;margin-bottom:8px;flex-wrap:wrap;
}
.tpl-btn{
  padding:4px 10px;border-radius:16px;border:1px solid rgba(0,168,132,.3);
  background:rgba(0,168,132,.08);color:var(--green);font-family:'Cairo',sans-serif;
  font-size:11px;font-weight:600;cursor:pointer;transition:all .15s;
}
.tpl-btn:hover{background:rgba(0,168,132,.15)}

.window-warn{
  display:flex;align-items:center;gap:6px;padding:6px 10px;margin-bottom:8px;
  background:rgba(245,158,11,.08);border:1px solid rgba(245,158,11,.2);border-radius:8px;
}
.window-warn span{font-size:11px;color:var(--amber)}

.input-row{display:flex;align-items:flex-end;gap:8px}
.input-box{
  flex:1;background:rgba(255,255,255,.05);border-radius:12px;
  padding:10px 14px;display:flex;align-items:flex-end;gap:8px;
  border:1.5px solid transparent;transition:border .2s;
}
.input-box:focus-within{border-color:rgba(0,168,132,.3)}
textarea.msg-input{
  flex:1;background:transparent;border:none;outline:none;resize:none;
  color:var(--t1);font-family:'Cairo',sans-serif;font-size:14px;
  max-height:120px;line-height:1.5;scrollbar-width:none;
}
textarea.msg-input::placeholder{color:var(--t4)}
textarea.msg-input::-webkit-scrollbar{display:none}

.send-btn{
  width:46px;height:46px;border-radius:50%;border:none;cursor:pointer;flex-shrink:0;
  background:var(--green);color:#fff;display:flex;align-items:center;justify-content:center;
  transition:all .2s var(--ease);
}
.send-btn:hover{background:#00CF9C;transform:scale(1.05)}
.send-btn:active{transform:scale(.95)}
.send-btn:disabled{background:rgba(0,168,132,.3);cursor:not-allowed;transform:none}
.send-btn svg{width:20px;height:20px;fill:#fff}

/* ══ RIGHT PANEL ══ */
.right-panel{
  width:320px;min-width:260px;display:flex;flex-direction:column;
  background:var(--s1);border-right:1px solid var(--border);flex-shrink:0;overflow:hidden;
}
.rp-head{
  padding:14px 16px;border-bottom:1px solid var(--border);
  display:flex;align-items:center;gap:8px;
}
.rp-head h3{font-size:13px;font-weight:700;color:var(--t1);flex:1}
.rp-head span{font-size:11px;color:var(--t4)}

.rp-body{flex:1;overflow-y:auto;padding:14px;display:flex;flex-direction:column;gap:12px;scrollbar-width:thin;scrollbar-color:rgba(255,255,255,.06) transparent}
.rp-body::-webkit-scrollbar{width:4px}
.rp-body::-webkit-scrollbar-thumb{background:rgba(255,255,255,.06);border-radius:4px}

.crm-empty{text-align:center;color:var(--t4);font-size:13px;padding:40px 0}

.crm-card{background:var(--s3);border:1px solid var(--border);border-radius:12px;padding:14px}
.crm-card-head{display:flex;align-items:center;gap:10px;margin-bottom:12px}
.crm-avatar{
  width:42px;height:42px;border-radius:50%;
  background:linear-gradient(135deg,#1D4ED8,#2563EB);
  display:flex;align-items:center;justify-content:center;
  font-size:16px;font-weight:700;color:#fff;flex-shrink:0;
}
.crm-name{font-size:14px;font-weight:700;color:var(--t1)}
.crm-phone{font-size:11px;color:var(--t3);margin-top:2px;direction:ltr;text-align:right}

.crm-section{margin-bottom:2px}
.crm-section-title{font-size:10px;font-weight:700;color:var(--t4);letter-spacing:.08em;text-transform:uppercase;margin-bottom:8px}

.stat-row{display:flex;justify-content:space-between;align-items:center;padding:4px 0;border-bottom:1px solid var(--border2)}
.stat-row:last-child{border-bottom:none}
.stat-label{font-size:12px;color:var(--t3)}
.stat-val{font-size:12px;font-weight:700;color:var(--t1)}
.stat-val.green{color:var(--green)}
.stat-val.amber{color:var(--amber)}

.booking-card{
  background:rgba(255,255,255,.03);border:1px solid var(--border2);border-radius:8px;
  padding:10px 12px;margin-bottom:6px;
}
.booking-card .bk-apt{font-size:13px;font-weight:600;color:var(--t1)}
.booking-card .bk-dates{font-size:11px;color:var(--t3);margin-top:3px;direction:ltr;text-align:right}
.booking-card .bk-status{
  display:inline-block;padding:2px 8px;border-radius:6px;font-size:10px;font-weight:700;margin-top:4px;
}
.bk-status.active{background:rgba(0,168,132,.12);color:var(--green)}
.bk-status.confirmed{background:rgba(59,130,246,.12);color:var(--blue)}
.bk-status.completed{background:rgba(255,255,255,.05);color:var(--t4)}

.notes-area{
  width:100%;background:rgba(255,255,255,.04);border:1.5px solid var(--border);
  border-radius:8px;padding:9px 11px;color:var(--t1);font-family:'Cairo',sans-serif;
  font-size:12px;resize:none;outline:none;line-height:1.6;transition:border .2s;
}
.notes-area:focus{border-color:rgba(0,168,132,.3)}
.notes-area::placeholder{color:var(--t4)}
.notes-save{
  margin-top:6px;padding:6px 14px;border-radius:8px;border:none;cursor:pointer;
  background:rgba(0,168,132,.12);color:var(--green);font-family:'Cairo',sans-serif;
  font-size:12px;font-weight:600;transition:all .15s;
}
.notes-save:hover{background:rgba(0,168,132,.2)}

/* Toast */
.toast{
  position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(20px);
  background:var(--s3);border:1px solid var(--border);color:var(--t1);
  padding:10px 20px;border-radius:10px;font-size:13px;z-index:999;
  opacity:0;transition:all .25s;pointer-events:none;
}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
.toast.error{border-color:rgba(239,68,68,.3);color:#FCA5A5}

/* Scrollbar global */
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-thumb{background:rgba(255,255,255,.08);border-radius:4px}
</style>
</head>
<body>

<!-- TOP BAR -->
<div class="topbar">
  <div class="topbar-brand">
    <div class="ico">
      <svg viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
    </div>
    <span>Barez Workspace</span>
    <small>WhatsApp Omnichannel</small>
  </div>
  <div class="topbar-spacer"></div>
  <div class="agent-chip">
    <div class="agent-dot"></div>
    <span><%= agent.name %></span>
  </div>
  <a href="/ws/logout" class="topbar-btn" title="خروج">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9"/></svg>
  </a>
</div>

<!-- WORKSPACE -->
<div class="workspace">

  <!-- ══ LEFT PANEL ══ -->
  <div class="left-panel">
    <div class="lp-head">
      <h3>المحادثات</h3>
      <div class="tabs">
        <button class="tab active" data-tab="all" onclick="setTab(this,'all')">الكل <span class="badge" id="badge-all" style="display:none"></span></button>
        <button class="tab" data-tab="unread" onclick="setTab(this,'unread')">غير مقروء <span class="badge" id="badge-unread" style="display:none"></span></button>
      </div>
    </div>
    <div class="search-wrap">
      <input type="text" id="searchInput" placeholder="بحث برقم أو اسم..." oninput="filterConvs(this.value)">
    </div>
    <div class="conv-list" id="convList">
      <div style="padding:30px;text-align:center;color:var(--t4);font-size:13px;">جاري التحميل...</div>
    </div>
  </div>

  <!-- ══ MIDDLE PANEL ══ -->
  <div class="mid-panel">
    <!-- No chat placeholder -->
    <div class="no-chat" id="noChatView">
      <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
      <p>اختر محادثة للبدء</p>
    </div>

    <!-- Active chat -->
    <div id="chatView" style="display:none;flex-direction:column;flex:1;min-height:0;">
      <!-- Header -->
      <div class="chat-head">
        <div class="chat-head-avatar" id="chatAvatar">—</div>
        <div class="chat-head-info">
          <h3 id="chatName">—</h3>
          <p id="chatSub">—</p>
        </div>
        <span id="lockBadge" class="lock-badge" style="display:none"></span>
        <div class="chat-head-actions">
          <a id="chatWaLink" href="#" target="_blank" class="icon-btn" title="فتح واتساب">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
          </a>
        </div>
      </div>

      <!-- Messages -->
      <div class="msgs-area" id="msgsArea" onscroll="handleScroll(this)">
        <div class="load-more" id="loadMoreBtn" style="display:none">
          <button onclick="loadOlderMessages()">تحميل رسائل أقدم</button>
        </div>
      </div>

      <!-- Input zone -->
      <div class="input-zone" id="inputZone">
        <div class="template-bar" id="templateBar">
          <button class="tpl-btn" onclick="sendTemplate('barez_booking_confirmed')">✅ تأكيد حجز</button>
          <button class="tpl-btn" onclick="sendTemplate('barez_check_in')">🏠 تسجيل دخول</button>
          <button class="tpl-btn" onclick="sendTemplate('barez_check_out')">🚪 تسجيل خروج</button>
          <button class="tpl-btn" onclick="sendTemplate('barez_reminder_v1')">⏰ تذكير</button>
        </div>
        <div id="windowWarn" class="window-warn" style="display:none">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#F59E0B" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <span>انتهت نافذة 24 ساعة — استخدم قالب للرد</span>
        </div>
        <div class="input-row">
          <div class="input-box">
            <textarea class="msg-input" id="msgInput" rows="1" placeholder="اكتب رسالة..."
              onkeydown="handleKey(event)" oninput="onTyping(this)" onblur="stopTyping()"></textarea>
          </div>
          <button class="send-btn" id="sendBtn" onclick="sendMessage()" title="إرسال">
            <svg viewBox="0 0 24 24"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- ══ RIGHT PANEL ══ -->
  <div class="right-panel">
    <div class="rp-head">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color:var(--t3)"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      <h3>بطاقة العميل</h3>
    </div>
    <div class="rp-body" id="crmBody">
      <div class="crm-empty">اختر محادثة لعرض بيانات العميل</div>
    </div>
  </div>

</div><!-- .workspace -->

<div class="toast" id="toast"></div>

<script>
// ═══════════════════════════════════════════════════════
//  BAREZ WORKSPACE — CLIENT ENGINE
//  Agent: <%= JSON.stringify(agent) %>
// ═══════════════════════════════════════════════════════

const AGENT = <%- JSON.stringify(agent) %>;
const TEMPLATES = {
  barez_booking_confirmed: { name: 'barez_booking_confirmed', params: [] },
  barez_check_in:          { name: 'barez_check_in',          params: [] },
  barez_check_out:         { name: 'barez_check_out',         params: [] },
  barez_reminder_v1:       { name: 'barez_reminder_v1',       params: [] },
};

// ── State ──────────────────────────────────────────────
let _convs        = [];
let _activePhone  = null;
let _locks        = {};         // phone → lock state from SSE
let _oldestMsgAt  = null;      // cursor for infinite scroll
let _hasMore      = true;
let _tab          = 'all';
let _typingTimer  = null;
let _optimisticIds = new Map(); // tempId → DOM element
let _convPollTimer = null;

// ── SSE — real-time events ────────────────────────────
const _sse = new EventSource('/ws/api/events');
_sse.onmessage = (e) => {
  try {
    const ev = JSON.parse(e.data);
    if (ev.type === 'snapshot')    { _locks = ev.locks || {}; _applyAllLocks(); }
    if (ev.type === 'lock_update') { _locks[ev.phone] = ev.state; _applyLock(ev.phone); }
    if (ev.type === 'typing')      { _renderTyping(ev.phone, ev.agentId, ev.isTyping); }
    if (ev.type === 'new_message') { _onNewMessage(ev.phone, ev.msg); }
  } catch {}
};
_sse.onerror = () => {};

// ── Init ──────────────────────────────────────────────
loadConvs();
_convPollTimer = setInterval(loadConvs, 8000);

async function loadConvs() {
  try {
    const data = await api(`/ws/api/conversations?tab=${_tab}`);
    _convs = data;
    renderConvList(data);
    _updateBadges(data);
  } catch {}
}

function _updateBadges(convs) {
  const unread = convs.filter(c => c.unread > 0).length;
  const badgeAll = document.getElementById('badge-all');
  const badgeUnread = document.getElementById('badge-unread');
  if (unread > 0) {
    badgeAll.textContent = unread; badgeAll.style.display = 'flex';
    badgeUnread.textContent = unread; badgeUnread.style.display = 'flex';
  } else {
    badgeAll.style.display = 'none'; badgeUnread.style.display = 'none';
  }
}

function setTab(el, tab) {
  _tab = tab;
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  loadConvs();
}

function renderConvList(list) {
  const el = document.getElementById('convList');
  if (!list.length) {
    el.innerHTML = '<div class="conv-empty">لا توجد محادثات</div>';
    return;
  }
  el.innerHTML = list.map(c => {
    const phone  = c._id || '';
    const last   = c.lastMsg || {};
    const lock   = _locks[phone] || {};
    const isActive = phone === _activePhone;
    const isLocked = lock.isLocked && lock.assignedAgentId !== AGENT.id;
    const preview = last.direction === 'out' ? `أنت: ${esc(last.body)}` : esc(last.body || '');
    const sla    = _slaText(last.sentAt, last.direction);
    const initial = (c.fromName || phone).slice(0, 2);
    return `
      <div class="conv-item${isActive?' active':''}${isLocked?' locked':''}" onclick="openChat('${phone}')">
        <div class="conv-avatar">
          ${initial}
          ${c.unread > 0 ? '<div class="unread-dot"></div>' : ''}
        </div>
        <div class="conv-body">
          <div class="conv-name">${esc(c.fromName || fmtPhone(phone))}</div>
          <div class="conv-preview${lock.agentTypingStatus && lock.assignedAgentId !== AGENT.id ? ' typing' : ''}">
            ${lock.agentTypingStatus && lock.assignedAgentId !== AGENT.id
              ? `${esc(lock.agentName || '...')} يكتب...`
              : preview}
          </div>
        </div>
        <div class="conv-side">
          <div class="conv-time">${relTime(last.sentAt)}</div>
          ${c.unread > 0 ? `<div class="conv-unread">${c.unread}</div>` : ''}
          ${sla ? `<div class="sla-warn${sla.breach ? ' sla-breach' : ''}">${sla.text}</div>` : ''}
        </div>
      </div>`;
  }).join('');
}

function filterConvs(q) {
  if (!q) { renderConvList(_convs); return; }
  const qLower = q.toLowerCase().replace(/\D/g,'');
  renderConvList(_convs.filter(c =>
    (c._id||'').includes(qLower) ||
    (c.fromName||'').toLowerCase().includes(q.toLowerCase())
  ));
}

// ── Open chat ─────────────────────────────────────────
async function openChat(phone) {
  // Release old lock
  if (_activePhone && _activePhone !== phone) {
    api('/ws/api/unlock', { method:'POST', body:{ phone: _activePhone } }).catch(()=>{});
  }

  _activePhone  = phone;
  _oldestMsgAt  = null;
  _hasMore      = true;

  document.getElementById('noChatView').style.display = 'none';
  const cv = document.getElementById('chatView');
  cv.style.display = 'flex';

  const name = _convs.find(c => c._id === phone)?.fromName || fmtPhone(phone);
  document.getElementById('chatAvatar').textContent = name.slice(0,2);
  document.getElementById('chatName').textContent   = name;
  document.getElementById('chatSub').textContent    = '+' + phone;
  document.getElementById('chatWaLink').href        = `https://wa.me/${phone}`;

  _applyLock(phone);

  // Acquire lock
  const lockRes = await api('/ws/api/lock', { method:'POST', body:{ phone } }).catch(()=>({ok:false}));
  if (!lockRes.ok) {
    showToast(`المحادثة مأخوذة من ${lockRes.heldBy}`, 'error');
  }

  // Highlight active
  document.querySelectorAll('.conv-item').forEach(el => el.classList.remove('active'));
  document.querySelectorAll('.conv-item').forEach(el => {
    if (el.onclick?.toString().includes(`'${phone}'`)) el.classList.add('active');
  });

  document.getElementById('msgsArea').innerHTML = '';
  await loadMsgs(phone, false);
  loadCRM(phone);
}

// ── Messages ──────────────────────────────────────────
async function loadMsgs(phone, prepend = false) {
  try {
    const url = `/ws/api/messages/${phone}` + (_oldestMsgAt ? `?before=${_oldestMsgAt}` : '');
    const msgs = await api(url);

    _hasMore = msgs.length >= 40;
    document.getElementById('loadMoreBtn').style.display = _hasMore ? 'block' : 'none';

    if (msgs.length > 0) _oldestMsgAt = msgs[0].sentAt;

    if (prepend) {
      prependMsgs(msgs);
    } else {
      renderMsgs(msgs);
      _check24hWindow(msgs);
    }
  } catch(e) { showToast('تعذّر تحميل الرسائل', 'error'); }
}

async function loadOlderMessages() {
  if (!_activePhone || !_hasMore) return;
  const area = document.getElementById('msgsArea');
  const prevHeight = area.scrollHeight;
  await loadMsgs(_activePhone, true);
  area.scrollTop = area.scrollHeight - prevHeight;
}

function handleScroll(el) {
  if (el.scrollTop < 60 && _hasMore && _activePhone) loadOlderMessages();
}

function renderMsgs(msgs) {
  const area  = document.getElementById('msgsArea');
  const html  = _buildMsgsHtml(msgs);
  const lmBtn = document.getElementById('loadMoreBtn');
  area.innerHTML = '';
  if (_hasMore) area.appendChild(lmBtn.cloneNode(true));
  area.insertAdjacentHTML('beforeend', html);
  area.scrollTop = area.scrollHeight;
}

function prependMsgs(msgs) {
  const area = document.getElementById('msgsArea');
  const frag = document.createElement('div');
  frag.innerHTML = _buildMsgsHtml(msgs);
  const ref = area.querySelector('.bubble-row, .date-sep');
  if (ref) { while (frag.firstChild) area.insertBefore(frag.firstChild, ref); }
  else area.insertAdjacentHTML('afterbegin', frag.innerHTML);
}

function _buildMsgsHtml(msgs) {
  let html = '', lastDate = '';
  for (const m of msgs) {
    const d       = new Date(m.sentAt || m.createdAt);
    const dateStr = _dateSep(d);
    if (dateStr !== lastDate) {
      html += `<div class="date-sep"><span>${dateStr}</span></div>`;
      lastDate = dateStr;
    }
    html += _bubbleHtml(m);
  }
  return html;
}

function _bubbleHtml(m, isOptimistic = false) {
  const dir   = m.direction === 'in' ? 'in' : 'out';
  const d     = new Date(m.sentAt || m.createdAt);
  const t     = d.toLocaleTimeString('ar-SA',{hour:'2-digit',minute:'2-digit'});
  const optCls = isOptimistic ? ' optimistic' : (m.status === 'failed' ? ' failed' : '');
  const id     = m._id ? `data-id="${m._id}"` : '';

  let content = esc(m.body);
  if (m.mediaUrl) {
    const mime = m.mediaUrl.split(';')[0].replace('data:','');
    if (mime.startsWith('image')) {
      content = `<img class="bubble-media" src="${m.mediaUrl}" onclick="window.open(this.src)" alt="صورة"><br>${esc(m.body)}`;
    } else if (mime.startsWith('audio')) {
      content = `<audio class="bubble-audio" controls src="${m.mediaUrl}"></audio>`;
    } else {
      content = `<a href="${m.mediaUrl}" download style="color:var(--green)">📄 ${esc(m.body)}</a>`;
    }
  }

  const statusIcon = dir === 'out' ? _statusIcon(m.status) : '';
  const retryBtn   = m.status === 'failed' ? `<button class="retry-btn" onclick="retryMsg('${m._id}','${_activePhone}',event)">إعادة المحاولة</button>` : '';

  return `
    <div class="bubble-row ${dir}${optCls}" ${id}>
      <div class="bubble">
        ${content}
        <div class="bubble-footer">
          <span class="bubble-time">${t}</span>
          ${statusIcon}
          ${retryBtn}
        </div>
      </div>
    </div>`;
}

function _statusIcon(status) {
  const cls = status || 'sent';
  const icons = {
    sending:   '🕐',
    sent:      '✓',
    delivered: '✓✓',
    read:      '✓✓',
    failed:    '⚠️',
  };
  return `<span class="bubble-status ${cls}">${icons[cls]||'✓'}</span>`;
}

// ── Optimistic send ───────────────────────────────────
async function sendMessage() {
  const input = document.getElementById('msgInput');
  const body  = input.value.trim();
  if (!body || !_activePhone) return;

  const btn    = document.getElementById('sendBtn');
  const tempId = 'opt_' + Date.now();

  // Append optimistic bubble immediately
  const area = document.getElementById('msgsArea');
  area.insertAdjacentHTML('beforeend', _bubbleHtml(
    { body, direction: 'out', status: 'sending', sentAt: new Date() }, true
  ));
  const optEl = area.lastElementChild;
  optEl.dataset.tempId = tempId;
  area.scrollTop = area.scrollHeight;

  input.value = '';
  input.style.height = '';
  btn.disabled = true;
  stopTyping();

  try {
    const res = await api('/ws/api/send', {
      method: 'POST',
      body:   { phone: _activePhone, body, optimisticId: tempId },
    });
    // Replace optimistic with confirmed msg
    if (optEl && res.msg) {
      optEl.outerHTML = _bubbleHtml(res.msg);
    }
    _check24hWindow([res.msg]);
    loadConvs();
  } catch (err) {
    // Rollback: show failed state
    if (optEl) {
      optEl.classList.remove('optimistic');
      optEl.classList.add('failed');
      const bubble = optEl.querySelector('.bubble');
      if (bubble) bubble.insertAdjacentHTML('beforeend', `<br><button class="retry-btn" onclick="retryFailed(this,event)">${body}</button>`);
    }
    showToast('فشل الإرسال — اضغط إعادة المحاولة', 'error');
  } finally {
    btn.disabled = false;
    input.focus();
  }
}

async function retryMsg(msgId, phone, e) {
  e?.stopPropagation();
  const row = document.querySelector(`[data-id="${msgId}"]`);
  if (row) {
    const body = row.querySelector('.bubble').childNodes[0]?.textContent?.trim();
    if (body) await _doSend(phone, body, row);
  }
}

// ── Templates ─────────────────────────────────────────
async function sendTemplate(name) {
  if (!_activePhone) return;
  try {
    await api('/ws/api/send-template', {
      method: 'POST',
      body:   { phone: _activePhone, templateName: name, params: [] },
    });
    showToast('تم إرسال القالب');
    await loadMsgs(_activePhone, false);
  } catch(e) { showToast('فشل إرسال القالب', 'error'); }
}

// ── Typing ────────────────────────────────────────────
function onTyping(el) {
  el.style.height = '';
  el.style.height = Math.min(el.scrollHeight, 120) + 'px';
  clearTimeout(_typingTimer);
  if (_activePhone) {
    api('/ws/api/typing', { method:'POST', body:{ phone: _activePhone, isTyping: true } }).catch(()=>{});
    _typingTimer = setTimeout(stopTyping, 4000);
  }
}

function stopTyping() {
  clearTimeout(_typingTimer);
  if (_activePhone) {
    api('/ws/api/typing', { method:'POST', body:{ phone: _activePhone, isTyping: false } }).catch(()=>{});
  }
}

function _renderTyping(phone, agentId, isTyping) {
  if (phone !== _activePhone || agentId === AGENT.id) return;
  const existing = document.getElementById('typing-indicator-row');
  if (isTyping && !existing) {
    const area = document.getElementById('msgsArea');
    area.insertAdjacentHTML('beforeend', `
      <div class="bubble-row in" id="typing-indicator-row">
        <div class="typing-indicator">
          <div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div>
        </div>
      </div>`);
    area.scrollTop = area.scrollHeight;
  } else if (!isTyping && existing) {
    existing.remove();
  }
}

function handleKey(e) {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
}

// ── CRM Panel ─────────────────────────────────────────
async function loadCRM(phone) {
  const body = document.getElementById('crmBody');
  body.innerHTML = '<div class="crm-empty">جاري التحميل...</div>';
  try {
    const data = await api(`/ws/api/crm/${phone}`);
    renderCRM(phone, data);
  } catch { body.innerHTML = '<div class="crm-empty">تعذّر تحميل البيانات</div>'; }
}

function renderCRM(phone, data) {
  const body  = document.getElementById('crmBody');
  const name  = data.customer?.name || fmtPhone(phone);
  const spend = (data.totalSpend || 0).toLocaleString('ar-SA');
  const bkCount = data.bookings?.length || 0;
  const active  = data.activeBooking;

  let bookingsHtml = '';
  for (const b of (data.bookings || []).slice(0, 5)) {
    const chIn  = b.checkIn  ? new Date(b.checkIn).toLocaleDateString('ar-SA',{month:'short',day:'numeric'}) : '—';
    const chOut = b.checkOut ? new Date(b.checkOut).toLocaleDateString('ar-SA',{month:'short',day:'numeric'}) : '—';
    const st    = b.status === 'active' ? 'active' : b.status === 'confirmed' ? 'confirmed' : 'completed';
    const stLabel = { active:'نشط', confirmed:'مؤكد', completed:'منتهي', cancelled:'ملغي' }[b.status] || b.status;
    bookingsHtml += `
      <div class="booking-card">
        <div class="bk-apt">${esc(b.apartment || b.apt || '—')} — ${esc(b.building || '—')}</div>
        <div class="bk-dates">${chIn} → ${chOut}</div>
        <span class="bk-status ${st}">${stLabel}</span>
      </div>`;
  }

  body.innerHTML = `
    <div class="crm-card">
      <div class="crm-card-head">
        <div class="crm-avatar">${name.slice(0,2)}</div>
        <div>
          <div class="crm-name">${esc(name)}</div>
          <div class="crm-phone">+${phone}</div>
        </div>
      </div>
      <div class="crm-section">
        <div class="crm-section-title">الإحصائيات</div>
        <div class="stat-row"><span class="stat-label">إجمالي الحجوزات</span><span class="stat-val">${bkCount}</span></div>
        <div class="stat-row"><span class="stat-label">إجمالي الإنفاق</span><span class="stat-val green">${spend} ﷼</span></div>
        ${active ? `<div class="stat-row"><span class="stat-label">حجز نشط</span><span class="stat-val amber">✓ ${esc(active.apartment||'')}</span></div>` : ''}
      </div>
    </div>
    ${bookingsHtml ? `
    <div class="crm-card">
      <div class="crm-section-title" style="margin-bottom:10px">الحجوزات الأخيرة</div>
      ${bookingsHtml}
    </div>` : ''}
    <div class="crm-card">
      <div class="crm-section-title" style="margin-bottom:8px">ملاحظات</div>
      <textarea class="notes-area" id="notesArea" rows="4" placeholder="أضف ملاحظة عن العميل...">${esc(data.customer?.notes || '')}</textarea>
      <button class="notes-save" onclick="saveNotes('${phone}')">حفظ الملاحظات</button>
    </div>`;
}

async function saveNotes(phone) {
  const notes = document.getElementById('notesArea')?.value || '';
  try {
    await api(`/ws/api/crm/${phone}/notes`, { method:'POST', body:{ notes } });
    showToast('تم حفظ الملاحظات');
  } catch { showToast('فشل حفظ الملاحظات', 'error'); }
}

// ── Lock management ───────────────────────────────────
function _applyLock(phone) {
  if (phone !== _activePhone) return;
  const lock = _locks[phone] || {};
  const badge = document.getElementById('lockBadge');
  if (lock.isLocked && lock.assignedAgentId === AGENT.id) {
    badge.style.display = 'flex';
    badge.textContent   = `🔒 محجوز لك`;
    badge.className     = 'lock-badge';
  } else if (lock.isLocked) {
    badge.style.display = 'flex';
    badge.textContent   = `🔒 ${lock.agentName || 'وكيل آخر'}`;
    badge.className     = 'lock-badge locked-other';
  } else {
    badge.style.display = 'none';
  }
}

function _applyAllLocks() {
  renderConvList(_convs);
  if (_activePhone) _applyLock(_activePhone);
}

// ── SSE: new message ──────────────────────────────────
function _onNewMessage(phone, msg) {
  if (phone === _activePhone) {
    const area = document.getElementById('msgsArea');
    const atBottom = area.scrollHeight - area.scrollTop - area.clientHeight < 80;
    area.insertAdjacentHTML('beforeend', _bubbleHtml(msg));
    if (atBottom) area.scrollTop = area.scrollHeight;
  }
  loadConvs();
}

// ── 24h window check ──────────────────────────────────
function _check24hWindow(msgs) {
  const lastIn = [...msgs].reverse().find(m => m.direction === 'in');
  const warn   = document.getElementById('windowWarn');
  if (lastIn) {
    const diff = Date.now() - new Date(lastIn.sentAt).getTime();
    warn.style.display = diff > 23 * 3600 * 1000 ? 'flex' : 'none';
  } else {
    warn.style.display = 'none';
  }
}

// ── Helpers ───────────────────────────────────────────
async function api(url, opts={}) {
  const res = await fetch(url, {
    method:  opts.method || 'GET',
    headers: opts.body ? {'Content-Type':'application/json'} : {},
    body:    opts.body  ? JSON.stringify(opts.body) : undefined,
  });
  if (!res.ok) throw new Error(await res.text());
  return res.json();
}

function fmtPhone(p) {
  if (!p) return '—';
  if (p.startsWith('966') && p.length >= 12) return '0' + p.slice(3);
  return '+' + p;
}

function esc(s) {
  return String(s||'')
    .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
    .replace(/\n/g,'<br>');
}

function relTime(d) {
  if (!d) return '';
  const diff = Date.now() - new Date(d).getTime();
  const m    = Math.floor(diff/60000);
  if (m < 1)   return 'الآن';
  if (m < 60)  return `${m}د`;
  const h    = Math.floor(m/60);
  if (h < 24)  return `${h}س`;
  return new Date(d).toLocaleDateString('ar-SA',{month:'short',day:'numeric'});
}

function _dateSep(d) {
  const today = new Date(); today.setHours(0,0,0,0);
  const date  = new Date(d); date.setHours(0,0,0,0);
  const diff  = Math.round((today-date)/(86400000));
  if (diff===0) return 'اليوم';
  if (diff===1) return 'أمس';
  return new Date(d).toLocaleDateString('ar-SA',{weekday:'long',year:'numeric',month:'long',day:'numeric'});
}

function _slaText(sentAt, dir) {
  if (dir !== 'in' || !sentAt) return null;
  const mins = Math.floor((Date.now() - new Date(sentAt).getTime()) / 60000);
  if (mins < 15) return null;
  if (mins < 60) return { text: `${mins}د بلا رد`, breach: mins > 30 };
  const hrs = Math.floor(mins/60);
  return { text: `${hrs}س بلا رد`, breach: true };
}

let _toastTimer;
function showToast(msg, type='') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className   = `toast${type ? ' '+type : ''} show`;
  clearTimeout(_toastTimer);
  _toastTimer = setTimeout(() => t.classList.remove('show'), 3000);
}

// Cleanup on page leave
window.addEventListener('beforeunload', () => {
  if (_activePhone) {
    navigator.sendBeacon('/ws/api/unlock', JSON.stringify({ phone: _activePhone }));
  }
});
</script>
</body>
