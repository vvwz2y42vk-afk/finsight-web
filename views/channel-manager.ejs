<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>إدارة القنوات — BAREZ</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#F0F4FA;--surface:#fff;--s2:#F6F8FD;--s3:#EEF2FB;
  --border:#E2E8F0;--border-s:#EEF2F8;
  --t1:#0F172A;--t2:#334155;--t3:#64748B;--t4:#94A3B8;
  --brand:#1a3d8f;--brand-l:#2563eb;--brand-m:rgba(26,61,143,.09);
  --green:#047857;--green-bg:rgba(4,120,87,.08);
  --red:#B91C1C;--red-bg:rgba(185,28,28,.08);
  --amber:#B45309;--amber-bg:rgba(180,83,9,.08);
  --r:14px;--sh:0 4px 24px rgba(15,23,42,.07),0 1px 3px rgba(15,23,42,.04);
  --sh-sm:0 2px 10px rgba(15,23,42,.05);
  --ease:cubic-bezier(.4,0,.2,1);
  --sb:64px;
  --air:#FF5A5F;--bkg:#003580;--gth:#1a6b3c;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Cairo',sans-serif;background:var(--bg);direction:rtl;display:flex;min-height:100vh;color:var(--t1);-webkit-font-smoothing:antialiased;}

/* ── Sidebar (same style as dashboard) ── */
.sb{
  width:var(--sb);background:linear-gradient(180deg,#0A1628,#071530 55%,#050D1A);
  border-left:1px solid rgba(255,255,255,.05);display:flex;flex-direction:column;
  align-items:center;padding:20px 0;position:fixed;top:0;right:0;bottom:0;z-index:100;
  transition:width .28s var(--ease);box-shadow:-4px 0 28px rgba(0,0,0,.18);
}
.sb:hover{width:204px;}
.sb-logo{display:flex;align-items:center;justify-content:center;margin-bottom:28px;padding:8px 0;}
.sb-logo img{filter:brightness(0) invert(1);opacity:.9;}
.sb-nav{flex:1;width:100%;display:flex;flex-direction:column;gap:2px;padding:0 10px;}
.sn{display:flex;align-items:center;gap:11px;padding:10px;border-radius:10px;cursor:pointer;color:rgba(255,255,255,.4);transition:all .2s var(--ease);white-space:nowrap;overflow:hidden;text-decoration:none;}
.sn:hover{background:rgba(255,255,255,.06);color:rgba(255,255,255,.82);}
.sn.active{background:linear-gradient(135deg,rgba(37,99,235,.28),rgba(26,61,143,.18));color:#BFDBFE;box-shadow:inset 0 0 0 1px rgba(59,130,246,.3);}
.sn.active::after{content:'';position:absolute;right:0;top:12%;bottom:12%;width:3px;border-radius:2px 0 0 2px;background:linear-gradient(180deg,#60A5FA,#3B82F6,#60A5FA);box-shadow:0 0 16px rgba(96,165,250,.9);}
.sn{position:relative;}
.sn-ico{flex-shrink:0;width:22px;display:flex;align-items:center;justify-content:center;}
.sn-lbl{font-size:13px;font-weight:500;opacity:0;transition:opacity .2s var(--ease);}
.sb:hover .sn-lbl{opacity:1;}
.sb-foot{width:100%;padding:0 10px 10px;}
.sb-logout{display:flex;align-items:center;gap:11px;padding:10px;border-radius:10px;cursor:pointer;color:rgba(248,113,113,.65);text-decoration:none;white-space:nowrap;overflow:hidden;transition:all .2s var(--ease);}
.sb:hover .sb-logout{color:rgba(248,113,113,.65);}
.sb-logout:hover{background:rgba(239,68,68,.1);color:#FCA5A5;}

/* ── Main ── */
.main{margin-right:var(--sb);flex:1;display:flex;flex-direction:column;min-height:100vh;}

/* ── Topbar ── */
.topbar{
  background:rgba(255,255,255,.97);backdrop-filter:blur(24px);
  padding:14px 28px;display:flex;align-items:center;justify-content:space-between;
  border-bottom:1px solid var(--border-s);position:sticky;top:0;z-index:50;
  box-shadow:0 1px 12px rgba(15,23,42,.05);
}
.tb-title{font-size:16px;font-weight:700;color:var(--t1);}
.tb-title span{color:var(--brand);}
.tb-right{display:flex;align-items:center;gap:12px;}
.tb-avatar{width:34px;height:34px;border-radius:9px;background:linear-gradient(135deg,var(--brand),var(--brand-l));display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:#fff;}
.tb-info-name{font-size:13px;font-weight:600;color:var(--t2);}
.tb-info-role{font-size:11px;color:var(--t4);margin-top:1px;}
.tb-back{display:flex;align-items:center;gap:6px;padding:8px 14px;border-radius:10px;border:1.5px solid var(--border);background:var(--surface);color:var(--t2);text-decoration:none;font-size:12px;font-weight:700;transition:all .18s;}
.tb-back:hover{background:var(--s2);border-color:rgba(26,61,143,.2);}

/* ── Content ── */
.content{padding:28px;flex:1;}

/* ── Platform Settings Cards ── */
.cfg-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:14px;margin-bottom:32px;}
.cfg-card{background:var(--surface);border-radius:16px;border:1.5px solid var(--border);box-shadow:var(--sh-sm);overflow:hidden;transition:all .22s var(--ease);}
.cfg-card:hover{box-shadow:var(--sh);}
.cfg-hd{padding:16px 18px 12px;display:flex;align-items:center;gap:12px;}
.cfg-ico{width:42px;height:42px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;font-weight:900;}
.cfg-ico.air{background:#fff0f0;}
.cfg-ico.bkg{background:#e8f0fa;}
.cfg-ico.gth{background:#eafaf1;}
.cfg-name{font-size:14px;font-weight:800;color:var(--t1);}
.cfg-sub{font-size:10px;color:var(--t4);margin-top:2px;}
.cfg-body{padding:6px 18px 16px;}
.cfg-field{margin-bottom:10px;}
.cfg-label{font-size:10px;font-weight:700;color:var(--t3);letter-spacing:.04em;text-transform:uppercase;margin-bottom:4px;}
.cfg-inp{width:100%;padding:7px 11px;border:1.5px solid var(--border);border-radius:9px;font-family:inherit;font-size:12px;outline:none;color:var(--t1);transition:border-color .18s;}
.cfg-inp:focus{border-color:var(--brand);box-shadow:0 0 0 3px var(--brand-m);}
.cfg-row{display:flex;gap:8px;align-items:center;margin-top:10px;}
.cfg-save{flex:1;padding:8px;background:linear-gradient(135deg,var(--brand),var(--brand-l));color:#fff;border:none;border-radius:9px;font-family:inherit;font-size:12px;font-weight:700;cursor:pointer;transition:all .18s;}
.cfg-save:hover{box-shadow:0 3px 12px rgba(26,61,143,.3);transform:translateY(-1px);}
.cfg-msg{font-size:11px;font-weight:700;margin-top:7px;min-height:14px;}

/* ── iCal Export Box ── */
.ical-export{background:var(--s2);border-radius:10px;padding:8px 12px;display:flex;align-items:center;gap:8px;border:1px dashed var(--border);margin-top:10px;}
.ical-url{font-size:10px;color:var(--t3);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-family:monospace;}
.ical-copy{background:var(--brand);color:#fff;border:none;border-radius:7px;padding:4px 10px;font-size:10px;font-weight:700;cursor:pointer;font-family:inherit;white-space:nowrap;flex-shrink:0;}

/* ── Building Tabs ── */
.bld-tabs{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:20px;}
.btab{padding:8px 18px;border-radius:25px;border:1.5px solid var(--border);background:var(--surface);font-family:inherit;font-size:12px;font-weight:700;cursor:pointer;color:var(--t3);transition:all .18s var(--ease);display:flex;align-items:center;gap:6px;}
.btab:hover{background:var(--s2);color:var(--t2);}
.btab.active{background:var(--brand);border-color:transparent;color:#fff;box-shadow:0 3px 12px rgba(26,61,143,.28);}
.btab .bcnt{font-size:10px;padding:1px 7px;border-radius:20px;background:rgba(255,255,255,.22);font-weight:800;}
.btab:not(.active) .bcnt{background:var(--s3);color:var(--brand);}

/* ── Matrix Table ── */
.matrix-wrap{background:var(--surface);border-radius:16px;border:1px solid var(--border);box-shadow:var(--sh-sm);overflow:hidden;}
.matrix-toolbar{padding:14px 20px;border-bottom:1px solid var(--border-s);display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;}
.mtb-title{font-size:14px;font-weight:800;color:var(--t1);display:flex;align-items:center;gap:8px;}
.mtb-title::before{content:'';display:block;width:4px;height:16px;background:linear-gradient(180deg,var(--brand-l),var(--brand));border-radius:3px;}
.mtb-actions{display:flex;gap:8px;align-items:center;flex-wrap:wrap;}
.mtb-btn{padding:7px 14px;border-radius:9px;border:1.5px solid var(--border);background:var(--surface);font-family:inherit;font-size:12px;font-weight:700;cursor:pointer;color:var(--t2);display:flex;align-items:center;gap:6px;transition:all .18s;}
.mtb-btn:hover{background:var(--s2);}
.mtb-btn.primary{background:linear-gradient(135deg,var(--brand),var(--brand-l));color:#fff;border-color:transparent;box-shadow:0 2px 10px rgba(26,61,143,.22);}
.mtb-btn.primary:hover{box-shadow:0 4px 16px rgba(26,61,143,.32);transform:translateY(-1px);}
.mtb-btn.green{background:linear-gradient(135deg,#047857,#059669);color:#fff;border-color:transparent;box-shadow:0 2px 10px rgba(4,120,87,.2);}

.matrix-scroll{overflow-x:auto;}
.matrix{border-collapse:collapse;width:100%;font-size:12px;min-width:700px;}
.matrix th{background:linear-gradient(135deg,#F8FAFC,#F1F5F9);color:var(--t2);padding:10px 14px;text-align:right;font-weight:700;font-size:11px;letter-spacing:.04em;border-bottom:2px solid var(--border);white-space:nowrap;}
.matrix th.plat-hd{text-align:center;min-width:180px;}
.matrix th.plat-hd.air{color:var(--air);}
.matrix th.plat-hd.bkg{color:var(--bkg);}
.matrix th.plat-hd.gth{color:var(--gth);}
.matrix td{padding:8px 14px;border-bottom:1px solid var(--border-s);vertical-align:middle;}
.matrix tbody tr:hover td{background:rgba(237,242,252,.6);}
.matrix .apt-cell{font-size:15px;font-weight:900;color:var(--t1);white-space:nowrap;letter-spacing:-.03em;}
.matrix .floor-row td{background:var(--s3);padding:6px 14px;font-size:10px;font-weight:800;color:var(--brand);letter-spacing:.06em;text-transform:uppercase;border-bottom:1px solid var(--border-s);}

/* Platform cell */
.plat-cell{display:flex;align-items:center;gap:6px;}
.plat-inp{flex:1;padding:5px 9px;border:1.5px solid var(--border);border-radius:8px;font-family:monospace;font-size:11px;outline:none;color:var(--t1);transition:border-color .15s;min-width:0;}
.plat-inp:focus{border-color:var(--brand);box-shadow:0 0 0 2px var(--brand-m);}
.plat-inp.has-url{border-color:rgba(4,120,87,.4);background:rgba(4,120,87,.03);}
.plat-sync{width:26px;height:26px;border:none;border-radius:7px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .15s;background:var(--s2);color:var(--t3);}
.plat-sync:hover{background:var(--brand-m);color:var(--brand);}
.plat-sync.ok{background:var(--green-bg);color:var(--green);}
.plat-sync.error{background:var(--red-bg);color:var(--red);}
.plat-sync.syncing{animation:spin .7s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}
.plat-save{width:26px;height:26px;border:none;border-radius:7px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;background:var(--brand-m);color:var(--brand);transition:all .15s;}
.plat-save:hover{background:var(--brand);color:#fff;}

/* Status dot */
.sdot{width:8px;height:8px;border-radius:50%;flex-shrink:0;display:inline-block;}
.sdot.ok{background:#16a34a;}
.sdot.error{background:#dc2626;}
.sdot.never{background:#cbd5e1;}

/* ── Bulk Import Modal ── */
.modal-bg{position:fixed;inset:0;background:rgba(15,23,42,.45);z-index:200;display:none;align-items:center;justify-content:center;backdrop-filter:blur(4px);}
.modal-bg.open{display:flex;}
.modal{background:var(--surface);border-radius:20px;width:min(640px,96vw);max-height:90vh;display:flex;flex-direction:column;box-shadow:0 24px 80px rgba(15,23,42,.18);}
.modal-hd{padding:22px 26px;border-bottom:1px solid var(--border-s);display:flex;align-items:center;justify-content:space-between;}
.modal-title{font-size:16px;font-weight:800;color:var(--t1);}
.modal-close{width:32px;height:32px;border:none;background:var(--s2);border-radius:8px;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--t3);font-size:18px;line-height:1;}
.modal-close:hover{background:var(--s3);}
.modal-body{padding:22px 26px;overflow-y:auto;flex:1;}
.modal-ft{padding:16px 26px;border-top:1px solid var(--border-s);display:flex;justify-content:flex-end;gap:10px;}

/* CSV hint */
.csv-hint{background:var(--s2);border-radius:10px;padding:12px 16px;font-size:12px;color:var(--t2);margin-bottom:16px;line-height:1.7;}
.csv-hint code{background:var(--s3);color:var(--brand);padding:2px 6px;border-radius:5px;font-family:monospace;font-size:11px;}
.modal-textarea{width:100%;height:200px;padding:12px;border:1.5px solid var(--border);border-radius:10px;font-family:monospace;font-size:11px;resize:vertical;outline:none;color:var(--t1);}
.modal-textarea:focus{border-color:var(--brand);}

/* Sync All Progress */
.progress-bar-wrap{height:6px;background:var(--s3);border-radius:6px;overflow:hidden;margin-top:10px;display:none;}
.progress-bar-fill{height:100%;background:linear-gradient(90deg,var(--brand),var(--brand-l));border-radius:6px;width:0%;transition:width .3s;}

/* Toast */
#cm-toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(60px);background:#0f172a;color:#fff;padding:12px 24px;border-radius:12px;font-size:13px;font-weight:600;z-index:9999;transition:transform .3s,opacity .3s;opacity:0;font-family:'Cairo',sans-serif;white-space:nowrap;}
</style>
</head>
<body>

<!-- Sidebar -->
<aside class="sb">
  <div class="sb-logo"><img src="/images/logo-dark.png" alt="Barez" style="height:44px;width:auto;"></div>
  <nav class="sb-nav">
    <a href="/staff/dashboard" class="sn"><span class="sn-ico"><svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg></span><span class="sn-lbl">الداشبورد</span></a>
    <a href="/staff/channels" class="sn active"><span class="sn-ico"><svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="5" r="3"/><circle cx="5" cy="19" r="3"/><circle cx="19" cy="19" r="3"/><line x1="12" y1="8" x2="5.5" y2="16.5"/><line x1="12" y1="8" x2="18.5" y2="16.5"/></svg></span><span class="sn-lbl">إدارة القنوات</span></a>
  </nav>
  <div class="sb-foot">
    <a href="/staff/logout" class="sb-logout"><span class="sn-ico"><svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg></span><span class="sn-lbl">خروج</span></a>
  </div>
</aside>

<!-- Main -->
<div class="main">
  <!-- Topbar -->
  <div class="topbar">
    <div>
      <div class="tb-title">BAREZ — <span>إدارة قنوات الحجز</span></div>
      <div style="font-size:11px;color:var(--t4);margin-top:2px;">ربط المنصات · منع الازدواجية · مزامنة تلقائية</div>
    </div>
    <div class="tb-right">
      <a href="/staff/dashboard" class="tb-back">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
        العودة للداشبورد
      </a>
      <div style="display:flex;align-items:center;gap:8px;">
        <div class="tb-avatar"><%= staff.name.charAt(0) %></div>
        <div><div class="tb-info-name"><%= staff.name %></div><div class="tb-info-role"><%= staff.building %></div></div>
      </div>
    </div>
  </div>

  <div class="content">

    <!-- ══ Platform Global Settings ══ -->
    <div style="margin-bottom:8px;font-size:11px;font-weight:700;color:var(--t3);letter-spacing:.06em;text-transform:uppercase;">إعدادات المنصات — إيميل الإشعارات ورابط iCal للتصدير</div>
    <div class="cfg-grid" id="cfg-cards">
      <div style="color:var(--t4);font-size:13px;padding:20px;">جاري التحميل…</div>
    </div>

    <!-- ══ Matrix Section ══ -->
    <div style="margin-bottom:14px;font-size:11px;font-weight:700;color:var(--t3);letter-spacing:.06em;text-transform:uppercase;">ربط كل شقة بكل منصة</div>

    <!-- Building Tabs -->
    <div class="bld-tabs" id="bld-tabs">
      <div style="color:var(--t4);font-size:13px;">جاري التحميل…</div>
    </div>

    <!-- Matrix -->
    <div class="matrix-wrap" id="matrix-wrap">
      <div class="matrix-toolbar">
        <div class="mtb-title" id="mtb-bld-name">—</div>
        <div class="mtb-actions">
          <button class="mtb-btn" onclick="openBulkModal()">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
            استيراد CSV
          </button>
          <button class="mtb-btn" onclick="exportTemplate()">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            تصدير قالب
          </button>
          <button class="mtb-btn green" id="sync-all-btn" onclick="syncBuilding()">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="1 4 1 10 7 10"/><polyline points="23 20 23 14 17 14"/><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15"/></svg>
            مزامنة العمارة كلها
          </button>
        </div>
      </div>
      <div class="progress-bar-wrap" id="sync-progress-wrap">
        <div class="progress-bar-fill" id="sync-progress-fill"></div>
      </div>
      <div id="sync-status" style="font-size:11px;color:var(--t3);padding:0 20px 8px;min-height:16px;font-weight:700;"></div>
      <div class="matrix-scroll">
        <table class="matrix" id="matrix-table">
          <thead>
            <tr>
              <th style="min-width:70px;">الشقة</th>
              <th class="plat-hd air">🏡 Airbnb — رابط iCal</th>
              <th class="plat-hd bkg">🌐 Booking.com — رابط iCal</th>
              <th class="plat-hd gth">🏘️ Gathering — رابط iCal</th>
            </tr>
          </thead>
          <tbody id="matrix-body">
            <tr><td colspan="4" style="padding:32px;text-align:center;color:var(--t4);">اختر عمارة من الأعلى</td></tr>
          </tbody>
        </table>
      </div>
    </div>

  </div><!-- /content -->
</div><!-- /main -->

<!-- ══ Bulk Import Modal ══ -->
<div class="modal-bg" id="bulk-modal">
  <div class="modal">
    <div class="modal-hd">
      <div class="modal-title">استيراد روابط iCal من CSV</div>
      <button class="modal-close" onclick="closeBulkModal()">×</button>
    </div>
    <div class="modal-body">
      <div class="csv-hint">
        الصق بيانات CSV بالتنسيق التالي (سطر لكل شقة):<br>
        <code>عمارة, شقة, منصة, رابط_iCal</code><br><br>
        مثال:<br>
        <code>المنارا, 101, airbnb, https://www.airbnb.com/calendar/ical/…</code><br>
        <code>المنارا, 101, booking, https://ical.booking.com/v1/…</code><br>
        <code>المنارا, 102, airbnb, https://www.airbnb.com/calendar/ical/…</code><br><br>
        قيم المنصة: <code>airbnb</code> · <code>booking</code> · <code>gathering</code>
      </div>
      <textarea class="modal-textarea" id="bulk-csv" placeholder="المنارا, 101, airbnb, https://…&#10;المنارا, 101, booking, https://…&#10;المنارا, 102, airbnb, https://…"></textarea>
      <div id="bulk-result" style="font-size:12px;font-weight:700;margin-top:10px;min-height:16px;"></div>
    </div>
    <div class="modal-ft">
      <button class="mtb-btn" onclick="closeBulkModal()">إلغاء</button>
      <button class="mtb-btn primary" onclick="submitBulk()">
        <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        استيراد
      </button>
    </div>
  </div>
</div>

<div id="cm-toast"></div>

<script>
const STAFF_BUILDING = '<%= staff.building %>';
const PLATFORMS = ['airbnb','booking','gathering'];
const PLAT_LABEL = { airbnb:'Airbnb', booking:'Booking.com', gathering:'Gathering' };
const PLAT_COLOR = { airbnb:'var(--air)', booking:'var(--bkg)', gathering:'var(--gth)' };

let _bldgs = {};       // { building: { floors: [{l,r}] } }
let _listings = {};    // keyed: `${building}|${apt}|${platform}` → listing doc
let _curBuilding = ''; // active building tab

// ── Boot ─────────────────────────────────────────────────
window.onload = async () => {
  await Promise.all([loadCfgCards(), loadListings()]);
};

// ── Platform Config Cards ─────────────────────────────────
async function loadCfgCards() {
  try {
    const r = await fetch('/staff/api/channels');
    if (!r.ok) throw new Error('فشل التحميل');
    const { configs } = await r.json();
    const container = document.getElementById('cfg-cards');
    container.innerHTML = '';
    for (const cfg of configs.filter(c => c.platform !== 'website')) {
      const p = cfg.platform;
      const ico = { airbnb:'🏡', booking:'🌐', gathering:'🏘️' }[p] || '📡';
      const cls = { airbnb:'air', booking:'bkg', gathering:'gth' }[p] || '';
      const card = document.createElement('div');
      card.className = 'cfg-card';
      card.innerHTML = `
        <div class="cfg-hd">
          <div class="cfg-ico ${cls}">${ico}</div>
          <div><div class="cfg-name">${cfg.label}</div><div class="cfg-sub">إعدادات عامة</div></div>
        </div>
        <div class="cfg-body">
          <div class="cfg-field">
            <div class="cfg-label">إيميل الإشعارات</div>
            <input class="cfg-inp" type="email" id="cfg-email-${p}" value="${esc(cfg.notifyEmail||'')}" placeholder="admin@example.com">
          </div>
          ${cfg.icalExportUrl ? `
          <div class="cfg-label" style="margin-bottom:4px;">رابط iCal للتصدير (أعطه للمنصة)</div>
          <div class="ical-export">
            <span class="ical-url" id="cfg-export-${p}">${esc(cfg.icalExportUrl)}</span>
            <button class="ical-copy" onclick="copyUrl('cfg-export-${p}',this)">نسخ</button>
          </div>` : `<div style="font-size:11px;color:var(--t4);">احفظ لتوليد رابط iCal</div>`}
          <div class="cfg-row">
            <button class="cfg-save" onclick="saveCfg('${p}',this)">حفظ</button>
          </div>
          <div class="cfg-msg" id="cfg-msg-${p}"></div>
        </div>`;
      container.appendChild(card);
    }
  } catch(e) {
    document.getElementById('cfg-cards').innerHTML = `<div style="color:var(--red);font-size:12px;">${e.message}</div>`;
  }
}

async function saveCfg(platform, btn) {
  const orig = btn.textContent; btn.disabled = true; btn.textContent = '…';
  try {
    const notifyEmail = (document.getElementById(`cfg-email-${platform}`) || {}).value || '';
    const r = await fetch(`/staff/api/channels/${platform}`, {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ notifyEmail }),
    });
    const d = await r.json();
    const msgEl = document.getElementById(`cfg-msg-${platform}`);
    if (d.success) {
      msgEl.textContent = '✅ تم الحفظ'; msgEl.style.color = '#16a34a';
      if (d.icalExportUrl) {
        const el = document.getElementById(`cfg-export-${platform}`);
        if (el) el.textContent = d.icalExportUrl;
      }
    } else { msgEl.textContent = '❌ ' + (d.error||'خطأ'); msgEl.style.color = '#dc2626'; }
    setTimeout(() => { msgEl.textContent = ''; }, 3000);
  } catch(e) {
    const m = document.getElementById(`cfg-msg-${platform}`);
    if (m) { m.textContent = '❌ ' + e.message; m.style.color = '#dc2626'; }
  } finally { btn.disabled = false; btn.textContent = orig; }
}

// ── Matrix Data ───────────────────────────────────────────
async function loadListings() {
  try {
    const r = await fetch('/staff/api/listings');
    if (!r.ok) throw new Error('فشل تحميل البيانات');
    const { listings, bldgs } = await r.json();
    _bldgs = bldgs || {};

    // Index listings
    _listings = {};
    for (const lst of listings) {
      _listings[`${lst.building}|${lst.apt}|${lst.platform}`] = lst;
    }

    // Render building tabs
    renderBldTabs();

    // Auto-select first building
    const first = Object.keys(_bldgs)[0];
    if (first) selectBuilding(first);
  } catch(e) {
    document.getElementById('bld-tabs').innerHTML = `<div style="color:var(--red);font-size:12px;">${e.message}</div>`;
  }
}

function renderBldTabs() {
  const container = document.getElementById('bld-tabs');
  container.innerHTML = '';
  for (const bld of Object.keys(_bldgs)) {
    const totalApts = (_bldgs[bld]?.floors || []).reduce((s,f)=>s+f.r.length,0);
    const connected = PLATFORMS.reduce((s,p) =>
      s + Object.keys(_listings).filter(k => k.startsWith(`${bld}|`) && k.endsWith(`|${p}`) && _listings[k].icalImport).length, 0);
    const btn = document.createElement('button');
    btn.className = 'btab' + (bld === _curBuilding ? ' active' : '');
    btn.id = `btab-${bld}`;
    btn.innerHTML = `${esc(bld)} <span class="bcnt">${connected}/${totalApts * PLATFORMS.length}</span>`;
    btn.onclick = () => selectBuilding(bld);
    container.appendChild(btn);
  }
}

function selectBuilding(bld) {
  _curBuilding = bld;
  document.querySelectorAll('.btab').forEach(b => b.classList.remove('active'));
  const tab = document.getElementById(`btab-${bld}`);
  if (tab) tab.classList.add('active');
  document.getElementById('mtb-bld-name').textContent = bld;
  renderMatrix(bld);
}

function renderMatrix(bld) {
  const body = document.getElementById('matrix-body');
  const cfg = _bldgs[bld];
  if (!cfg) { body.innerHTML = '<tr><td colspan="4" style="padding:28px;text-align:center;color:var(--t4);">لا توجد بيانات</td></tr>'; return; }

  let html = '';
  for (const floor of cfg.floors) {
    html += `<tr class="floor-row"><td colspan="4">${esc(floor.l)}</td></tr>`;
    for (const apt of floor.r) {
      html += `<tr id="row-${bld}-${apt}">`;
      html += `<td class="apt-cell">${esc(apt)}</td>`;
      for (const plat of PLATFORMS) {
        const key = `${bld}|${apt}|${plat}`;
        const lst = _listings[key] || {};
        const hasUrl = !!(lst.icalImport);
        const status = lst.lastSyncStatus || 'never';
        const tip = status === 'ok' ? lst.lastSyncMsg || 'مزامن' : status === 'error' ? lst.lastSyncMsg || 'خطأ' : 'لم تتم المزامنة';
        html += `
          <td>
            <div class="plat-cell">
              <span class="sdot ${status}" title="${esc(tip)}"></span>
              <input class="plat-inp ${hasUrl?'has-url':''}" type="url"
                id="inp-${bld}-${apt}-${plat}"
                value="${esc(lst.icalImport||'')}"
                placeholder="الصق رابط iCal…"
                onchange="markDirty(this)"
                onpaste="setTimeout(()=>markDirty(this),50)">
              <button class="plat-save" title="حفظ" onclick="saveRow('${bld}','${apt}','${plat}',this)">
                <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/></svg>
              </button>
              <button class="plat-sync ${status}" title="${esc(tip)}" id="sync-${bld}-${apt}-${plat}" onclick="syncRow('${bld}','${apt}','${plat}',this)">
                <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="1 4 1 10 7 10"/><polyline points="23 20 23 14 17 14"/><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15"/></svg>
              </button>
            </div>
          </td>`;
      }
      html += '</tr>';
    }
  }
  body.innerHTML = html;
}

function markDirty(inp) {
  inp.classList.add('has-url');
}

async function saveRow(bld, apt, plat, btn) {
  const inp = document.getElementById(`inp-${bld}-${apt}-${plat}`);
  const icalImport = inp ? inp.value.trim() : '';
  const orig = btn.innerHTML; btn.disabled = true;
  try {
    const r = await fetch('/staff/api/listings', {
      method: 'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ building: bld, apt, platform: plat, icalImport }),
    });
    const d = await r.json();
    if (d.success) {
      const key = `${bld}|${apt}|${plat}`;
      _listings[key] = { ...(_listings[key]||{}), building:bld, apt, platform:plat, icalImport };
      if (inp) inp.className = 'plat-inp' + (icalImport ? ' has-url' : '');
      btn.style.background = '#dcfce7'; btn.style.color = '#16a34a';
      setTimeout(() => { btn.style.background=''; btn.style.color=''; btn.disabled = false; btn.innerHTML = orig; }, 1500);
      renderBldTabs();
    } else { showToast('❌ ' + (d.error||'خطأ')); btn.disabled = false; }
  } catch(e) { showToast('❌ ' + e.message); btn.disabled = false; }
}

async function syncRow(bld, apt, plat, btn) {
  btn.classList.add('syncing'); btn.disabled = true;
  try {
    const r = await fetch(`/staff/api/listings/sync/${encodeURIComponent(bld)}`, {
      method: 'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ apt, platform: plat }),
    });
    const d = await r.json();
    const res = (d.results||[])[0] || {};
    const syncBtn = document.getElementById(`sync-${bld}-${apt}-${plat}`);
    if (syncBtn) {
      syncBtn.classList.remove('syncing','ok','error','never');
      syncBtn.classList.add(res.ok ? 'ok' : 'error');
      syncBtn.title = res.ok ? (res.newCount > 0 ? `${res.newCount} حجز جديد` : 'لا جديد') : (res.msg||'خطأ');
    }
    const key = `${bld}|${apt}|${plat}`;
    if (_listings[key]) { _listings[key].lastSyncStatus = res.ok ? 'ok' : 'error'; }
    if (res.newCount > 0) showToast(`✅ ${res.newCount} حجز جديد من ${PLAT_LABEL[plat]}`);
  } catch(e) { showToast('❌ ' + e.message); }
  finally { btn.classList.remove('syncing'); btn.disabled = false; }
}

async function syncBuilding() {
  if (!_curBuilding) return;
  const btn = document.getElementById('sync-all-btn');
  const origHtml = btn.innerHTML;
  const statusEl = document.getElementById('sync-status');
  const progressWrap = document.getElementById('sync-progress-wrap');
  const progressFill = document.getElementById('sync-progress-fill');

  const cfg = _bldgs[_curBuilding];
  const allApts = (cfg?.floors||[]).flatMap(f=>f.r);
  const jobs = [];
  for (const apt of allApts) for (const plat of PLATFORMS) {
    const key = `${_curBuilding}|${apt}|${plat}`;
    if (_listings[key]?.icalImport) jobs.push({ apt, plat });
  }
  if (!jobs.length) { showToast('لا توجد روابط iCal مضبوطة في هذه العمارة'); return; }

  btn.disabled = true; btn.innerHTML = '<svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="animation:spin .7s linear infinite"><polyline points="1 4 1 10 7 10"/><polyline points="23 20 23 14 17 14"/><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15"/></svg> جاري المزامنة…';
  progressWrap.style.display = 'block'; progressFill.style.width = '0%';

  let done = 0, totalNew = 0;
  for (const { apt, plat } of jobs) {
    try {
      const r = await fetch(`/staff/api/listings/sync/${encodeURIComponent(_curBuilding)}`, {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ apt, platform: plat }),
      });
      const d = await r.json();
      totalNew += d.totalNew || 0;
      const res = (d.results||[])[0];
      const syncBtn = document.getElementById(`sync-${_curBuilding}-${apt}-${plat}`);
      if (syncBtn && res) {
        syncBtn.classList.remove('syncing','ok','error','never');
        syncBtn.classList.add(res.ok ? 'ok' : 'error');
      }
    } catch(e) {}
    done++;
    const pct = Math.round(done / jobs.length * 100);
    progressFill.style.width = pct + '%';
    statusEl.textContent = `${done}/${jobs.length} — ${totalNew} حجز جديد`;
  }

  btn.disabled = false; btn.innerHTML = origHtml;
  setTimeout(() => { progressWrap.style.display = 'none'; statusEl.textContent = ''; }, 3000);
  showToast(`✅ اكتملت المزامنة — ${totalNew} حجز جديد`);
}

// ── Bulk Import ───────────────────────────────────────────
function openBulkModal() { document.getElementById('bulk-modal').classList.add('open'); }
function closeBulkModal() {
  document.getElementById('bulk-modal').classList.remove('open');
  document.getElementById('bulk-result').textContent = '';
  document.getElementById('bulk-csv').value = '';
}

async function submitBulk() {
  const raw = document.getElementById('bulk-csv').value.trim();
  if (!raw) return;
  const resultEl = document.getElementById('bulk-result');
  resultEl.textContent = 'جاري الاستيراد…'; resultEl.style.color = 'var(--t3)';
  const rows = raw.split('\n').map(l => l.split(',').map(s => s.trim()));
  const payload = rows
    .filter(r => r.length >= 3)
    .map(r => ({
      building: r[0],
      apt:      r[1],
      platform: r[2].toLowerCase(),
      icalImport: r[3] || '',
    }))
    .filter(r => r.building && r.apt && ['airbnb','booking','gathering'].includes(r.platform));

  if (!payload.length) { resultEl.textContent = '⚠️ لا توجد صفوف صالحة'; resultEl.style.color = '#b45309'; return; }

  try {
    const r = await fetch('/staff/api/listings/bulk', {
      method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(payload),
    });
    const d = await r.json();
    resultEl.textContent = `✅ تم استيراد ${d.saved} صف${d.errors?.length ? ` · ${d.errors.length} خطأ` : ''}`;
    resultEl.style.color = '#16a34a';
    await loadListings();
    setTimeout(closeBulkModal, 2000);
  } catch(e) {
    resultEl.textContent = '❌ ' + e.message; resultEl.style.color = '#dc2626';
  }
}

// ── Export CSV Template ───────────────────────────────────
function exportTemplate() {
  const cfg = _bldgs[_curBuilding];
  if (!cfg) { showToast('اختر عمارة أولاً'); return; }
  const rows = ['عمارة,شقة,منصة,رابط_iCal'];
  for (const floor of cfg.floors) for (const apt of floor.r) for (const plat of PLATFORMS) {
    const key = `${_curBuilding}|${apt}|${plat}`;
    const url = _listings[key]?.icalImport || '';
    rows.push(`${_curBuilding},${apt},${plat},${url}`);
  }
  const blob = new Blob(['﻿' + rows.join('\n')], { type:'text/csv;charset=utf-8' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `channels-${_curBuilding}-${Date.now()}.csv`;
  a.click();
}

// ── Helpers ───────────────────────────────────────────────
function copyUrl(elId, btn) {
  const el = document.getElementById(elId);
  if (!el) return;
  navigator.clipboard.writeText(el.textContent).then(() => {
    const orig = btn.textContent; btn.textContent = 'تم!'; btn.style.background = '#16a34a';
    setTimeout(() => { btn.textContent = orig; btn.style.background = ''; }, 1800);
  });
}

function esc(s) { return String(s||'').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

function showToast(msg) {
  const t = document.getElementById('cm-toast');
  t.textContent = msg;
  t.style.transform = 'translateX(-50%) translateY(0)'; t.style.opacity = '1';
  setTimeout(() => { t.style.transform = 'translateX(-50%) translateY(60px)'; t.style.opacity = '0'; }, 3000);
}
</script>
</body>
</html>
