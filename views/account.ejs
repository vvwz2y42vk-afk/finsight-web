<script>
function toggleSidebar(){document.getElementById('clientSidebar').classList.toggle('open');document.getElementById('csbOverlay').classList.toggle('open');document.getElementById('csbHam').classList.toggle('active');}
function closeSidebar(){document.getElementById('clientSidebar').classList.remove('open');document.getElementById('csbOverlay').classList.remove('open');document.getElementById('csbHam').classList.remove('active');}

function switchTab(id, btn) {
  document.querySelectorAll('.acc-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.acc-panel').forEach(p => p.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('panel-' + id).classList.add('active');
  if (id === 'messages') loadConvs();
}

// ─── Messaging ────────────────────────────────────────────
let activeConvId = null, msgPollTimer = null;

async function loadConvs() {
  try {
    const r = await fetch('/account/messages');
    const convs = await r.json();
    const el = document.getElementById('msgConvList');
    if (!convs.length) {
      el.innerHTML = '<div style="padding:24px;text-align:center;color:var(--text3);font-size:13px;">لا توجد محادثات<br><small style="font-size:11px;">ابدأ محادثة جديدة</small></div>';
      return;
    }
    el.innerHTML = convs.map(c => `
      <div class="msg-conv-item${c._id===activeConvId?' active':''}" onclick="openConv('${c._id}')">
        <div style="display:flex;align-items:center;gap:6px;">
          <div class="msg-conv-subject" style="flex:1;">${esc(c.subject)}</div>
          ${c.unreadCustomer>0?`<span class="msg-conv-badge">${c.unreadCustomer}</span>`:''}
        </div>
        <div style="display:flex;align-items:center;justify-content:space-between;margin-top:3px;">
          <span style="font-size:11px;color:var(--text3);">${new Date(c.lastAt).toLocaleDateString('ar-SA')}</span>
          <span style="font-size:10px;padding:1px 7px;border-radius:8px;${c.status==='open'?'background:rgba(39,174,96,.1);color:#27ae60':'background:var(--light);color:var(--text3)'};">${c.status==='open'?'مفتوحة':'مغلقة'}</span>
        </div>
      </div>`).join('');
    const unreadTotal = convs.reduce((s,c)=>s+(c.unreadCustomer||0),0);
    const btn = document.getElementById('tab-btn-messages');
    if (btn) btn.textContent = '💬 رسائلي' + (unreadTotal>0?` (${unreadTotal})`:'');
  } catch (e) {}
}

async function openConv(id) {
  activeConvId = id;
  clearInterval(msgPollTimer);
  try {
    const r = await fetch('/account/messages/' + id);
    const { conv, messages } = await r.json();
    renderChat(conv, messages);
    loadConvs();
    msgPollTimer = setInterval(async () => {
      if (activeConvId !== id) return clearInterval(msgPollTimer);
      try {
        const rp = await fetch('/account/messages/' + id);
        const d  = await rp.json();
        renderChatMsgs(d.messages);
      } catch(e) {}
    }, 8000);
  } catch (e) {}
}

function esc(s) { return String(s).replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

function renderChat(conv, messages) {
  const area = document.getElementById('msgChatArea');
  const isOpen = conv.status === 'open';
  area.innerHTML = `
    <div class="msg-chat-hd">
      <span>💬</span><span style="flex:1;">${esc(conv.subject)}</span>
      <span style="font-size:10px;padding:2px 8px;border-radius:8px;${isOpen?'background:rgba(39,174,96,.1);color:#27ae60':'background:var(--light);color:var(--text3)'};">${isOpen?'مفتوحة':'مغلقة'}</span>
    </div>
    <div class="msg-chat-body" id="msgChatBody"></div>
    ${isOpen?`<div class="msg-chat-foot">
      <textarea class="msg-chat-ta" id="msgReplyBody" rows="2" placeholder="اكتب ردك هنا..." maxlength="2000"></textarea>
      <div style="display:flex;gap:8px;align-items:center;">
        <button onclick="sendReply('${conv._id}')" class="msg-send-btn">إرسال ←</button>
      </div>
    </div>`:'<div style="padding:10px 16px;text-align:center;font-size:12px;color:var(--text3);">هذه المحادثة مغلقة</div>'}`;
  renderChatMsgs(messages);
}

function renderChatMsgs(messages) {
  const body = document.getElementById('msgChatBody');
  if (!body) return;
  if (!messages.length) { body.innerHTML = '<div style="text-align:center;color:var(--text3);font-size:12px;padding:20px;">لا توجد رسائل بعد</div>'; return; }
  body.innerHTML = messages.map(m => `
    <div style="display:flex;flex-direction:column;align-items:${m.from==='customer'?'flex-end':'flex-start'};">
      <div class="msg-bubble from-${m.from}">
        ${esc(m.body).replace(/\n/g,'<br>')}
        <div class="msg-bubble-time">${new Date(m.createdAt).toLocaleString('ar-SA',{hour:'2-digit',minute:'2-digit',day:'2-digit',month:'short'})}</div>
      </div>
    </div>`).join('');
  body.scrollTop = body.scrollHeight;
}

async function sendReply(id) {
  const ta = document.getElementById('msgReplyBody');
  const body = ta?.value.trim();
  if (!body) return;
  ta.disabled = true;
  try {
    await fetch('/account/messages/' + id + '/reply', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ body }) });
    ta.value = '';
    openConv(id);
  } catch(e) {}
  ta.disabled = false;
}

function toggleNewConv() {
  const f = document.getElementById('msgNewForm');
  f.style.display = f.style.display === 'none' ? 'block' : 'none';
}

async function sendNewConv() {
  const subject = document.getElementById('msgNewSubject').value.trim();
  const body    = document.getElementById('msgNewBody').value.trim();
  if (!body) return alert('الرجاء كتابة رسالة');
  try {
    const r = await fetch('/account/messages', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ subject, body }) });
    const data = await r.json();
    document.getElementById('msgNewSubject').value = '';
    document.getElementById('msgNewBody').value = '';
    document.getElementById('msgNewForm').style.display = 'none';
    if (data.conv) openConv(data.conv._id);
    else loadConvs();
  } catch(e) {}
}

document.querySelector('form[action="/account/change-password"]')?.addEventListener('submit', function(e) {
  const p1 = document.getElementById('newPwd').value;
  const p2 = document.getElementById('newPwd2').value;
  if (p1 !== p2) { e.preventDefault(); alert('كلمتا المرور غير متطابقتين'); }
});

function toggleReview(id) {
  const f = document.getElementById('rev-form-' + id);
  if (!f) return;
  f.style.display = f.style.display === 'none' ? 'block' : 'none';
}

function setStar(id, val) {
  document.getElementById('rating-' + id).value = val;
  const stars = document.querySelectorAll('#stars-' + id + ' .bk-star');
  stars.forEach(s => {
    const i = parseInt(s.dataset.i);
    s.classList.toggle('on', i <= val);
  });
}
</script>
