<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>حسابي — Finsight Real Estate</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/client.css">
<style>
.acc-layout{max-width:900px;margin:0 auto;padding:40px 16px 80px;}
.acc-header{display:flex;align-items:center;gap:16px;margin-bottom:32px;padding:24px;background:#fff;border-radius:16px;border:1px solid var(--border);}
.acc-avatar{width:60px;height:60px;border-radius:50%;background:var(--gold);color:#fff;font-size:22px;font-weight:900;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.acc-name{font-size:1.3rem;font-weight:800;}
.acc-phone{font-size:13px;color:var(--text3);margin-top:2px;}
.acc-tabs{display:flex;gap:8px;margin-bottom:24px;border-bottom:2px solid var(--border);padding-bottom:0;}
.acc-tab{padding:10px 20px;font-family:inherit;font-size:14px;font-weight:600;border:none;background:none;cursor:pointer;color:var(--text3);border-bottom:2px solid transparent;margin-bottom:-2px;transition:all .15s;}
.acc-tab.active{color:var(--gold);border-bottom-color:var(--gold);}
.acc-panel{display:none;}.acc-panel.active{display:block;}
.acc-card{background:#fff;border-radius:16px;border:1px solid var(--border);padding:24px;margin-bottom:16px;}
.acc-card-title{font-size:1rem;font-weight:700;margin-bottom:20px;padding-bottom:12px;border-bottom:1px solid var(--border);}
.acc-form-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;}
.acc-lbl{display:block;font-size:12px;font-weight:600;color:var(--text3);margin-bottom:5px;text-transform:uppercase;letter-spacing:.5px;}
.acc-inp{width:100%;padding:10px 14px;border-radius:10px;border:1px solid var(--border);font-family:inherit;font-size:14px;outline:none;transition:border .2s;}
.acc-inp:focus{border-color:var(--gold);}
.acc-inp:disabled{background:var(--light);color:var(--text3);}
.acc-save-btn{padding:10px 28px;background:var(--gold);border:none;border-radius:10px;color:#fff;font-family:inherit;font-size:14px;font-weight:700;cursor:pointer;}
.acc-save-btn:hover{opacity:.9;}
.bk-card{background:#fff;border-radius:14px;border:1px solid var(--border);padding:16px 20px;margin-bottom:12px;display:flex;align-items:flex-start;gap:16px;}
.bk-photo{width:72px;height:72px;border-radius:10px;overflow:hidden;flex-shrink:0;background:var(--light);}
.bk-photo img{width:100%;height:100%;object-fit:cover;}
.bk-photo-ph{width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:24px;}
.bk-info{flex:1;min-width:0;}
.bk-title{font-size:15px;font-weight:700;margin-bottom:4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.bk-meta{font-size:12px;color:var(--text3);margin-bottom:8px;}
.bk-badges{display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.bk-status{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;}
.bk-status.pending{background:rgba(184,134,11,.1);color:#b8860b;}
.bk-status.awaiting_payment{background:rgba(52,152,219,.1);color:#2980b9;}
.bk-status.awaiting_checkin{background:rgba(230,126,34,.1);color:#e67e22;}
.bk-status.active{background:rgba(39,174,96,.1);color:#27ae60;}
.bk-status.checkout{background:rgba(142,68,173,.1);color:#8e44ad;}
.bk-status.cancelled{background:rgba(192,57,43,.1);color:#c0392b;}
.bk-cancel-btn{padding:4px 12px;border-radius:8px;border:1px solid rgba(192,57,43,.3);background:rgba(192,57,43,.05);color:#c0392b;font-family:inherit;font-size:11px;font-weight:600;cursor:pointer;}
.bk-cancel-btn:hover{background:rgba(192,57,43,.1);}
.bk-type{background:var(--light);color:var(--text3);border:1px solid var(--border);padding:3px 10px;border-radius:20px;font-size:11px;}
.bk-date{font-size:12px;color:var(--text3);}
.bk-price{font-size:13px;font-weight:700;color:var(--gold);}
.acc-empty{text-align:center;padding:48px 20px;}
.acc-empty__ico{font-size:3rem;margin-bottom:12px;}
.acc-success{background:rgba(39,174,96,.08);border:1px solid rgba(39,174,96,.3);border-radius:10px;padding:12px 16px;margin-bottom:16px;font-size:13px;color:#27ae60;font-weight:600;}
.acc-err{background:rgba(192,57,43,.08);border:1px solid rgba(192,57,43,.3);border-radius:10px;padding:12px 16px;margin-bottom:16px;font-size:13px;color:#c0392b;font-weight:600;}
@media(max-width:600px){.acc-form-row{grid-template-columns:1fr;}.acc-header{flex-direction:column;text-align:center;}.bk-card{flex-direction:column;}.bk-photo{width:100%;height:120px;}}
</style>
</head>
<body class="home-page csb-layout">

<aside class="client-sidebar" id="clientSidebar">
  <div class="csb-logo">
    <div class="nav-logo-icon">FS</div>
    <div><div class="nav-logo-name">Finsight</div><div class="nav-logo-sub">Real Estate</div></div>
  </div>
  <nav class="csb-nav">
    <a href="/" class="csb-lnk"><span class="csb-ico">⬡</span><span>الرئيسية</span></a>
    <div class="csb-divider"></div>
    <a href="/listings" class="csb-lnk"><span class="csb-ico">🏢</span><span>عقاراتنا</span></a>
    <div class="csb-sub">
      <a href="/listings?cat=rental_apartment" class="csb-sublnk">🛏 شقق للإيجار</a>
      <a href="/listings?cat=rental_commercial" class="csb-sublnk">🏪 معارض للإيجار</a>
      <a href="/listings?cat=sale_land" class="csb-sublnk">🌍 أراضي للبيع</a>
      <a href="/listings?cat=sale_apartment" class="csb-sublnk">🏠 شقق للبيع</a>
    </div>
    <div class="csb-divider"></div>
    <a href="/search" class="csb-lnk"><span class="csb-ico">🔍</span><span>بحث</span></a>
    <a href="/account" class="csb-lnk active"><span class="csb-ico">👤</span><span>حسابي</span></a>
    <a href="/about" class="csb-lnk"><span class="csb-ico">ℹ️</span><span>من نحن</span></a>
    <a href="/inquiry" class="csb-lnk"><span class="csb-ico">💬</span><span>تواصل معنا</span></a>
    <a href="/account/logout" class="csb-lnk" style="color:var(--text3);"><span class="csb-ico">🚪</span><span>تسجيل الخروج</span></a>
  </nav>
  <div class="csb-foot">
    <a href="https://wa.me/966590561057" target="_blank" class="csb-wa">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
      <span>0590561057</span>
    </a>
  </div>
</aside>
<div class="csb-overlay" id="csbOverlay" onclick="closeSidebar()"></div>
<button class="csb-ham" id="csbHam" onclick="toggleSidebar()"><span></span><span></span><span></span></button>

<div class="csb-content">
<section style="padding:48px 0 0;background:var(--light);">
<div class="acc-layout">

  <!-- HEADER -->
  <div class="acc-header">
    <div class="acc-avatar"><%= customer.name.charAt(0) %></div>
    <div>
      <div class="acc-name"><%= customer.name %></div>
      <div class="acc-phone"><%= customer.phone %></div>
      <% if (customer.nationality) { %><div style="font-size:12px;color:var(--gold);margin-top:4px;font-weight:600;"><%= customer.nationality %></div><% } %>
    </div>
    <a href="/listings" class="btn btn-gold" style="margin-right:auto;font-size:13px;">استعرض العقارات</a>
  </div>

  <!-- ALERTS -->
  <% if (success) { %><div class="acc-success">✅ <%= success %></div><% } %>
  <% if (error) { %><div class="acc-err">⚠️ <%= error %></div><% } %>

  <!-- TABS -->
  <div class="acc-tabs">
    <button class="acc-tab active" onclick="switchTab('bookings',this)">📅 حجوزاتي (<%= bookings.length %>)</button>
    <button class="acc-tab" onclick="switchTab('profile',this)">👤 بياناتي</button>
    <button class="acc-tab" onclick="switchTab('password',this)">🔒 كلمة المرور</button>
  </div>

  <!-- PANEL: BOOKINGS -->
  <div class="acc-panel active" id="panel-bookings">
    <% if (bookings.length === 0) { %>
    <div class="acc-empty">
      <div class="acc-empty__ico">🏠</div>
      <h3 style="font-size:1.1rem;font-weight:700;margin-bottom:8px;">لا توجد حجوزات بعد</h3>
      <p style="color:var(--text3);margin-bottom:20px;">تصفّح عقاراتنا واحجز وحدتك المفضلة</p>
      <a href="/listings" class="btn btn-gold" style="display:inline-flex;">استعرض العقارات</a>
    </div>
    <% } else { %>
    <% bookings.forEach(b => { %>
    <div class="bk-card">
      <div class="bk-photo">
        <% const photo = b.listing?.photos?.[0]; %>
        <% if (photo) { %>
        <img src="<%= photo %>" alt="<%= b.listingTitle %>">
        <% } else { %>
        <div class="bk-photo-ph">🏢</div>
        <% } %>
      </div>
      <div class="bk-info">
        <div class="bk-title"><%= b.listingTitle || 'عقار' %></div>
        <div class="bk-meta">
          <% if (b.building) { %>📍 <%= b.building %>&nbsp;&nbsp;<% } %>
          <% if (b.bookingType === 'daily' && b.checkIn && b.checkOut) { %>
            📅 <%= new Date(b.checkIn).toLocaleDateString('ar-SA') %> — <%= new Date(b.checkOut).toLocaleDateString('ar-SA') %>
            <% if (b.nights) { %> · <%= b.nights %> ليلة<% } %>
          <% } else if (b.bookingType === 'annual' && b.checkIn) { %>
            📅 بدء من: <%= new Date(b.checkIn).toLocaleDateString('ar-SA') %>
          <% } %>
        </div>
        <div class="bk-badges">
          <span class="bk-status <%= b.status %>">
            <% if(b.status==='pending'){ %>⏳ جديد
            <% } else if(b.status==='awaiting_payment'){ %>💳 في انتظار الدفع
            <% } else if(b.status==='awaiting_checkin'){ %>🔑 في انتظار دخول العميل
            <% } else if(b.status==='active'){ %>✅ العقد مفتوح الآن
            <% } else if(b.status==='checkout'){ %>🏁 خروج
            <% } else { %>❌ ملغي<% } %>
          </span>
          <span class="bk-type">
            <%= b.bookingType==='daily'?'يومي':b.bookingType==='annual'?'شهري':'استفسار' %>
          </span>
          <% if (b.totalPrice) { %><span class="bk-price"><%= b.totalPrice.toLocaleString() %> ريال</span><% } %>
          <span class="bk-date">طُلب: <%= new Date(b.createdAt).toLocaleDateString('ar-SA') %></span>
        </div>
      </div>
      <div style="display:flex;flex-direction:column;gap:6px;align-items:flex-end;">
        <% if (b.status === 'awaiting_payment' && b.totalPrice) { %>
        <a href="/account/pay/<%= b._id %>" style="display:inline-flex;align-items:center;gap:6px;padding:9px 18px;background:linear-gradient(135deg,#DAA520,#f0c040);border-radius:10px;color:#111;font-family:'Cairo',sans-serif;font-size:13px;font-weight:800;text-decoration:none;white-space:nowrap;">
          💳 ادفع الآن
        </a>
        <% } %>
        <% if (!['active','checkout','cancelled'].includes(b.status)) { %>
        <form method="POST" action="/account/cancel/<%= b._id %>" onsubmit="return confirm('هل تريد إلغاء هذا الحجز؟')">
          <button type="submit" class="bk-cancel-btn">إلغاء</button>
        </form>
        <% } %>
        <% if (b.paidAt) { %>
        <span style="font-size:10px;color:var(--green, #1a7340);font-weight:600;">✅ مدفوع</span>
        <% } %>
      </div>
    </div>
    <% }); %>
    <% } %>
  </div>

  <!-- PANEL: PROFILE -->
  <div class="acc-panel" id="panel-profile">
    <div class="acc-card">
      <div class="acc-card-title">تعديل البيانات الشخصية</div>
      <form method="POST" action="/account/update">
        <div class="acc-form-row">
          <div>
            <label class="acc-lbl">الاسم الكامل</label>
            <input type="text" name="name" class="acc-inp" value="<%= customer.name %>" required>
          </div>
          <div>
            <label class="acc-lbl">رقم الجوال</label>
            <input type="tel" class="acc-inp" value="<%= customer.phone %>" disabled>
            <p style="font-size:11px;color:var(--text3);margin-top:4px;">رقم الجوال لا يمكن تغييره</p>
          </div>
        </div>
        <div class="acc-form-row">
          <div>
            <label class="acc-lbl">البريد الإلكتروني</label>
            <input type="email" name="email" class="acc-inp" value="<%= customer.email || '' %>" placeholder="example@email.com">
          </div>
          <div>
            <label class="acc-lbl">رقم الهوية / الإقامة</label>
            <input type="text" name="nationalId" class="acc-inp" value="<%= customer.nationalId || '' %>" placeholder="10XXXXXXXX">
          </div>
        </div>
        <div style="margin-bottom:20px;">
          <label class="acc-lbl">الجنسية</label>
          <select name="nationality" class="acc-inp" style="max-width:220px;">
            <option value="سعودي" <%= customer.nationality==='سعودي'?'selected':'' %>>سعودي</option>
            <option value="غير سعودي" <%= customer.nationality==='غير سعودي'?'selected':'' %>>غير سعودي</option>
          </select>
        </div>
        <button type="submit" class="acc-save-btn">حفظ التغييرات</button>
      </form>
    </div>
  </div>

  <!-- PANEL: PASSWORD -->
  <div class="acc-panel" id="panel-password">
    <div class="acc-card">
      <div class="acc-card-title">تغيير كلمة المرور</div>
      <form method="POST" action="/account/change-password" style="max-width:380px;">
        <div style="margin-bottom:16px;">
          <label class="acc-lbl">كلمة المرور الحالية</label>
          <input type="password" name="currentPassword" class="acc-inp" required>
        </div>
        <div style="margin-bottom:16px;">
          <label class="acc-lbl">كلمة المرور الجديدة</label>
          <input type="password" name="newPassword" id="newPwd" class="acc-inp" minlength="6" required>
        </div>
        <div style="margin-bottom:20px;">
          <label class="acc-lbl">تأكيد كلمة المرور الجديدة</label>
          <input type="password" id="newPwd2" class="acc-inp" required>
        </div>
        <button type="submit" class="acc-save-btn">تغيير كلمة المرور</button>
      </form>
    </div>
  </div>

</div>
</section>

<!-- FOOTER -->
<footer class="site-footer-new">
  <div class="page-container">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="footer-brand__logo">
          <div class="nav-logo-icon">FS</div>
          <div><div class="nav-logo-name">Finsight</div><div class="nav-logo-sub">Real Estate</div></div>
        </div>
        <p class="footer-brand__desc">شركة رائدة في إدارة الأملاك والوساطة العقارية بالمدينة المنورة.</p>
      </div>
      <div class="footer-col">
        <div class="footer-col__title">الأقسام</div>
        <a href="/listings?cat=rental_apartment">🏠 شقق للإيجار</a>
        <a href="/listings?cat=rental_commercial">🏪 معارض للإيجار</a>
        <a href="/listings?cat=sale_land">🌍 أراضي للبيع</a>
      </div>
      <div class="footer-col">
        <div class="footer-col__title">روابط سريعة</div>
        <a href="/">الرئيسية</a>
        <a href="/about">من نحن</a>
        <a href="/inquiry">تواصل معنا</a>
      </div>
      <div class="footer-col">
        <div class="footer-col__title">تواصل معنا</div>
        <a href="https://wa.me/966590561057">0590561057</a>
        <a href="mailto:realstate@barezz.com">realstate@barezz.com</a>
      </div>
    </div>
    <div class="footer-bottom">
      <p>© 2026 Finsight Real Estate — جميع الحقوق محفوظة &nbsp;·&nbsp; <a href="/terms" style="color:inherit;opacity:.6;">الشروط والأحكام</a></p>
    </div>
  </div>
</footer>

</div><!-- /csb-content -->
<script>
function toggleSidebar(){document.getElementById('clientSidebar').classList.toggle('open');document.getElementById('csbOverlay').classList.toggle('open');document.getElementById('csbHam').classList.toggle('active');}
function closeSidebar(){document.getElementById('clientSidebar').classList.remove('open');document.getElementById('csbOverlay').classList.remove('open');document.getElementById('csbHam').classList.remove('active');}

function switchTab(id, btn) {
  document.querySelectorAll('.acc-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.acc-panel').forEach(p => p.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('panel-' + id).classList.add('active');
}

document.querySelector('form[action="/account/change-password"]')?.addEventListener('submit', function(e) {
  const p1 = document.getElementById('newPwd').value;
  const p2 = document.getElementById('newPwd2').value;
  if (p1 !== p2) { e.preventDefault(); alert('كلمتا المرور غير متطابقتين'); }
});
</script>
</body>
</html>
