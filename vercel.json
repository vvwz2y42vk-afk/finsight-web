{
  "version": 2,
  "builds": [{
    "src": "server.js",
    "use": "@vercel/node",
    "config": {
      "includeFiles": ["views/**", "public/**", "middleware/**", "utils/**", "models/**"]
    }
  }],
  "routes": [{ "src": "/(.*)", "dest": "server.js" }],
  "crons": [
    {
      "path": "/api/cron/checkout-reminders",
      "schedule": "0 5 * * *"
    }
  ]
}
