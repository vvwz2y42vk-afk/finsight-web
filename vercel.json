{
  "version": 2,
  "buildCommand": "node scripts/verify-views.js",
  "builds": [{
    "src": "server.js",
    "use": "@vercel/node",
    "config": {
      "includeFiles": ["views/**", "public/**", "middleware/**", "utils/**", "models/**", "scripts/**"]
    }
  }],
  "routes": [{ "src": "/(.*)", "dest": "server.js" }],
  "crons": [
    {
      "path": "/api/cron/checkout-reminders",
      "schedule": "0 5 * * *"
    }
  ]
}
